<?xml version="1.0" encoding="utf-8"?>
<tt xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:ttp="http://www.w3.org/ns/ttml#parameter" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xml:lang="zh-Hans" ttp:frameRate="25" ttp:frameRateMultiplier="1 1" ttp:timeBase="media" xmlns="http://www.w3.org/ns/ttml">
  <head>
    <metadata>
      <ttm:title>SIM-Ne Zha 2_FA011623_LowRes_25F-TMP-Terry-TMP-Sora</ttm:title>
    </metadata>
    <styling>
      <style xml:id="s1" tts:fontFamily="default" tts:fontSize="100%" tts:fontStyle="normal" tts:fontWeight="normal" tts:color="white" />
    </styling>
    <layout>
      <region xml:id="bottomCenter" tts:origin="10% 10%" tts:extent="80% 80%" tts:displayAlign="after" tts:textAlign="center" />
      <region xml:id="topCenter" tts:origin="10% 10%" tts:extent="80% 80%" tts:displayAlign="before" tts:textAlign="center" />
    </layout>
  </head>
  <body>
    <div xml:id="d1" style="s1" xml:lang="zh-Hans">
      <p xml:id="p1" begin="00:00:47.040" end="00:00:48.720" region="bottomCenter">天地灵气</p>
      <p xml:id="p2" begin="00:00:48.840" end="00:00:51.920" region="bottomCenter">孕育出一颗混元珠</p>
      <p xml:id="p3" begin="00:00:52.600" end="00:00:55.840" region="bottomCenter">元始天尊将其一分为二</p>
      <p xml:id="p4" begin="00:00:55.960" end="00:00:57.880" region="bottomCenter">仙气化作灵珠</p>
      <p xml:id="p5" begin="00:00:58.000" end="00:01:00.480" region="bottomCenter">魔气聚为魔丸</p>
      <p xml:id="p6" begin="00:01:01.000" end="00:01:04.640" region="bottomCenter">且在魔丸上施下天劫咒</p>
      <p xml:id="p7" begin="00:01:05.000" end="00:01:09.560" region="bottomCenter">三年后引天雷摧毁魔丸</p>
      <p xml:id="p8" begin="00:01:10.120" end="00:01:13.720" region="bottomCenter">后因申公豹从中作梗</p>
      <p xml:id="p9" begin="00:01:13.840" end="00:01:17.960" region="bottomCenter">魔丸投胎为陈塘关三太子哪吒</p>
      <p xml:id="p10" begin="00:01:18.080" end="00:01:22.480" region="bottomCenter">而灵珠则投胎为龙王三太子敖丙</p>
      <p xml:id="p11" begin="00:01:22.800" end="00:01:25.120" region="bottomCenter">机缘巧合下</p>
      <p xml:id="p12" begin="00:01:25.240" end="00:01:28.280" region="bottomCenter">二人居然结为挚友</p>
      <p xml:id="p13" begin="00:01:29.080" end="00:01:32.400" region="bottomCenter">魔丸哪吒受父母感化</p>
      <p xml:id="p14" begin="00:01:32.520" end="00:01:34.000" region="bottomCenter">褪去魔性</p>
      <p xml:id="p15" begin="00:01:34.120" end="00:01:36.480" region="bottomCenter">拯救了陈塘关</p>
      <p xml:id="p16" begin="00:01:36.600" end="00:01:38.640" region="bottomCenter">并与敖丙携手</p>
      <p xml:id="p17" begin="00:01:38.760" end="00:01:40.880" region="bottomCenter">共抗天劫</p>
      <p xml:id="p18" begin="00:01:41.280" end="00:01:42.480" region="bottomCenter">最终</p>
      <p xml:id="p19" begin="00:01:42.640" end="00:01:46.160" region="bottomCenter">扭转了命运</p>
      <p xml:id="p20" begin="00:02:02.400" end="00:02:04.880" region="bottomCenter">虽扛下了天劫</p>
      <p xml:id="p21" begin="00:02:05.000" end="00:02:07.080" region="bottomCenter">但你们的肉身被毁</p>
      <p xml:id="p22" begin="00:02:07.200" end="00:02:09.000" region="bottomCenter">魂魄若无依托</p>
      <p xml:id="p23" begin="00:02:09.120" end="00:02:12.600" region="bottomCenter">片刻便会魂飞魄散</p>
      <p xml:id="p24" begin="00:02:12.720" end="00:02:14.760" region="bottomCenter">七色宝莲主守护及孕育</p>
      <p xml:id="p25" begin="00:02:14.880" end="00:02:17.280" region="bottomCenter">为师现在就要用它为你们</p>
      <p xml:id="p26" begin="00:02:17.400" end="00:02:19.920" region="bottomCenter">重塑肉身</p>
      <p xml:id="p27" begin="00:02:48.920" end="00:02:50.920" region="bottomCenter">哇　　好美</p>
      <p xml:id="p28" begin="00:02:51.280" end="00:02:52.360" region="bottomCenter">开工</p>
      <p xml:id="p29" begin="00:03:26.840" end="00:03:27.760" region="bottomCenter">画风不对啊</p>
      <p xml:id="p30" begin="00:03:27.920" end="00:03:29.520" region="bottomCenter">没错啊，仙藕制成藕粉</p>
      <p xml:id="p31" begin="00:03:29.640" end="00:03:31.120" region="bottomCenter">才能重塑肉身噻</p>
      <p xml:id="p32" begin="00:03:32.040" end="00:03:32.880" region="bottomCenter">你刚才是不是用</p>
      <p xml:id="p33" begin="00:03:33.000" end="00:03:34.360" region="bottomCenter">抠了脚的手在做藕粉？</p>
      <p xml:id="p34" begin="00:03:34.480" end="00:03:35.960" region="bottomCenter">哦，没事</p>
      <p xml:id="p35" begin="00:03:36.080" end="00:03:38.240" region="bottomCenter">脚上粘一些一会儿洗洗脚就好了</p>
      <p xml:id="p36" begin="00:03:38.480" end="00:03:41.040" region="bottomCenter">我不是关心你的脚</p>
      <p xml:id="p37" begin="00:03:41.920" end="00:03:43.680" region="bottomCenter">你刚才是不是擤了鼻涕？</p>
      <p xml:id="p38" begin="00:03:44.120" end="00:03:45.840" region="bottomCenter">哎呀没鼻涕没鼻涕</p>
      <p xml:id="p39" begin="00:03:45.960" end="00:03:46.880" region="bottomCenter">这是藕粉</p>
      <p xml:id="p40" begin="00:03:47.000" end="00:03:48.520" region="bottomCenter">看嘛，藕粉啊</p>
      <p xml:id="p41" begin="00:03:50.360" end="00:03:52.040" region="bottomCenter">藕粉拌好了啊</p>
      <p xml:id="p42" begin="00:03:52.520" end="00:03:53.720" region="bottomCenter">来来来来来</p>
      <p xml:id="p43" begin="00:03:53.840" end="00:03:55.040" region="bottomCenter">你们一人一坨</p>
      <p xml:id="p44" begin="00:03:55.160" end="00:03:56.720" region="bottomCenter">不是，一…一份</p>
      <p xml:id="p45" begin="00:03:57.640" end="00:03:59.680" region="bottomCenter">搞快噻你魂儿都要散了</p>
      <p xml:id="p46" begin="00:03:59.800" end="00:04:00.960" region="bottomCenter">让我散了得了</p>
      <p xml:id="p47" begin="00:04:01.080" end="00:04:02.760" region="bottomCenter">臭讲究，你花样儿多哟</p>
      <p xml:id="p48" begin="00:04:09.480" end="00:04:10.480" region="bottomCenter">能动了耶</p>
      <p xml:id="p49" begin="00:04:10.920" end="00:04:11.760" region="bottomCenter">嗯</p>
      <p xml:id="p50" begin="00:04:13.320" end="00:04:14.160" region="bottomCenter">这啥玩意？</p>
      <p xml:id="p51" begin="00:04:14.280" end="00:04:15.200" region="bottomCenter">谢谢啊</p>
      <p xml:id="p52" begin="00:04:15.320" end="00:04:16.920" region="bottomCenter">就说刚才怎么找不见了</p>
      <p xml:id="p53" begin="00:04:21.160" end="00:04:22.120" region="bottomCenter">塑形</p>
      <p xml:id="p54" begin="00:04:24.440" end="00:04:27.440" region="bottomCenter">飞天猪的记忆力无人能及</p>
      <p xml:id="p55" begin="00:04:27.560" end="00:04:30.640" region="bottomCenter">雕刻技术也是巧夺天工</p>
      <p xml:id="p56" begin="00:04:32.160" end="00:04:33.880" region="bottomCenter">你瞧一下像不像？</p>
      <p xml:id="p57" begin="00:04:37.640" end="00:04:38.800" region="bottomCenter">多谢猪兄</p>
      <p xml:id="p58" begin="00:04:39.600" end="00:04:41.840" region="bottomCenter">莫乱动身体还没有定型</p>
      <p xml:id="p59" begin="00:04:44.320" end="00:04:45.160" region="bottomCenter">仙长</p>
      <p xml:id="p60" begin="00:04:45.280" end="00:04:47.040" region="bottomCenter">我已经召集陈塘关全军戒备</p>
      <p xml:id="p61" begin="00:04:47.160" end="00:04:49.240" region="bottomCenter">以防申公豹和东海龙族来犯</p>
      <p xml:id="p62" begin="00:04:49.360" end="00:04:50.600" region="bottomCenter">放心</p>
      <p xml:id="p63" begin="00:04:50.720" end="00:04:51.920" region="bottomCenter">龙族都在镇压海底妖兽</p>
      <p xml:id="p64" begin="00:04:52.040" end="00:04:53.880" region="bottomCenter">我担保他们一条都出不来</p>
      <p xml:id="p65" begin="00:04:54.000" end="00:04:55.680" region="bottomCenter">一个申公豹就没什么好怕的</p>
      <p xml:id="p66" begin="00:04:56.000" end="00:04:57.920" region="bottomCenter">你们还是来看一下</p>
      <p xml:id="p67" begin="00:04:58.520" end="00:05:00.120" region="bottomCenter">像不像？</p>
      <p xml:id="p68" begin="00:05:02.160" end="00:05:03.560" region="bottomCenter">我教的手艺</p>
      <p xml:id="p69" begin="00:05:03.680" end="00:05:04.560" region="bottomCenter">不过</p>
      <p xml:id="p70" begin="00:05:04.680" end="00:05:05.960" region="bottomCenter">也没必要一模一样嘛</p>
      <p xml:id="p71" begin="00:05:06.080" end="00:05:07.240" region="bottomCenter">可以再美化些吗？</p>
      <p xml:id="p72" begin="00:05:07.360" end="00:05:08.200" region="bottomCenter">啊？</p>
      <p xml:id="p73" begin="00:05:10.800" end="00:05:11.640" region="bottomCenter">也对</p>
      <p xml:id="p74" begin="00:05:11.760" end="00:05:13.720" region="bottomCenter">哪个父母不想儿子变得更优秀呢？</p>
      <p xml:id="p75" begin="00:05:13.840" end="00:05:14.680" region="bottomCenter">嗯</p>
      <p xml:id="p76" begin="00:05:15.200" end="00:05:16.320" region="bottomCenter">改得高大威猛些</p>
      <p xml:id="p77" begin="00:05:17.560" end="00:05:19.120" region="bottomCenter">还要俊美秀气</p>
      <p xml:id="p78" begin="00:05:19.520" end="00:05:21.640" region="bottomCenter">男子汉就得阳刚硬朗</p>
      <p xml:id="p79" begin="00:05:22.640" end="00:05:23.800" region="bottomCenter">相貌英俊帅气</p>
      <p xml:id="p80" begin="00:05:24.280" end="00:05:25.800" region="bottomCenter">还得可爱乖巧</p>
      <p xml:id="p81" begin="00:05:27.040" end="00:05:29.480" region="bottomCenter">到底怎么改你们统一下噻？</p>
      <p xml:id="p82" begin="00:05:29.600" end="00:05:30.640" region="bottomCenter">高大威猛</p>
      <p xml:id="p83" begin="00:05:30.760" end="00:05:32.600" region="bottomCenter">兼备俊美秀气</p>
      <p xml:id="p84" begin="00:05:32.720" end="00:05:33.760" region="bottomCenter">阳刚硬朗</p>
      <p xml:id="p85" begin="00:05:33.880" end="00:05:35.720" region="bottomCenter">不失活泼可爱</p>
      <p xml:id="p86" begin="00:05:39.960" end="00:05:40.800" region="bottomCenter">啥意思啊？</p>
      <p xml:id="p87" begin="00:05:40.920" end="00:05:42.280" region="bottomCenter">它说，它说你行你上</p>
      <p xml:id="p88" begin="00:05:42.480" end="00:05:44.480" region="bottomCenter">切，早该我来了</p>
      <p xml:id="p89" begin="00:05:44.600" end="00:05:45.680" region="bottomCenter">自己做的才最满意嘛</p>
      <p xml:id="p90" begin="00:05:46.760" end="00:05:47.960" region="bottomCenter">这下有得等了</p>
      <p xml:id="p91" begin="00:05:48.200" end="00:05:49.880" region="bottomCenter">先给你定型吧</p>
      <p xml:id="p92" begin="00:05:50.720" end="00:05:52.400" region="bottomCenter">你天生水象</p>
      <p xml:id="p93" begin="00:05:52.520" end="00:05:54.000" region="bottomCenter">需以坎水淬炼</p>
      <p xml:id="p94" begin="00:06:12.280" end="00:06:13.200" region="bottomCenter">开</p>
      <p xml:id="p95" begin="00:06:20.800" end="00:06:22.400" region="bottomCenter">啊，大功告成</p>
      <p xml:id="p96" begin="00:06:23.160" end="00:06:24.200" region="bottomCenter">你整完没得？</p>
      <p xml:id="p97" begin="00:06:26.280" end="00:06:27.640" region="bottomCenter">差不多吧</p>
      <p xml:id="p98" begin="00:06:31.800" end="00:06:34.520" region="bottomCenter">虽然这版肯定是最出彩的</p>
      <p xml:id="p99" begin="00:06:34.640" end="00:06:37.640" region="bottomCenter">但是细节打磨还需要很长时间</p>
      <p xml:id="p100" begin="00:06:37.760" end="00:06:38.920" region="bottomCenter">不如暂时就用第一版吧？</p>
      <p xml:id="p101" begin="00:06:39.040" end="00:06:41.360" region="bottomCenter">对，第一版还是可以</p>
      <p xml:id="p102" begin="00:06:41.480" end="00:06:43.600" region="bottomCenter">嗯，我也觉得</p>
      <p xml:id="p103" begin="00:06:45.000" end="00:06:46.200" region="bottomCenter">嗯</p>
      <p xml:id="p104" begin="00:06:47.240" end="00:06:49.440" region="bottomCenter">你天生火象</p>
      <p xml:id="p105" begin="00:06:49.560" end="00:06:51.400" region="bottomCenter">需以离火煅烧</p>
      <p xml:id="p106" begin="00:07:00.480" end="00:07:01.800" region="bottomCenter">报</p>
      <p xml:id="p107" begin="00:07:02.120" end="00:07:03.320" region="bottomCenter">海面出现敌情</p>
      <p xml:id="p108" begin="00:07:03.440" end="00:07:04.360" region="bottomCenter">好像是申公豹</p>
      <p xml:id="p109" begin="00:07:04.560" end="00:07:06.600" region="bottomCenter">有多少敌人？　　就他一人</p>
      <p xml:id="p110" begin="00:07:06.840" end="00:07:08.360" region="bottomCenter">奇怪</p>
      <p xml:id="p111" begin="00:07:08.520" end="00:07:09.600" region="bottomCenter">您继续施法</p>
      <p xml:id="p112" begin="00:07:09.720" end="00:07:10.800" region="bottomCenter">我等前去御敌</p>
      <p xml:id="p113" begin="00:07:11.240" end="00:07:12.960" region="bottomCenter">仙长，让我去跟师父求求情</p>
      <p xml:id="p114" begin="00:07:13.080" end="00:07:15.040" region="bottomCenter">莫动，还需一炷香的时间</p>
      <p xml:id="p115" begin="00:07:15.160" end="00:07:16.520" region="bottomCenter">你肉身才能稳定</p>
      <p xml:id="p116" begin="00:07:45.520" end="00:07:46.560" region="bottomCenter">申公豹</p>
      <p xml:id="p117" begin="00:07:46.680" end="00:07:48.760" region="bottomCenter">你去而复返是何用意？</p>
      <p xml:id="p118" begin="00:07:49.080" end="00:07:52.840" region="bottomCenter">你们既已知晓我和龙族的计划</p>
      <p xml:id="p119" begin="00:07:52.960" end="00:07:56.560" region="bottomCenter">我心里始终不踏…踏实</p>
      <p xml:id="p120" begin="00:07:56.680" end="00:07:58.880" region="bottomCenter">陈塘关现有重兵把守</p>
      <p xml:id="p121" begin="00:07:59.000" end="00:08:00.720" region="bottomCenter">太乙仙长也在城内</p>
      <p xml:id="p122" begin="00:08:00.840" end="00:08:03.480" region="bottomCenter">你单枪匹马怕是难有什么作为</p>
      <p xml:id="p123" begin="00:08:03.720" end="00:08:08.920" region="bottomCenter">谁…谁说我单枪匹马？</p>
      <p xml:id="p124" begin="00:08:13.280" end="00:08:16.160" region="bottomCenter">盗取灵珠之事一旦败露</p>
      <p xml:id="p125" begin="00:08:16.680" end="00:08:19.000" region="bottomCenter">别说替你儿报仇</p>
      <p xml:id="p126" begin="00:08:19.680" end="00:08:22.160" region="bottomCenter">就是东海龙族</p>
      <p xml:id="p127" begin="00:08:22.600" end="00:08:24.960" region="bottomCenter">也罪责难逃</p>
      <p xml:id="p128" begin="00:08:25.360" end="00:08:26.400" region="bottomCenter">等事情败露</p>
      <p xml:id="p129" begin="00:08:26.520" end="00:08:28.280" region="bottomCenter">你也被打入海底炼狱</p>
      <p xml:id="p130" begin="00:08:28.400" end="00:08:30.200" region="bottomCenter">下面全是你的老熟人</p>
      <p xml:id="p131" begin="00:08:30.320" end="00:08:31.840" region="bottomCenter">看我们怎么招待你</p>
      <p xml:id="p132" begin="00:08:32.080" end="00:08:33.920" region="bottomCenter">出不了龙宫</p>
      <p xml:id="p133" begin="00:08:34.040" end="00:08:36.480" region="bottomCenter">报不了你儿的血海深仇</p>
      <p xml:id="p134" begin="00:08:36.600" end="00:08:38.360" region="bottomCenter">我都替你着急</p>
      <p xml:id="p135" begin="00:08:47.800" end="00:08:51.600" region="bottomCenter">还轮不到你们在这儿幸灾乐祸</p>
      <p xml:id="p136" begin="00:08:51.800" end="00:08:54.040" region="bottomCenter">小妹原想献计</p>
      <p xml:id="p137" begin="00:08:54.520" end="00:08:58.320" region="bottomCenter">看来大哥是不领情了</p>
      <p xml:id="p138" begin="00:09:07.440" end="00:09:10.520" region="bottomCenter">大哥怕是忘了小妹的能耐</p>
      <p xml:id="p139" begin="00:09:13.920" end="00:09:15.960" region="bottomCenter">啊！我知道</p>
      <p xml:id="p140" begin="00:09:16.160" end="00:09:19.240" region="bottomCenter">裂…裂…裂...</p>
      <p xml:id="p141" begin="00:09:19.360" end="00:09:21.560" region="bottomCenter">裂空爪</p>
      <p xml:id="p142" begin="00:09:21.680" end="00:09:22.880" region="bottomCenter">谢谢</p>
      <p xml:id="p143" begin="00:09:25.440" end="00:09:29.240" region="bottomCenter">若申道长携此龙爪前去陈塘关</p>
      <p xml:id="p144" begin="00:09:29.360" end="00:09:32.320" region="bottomCenter">切开直通本王身边的裂缝</p>
      <p xml:id="p145" begin="00:09:32.440" end="00:09:38.440" region="bottomCenter">海底妖族便能助大哥铲平陈塘关</p>
      <p xml:id="p146" begin="00:10:28.320" end="00:10:29.640" region="bottomCenter">海底妖族</p>
      <p xml:id="p147" begin="00:10:30.440" end="00:10:32.040" region="bottomCenter">这…这怎么可能？</p>
      <p xml:id="p148" begin="00:10:32.160" end="00:10:33.000" region="bottomCenter">是千年前镇压在</p>
      <p xml:id="p149" begin="00:10:33.120" end="00:10:34.200" region="bottomCenter">锁妖阵下的妖族</p>
      <p xml:id="p150" begin="00:10:34.320" end="00:10:35.240" region="bottomCenter">它们怎么出得来？</p>
      <p xml:id="p151" begin="00:10:35.360" end="00:10:37.160" region="bottomCenter">龙…龙族已经把它们放了吗？</p>
      <p xml:id="p152" begin="00:10:37.840" end="00:10:40.440" region="bottomCenter">有定海锁链相连</p>
      <p xml:id="p153" begin="00:10:40.560" end="00:10:43.000" region="bottomCenter">也不必担心我们逃得掉</p>
      <p xml:id="p154" begin="00:10:43.600" end="00:10:46.840" region="bottomCenter">这两全其美的借兵之法</p>
      <p xml:id="p155" begin="00:10:47.080" end="00:10:48.680" region="bottomCenter">大哥满意否？</p>
      <p xml:id="p156" begin="00:10:49.000" end="00:10:51.080" region="bottomCenter">你会这么好心？</p>
      <p xml:id="p157" begin="00:10:52.480" end="00:10:55.240" region="bottomCenter">说吧…你的条件</p>
      <p xml:id="p158" begin="00:10:57.160" end="00:10:59.240" region="bottomCenter">这炼狱里啊</p>
      <p xml:id="p159" begin="00:10:59.360" end="00:11:00.840" region="bottomCenter">烈焰焚身</p>
      <p xml:id="p160" begin="00:11:00.960" end="00:11:02.440" region="bottomCenter">度日如年</p>
      <p xml:id="p161" begin="00:11:02.680" end="00:11:05.440" region="bottomCenter">若大哥稍降岩浆火力</p>
      <p xml:id="p162" begin="00:11:05.560" end="00:11:07.760" region="bottomCenter">缓减灼烧之苦</p>
      <p xml:id="p163" begin="00:11:08.560" end="00:11:11.600" region="bottomCenter">我等甘效犬马之劳</p>
      <p xml:id="p164" begin="00:11:13.520" end="00:11:14.400" region="bottomCenter">怎么啰？</p>
      <p xml:id="p165" begin="00:11:14.520" end="00:11:16.400" region="bottomCenter">申…申公豹在搞什么名堂？</p>
      <p xml:id="p166" begin="00:11:24.440" end="00:11:27.240" region="bottomCenter">终于出来了！耶</p>
      <p xml:id="p167" begin="00:11:28.160" end="00:11:29.800" region="bottomCenter">拜拜</p>
      <p xml:id="p168" begin="00:11:33.400" end="00:11:35.480" region="bottomCenter">卑鄙呀</p>
      <p xml:id="p169" begin="00:11:35.600" end="00:11:36.440" region="bottomCenter">完了</p>
      <p xml:id="p170" begin="00:11:36.560" end="00:11:38.720" region="bottomCenter">这下怎么向李大人交代啊？</p>
      <p xml:id="p171" begin="00:11:38.920" end="00:11:40.240" region="bottomCenter">还好没有人看到</p>
      <p xml:id="p172" begin="00:11:40.520" end="00:11:42.240" region="bottomCenter">给　　干嘛？</p>
      <p xml:id="p173" begin="00:11:42.360" end="00:11:44.040" region="bottomCenter">我把你打残，你把我打残</p>
      <p xml:id="p174" begin="00:11:44.160" end="00:11:45.280" region="bottomCenter">就说是夜叉干的</p>
      <p xml:id="p175" begin="00:11:45.440" end="00:11:48.280" region="bottomCenter">哦，李大人看我们被打得那么惨</p>
      <p xml:id="p176" begin="00:11:48.400" end="00:11:49.760" region="bottomCenter">就不会怪罪我们了</p>
      <p xml:id="p177" begin="00:11:49.880" end="00:11:50.720" region="bottomCenter">别手软</p>
      <p xml:id="p178" begin="00:11:50.960" end="00:11:52.000" region="bottomCenter">使点儿劲儿</p>
      <p xml:id="p179" begin="00:11:55.400" end="00:11:57.800" region="bottomCenter">喂，喂</p>
      <p xml:id="p180" begin="00:12:00.080" end="00:12:01.200" region="bottomCenter">喂，你们两个</p>
      <p xml:id="p181" begin="00:12:03.920" end="00:12:05.720" region="bottomCenter">仙长，您在这儿呢</p>
      <p xml:id="p182" begin="00:12:08.440" end="00:12:09.560" region="bottomCenter">夜叉是它放跑的</p>
      <p xml:id="p183" begin="00:12:09.680" end="00:12:13.000" region="bottomCenter">啊？明明是你粗心大意</p>
      <p xml:id="p184" begin="00:12:13.120" end="00:12:14.000" region="bottomCenter">你含血喷人</p>
      <p xml:id="p185" begin="00:12:14.120" end="00:12:15.120" region="bottomCenter">你推卸责任</p>
      <p xml:id="p186" begin="00:12:18.280" end="00:12:19.320" region="bottomCenter">嗨呀</p>
      <p xml:id="p187" begin="00:12:19.440" end="00:12:20.760" region="bottomCenter">两个神经病</p>
      <p xml:id="p188" begin="00:12:20.880" end="00:12:21.720" region="bottomCenter">喂</p>
      <p xml:id="p189" begin="00:12:21.840" end="00:12:23.520" region="bottomCenter">打个大西瓜，你们两个</p>
      <p xml:id="p190" begin="00:12:23.640" end="00:12:25.400" region="bottomCenter">滚过来给我护法</p>
      <p xml:id="p191" begin="00:12:25.760" end="00:12:27.440" region="bottomCenter">是是是　　好嘞好嘞</p>
      <p xml:id="p192" begin="00:13:38.160" end="00:13:40.200" region="bottomCenter">不留活口</p>
      <p xml:id="p193" begin="00:14:34.160" end="00:14:36.200" region="bottomCenter">申公豹，敖丙并未殒命</p>
      <p xml:id="p194" begin="00:14:36.320" end="00:14:38.800" region="bottomCenter">陈塘关和龙族并非势不两立</p>
      <p xml:id="p195" begin="00:14:38.920" end="00:14:40.920" region="bottomCenter">太乙仙长正为敖丙重塑肉身</p>
      <p xml:id="p196" begin="00:14:44.160" end="00:14:45.960" region="bottomCenter">信口雌黄</p>
      <p xml:id="p197" begin="00:14:47.720" end="00:14:48.600" region="bottomCenter">结界</p>
      <p xml:id="p198" begin="00:14:50.640" end="00:14:51.480" region="bottomCenter">不好</p>
      <p xml:id="p199" begin="00:15:08.040" end="00:15:09.960" region="bottomCenter">师父，师父</p>
      <p xml:id="p200" begin="00:15:10.680" end="00:15:11.680" region="bottomCenter">敖丙</p>
      <p xml:id="p201" begin="00:15:11.840" end="00:15:13.520" region="bottomCenter">太乙师伯为徒儿重塑了肉身</p>
      <p xml:id="p202" begin="00:15:13.640" end="00:15:14.520" region="bottomCenter">快快停战吧</p>
      <p xml:id="p203" begin="00:15:14.720" end="00:15:15.800" region="bottomCenter">申公豹</p>
      <p xml:id="p204" begin="00:15:15.920" end="00:15:17.520" region="bottomCenter">我救了你徒儿，你该怎么谢我？</p>
      <p xml:id="p205" begin="00:15:17.720" end="00:15:21.720" region="bottomCenter">那…这里边是哪吒啰？</p>
      <p xml:id="p206" begin="00:15:24.080" end="00:15:26.240" region="bottomCenter">嗨呀，你个没良心的</p>
      <p xml:id="p207" begin="00:15:26.360" end="00:15:28.720" region="bottomCenter">师父　　他们必须死</p>
      <p xml:id="p208" begin="00:15:36.120" end="00:15:37.880" region="bottomCenter">就凭你破得了这结界</p>
      <p xml:id="p209" begin="00:15:38.000" end="00:15:39.960" region="bottomCenter">你打我噻！你打我噻</p>
      <p xml:id="p210" begin="00:16:06.280" end="00:16:07.440" region="bottomCenter">不要</p>
      <p xml:id="p211" begin="00:16:40.840" end="00:16:42.360" region="bottomCenter">这气息</p>
      <p xml:id="p212" begin="00:16:51.440" end="00:16:52.400" region="bottomCenter">敖丙</p>
      <p xml:id="p213" begin="00:16:52.520" end="00:16:53.520" region="bottomCenter">父王</p>
      <p xml:id="p214" begin="00:17:05.960" end="00:17:06.920" region="bottomCenter">父王</p>
      <p xml:id="p215" begin="00:17:07.520" end="00:17:09.320" region="bottomCenter">孩儿未能完成龙族的使命</p>
      <p xml:id="p216" begin="00:17:09.440" end="00:17:11.280" region="bottomCenter">不，那些都不重要</p>
      <p xml:id="p217" begin="00:17:11.400" end="00:17:13.160" region="bottomCenter">我只要你活着</p>
      <p xml:id="p218" begin="00:17:13.280" end="00:17:15.840" region="bottomCenter">活着就好，活着就好</p>
      <p xml:id="p219" begin="00:17:23.960" end="00:17:24.800" region="bottomCenter">开</p>
      <p xml:id="p220" begin="00:17:32.920" end="00:17:33.920" region="bottomCenter">你的身体怎么</p>
      <p xml:id="p221" begin="00:17:34.040" end="00:17:35.200" region="bottomCenter">哎呀，刚造的肉身</p>
      <p xml:id="p222" begin="00:17:35.320" end="00:17:37.320" region="bottomCenter">怎么遭得住那么强的冲击嘛？</p>
      <p xml:id="p223" begin="00:17:37.440" end="00:17:38.280" region="bottomCenter">敖丙</p>
      <p xml:id="p224" begin="00:17:38.720" end="00:17:39.960" region="bottomCenter">喂！火候没到</p>
      <p xml:id="p225" begin="00:17:40.080" end="00:17:41.360" region="bottomCenter">莫动啊！莫动</p>
      <p xml:id="p226" begin="00:17:41.480" end="00:17:42.400" region="bottomCenter">敖丙，你怎么了？</p>
      <p xml:id="p227" begin="00:17:42.520" end="00:17:45.240" region="bottomCenter">肉身还没定型，动什么嘛动</p>
      <p xml:id="p228" begin="00:17:45.360" end="00:17:46.400" region="bottomCenter">以后你的身体超过负荷</p>
      <p xml:id="p229" begin="00:17:46.520" end="00:17:47.840" region="bottomCenter">也会崩的啊</p>
      <p xml:id="p230" begin="00:17:47.960" end="00:17:49.440" region="bottomCenter">哎呀呀真的是</p>
      <p xml:id="p231" begin="00:17:49.560" end="00:17:50.400" region="bottomCenter">死胖子</p>
      <p xml:id="p232" begin="00:17:50.520" end="00:17:53.000" region="bottomCenter">还不赶紧给敖丙做…做个肉身</p>
      <p xml:id="p233" begin="00:17:54.080" end="00:17:55.360" region="bottomCenter">连造两个肉身</p>
      <p xml:id="p234" begin="00:17:55.480" end="00:17:57.080" region="bottomCenter">宝莲仙气都耗光了</p>
      <p xml:id="p235" begin="00:17:57.200" end="00:17:58.680" region="bottomCenter">没肉身不是会魂飞魄散吗？</p>
      <p xml:id="p236" begin="00:17:58.800" end="00:18:00.080" region="bottomCenter">师父你想想办法呀</p>
      <p xml:id="p237" begin="00:18:00.200" end="00:18:01.200" region="bottomCenter">没得宝莲</p>
      <p xml:id="p238" begin="00:18:01.320" end="00:18:02.920" region="bottomCenter">我…我也弄不成噻</p>
      <p xml:id="p239" begin="00:18:03.120" end="00:18:04.160" region="bottomCenter">没关系</p>
      <p xml:id="p240" begin="00:18:04.720" end="00:18:06.960" region="bottomCenter">是我占了灵珠才连累了你</p>
      <p xml:id="p241" begin="00:18:07.680" end="00:18:09.400" region="bottomCenter">若以我一命</p>
      <p xml:id="p242" begin="00:18:09.520" end="00:18:10.920" region="bottomCenter">能换你重生</p>
      <p xml:id="p243" begin="00:18:11.480" end="00:18:13.120" region="bottomCenter">也算稍抵罪过了</p>
      <p xml:id="p244" begin="00:18:13.240" end="00:18:14.480" region="bottomCenter">谁要你抵罪？</p>
      <p xml:id="p245" begin="00:18:14.600" end="00:18:16.200" region="bottomCenter">当魔丸我一样活得开心</p>
      <p xml:id="p246" begin="00:18:16.320" end="00:18:17.560" region="bottomCenter">我不准你死</p>
      <p xml:id="p247" begin="00:18:18.480" end="00:18:19.600" region="bottomCenter">父王</p>
      <p xml:id="p248" begin="00:18:20.400" end="00:18:22.360" region="bottomCenter">求您放过陈塘关吧</p>
      <p xml:id="p249" begin="00:18:23.400" end="00:18:25.720" region="bottomCenter">我们不能一错再错</p>
      <p xml:id="p250" begin="00:18:26.640" end="00:18:29.320" region="bottomCenter">这是孩儿最后的心愿</p>
      <p xml:id="p251" begin="00:18:34.880" end="00:18:35.960" region="bottomCenter">你肯定还有办法</p>
      <p xml:id="p252" begin="00:18:36.200" end="00:18:37.600" region="bottomCenter">必须还有办法</p>
      <p xml:id="p253" begin="00:18:37.720" end="00:18:39.520" region="bottomCenter">快点想！快点想</p>
      <p xml:id="p254" begin="00:18:39.640" end="00:18:41.200" region="bottomCenter">让敖丙先附你身上</p>
      <p xml:id="p255" begin="00:18:41.320" end="00:18:42.440" region="bottomCenter">附你身上</p>
      <p xml:id="p256" begin="00:18:42.760" end="00:18:45.480" region="bottomCenter">两个魂魄共用一个肉身</p>
      <p xml:id="p257" begin="00:18:45.600" end="00:18:47.440" region="bottomCenter">必会相互排斥</p>
      <p xml:id="p258" begin="00:18:47.560" end="00:18:49.400" region="bottomCenter">灵珠魔丸本是同根生</p>
      <p xml:id="p259" begin="00:18:49.520" end="00:18:50.400" region="bottomCenter">共用一个肉身</p>
      <p xml:id="p260" begin="00:18:50.520" end="00:18:52.800" region="bottomCenter">七天内没有问题</p>
      <p xml:id="p261" begin="00:18:52.920" end="00:18:53.760" region="bottomCenter">好啊</p>
      <p xml:id="p262" begin="00:18:53.880" end="00:18:55.320" region="bottomCenter">敖丙你快上来，快</p>
      <p xml:id="p263" begin="00:18:56.720" end="00:18:57.600" region="bottomCenter">好</p>
      <p xml:id="p264" begin="00:19:04.320" end="00:19:06.120" region="bottomCenter">好奇怪的感觉</p>
      <p xml:id="p265" begin="00:19:06.320" end="00:19:07.400" region="bottomCenter">敖丙你在吗？</p>
      <p xml:id="p266" begin="00:19:07.680" end="00:19:08.560" region="bottomCenter">我在</p>
      <p xml:id="p267" begin="00:19:08.680" end="00:19:10.560" region="bottomCenter">我脑袋里能听到你的声音诶</p>
      <p xml:id="p268" begin="00:19:10.680" end="00:19:12.080" region="bottomCenter">好玩好玩真好玩</p>
      <p xml:id="p269" begin="00:19:12.200" end="00:19:14.320" region="bottomCenter">这也只是权宜之计</p>
      <p xml:id="p270" begin="00:19:14.440" end="00:19:16.560" region="bottomCenter">七天后又当如何？</p>
      <p xml:id="p271" begin="00:19:16.680" end="00:19:18.240" region="bottomCenter">玉虚宫的宝库里有种法宝</p>
      <p xml:id="p272" begin="00:19:18.360" end="00:19:20.880" region="bottomCenter">名叫玉液琼浆</p>
      <p xml:id="p273" begin="00:19:21.000" end="00:19:23.120" region="bottomCenter">有恢复法器神力的功效</p>
      <p xml:id="p274" begin="00:19:23.240" end="00:19:24.200" region="bottomCenter">用它浇灌后</p>
      <p xml:id="p275" begin="00:19:24.320" end="00:19:27.240" region="bottomCenter">七色宝莲定可重开</p>
      <p xml:id="p276" begin="00:19:27.400" end="00:19:29.760" region="bottomCenter">但你想如何取来呢？</p>
      <p xml:id="p277" begin="00:19:29.880" end="00:19:31.480" region="bottomCenter">当然是求天尊赏赐呀</p>
      <p xml:id="p278" begin="00:19:32.200" end="00:19:33.280" region="bottomCenter">难不成</p>
      <p xml:id="p279" begin="00:19:33.400" end="00:19:35.400" region="bottomCenter">你要告发我和龙族？</p>
      <p xml:id="p280" begin="00:19:35.520" end="00:19:39.440" region="bottomCenter">天尊又岂会救…救龙族之子</p>
      <p xml:id="p281" begin="00:19:39.560" end="00:19:40.760" region="bottomCenter">求不到</p>
      <p xml:id="p282" begin="00:19:40.880" end="00:19:41.960" region="bottomCenter">那就抢</p>
      <p xml:id="p283" begin="00:19:42.400" end="00:19:44.360" region="bottomCenter">玉虚宫乃阐教核心</p>
      <p xml:id="p284" begin="00:19:44.480" end="00:19:45.480" region="bottomCenter">高手如云</p>
      <p xml:id="p285" begin="00:19:45.600" end="00:19:46.840" region="bottomCenter">为了我儿</p>
      <p xml:id="p286" begin="00:19:46.960" end="00:19:49.440" region="bottomCenter">就是天庭我也照闯</p>
      <p xml:id="p287" begin="00:19:49.560" end="00:19:51.000" region="bottomCenter">龙王稍安勿躁</p>
      <p xml:id="p288" begin="00:19:51.120" end="00:19:53.080" region="bottomCenter">我倒有一计</p>
      <p xml:id="p289" begin="00:19:53.200" end="00:19:55.320" region="bottomCenter">阐教弟子修行到家</p>
      <p xml:id="p290" begin="00:19:55.440" end="00:19:58.160" region="bottomCenter">皆可参加升仙考核</p>
      <p xml:id="p291" begin="00:19:58.280" end="00:20:01.400" region="bottomCenter">通过考核不仅可得道成仙</p>
      <p xml:id="p292" begin="00:20:01.520" end="00:20:03.680" region="bottomCenter">还能在玉虚宝库任选一样</p>
      <p xml:id="p293" begin="00:20:03.800" end="00:20:06.920" region="bottomCenter">法…法宝作为奖励</p>
      <p xml:id="p294" begin="00:20:07.040" end="00:20:08.920" region="bottomCenter">你是说，让吒儿参加考核</p>
      <p xml:id="p295" begin="00:20:09.040" end="00:20:10.080" region="bottomCenter">取得玉液琼浆？</p>
      <p xml:id="p296" begin="00:20:10.200" end="00:20:11.200" region="bottomCenter">要不得，要不得</p>
      <p xml:id="p297" begin="00:20:11.320" end="00:20:12.160" region="bottomCenter">他浑身魔气</p>
      <p xml:id="p298" begin="00:20:12.280" end="00:20:14.280" region="bottomCenter">一露功夫身份就暴露了</p>
      <p xml:id="p299" begin="00:20:14.400" end="00:20:16.080" region="bottomCenter">敖丙不是附哪吒身上了吗？</p>
      <p xml:id="p300" begin="00:20:16.200" end="00:20:18.080" region="bottomCenter">正好用灵气掩盖魔气</p>
      <p xml:id="p301" begin="00:20:19.280" end="00:20:21.800" region="bottomCenter">只要七天内通过考核</p>
      <p xml:id="p302" begin="00:20:21.920" end="00:20:24.720" region="bottomCenter">不仅可以取得玉液…琼浆</p>
      <p xml:id="p303" begin="00:20:24.840" end="00:20:25.840" region="bottomCenter">还可以</p>
      <p xml:id="p304" begin="00:20:25.960" end="00:20:26.920" region="bottomCenter">还可以成仙</p>
      <p xml:id="p305" begin="00:20:27.640" end="00:20:29.600" region="bottomCenter">成仙了是不是就不算魔啦？</p>
      <p xml:id="p306" begin="00:20:29.720" end="00:20:33.040" region="bottomCenter">既救敖丙也救哪吒</p>
      <p xml:id="p307" begin="00:20:33.160" end="00:20:35.680" region="bottomCenter">皆…皆大欢喜</p>
      <p xml:id="p308" begin="00:20:35.840" end="00:20:37.760" region="bottomCenter">此举绝非正道</p>
      <p xml:id="p309" begin="00:20:38.200" end="00:20:40.360" region="bottomCenter">那你待如何？</p>
      <p xml:id="p310" begin="00:20:40.480" end="00:20:42.200" region="bottomCenter">规行矩步</p>
      <p xml:id="p311" begin="00:20:42.520" end="00:20:43.840" region="bottomCenter">禀明天尊</p>
      <p xml:id="p312" begin="00:20:43.960" end="00:20:45.880" region="bottomCenter">盼天尊明察秋毫</p>
      <p xml:id="p313" begin="00:20:46.000" end="00:20:48.120" region="bottomCenter">我夫妇俩也会竭力相求</p>
      <p xml:id="p314" begin="00:20:48.240" end="00:20:51.720" region="bottomCenter">不让父辈之罪祸及两个无辜孩儿</p>
      <p xml:id="p315" begin="00:20:51.880" end="00:20:53.880" region="bottomCenter">区区凡人</p>
      <p xml:id="p316" begin="00:20:54.000" end="00:20:56.160" region="bottomCenter">几十年的阅历</p>
      <p xml:id="p317" begin="00:20:56.280" end="00:20:59.080" region="bottomCenter">就敢在我面前讲大道理？</p>
      <p xml:id="p318" begin="00:21:06.400" end="00:21:08.480" region="bottomCenter">我都记不清</p>
      <p xml:id="p319" begin="00:21:08.600" end="00:21:10.800" region="bottomCenter">活了几千年了</p>
      <p xml:id="p320" begin="00:21:10.920" end="00:21:14.200" region="bottomCenter">我老人家只告诉你一个道理</p>
      <p xml:id="p321" begin="00:21:14.320" end="00:21:16.560" region="bottomCenter">我儿若死了</p>
      <p xml:id="p322" begin="00:21:16.680" end="00:21:19.840" region="bottomCenter">全陈塘关都得陪葬</p>
      <p xml:id="p323" begin="00:21:27.120" end="00:21:28.320" region="bottomCenter">住手</p>
      <p xml:id="p324" begin="00:21:29.160" end="00:21:30.880" region="bottomCenter">敖丙是我朋友</p>
      <p xml:id="p325" begin="00:21:31.000" end="00:21:32.920" region="bottomCenter">我肯定会救他</p>
      <p xml:id="p326" begin="00:21:33.040" end="00:21:35.040" region="bottomCenter">但你要敢动陈塘关</p>
      <p xml:id="p327" begin="00:21:35.160" end="00:21:36.840" region="bottomCenter">我就把龙宫砸个</p>
      <p xml:id="p328" begin="00:21:36.960" end="00:21:38.640" region="bottomCenter">稀巴烂！</p>
      <p xml:id="p329" begin="00:21:44.040" end="00:21:45.880" region="bottomCenter">除了哪吒和太乙</p>
      <p xml:id="p330" begin="00:21:46.000" end="00:21:49.400" region="bottomCenter">任何人不得离开陈塘关半步</p>
      <p xml:id="p331" begin="00:21:49.520" end="00:21:51.880" region="bottomCenter">七天内取不到玉液琼浆</p>
      <p xml:id="p332" begin="00:21:52.000" end="00:21:54.960" region="bottomCenter">或走漏半点龙族的风声</p>
      <p xml:id="p333" begin="00:21:55.080" end="00:21:57.240" region="bottomCenter">我就让陈塘关</p>
      <p xml:id="p334" begin="00:21:57.360" end="00:21:58.720" region="bottomCenter">鸡犬不留</p>
      <p xml:id="p335" begin="00:21:59.920" end="00:22:02.040" region="bottomCenter">我那三兄妹信不过</p>
      <p xml:id="p336" begin="00:22:02.160" end="00:22:04.640" region="bottomCenter">我也不能长时间灵魂出窍</p>
      <p xml:id="p337" begin="00:22:04.760" end="00:22:06.440" region="bottomCenter">看守陈塘关</p>
      <p xml:id="p338" begin="00:22:06.560" end="00:22:07.960" region="bottomCenter">只有靠你了</p>
      <p xml:id="p339" begin="00:22:12.600" end="00:22:13.440" region="bottomCenter">嗯</p>
      <p xml:id="p340" begin="00:22:13.640" end="00:22:14.720" region="bottomCenter">对嘛</p>
      <p xml:id="p341" begin="00:22:14.840" end="00:22:16.560" region="bottomCenter">没有什么意思是点个头</p>
      <p xml:id="p342" begin="00:22:16.680" end="00:22:18.160" region="bottomCenter">无法表达的</p>
      <p xml:id="p343" begin="00:22:25.440" end="00:22:26.920" region="bottomCenter">李大人</p>
      <p xml:id="p344" begin="00:22:27.040" end="00:22:29.840" region="bottomCenter">大伙儿来给三少爷送行</p>
      <p xml:id="p345" begin="00:22:29.960" end="00:22:33.680" region="bottomCenter">感谢他救了全城老小的性命</p>
      <p xml:id="p346" begin="00:22:33.840" end="00:22:35.000" region="bottomCenter">不敢当</p>
      <p xml:id="p347" begin="00:22:35.120" end="00:22:36.400" region="bottomCenter">犬子这些年</p>
      <p xml:id="p348" begin="00:22:36.520" end="00:22:37.720" region="bottomCenter">给大家添乱了</p>
      <p xml:id="p349" begin="00:22:38.240" end="00:22:42.560" region="bottomCenter">老夫早看出三少爷必定大有作为</p>
      <p xml:id="p350" begin="00:22:42.680" end="00:22:43.680" region="bottomCenter">大家瞧瞧</p>
      <p xml:id="p351" begin="00:22:43.800" end="00:22:45.120" region="bottomCenter">天庭饱满</p>
      <p xml:id="p352" begin="00:22:45.240" end="00:22:46.480" region="bottomCenter">面庞宽大</p>
      <p xml:id="p353" begin="00:22:46.600" end="00:22:47.960" region="bottomCenter">鼻梁丰起</p>
      <p xml:id="p354" begin="00:22:48.080" end="00:22:49.640" region="bottomCenter">腮鼓唇厚</p>
      <p xml:id="p355" begin="00:22:49.760" end="00:22:53.160" region="bottomCenter">此乃盖世英雄之面相</p>
      <p xml:id="p356" begin="00:22:53.280" end="00:22:54.480" region="bottomCenter">老夫从不会看走眼</p>
      <p xml:id="p357" begin="00:22:59.480" end="00:23:02.400" region="bottomCenter">少爷饭后可得记得刷牙呀</p>
      <p xml:id="p358" begin="00:23:03.720" end="00:23:04.720" region="bottomCenter">老大</p>
      <p xml:id="p359" begin="00:23:05.360" end="00:23:07.640" region="bottomCenter">伏魔帮从此改名哪吒帮</p>
      <p xml:id="p360" begin="00:23:07.760" end="00:23:10.600" region="bottomCenter">全体成员尊奉老大号令</p>
      <p xml:id="p361" begin="00:23:11.480" end="00:23:12.520" region="bottomCenter">少爷想练字吗？</p>
      <p xml:id="p362" begin="00:23:12.640" end="00:23:13.480" region="bottomCenter">找我呀</p>
      <p xml:id="p363" begin="00:23:13.600" end="00:23:14.600" region="bottomCenter">少爷都三岁了</p>
      <p xml:id="p364" begin="00:23:14.720" end="00:23:15.840" region="bottomCenter">是时候找个对象了</p>
      <p xml:id="p365" begin="00:23:15.960" end="00:23:16.840" region="bottomCenter">想学乐器吗？</p>
      <p xml:id="p366" begin="00:23:16.960" end="00:23:17.880" region="bottomCenter">我们样样精通</p>
      <p xml:id="p367" begin="00:23:20.920" end="00:23:22.120" region="bottomCenter">我想</p>
      <p xml:id="p368" begin="00:23:22.480" end="00:23:23.480" region="bottomCenter">踢毽子</p>
      <p xml:id="p369" begin="00:23:25.160" end="00:23:26.000" region="bottomCenter">怎么？</p>
      <p xml:id="p370" begin="00:23:26.120" end="00:23:26.960" region="bottomCenter">很好玩的</p>
      <p xml:id="p371" begin="00:23:27.560" end="00:23:28.520" region="bottomCenter">没人踢吗？</p>
      <p xml:id="p372" begin="00:23:32.560" end="00:23:33.600" region="bottomCenter">我陪你</p>
      <p xml:id="p373" begin="00:23:34.360" end="00:23:36.800" region="bottomCenter">你不是一直想和爹踢毽子吗？</p>
      <p xml:id="p374" begin="00:23:37.160" end="00:23:39.240" region="bottomCenter">那个…吒儿力道有点大</p>
      <p xml:id="p375" begin="00:23:40.800" end="00:23:42.440" region="bottomCenter">我堂堂武将</p>
      <p xml:id="p376" begin="00:23:44.560" end="00:23:45.400" region="bottomCenter">爹</p>
      <p xml:id="p377" begin="00:23:45.520" end="00:23:46.760" region="bottomCenter">不愧我儿</p>
      <p xml:id="p378" begin="00:23:48.440" end="00:23:50.400" region="bottomCenter">要不…改天再踢吧？</p>
      <p xml:id="p379" begin="00:23:50.520" end="00:23:51.800" region="bottomCenter">哪里的话</p>
      <p xml:id="p380" begin="00:23:51.920" end="00:23:53.600" region="bottomCenter">今天就要踢尽兴</p>
      <p xml:id="p381" begin="00:23:53.920" end="00:23:54.960" region="bottomCenter">没事儿，没事儿</p>
      <p xml:id="p382" begin="00:23:55.400" end="00:23:56.480" region="bottomCenter">那我也来</p>
      <p xml:id="p383" begin="00:23:56.600" end="00:23:58.160" region="bottomCenter">夫人，你又何苦</p>
      <p xml:id="p384" begin="00:23:58.280" end="00:23:59.360" region="bottomCenter">瞧不起老娘啊</p>
      <p xml:id="p385" begin="00:23:59.480" end="00:24:00.680" region="bottomCenter">我也堂堂武将</p>
      <p xml:id="p386" begin="00:24:01.520" end="00:24:02.920" region="bottomCenter">吒儿，接着</p>
      <p xml:id="p387" begin="00:24:05.440" end="00:24:06.400" region="bottomCenter">你这孩子</p>
      <p xml:id="p388" begin="00:24:06.520" end="00:24:07.640" region="bottomCenter">咋这都接不住呢？</p>
      <p xml:id="p389" begin="00:24:08.320" end="00:24:10.000" region="bottomCenter">我不是魔丸就好了</p>
      <p xml:id="p390" begin="00:24:10.200" end="00:24:11.160" region="bottomCenter">你说什么？</p>
      <p xml:id="p391" begin="00:24:11.280" end="00:24:12.360" region="bottomCenter">没啥</p>
      <p xml:id="p392" begin="00:24:12.480" end="00:24:13.680" region="bottomCenter">我也该出发了</p>
      <p xml:id="p393" begin="00:24:14.040" end="00:24:15.360" region="bottomCenter">走之前</p>
      <p xml:id="p394" begin="00:24:15.480" end="00:24:16.640" region="bottomCenter">能不能给娘一个</p>
      <p xml:id="p395" begin="00:24:17.040" end="00:24:18.120" region="bottomCenter">大大的拥抱？</p>
      <p xml:id="p396" begin="00:24:21.600" end="00:24:23.200" region="bottomCenter">哎呀，都看着呐</p>
      <p xml:id="p397" begin="00:24:25.720" end="00:24:26.640" region="bottomCenter">等一等</p>
      <p xml:id="p398" begin="00:24:28.240" end="00:24:30.040" region="bottomCenter">这都是娘亲手做的好吃的</p>
      <p xml:id="p399" begin="00:24:30.280" end="00:24:31.520" region="bottomCenter">你和师父带路上吃</p>
      <p xml:id="p400" begin="00:24:31.640" end="00:24:33.040" region="bottomCenter">知道了知道了，走啦</p>
      <p xml:id="p401" begin="00:24:33.200" end="00:24:35.160" region="bottomCenter">喂，我还没上来</p>
      <p xml:id="p402" begin="00:24:41.160" end="00:24:42.600" region="bottomCenter">你肉身还欠火候</p>
      <p xml:id="p403" begin="00:24:42.720" end="00:24:44.080" region="bottomCenter">千万别乱用蛮力</p>
      <p xml:id="p404" begin="00:24:44.200" end="00:24:45.040" region="bottomCenter">知道啦</p>
      <p xml:id="p405" begin="00:24:45.560" end="00:24:47.040" region="bottomCenter">你脾气大</p>
      <p xml:id="p406" begin="00:24:47.160" end="00:24:49.160" region="bottomCenter">在外遇事要冷静</p>
      <p xml:id="p407" begin="00:24:49.800" end="00:24:51.840" region="bottomCenter">爹娘不在身边</p>
      <p xml:id="p408" begin="00:24:51.960" end="00:24:54.520" region="bottomCenter">要学会照顾自己</p>
      <p xml:id="p409" begin="00:24:55.480" end="00:24:57.040" region="bottomCenter">你这家伙</p>
      <p xml:id="p410" begin="00:24:57.160" end="00:24:58.800" region="bottomCenter">就抱一下你娘又怎么了嘛？</p>
      <p xml:id="p411" begin="00:24:59.200" end="00:25:00.960" region="bottomCenter">不觉得肉麻呀，又不是见不到了</p>
      <p xml:id="p412" begin="00:25:01.080" end="00:25:02.000" region="bottomCenter">快走快走</p>
      <p xml:id="p413" begin="00:25:19.400" end="00:25:21.400" region="bottomCenter">叹什么气？不好吃吗？</p>
      <p xml:id="p414" begin="00:25:21.520" end="00:25:23.000" region="bottomCenter">吃吃吃，就晓得吃</p>
      <p xml:id="p415" begin="00:25:23.240" end="00:25:24.240" region="bottomCenter">你看我都</p>
      <p xml:id="p416" begin="00:25:24.360" end="00:25:25.320" region="bottomCenter">愁得都吃不下饭了</p>
      <p xml:id="p417" begin="00:25:25.440" end="00:25:27.280" region="bottomCenter">你有没有想过怎么通过修仙考核？</p>
      <p xml:id="p418" begin="00:25:28.840" end="00:25:30.600" region="bottomCenter">考些啥呀？</p>
      <p xml:id="p419" begin="00:25:30.720" end="00:25:32.680" region="bottomCenter">考你道行够不够深</p>
      <p xml:id="p420" begin="00:25:33.080" end="00:25:34.480" region="bottomCenter">你当着监考官的面</p>
      <p xml:id="p421" begin="00:25:34.600" end="00:25:37.080" region="bottomCenter">赤手空拳降服三只地仙级别的妖王</p>
      <p xml:id="p422" begin="00:25:37.200" end="00:25:39.120" region="bottomCenter">打架…我最擅长了</p>
      <p xml:id="p423" begin="00:25:39.640" end="00:25:40.560" region="bottomCenter">一发出魔气</p>
      <p xml:id="p424" begin="00:25:40.680" end="00:25:41.520" region="bottomCenter">你身份就暴露了</p>
      <p xml:id="p425" begin="00:25:41.640" end="00:25:43.040" region="bottomCenter">那就让敖丙控制我身体呗</p>
      <p xml:id="p426" begin="00:25:43.160" end="00:25:44.200" region="bottomCenter">用他的灵气</p>
      <p xml:id="p427" begin="00:25:44.320" end="00:25:45.240" region="bottomCenter">还不是一样厉害</p>
      <p xml:id="p428" begin="00:25:45.920" end="00:25:47.520" region="bottomCenter">说得简单，来试下哇</p>
      <p xml:id="p429" begin="00:25:48.600" end="00:25:51.200" region="bottomCenter">哪吒，你全身放松</p>
      <p xml:id="p430" begin="00:25:51.320" end="00:25:54.480" region="bottomCenter">让敖丙控制你的身体和我过两招</p>
      <p xml:id="p431" begin="00:25:57.600" end="00:25:58.960" region="bottomCenter">敖丙你搞啥？</p>
      <p xml:id="p432" begin="00:25:59.080" end="00:25:59.920" region="bottomCenter">站稳点儿</p>
      <p xml:id="p433" begin="00:26:00.040" end="00:26:01.680" region="bottomCenter">灵魂附在别人身上</p>
      <p xml:id="p434" begin="00:26:01.800" end="00:26:04.000" region="bottomCenter">除非比宿主的精神力强大得多</p>
      <p xml:id="p435" begin="00:26:04.120" end="00:26:06.240" region="bottomCenter">否则是控制不了宿主的身体的</p>
      <p xml:id="p436" begin="00:26:09.240" end="00:26:10.520" region="bottomCenter">哪吒你还别急</p>
      <p xml:id="p437" begin="00:26:10.680" end="00:26:12.200" region="bottomCenter">你越使劲儿</p>
      <p xml:id="p438" begin="00:26:12.320" end="00:26:13.720" region="bottomCenter">敖丙就越控制不住</p>
      <p xml:id="p439" begin="00:26:14.640" end="00:26:15.600" region="bottomCenter">用腿啊</p>
      <p xml:id="p440" begin="00:26:15.880" end="00:26:17.480" region="bottomCenter">扫他呀，扫他呀</p>
      <p xml:id="p441" begin="00:26:25.960" end="00:26:28.400" region="bottomCenter">莫慌，我来救</p>
      <p xml:id="p442" begin="00:26:30.760" end="00:26:31.800" region="bottomCenter">你</p>
      <p xml:id="p443" begin="00:26:38.680" end="00:26:39.960" region="bottomCenter">玩得挺开心是吧？</p>
      <p xml:id="p444" begin="00:26:40.240" end="00:26:42.280" region="bottomCenter">马上都到玉虚宫了，还玩</p>
      <p xml:id="p445" begin="00:26:42.520" end="00:26:44.720" region="bottomCenter">你瞧瞧你从头到脚哪有个师父的样？</p>
      <p xml:id="p446" begin="00:26:44.840" end="00:26:46.320" region="bottomCenter">站这儿给我好好反省反省</p>
      <p xml:id="p447" begin="00:26:46.440" end="00:26:47.800" region="bottomCenter">想不出办法不准吃饭</p>
      <p xml:id="p448" begin="00:26:48.400" end="00:26:49.240" region="bottomCenter">这么大个人儿了</p>
      <p xml:id="p449" begin="00:26:49.360" end="00:26:50.800" region="bottomCenter">一点儿都不让人省心</p>
      <p xml:id="p450" begin="00:26:52.920" end="00:26:53.760" region="bottomCenter">有了</p>
      <p xml:id="p451" begin="00:26:53.880" end="00:26:56.040" region="bottomCenter">迷迷眠眠丹</p>
      <p xml:id="p452" begin="00:26:56.800" end="00:26:57.680" region="bottomCenter">啥玩意儿？</p>
      <p xml:id="p453" begin="00:26:57.840" end="00:26:59.800" region="bottomCenter">吃了这个立马睡着</p>
      <p xml:id="p454" begin="00:26:59.920" end="00:27:01.080" region="bottomCenter">你一睡着</p>
      <p xml:id="p455" begin="00:27:01.200" end="00:27:03.480" region="bottomCenter">敖丙不就完全控制你身体了嘛</p>
      <p xml:id="p456" begin="00:27:03.640" end="00:27:04.640" region="bottomCenter">妙哉</p>
      <p xml:id="p457" begin="00:27:06.360" end="00:27:07.360" region="bottomCenter">一颗就够了</p>
      <p xml:id="p458" begin="00:27:07.720" end="00:27:09.840" region="bottomCenter">不早…说</p>
      <p xml:id="p459" begin="00:27:12.120" end="00:27:13.160" region="bottomCenter">安逸了</p>
      <p xml:id="p460" begin="00:27:20.600" end="00:27:21.640" region="bottomCenter">师伯</p>
      <p xml:id="p461" begin="00:27:23.080" end="00:27:25.440" region="bottomCenter">这个才像正版的嘛</p>
      <p xml:id="p462" begin="00:27:25.800" end="00:27:26.760" region="bottomCenter">怎么了，师伯？</p>
      <p xml:id="p463" begin="00:27:28.000" end="00:27:29.400" region="bottomCenter">没什么没什么</p>
      <p xml:id="p464" begin="00:27:29.520" end="00:27:32.760" region="bottomCenter">你已完全接管哪吒身体</p>
      <p xml:id="p465" begin="00:27:32.880" end="00:27:33.960" region="bottomCenter">再试一下</p>
      <p xml:id="p466" begin="00:27:35.600" end="00:27:38.080" region="bottomCenter">师伯要动真的了</p>
      <p xml:id="p467" begin="00:27:38.320" end="00:27:40.960" region="bottomCenter">你最好全力以赴</p>
      <p xml:id="p468" begin="00:27:51.480" end="00:27:53.000" region="bottomCenter">还请师伯多多指点</p>
      <p xml:id="p469" begin="00:27:53.600" end="00:27:54.760" region="bottomCenter">还行吧</p>
      <p xml:id="p470" begin="00:27:54.880" end="00:27:56.480" region="bottomCenter">勉强能和我打个平手</p>
      <p xml:id="p471" begin="00:27:56.600" end="00:27:58.280" region="bottomCenter">师伯，您流鼻血了</p>
      <p xml:id="p472" begin="00:27:59.480" end="00:28:01.080" region="bottomCenter">上火而已，最近水喝少了</p>
      <p xml:id="p473" begin="00:28:01.200" end="00:28:02.280" region="bottomCenter">没得事，没得事</p>
      <p xml:id="p474" begin="00:28:10.440" end="00:28:12.920" region="bottomCenter">昆仑山到了</p>
      <p xml:id="p475" begin="00:28:13.360" end="00:28:14.360" region="bottomCenter">这里一天</p>
      <p xml:id="p476" begin="00:28:14.480" end="00:28:15.680" region="bottomCenter">不会地上一年吧</p>
      <p xml:id="p477" begin="00:28:15.920" end="00:28:18.040" region="bottomCenter">放心，这还不是天界</p>
      <p xml:id="p478" begin="00:28:18.160" end="00:28:19.000" region="bottomCenter">这么多人？</p>
      <p xml:id="p479" begin="00:28:19.120" end="00:28:20.640" region="bottomCenter">都是来拜师修仙的</p>
      <p xml:id="p480" begin="00:28:20.760" end="00:28:21.920" region="bottomCenter">阐教名扬四海</p>
      <p xml:id="p481" begin="00:28:22.040" end="00:28:23.800" region="bottomCenter">世人无不向往</p>
      <p xml:id="p482" begin="00:28:24.680" end="00:28:26.960" region="bottomCenter">你看下这个，绿佩</p>
      <p xml:id="p483" begin="00:28:27.080" end="00:28:28.720" region="bottomCenter">阐教仙人的凭证</p>
      <p xml:id="p484" begin="00:28:28.840" end="00:28:29.680" region="bottomCenter">有了它</p>
      <p xml:id="p485" begin="00:28:29.800" end="00:28:32.560" region="bottomCenter">走遍天下任谁都高看你一眼，我跟你说</p>
      <p xml:id="p486" begin="00:28:32.680" end="00:28:34.040" region="bottomCenter">成仙真好</p>
      <p xml:id="p487" begin="00:28:34.400" end="00:28:35.520" region="bottomCenter">你那两个哥哥都成仙了</p>
      <p xml:id="p488" begin="00:28:35.640" end="00:28:36.760" region="bottomCenter">你也没有问题</p>
      <p xml:id="p489" begin="00:28:37.160" end="00:28:38.360" region="bottomCenter">我是说哪吒他哥</p>
      <p xml:id="p490" begin="00:28:38.560" end="00:28:39.880" region="bottomCenter">他两个哥啊</p>
      <p xml:id="p491" begin="00:28:40.000" end="00:28:42.160" region="bottomCenter">都是三代弟子中的佼佼者</p>
      <p xml:id="p492" begin="00:28:42.280" end="00:28:43.400" region="bottomCenter">你晓得噻</p>
      <p xml:id="p493" begin="00:28:43.520" end="00:28:44.960" region="bottomCenter">哪吒这个娃儿调皮得很</p>
      <p xml:id="p494" begin="00:28:45.080" end="00:28:47.960" region="bottomCenter">我就经常摆两个哥的故事给他听</p>
      <p xml:id="p495" begin="00:28:48.080" end="00:28:49.600" region="bottomCenter">当正面榜样噻</p>
      <p xml:id="p496" begin="00:28:49.720" end="00:28:50.800" region="bottomCenter">我跟你说</p>
      <p xml:id="p497" begin="00:28:50.920" end="00:28:52.720" region="bottomCenter">哪吒崇拜他两个哥得很</p>
      <p xml:id="p498" begin="00:29:15.480" end="00:29:16.640" region="bottomCenter">哦哟，你运气不错</p>
      <p xml:id="p499" begin="00:29:16.760" end="00:29:18.760" region="bottomCenter">刚来就碰上名满天下的捕妖队</p>
      <p xml:id="p500" begin="00:29:19.120" end="00:29:20.160" region="bottomCenter">捕妖队？</p>
      <p xml:id="p501" begin="00:29:20.280" end="00:29:23.120" region="bottomCenter">全靠他们四处征讨祸乱人间的妖物</p>
      <p xml:id="p502" begin="00:29:23.240" end="00:29:25.400" region="bottomCenter">才保得天下太平</p>
      <p xml:id="p503" begin="00:29:26.320" end="00:29:28.040" region="bottomCenter">捕妖队现任头领啊</p>
      <p xml:id="p504" begin="00:29:28.160" end="00:29:30.160" region="bottomCenter">是我大师兄的大弟子</p>
      <p xml:id="p505" begin="00:29:30.640" end="00:29:32.960" region="bottomCenter">我咋记得前一任还是申公豹呢</p>
      <p xml:id="p506" begin="00:29:47.560" end="00:29:49.520" region="bottomCenter">师伯，那冒烟的是什么？</p>
      <p xml:id="p507" begin="00:29:49.760" end="00:29:52.720" region="bottomCenter">哦，那是玉虚宫的镇宫之宝</p>
      <p xml:id="p508" begin="00:29:52.840" end="00:29:54.760" region="bottomCenter">天元鼎</p>
      <p xml:id="p509" begin="00:30:03.400" end="00:30:06.480" region="bottomCenter">师弟，好久不见呐</p>
      <p xml:id="p510" begin="00:30:07.400" end="00:30:08.480" region="bottomCenter">大师兄</p>
      <p xml:id="p511" begin="00:30:08.680" end="00:30:10.160" region="bottomCenter">听闻师尊闭关期间</p>
      <p xml:id="p512" begin="00:30:10.280" end="00:30:12.160" region="bottomCenter">由大师兄代为执掌玉虚宫</p>
      <p xml:id="p513" begin="00:30:12.280" end="00:30:14.240" region="bottomCenter">我是带徒儿来参加升仙考核的</p>
      <p xml:id="p514" begin="00:30:14.480" end="00:30:16.640" region="bottomCenter">哪吒，还不快来拜见大师伯</p>
      <p xml:id="p515" begin="00:30:16.840" end="00:30:17.960" region="bottomCenter">拜见大师伯</p>
      <p xml:id="p516" begin="00:30:18.240" end="00:30:19.720" region="bottomCenter">你就是哪吒？</p>
      <p xml:id="p517" begin="00:30:19.840" end="00:30:21.160" region="bottomCenter">灵珠转世</p>
      <p xml:id="p518" begin="00:30:21.560" end="00:30:23.400" region="bottomCenter">哎呀呀</p>
      <p xml:id="p519" begin="00:30:23.520" end="00:30:25.200" region="bottomCenter">了不得！了不得</p>
      <p xml:id="p520" begin="00:30:25.320" end="00:30:29.000" region="bottomCenter">天尊可是对你寄予厚望啊</p>
      <p xml:id="p521" begin="00:30:29.120" end="00:30:30.560" region="bottomCenter">不愧为灵珠</p>
      <p xml:id="p522" begin="00:30:30.680" end="00:30:31.720" region="bottomCenter">瞧瞧，瞧瞧</p>
      <p xml:id="p523" begin="00:30:31.920" end="00:30:34.040" region="bottomCenter">朝气蓬勃</p>
      <p xml:id="p524" begin="00:30:34.160" end="00:30:36.000" region="bottomCenter">一身正气</p>
      <p xml:id="p525" begin="00:30:44.560" end="00:30:46.080" region="bottomCenter">他最近练功过度</p>
      <p xml:id="p526" begin="00:30:46.200" end="00:30:47.480" region="bottomCenter">状态有点不稳定</p>
      <p xml:id="p527" begin="00:30:50.680" end="00:30:52.120" region="bottomCenter">你这家伙要搞什么？</p>
      <p xml:id="p528" begin="00:30:52.240" end="00:30:53.720" region="bottomCenter">这是玉虚宫</p>
      <p xml:id="p529" begin="00:30:53.840" end="00:30:55.320" region="bottomCenter">尿胀</p>
      <p xml:id="p530" begin="00:30:55.560" end="00:30:57.280" region="bottomCenter">鹤童　　在</p>
      <p xml:id="p531" begin="00:30:57.440" end="00:30:59.720" region="bottomCenter">带小师侄去更衣</p>
      <p xml:id="p532" begin="00:31:00.000" end="00:31:01.840" region="bottomCenter">更啥衣啊？我又没说要换衣服</p>
      <p xml:id="p533" begin="00:31:01.960" end="00:31:03.120" region="bottomCenter">有病</p>
      <p xml:id="p534" begin="00:31:03.800" end="00:31:04.960" region="bottomCenter">更衣的意思</p>
      <p xml:id="p535" begin="00:31:05.080" end="00:31:07.480" region="bottomCenter">就是带你去厕所里撒尿</p>
      <p xml:id="p536" begin="00:31:08.360" end="00:31:09.840" region="bottomCenter">我这个徒儿粗鄙得很</p>
      <p xml:id="p537" begin="00:31:09.960" end="00:31:10.960" region="bottomCenter">莫怪莫怪</p>
      <p xml:id="p538" begin="00:31:18.360" end="00:31:20.320" region="bottomCenter">哇！好白</p>
      <p xml:id="p539" begin="00:31:22.000" end="00:31:23.520" region="bottomCenter">哇！好白</p>
      <p xml:id="p540" begin="00:31:25.160" end="00:31:26.520" region="bottomCenter">哇！好白</p>
      <p xml:id="p541" begin="00:31:27.920" end="00:31:29.640" region="bottomCenter">整个宫殿都是玉做的吗？</p>
      <p xml:id="p542" begin="00:31:29.880" end="00:31:31.760" region="bottomCenter">你们哪儿来那么多钱买玉啊？</p>
      <p xml:id="p543" begin="00:31:31.960" end="00:31:34.360" region="bottomCenter">玉虚宫的玉字就是说用玉做的吧？</p>
      <p xml:id="p544" begin="00:31:34.480" end="00:31:35.960" region="bottomCenter">那虚字啥意思？</p>
      <p xml:id="p545" begin="00:31:36.120" end="00:31:37.320" region="bottomCenter">是谦虚吗？</p>
      <p xml:id="p546" begin="00:31:37.440" end="00:31:38.840" region="bottomCenter">心虚？还是空虚？</p>
      <p xml:id="p547" begin="00:31:40.000" end="00:31:41.360" region="bottomCenter">茅房也是玉做的吗？</p>
      <p xml:id="p548" begin="00:31:41.680" end="00:31:43.200" region="bottomCenter">神仙也要用茅房啊？</p>
      <p xml:id="p549" begin="00:31:44.360" end="00:31:46.000" region="bottomCenter">仙翁也会拉屎吗？</p>
      <p xml:id="p550" begin="00:31:47.280" end="00:31:49.160" region="bottomCenter">清修之地，禁止喧哗</p>
      <p xml:id="p551" begin="00:31:50.240" end="00:31:51.520" region="bottomCenter">茅房还有多远啊？</p>
      <p xml:id="p552" begin="00:31:51.640" end="00:31:52.600" region="bottomCenter">快憋不住啦</p>
      <p xml:id="p553" begin="00:31:52.760" end="00:31:53.720" region="bottomCenter">喂，师姐等等我</p>
      <p xml:id="p554" begin="00:31:55.520" end="00:31:56.440" region="bottomCenter">你</p>
      <p xml:id="p555" begin="00:31:57.880" end="00:31:58.920" region="bottomCenter">我不是故意的</p>
      <p xml:id="p556" begin="00:31:59.120" end="00:32:00.040" region="bottomCenter">我要换裙子</p>
      <p xml:id="p557" begin="00:32:00.160" end="00:32:01.040" region="bottomCenter">你自己去吧</p>
      <p xml:id="p558" begin="00:32:01.360" end="00:32:02.680" region="bottomCenter">我不知道茅房在哪儿啊</p>
      <p xml:id="p559" begin="00:32:02.800" end="00:32:04.320" region="bottomCenter">穿过回廊右转再左转</p>
      <p xml:id="p560" begin="00:32:06.160" end="00:32:07.360" region="bottomCenter">哦</p>
      <p xml:id="p561" begin="00:32:21.360" end="00:32:24.000" region="bottomCenter">哇！不愧是神仙用的茅房</p>
      <p xml:id="p562" begin="00:32:24.120" end="00:32:25.960" region="bottomCenter">太有品味了</p>
      <p xml:id="p563" begin="00:32:50.360" end="00:32:52.600" region="bottomCenter">怪了，咋回不去了？</p>
      <p xml:id="p564" begin="00:32:53.800" end="00:32:54.880" region="bottomCenter">你往哪儿走？</p>
      <p xml:id="p565" begin="00:32:55.120" end="00:32:56.680" region="bottomCenter">哦，我迷路了</p>
      <p xml:id="p566" begin="00:32:57.640" end="00:32:58.560" region="bottomCenter">跟我来</p>
      <p xml:id="p567" begin="00:33:00.480" end="00:33:03.240" region="bottomCenter">师弟将灵珠培育成才</p>
      <p xml:id="p568" begin="00:33:03.360" end="00:33:06.720" region="bottomCenter">可算为本教立了大功一件啊</p>
      <p xml:id="p569" begin="00:33:06.840" end="00:33:09.320" region="bottomCenter">哪里哪里，全靠师尊的提携</p>
      <p xml:id="p570" begin="00:33:09.840" end="00:33:13.320" region="bottomCenter">这昆仑甘露乃修仙补品</p>
      <p xml:id="p571" begin="00:33:13.440" end="00:33:16.040" region="bottomCenter">原本半年才集得了一盆</p>
      <p xml:id="p572" begin="00:33:16.160" end="00:33:17.720" region="bottomCenter">今天叫人去看</p>
      <p xml:id="p573" begin="00:33:17.840" end="00:33:19.200" region="bottomCenter">居然满了</p>
      <p xml:id="p574" begin="00:33:20.080" end="00:33:22.960" region="bottomCenter">来得早不如来得巧啊</p>
      <p xml:id="p575" begin="00:33:23.080" end="00:33:24.040" region="bottomCenter">师弟</p>
      <p xml:id="p576" begin="00:33:24.160" end="00:33:26.720" region="bottomCenter">你说你是不是有福之人呐？</p>
      <p xml:id="p577" begin="00:33:30.480" end="00:33:32.800" region="bottomCenter">你抽疯啊？水都不会喝了</p>
      <p xml:id="p578" begin="00:33:33.240" end="00:33:34.680" region="bottomCenter">我这个徒儿粗鄙得很</p>
      <p xml:id="p579" begin="00:33:34.800" end="00:33:35.720" region="bottomCenter">莫怪莫怪</p>
      <p xml:id="p580" begin="00:33:37.400" end="00:33:39.200" region="bottomCenter">水里有我的尿</p>
      <p xml:id="p581" begin="00:33:43.320" end="00:33:44.720" region="bottomCenter">我这师父也粗鄙得很</p>
      <p xml:id="p582" begin="00:33:44.840" end="00:33:45.720" region="bottomCenter">莫怪莫怪</p>
      <p xml:id="p583" begin="00:33:46.280" end="00:33:47.840" region="bottomCenter">师兄，事不宜迟</p>
      <p xml:id="p584" begin="00:33:47.960" end="00:33:50.240" region="bottomCenter">我看还是立刻让哪吒参加考核吧</p>
      <p xml:id="p585" begin="00:33:50.480" end="00:33:52.000" region="bottomCenter">何必着急啊？</p>
      <p xml:id="p586" begin="00:33:52.120" end="00:33:53.560" region="bottomCenter">多喝几杯再走嘛</p>
      <p xml:id="p587" begin="00:33:53.840" end="00:33:55.040" region="bottomCenter">不喝了不喝了</p>
      <p xml:id="p588" begin="00:33:56.400" end="00:33:57.800" region="bottomCenter">那也行吧</p>
      <p xml:id="p589" begin="00:33:58.400" end="00:34:01.360" region="bottomCenter">那就派我的徒儿鹿童监考</p>
      <p xml:id="p590" begin="00:34:01.480" end="00:34:03.200" region="bottomCenter">捕妖队的下一个目标</p>
      <p xml:id="p591" begin="00:34:03.320" end="00:34:04.960" region="bottomCenter">就交给哪吒降服吧</p>
      <p xml:id="p592" begin="00:34:05.080" end="00:34:06.080" region="bottomCenter">师兄告辞</p>
      <p xml:id="p593" begin="00:34:10.000" end="00:34:13.120" region="bottomCenter">我这个师弟还是这么急性子</p>
      <p xml:id="p594" begin="00:34:16.840" end="00:34:19.680" region="bottomCenter">这次甘露的味道</p>
      <p xml:id="p595" begin="00:34:22.600" end="00:34:24.120" region="bottomCenter">特别浓郁</p>
      <p xml:id="p596" begin="00:34:24.960" end="00:34:27.760" region="bottomCenter">以后都要沿用这次的工艺</p>
      <p xml:id="p597" begin="00:34:27.920" end="00:34:28.920" region="bottomCenter">诺</p>
      <p xml:id="p598" begin="00:35:11.200" end="00:35:12.240" region="bottomCenter">怎么停了？</p>
      <p xml:id="p599" begin="00:35:12.640" end="00:35:14.520" region="bottomCenter">都三个时辰了，道长</p>
      <p xml:id="p600" begin="00:35:14.640" end="00:35:15.760" region="bottomCenter">实在扔不动了</p>
      <p xml:id="p601" begin="00:35:15.880" end="00:35:18.600" region="bottomCenter">废物！修炼怎可懈怠</p>
      <p xml:id="p602" begin="00:35:18.720" end="00:35:20.160" region="bottomCenter">我不说停</p>
      <p xml:id="p603" begin="00:35:20.280" end="00:35:21.360" region="bottomCenter">就…就不准停</p>
      <p xml:id="p604" begin="00:35:28.520" end="00:35:29.840" region="bottomCenter">陈塘关李靖求见</p>
      <p xml:id="p605" begin="00:35:30.400" end="00:35:31.520" region="bottomCenter">申道长</p>
      <p xml:id="p606" begin="00:35:31.640" end="00:35:32.600" region="bottomCenter">昨日一战</p>
      <p xml:id="p607" begin="00:35:32.720" end="00:35:34.880" region="bottomCenter">陈塘关军民伤者甚众</p>
      <p xml:id="p608" begin="00:35:35.000" end="00:35:36.440" region="bottomCenter">药物告罄</p>
      <p xml:id="p609" begin="00:35:36.920" end="00:35:39.400" region="bottomCenter">恳请道长开个通道</p>
      <p xml:id="p610" begin="00:35:39.520" end="00:35:42.040" region="bottomCenter">放几个大夫出城采买药物</p>
      <p xml:id="p611" begin="00:35:46.800" end="00:35:48.200" region="bottomCenter">好胆色</p>
      <p xml:id="p612" begin="00:35:48.360" end="00:35:49.240" region="bottomCenter">不愧是</p>
      <p xml:id="p613" begin="00:35:49.840" end="00:35:50.680" region="bottomCenter">哪个混账？</p>
      <p xml:id="p614" begin="00:35:51.160" end="00:35:52.360" region="bottomCenter">你个王八</p>
      <p xml:id="p615" begin="00:35:52.840" end="00:35:53.720" region="bottomCenter">我</p>
      <p xml:id="p616" begin="00:35:55.360" end="00:35:57.200" region="bottomCenter">停…停…停停停</p>
      <p xml:id="p617" begin="00:36:03.440" end="00:36:06.000" region="bottomCenter">把刚才捉到那位带上来</p>
      <p xml:id="p618" begin="00:36:06.760" end="00:36:09.520" region="bottomCenter">大战时从城里逃出来的</p>
      <p xml:id="p619" begin="00:36:09.640" end="00:36:11.080" region="bottomCenter">劳烦李总兵</p>
      <p xml:id="p620" begin="00:36:11.200" end="00:36:13.240" region="bottomCenter">把他也带…带回去</p>
      <p xml:id="p621" begin="00:36:13.360" end="00:36:14.880" region="bottomCenter">误会啊申道长</p>
      <p xml:id="p622" begin="00:36:15.000" end="00:36:16.600" region="bottomCenter">我也妖怪呀我</p>
      <p xml:id="p623" begin="00:36:16.720" end="00:36:17.800" region="bottomCenter">这海夜叉</p>
      <p xml:id="p624" begin="00:36:17.920" end="00:36:20.560" region="bottomCenter">我原本捉他来是为了还我儿清白</p>
      <p xml:id="p625" begin="00:36:20.680" end="00:36:22.000" region="bottomCenter">现下事情已了</p>
      <p xml:id="p626" begin="00:36:22.120" end="00:36:24.520" region="bottomCenter">他也没做什么伤天害理之事</p>
      <p xml:id="p627" begin="00:36:24.640" end="00:36:25.760" region="bottomCenter">就随他去吧</p>
      <p xml:id="p628" begin="00:36:26.240" end="00:36:27.120" region="bottomCenter">就是就是</p>
      <p xml:id="p629" begin="00:36:27.240" end="00:36:29.800" region="bottomCenter">我是配角，小配角</p>
      <p xml:id="p630" begin="00:36:30.800" end="00:36:32.920" region="bottomCenter">看来你是没听明白</p>
      <p xml:id="p631" begin="00:36:33.040" end="00:36:36.200" region="bottomCenter">我连只妖都不会放出去</p>
      <p xml:id="p632" begin="00:36:36.320" end="00:36:37.800" region="bottomCenter">何况人</p>
      <p xml:id="p633" begin="00:36:38.560" end="00:36:40.240" region="bottomCenter">道长开恩啊</p>
      <p xml:id="p634" begin="00:36:40.360" end="00:36:42.360" region="bottomCenter">我也是妖啊</p>
      <p xml:id="p635" begin="00:36:42.720" end="00:36:44.800" region="bottomCenter">我们都是反派呀</p>
      <p xml:id="p636" begin="00:36:44.920" end="00:36:47.280" region="bottomCenter">呸，谁…谁跟你是反派</p>
      <p xml:id="p637" begin="00:36:47.400" end="00:36:48.760" region="bottomCenter">知道灵珠秘密的</p>
      <p xml:id="p638" begin="00:36:48.880" end="00:36:50.040" region="bottomCenter">都别想出去</p>
      <p xml:id="p639" begin="00:36:50.160" end="00:36:51.520" region="bottomCenter">若无药医治</p>
      <p xml:id="p640" begin="00:36:51.640" end="00:36:54.200" region="bottomCenter">伤患性命难保</p>
      <p xml:id="p641" begin="00:36:55.880" end="00:36:57.400" region="bottomCenter">还望道长</p>
      <p xml:id="p642" begin="00:36:58.680" end="00:37:00.040" region="bottomCenter">网开一面</p>
      <p xml:id="p643" begin="00:37:01.800" end="00:37:02.720" region="bottomCenter">报</p>
      <p xml:id="p644" begin="00:37:02.840" end="00:37:03.960" region="bottomCenter">抓到一名奸细</p>
      <p xml:id="p645" begin="00:37:04.280" end="00:37:05.480" region="bottomCenter">这人是从城外来的</p>
      <p xml:id="p646" begin="00:37:05.600" end="00:37:06.920" region="bottomCenter">还伤了我们几个弟兄</p>
      <p xml:id="p647" begin="00:37:07.040" end="00:37:08.240" region="bottomCenter">也关…关进城去</p>
      <p xml:id="p648" begin="00:37:08.560" end="00:37:09.480" region="bottomCenter">哥</p>
      <p xml:id="p649" begin="00:37:10.120" end="00:37:11.200" region="bottomCenter">哥，是你吗？</p>
      <p xml:id="p650" begin="00:37:11.640" end="00:37:12.840" region="bottomCenter">你</p>
      <p xml:id="p651" begin="00:37:12.960" end="00:37:14.080" region="bottomCenter">哥，是我啊</p>
      <p xml:id="p652" begin="00:37:17.800" end="00:37:19.120" region="bottomCenter">申小豹</p>
      <p xml:id="p653" begin="00:37:21.360" end="00:37:22.720" region="bottomCenter">你百多年没回过家</p>
      <p xml:id="p654" begin="00:37:22.840" end="00:37:24.120" region="bottomCenter">我好想你啊</p>
      <p xml:id="p655" begin="00:37:25.200" end="00:37:26.280" region="bottomCenter">你怎么来了？</p>
      <p xml:id="p656" begin="00:37:26.400" end="00:37:27.680" region="bottomCenter">爹叫我来找你啊</p>
      <p xml:id="p657" begin="00:37:27.800" end="00:37:28.640" region="bottomCenter">瞧</p>
      <p xml:id="p658" begin="00:37:28.760" end="00:37:29.720" region="bottomCenter">你送我的罗盘</p>
      <p xml:id="p659" begin="00:37:29.840" end="00:37:31.160" region="bottomCenter">能测你的位置</p>
      <p xml:id="p660" begin="00:37:32.600" end="00:37:35.720" region="bottomCenter">爹…他老人家还好吗？</p>
      <p xml:id="p661" begin="00:37:35.840" end="00:37:36.680" region="bottomCenter">好着呢</p>
      <p xml:id="p662" begin="00:37:36.800" end="00:37:38.000" region="bottomCenter">自从你进了玉虚宫</p>
      <p xml:id="p663" begin="00:37:38.120" end="00:37:40.040" region="bottomCenter">爹就跟吃了大补丸似的</p>
      <p xml:id="p664" begin="00:37:40.160" end="00:37:41.760" region="bottomCenter">天天倍儿精神</p>
      <p xml:id="p665" begin="00:37:41.880" end="00:37:43.240" region="bottomCenter">我们七山五岭可就出了</p>
      <p xml:id="p666" begin="00:37:43.360" end="00:37:45.160" region="bottomCenter">你一个阐教仙人</p>
      <p xml:id="p667" begin="00:37:45.280" end="00:37:46.400" region="bottomCenter">十里八乡的妖族</p>
      <p xml:id="p668" begin="00:37:46.520" end="00:37:47.840" region="bottomCenter">都争着拜爹为师呢</p>
      <p xml:id="p669" begin="00:37:50.440" end="00:37:51.440" region="bottomCenter">对了</p>
      <p xml:id="p670" begin="00:37:52.200" end="00:37:53.360" region="bottomCenter">你来找我干嘛？</p>
      <p xml:id="p671" begin="00:37:54.640" end="00:37:55.880" region="bottomCenter">你以前不说过</p>
      <p xml:id="p672" begin="00:37:56.000" end="00:37:57.360" region="bottomCenter">等我修炼成人形</p>
      <p xml:id="p673" begin="00:37:57.480" end="00:37:59.040" region="bottomCenter">就引荐我进玉虚宫吗？</p>
      <p xml:id="p674" begin="00:37:59.160" end="00:38:00.520" region="bottomCenter">我会变人了耶</p>
      <p xml:id="p675" begin="00:38:07.480" end="00:38:09.360" region="bottomCenter">这些年我天天都用功</p>
      <p xml:id="p676" begin="00:38:09.480" end="00:38:10.880" region="bottomCenter">从没偷过懒哦</p>
      <p xml:id="p677" begin="00:38:11.000" end="00:38:12.640" region="bottomCenter">哥就是我的榜样</p>
      <p xml:id="p678" begin="00:38:12.760" end="00:38:15.440" region="bottomCenter">玉虚名门济天下</p>
      <p xml:id="p679" begin="00:38:15.560" end="00:38:18.880" region="bottomCenter">替天行道走四方</p>
      <p xml:id="p680" begin="00:38:21.680" end="00:38:22.720" region="bottomCenter">对了，哥</p>
      <p xml:id="p681" begin="00:38:22.840" end="00:38:23.720" region="bottomCenter">你在这儿干嘛呀？</p>
      <p xml:id="p682" begin="00:38:23.840" end="00:38:25.520" region="bottomCenter">我…我...</p>
      <p xml:id="p683" begin="00:38:25.640" end="00:38:27.200" region="bottomCenter">这些海妖都是你部下吗？</p>
      <p xml:id="p684" begin="00:38:27.480" end="00:38:29.240" region="bottomCenter">你们把陈塘关围起来干啥？</p>
      <p xml:id="p685" begin="00:38:29.360" end="00:38:30.440" region="bottomCenter">那个嘛</p>
      <p xml:id="p686" begin="00:38:30.560" end="00:38:32.400" region="bottomCenter">这…这是...</p>
      <p xml:id="p687" begin="00:38:32.680" end="00:38:35.040" region="bottomCenter">申道长在守卫陈塘关</p>
      <p xml:id="p688" begin="00:38:35.280" end="00:38:36.120" region="bottomCenter">啊</p>
      <p xml:id="p689" begin="00:38:36.360" end="00:38:38.160" region="bottomCenter">因有邪魔外道来犯</p>
      <p xml:id="p690" begin="00:38:38.280" end="00:38:41.440" region="bottomCenter">申道长率海族前来守城</p>
      <p xml:id="p691" begin="00:38:41.560" end="00:38:45.440" region="bottomCenter">我代全城百姓拜谢道长之义举</p>
      <p xml:id="p692" begin="00:38:47.520" end="00:38:49.480" region="bottomCenter">好说，好说</p>
      <p xml:id="p693" begin="00:38:51.080" end="00:38:52.800" region="bottomCenter">哥，你太了不起了</p>
      <p xml:id="p694" begin="00:38:53.280" end="00:38:55.280" region="bottomCenter">这就袭击陈塘关的妖怪吗？</p>
      <p xml:id="p695" begin="00:38:57.080" end="00:38:58.000" region="bottomCenter">啊</p>
      <p xml:id="p696" begin="00:38:58.120" end="00:38:59.920" region="bottomCenter">妖族的名声都被你们败光了</p>
      <p xml:id="p697" begin="00:39:00.040" end="00:39:01.040" region="bottomCenter">败类</p>
      <p xml:id="p698" begin="00:39:01.920" end="00:39:03.880" region="bottomCenter">那个，小豹啊</p>
      <p xml:id="p699" begin="00:39:04.080" end="00:39:09.280" region="bottomCenter">你…能不能等几年再上玉虚宫？</p>
      <p xml:id="p700" begin="00:39:09.400" end="00:39:11.720" region="bottomCenter">啊？为什么啊？</p>
      <p xml:id="p701" begin="00:39:11.840" end="00:39:13.480" region="bottomCenter">我会变人了啊</p>
      <p xml:id="p702" begin="00:39:14.240" end="00:39:15.520" region="bottomCenter">最近</p>
      <p xml:id="p703" begin="00:39:15.640" end="00:39:18.240" region="bottomCenter">我准备晋升十二金仙</p>
      <p xml:id="p704" begin="00:39:18.360" end="00:39:19.320" region="bottomCenter">不能分心</p>
      <p xml:id="p705" begin="00:39:19.480" end="00:39:20.920" region="bottomCenter">十二金仙</p>
      <p xml:id="p706" begin="00:39:21.280" end="00:39:22.760" region="bottomCenter">事成之后</p>
      <p xml:id="p707" begin="00:39:22.880" end="00:39:24.000" region="bottomCenter">再带你</p>
      <p xml:id="p708" begin="00:39:24.560" end="00:39:25.800" region="bottomCenter">好吗？</p>
      <p xml:id="p709" begin="00:39:28.520" end="00:39:29.440" region="bottomCenter">没事儿，哥</p>
      <p xml:id="p710" begin="00:39:29.560" end="00:39:30.600" region="bottomCenter">晋级重要</p>
      <p xml:id="p711" begin="00:39:30.720" end="00:39:32.920" region="bottomCenter">我什么时候上玉虚宫都一样</p>
      <p xml:id="p712" begin="00:39:33.920" end="00:39:35.160" region="bottomCenter">反正</p>
      <p xml:id="p713" begin="00:39:35.560" end="00:39:37.600" region="bottomCenter">我变人还不熟练</p>
      <p xml:id="p714" begin="00:39:37.840" end="00:39:38.920" region="bottomCenter">回去再练练</p>
      <p xml:id="p715" begin="00:39:39.680" end="00:39:40.720" region="bottomCenter">再练练</p>
      <p xml:id="p716" begin="00:39:43.960" end="00:39:44.960" region="bottomCenter">小豹</p>
      <p xml:id="p717" begin="00:39:45.360" end="00:39:47.000" region="bottomCenter">这是我进宫后攒的</p>
      <p xml:id="p718" begin="00:39:47.480" end="00:39:48.560" region="bottomCenter">这什么呀？</p>
      <p xml:id="p719" begin="00:39:48.760" end="00:39:51.600" region="bottomCenter">玉虚宫给所有弟子定期发放仙丹</p>
      <p xml:id="p720" begin="00:39:51.720" end="00:39:54.360" region="bottomCenter">吃一颗，顶…顶十年苦修</p>
      <p xml:id="p721" begin="00:39:54.480" end="00:39:57.080" region="bottomCenter">这…这太宝贵了</p>
      <p xml:id="p722" begin="00:39:57.200" end="00:39:58.880" region="bottomCenter">哥，你在晋级</p>
      <p xml:id="p723" begin="00:39:59.000" end="00:40:00.160" region="bottomCenter">还是你吃，你吃</p>
      <p xml:id="p724" begin="00:40:00.280" end="00:40:01.640" region="bottomCenter">哥吃不惯这个</p>
      <p xml:id="p725" begin="00:40:01.760" end="00:40:03.440" region="bottomCenter">就喜欢自己修炼</p>
      <p xml:id="p726" begin="00:40:03.560" end="00:40:04.760" region="bottomCenter">你…你拿回去</p>
      <p xml:id="p727" begin="00:40:04.880" end="00:40:06.000" region="bottomCenter">家里人分着吃</p>
      <p xml:id="p728" begin="00:40:07.120" end="00:40:09.040" region="bottomCenter">不行不行，爹肯定会怪我</p>
      <p xml:id="p729" begin="00:40:09.160" end="00:40:11.200" region="bottomCenter">小豹，不听哥话啦？</p>
      <p xml:id="p730" begin="00:40:11.320" end="00:40:12.520" region="bottomCenter">带上仙丹快走</p>
      <p xml:id="p731" begin="00:40:12.640" end="00:40:14.240" region="bottomCenter">这是前线</p>
      <p xml:id="p732" begin="00:40:14.360" end="00:40:15.480" region="bottomCenter">再…再不走</p>
      <p xml:id="p733" begin="00:40:15.600" end="00:40:16.800" region="bottomCenter">影响我指挥</p>
      <p xml:id="p734" begin="00:40:17.640" end="00:40:19.680" region="bottomCenter">那…我</p>
      <p xml:id="p735" begin="00:40:20.560" end="00:40:21.680" region="bottomCenter">走啦</p>
      <p xml:id="p736" begin="00:40:25.480" end="00:40:26.440" region="bottomCenter">哥</p>
      <p xml:id="p737" begin="00:40:26.560" end="00:40:28.920" region="bottomCenter">你一定要当上十二金仙</p>
      <p xml:id="p738" begin="00:40:30.680" end="00:40:32.600" region="bottomCenter">我也会继续努力的</p>
      <p xml:id="p739" begin="00:40:37.760" end="00:40:39.440" region="bottomCenter">你虽帮了我</p>
      <p xml:id="p740" begin="00:40:39.560" end="00:40:40.480" region="bottomCenter">但事关重大</p>
      <p xml:id="p741" begin="00:40:40.600" end="00:40:42.200" region="bottomCenter">我还是不能放人</p>
      <p xml:id="p742" begin="00:40:42.320" end="00:40:43.400" region="bottomCenter">这夜叉</p>
      <p xml:id="p743" begin="00:40:43.520" end="00:40:44.960" region="bottomCenter">你…你也带回去</p>
      <p xml:id="p744" begin="00:40:45.080" end="00:40:46.600" region="bottomCenter">我帮的不是你</p>
      <p xml:id="p745" begin="00:40:46.720" end="00:40:48.200" region="bottomCenter">而是那个少年</p>
      <p xml:id="p746" begin="00:40:48.440" end="00:40:50.160" region="bottomCenter">一个好的榜样</p>
      <p xml:id="p747" begin="00:40:50.680" end="00:40:52.440" region="bottomCenter">能改变他的一生</p>
      <p xml:id="p748" begin="00:40:54.720" end="00:40:55.760" region="bottomCenter">等一下</p>
      <p xml:id="p749" begin="00:40:57.680" end="00:40:59.760" region="bottomCenter">留…留个药材清单</p>
      <p xml:id="p750" begin="00:41:41.880" end="00:41:45.080" region="bottomCenter">我乃哪吒三太子</p>
      <p xml:id="p751" begin="00:41:45.200" end="00:41:48.080" region="bottomCenter">能降妖来会作诗</p>
      <p xml:id="p752" begin="00:41:48.200" end="00:41:50.800" region="bottomCenter">今日到此除奸恶</p>
      <p xml:id="p753" begin="00:41:50.920" end="00:41:54.480" region="bottomCenter">尔等妖孽快受死</p>
      <p xml:id="p754" begin="00:41:58.520" end="00:41:59.680" region="bottomCenter">还吃？</p>
      <p xml:id="p755" begin="00:41:59.800" end="00:42:01.560" region="bottomCenter">收你们来了</p>
      <p xml:id="p756" begin="00:42:04.200" end="00:42:05.920" region="bottomCenter">啊</p>
      <p xml:id="p757" begin="00:42:06.800" end="00:42:09.920" region="bottomCenter">谁吃了熊心豹子胆啦？</p>
      <p xml:id="p758" begin="00:42:10.280" end="00:42:13.200" region="bottomCenter">敢到土肥坡来撒野啊</p>
      <p xml:id="p759" begin="00:42:14.080" end="00:42:15.080" region="bottomCenter">你就是头儿？</p>
      <p xml:id="p760" begin="00:42:15.200" end="00:42:17.240" region="bottomCenter">来来来，领教下小爷的手段</p>
      <p xml:id="p761" begin="00:42:17.360" end="00:42:20.040" region="bottomCenter">小屁孩儿狂得没边儿</p>
      <p xml:id="p762" begin="00:42:20.160" end="00:42:22.200" region="bottomCenter">大哥，给他点儿颜色瞧瞧</p>
      <p xml:id="p763" begin="00:42:41.160" end="00:42:42.040" region="bottomCenter">出招吧</p>
      <p xml:id="p764" begin="00:42:44.120" end="00:42:45.120" region="bottomCenter">你上</p>
      <p xml:id="p765" begin="00:42:45.440" end="00:42:47.360" region="bottomCenter">不…不是，大哥</p>
      <p xml:id="p766" begin="00:42:47.480" end="00:42:49.400" region="bottomCenter">小弟怎么能跟你抢风头呢？</p>
      <p xml:id="p767" begin="00:42:49.520" end="00:42:51.480" region="bottomCenter">跟小孩儿打多没面子</p>
      <p xml:id="p768" begin="00:42:51.600" end="00:42:52.960" region="bottomCenter">叫你上你就上</p>
      <p xml:id="p769" begin="00:42:53.800" end="00:42:55.160" region="bottomCenter">小…小孩儿</p>
      <p xml:id="p770" begin="00:42:55.280" end="00:42:56.760" region="bottomCenter">看你小，不懂事儿</p>
      <p xml:id="p771" begin="00:42:56.880" end="00:42:58.320" region="bottomCenter">咱也不跟你计较</p>
      <p xml:id="p772" begin="00:42:58.440" end="00:42:59.840" region="bottomCenter">你...</p>
      <p xml:id="p773" begin="00:42:59.960" end="00:43:02.040" region="bottomCenter">现在想回家还来得及哈</p>
      <p xml:id="p774" begin="00:43:02.280" end="00:43:03.120" region="bottomCenter">咋回事儿？</p>
      <p xml:id="p775" begin="00:43:03.240" end="00:43:04.920" region="bottomCenter">你怎么又醒了？　　不知道啊</p>
      <p xml:id="p776" begin="00:43:05.040" end="00:43:05.880" region="bottomCenter">睡不沉</p>
      <p xml:id="p777" begin="00:43:06.000" end="00:43:07.440" region="bottomCenter">你抖了几下就把我颠醒了</p>
      <p xml:id="p778" begin="00:43:08.160" end="00:43:09.440" region="bottomCenter">糟了</p>
      <p xml:id="p779" begin="00:43:09.560" end="00:43:11.520" region="bottomCenter">上次药吃多了，有抗药性了</p>
      <p xml:id="p780" begin="00:43:12.000" end="00:43:12.920" region="bottomCenter">加大药量</p>
      <p xml:id="p781" begin="00:43:13.160" end="00:43:15.920" region="bottomCenter">再不走我不客气啦</p>
      <p xml:id="p782" begin="00:43:20.640" end="00:43:22.040" region="bottomCenter">我想往右躲呀</p>
      <p xml:id="p783" begin="00:43:22.160" end="00:43:23.680" region="bottomCenter">抱歉，我以为要向左</p>
      <p xml:id="p784" begin="00:43:26.320" end="00:43:27.560" region="bottomCenter">这么不经打</p>
      <p xml:id="p785" begin="00:43:27.680" end="00:43:29.960" region="bottomCenter">师伯，要不还是我上吧</p>
      <p xml:id="p786" begin="00:43:30.080" end="00:43:31.240" region="bottomCenter">师弟多练几年再来晋级</p>
      <p xml:id="p787" begin="00:43:31.360" end="00:43:32.400" region="bottomCenter">你再等一下</p>
      <p xml:id="p788" begin="00:43:32.520" end="00:43:34.360" region="bottomCenter">他在跟妖怪开玩笑</p>
      <p xml:id="p789" begin="00:43:34.480" end="00:43:36.360" region="bottomCenter">我这个徒弟就是…就是爱装</p>
      <p xml:id="p790" begin="00:43:37.200" end="00:43:39.960" region="bottomCenter">药…药，得吃药</p>
      <p xml:id="p791" begin="00:43:40.080" end="00:43:42.400" region="bottomCenter">叫你走你不走</p>
      <p xml:id="p792" begin="00:43:42.520" end="00:43:45.160" region="bottomCenter">现在知道爷的厉害了吧</p>
      <p xml:id="p793" begin="00:43:45.280" end="00:43:46.800" region="bottomCenter">糟了，药都化汤里了</p>
      <p xml:id="p794" begin="00:43:47.560" end="00:43:49.240" region="bottomCenter">那我就喝汤</p>
      <p xml:id="p795" begin="00:43:51.960" end="00:43:53.760" region="bottomCenter">还敢偷我们汤</p>
      <p xml:id="p796" begin="00:43:53.880" end="00:43:54.960" region="bottomCenter">欠打</p>
      <p xml:id="p797" begin="00:43:56.440" end="00:43:57.600" region="bottomCenter">让我来</p>
      <p xml:id="p798" begin="00:44:00.920" end="00:44:01.760" region="bottomCenter">太恶心了</p>
      <p xml:id="p799" begin="00:44:01.880" end="00:44:05.520" region="bottomCenter">大力金刚棒</p>
      <p xml:id="p800" begin="00:44:09.640" end="00:44:11.520" region="bottomCenter">你看，我说他装的嘛</p>
      <p xml:id="p801" begin="00:44:12.160" end="00:44:14.280" region="bottomCenter">刚才是大意了</p>
      <p xml:id="p802" begin="00:44:14.400" end="00:44:15.240" region="bottomCenter">不算</p>
      <p xml:id="p803" begin="00:44:32.120" end="00:44:34.840" region="bottomCenter">不可能！不可能</p>
      <p xml:id="p804" begin="00:44:40.280" end="00:44:42.520" region="bottomCenter">你咋这菜</p>
      <p xml:id="p805" begin="00:44:42.800" end="00:44:43.680" region="bottomCenter">一边儿待着</p>
      <p xml:id="p806" begin="00:44:43.800" end="00:44:44.960" region="bottomCenter">看我怎么收拾他</p>
      <p xml:id="p807" begin="00:44:45.200" end="00:44:46.400" region="bottomCenter">你怎么全吐了呀？</p>
      <p xml:id="p808" begin="00:44:46.520" end="00:44:48.080" region="bottomCenter">味道太冲，实在没忍住</p>
      <p xml:id="p809" begin="00:44:48.200" end="00:44:49.680" region="bottomCenter">看招</p>
      <p xml:id="p810" begin="00:44:53.440" end="00:44:54.400" region="bottomCenter">戏精</p>
      <p xml:id="p811" begin="00:44:54.720" end="00:44:55.680" region="bottomCenter">不行啊</p>
      <p xml:id="p812" begin="00:44:55.800" end="00:44:56.960" region="bottomCenter">只有吃药才有胜算</p>
      <p xml:id="p813" begin="00:45:05.920" end="00:45:06.840" region="bottomCenter">鹿童在这儿</p>
      <p xml:id="p814" begin="00:45:06.960" end="00:45:08.600" region="bottomCenter">我没法给你药啊</p>
      <p xml:id="p815" begin="00:45:08.720" end="00:45:09.600" region="bottomCenter">怎么办？怎么办？</p>
      <p xml:id="p816" begin="00:45:09.720" end="00:45:10.920" region="bottomCenter">有</p>
      <p xml:id="p817" begin="00:45:11.040" end="00:45:12.920" region="bottomCenter">还有一个办法</p>
      <p xml:id="p818" begin="00:45:13.520" end="00:45:14.680" region="bottomCenter">你该不会是想</p>
      <p xml:id="p819" begin="00:45:14.800" end="00:45:16.960" region="bottomCenter">把吐了的全吃回来</p>
      <p xml:id="p820" begin="00:45:17.120" end="00:45:18.640" region="bottomCenter">这…这怎么行</p>
      <p xml:id="p821" begin="00:45:20.000" end="00:45:21.000" region="bottomCenter">怕什么？</p>
      <p xml:id="p822" begin="00:45:21.120" end="00:45:22.600" region="bottomCenter">我连夜叉鼻涕都喝过</p>
      <p xml:id="p823" begin="00:45:23.600" end="00:45:25.200" region="bottomCenter">原来如此</p>
      <p xml:id="p824" begin="00:45:25.320" end="00:45:27.080" region="bottomCenter">能人所不能</p>
      <p xml:id="p825" begin="00:45:27.200" end="00:45:28.880" region="bottomCenter">忍人所不忍</p>
      <p xml:id="p826" begin="00:45:29.000" end="00:45:31.560" region="bottomCenter">哪吒果然是不认命</p>
      <p xml:id="p827" begin="00:45:32.000" end="00:45:35.800" region="bottomCenter">我肩负父母朋友的性命</p>
      <p xml:id="p828" begin="00:45:36.400" end="00:45:39.280" region="bottomCenter">陈塘关百姓的安危</p>
      <p xml:id="p829" begin="00:45:39.400" end="00:45:43.360" region="bottomCenter">受这点罪又算什么</p>
      <p xml:id="p830" begin="00:45:51.280" end="00:45:53.440" region="bottomCenter">无视世俗之偏见</p>
      <p xml:id="p831" begin="00:45:53.560" end="00:45:55.600" region="bottomCenter">突破心中之魔障</p>
      <p xml:id="p832" begin="00:45:55.720" end="00:45:58.320" region="bottomCenter">我要扭转命运</p>
      <p xml:id="p833" begin="00:46:17.640" end="00:46:19.920" region="bottomCenter">以前我就是低调</p>
      <p xml:id="p834" begin="00:46:20.040" end="00:46:21.840" region="bottomCenter">今儿跟大家露两手</p>
      <p xml:id="p835" begin="00:46:21.960" end="00:46:22.960" region="bottomCenter">师伯</p>
      <p xml:id="p836" begin="00:46:23.520" end="00:46:24.480" region="bottomCenter">先救哪吒</p>
      <p xml:id="p837" begin="00:46:24.600" end="00:46:26.200" region="bottomCenter">玉液琼浆只有另想办法了</p>
      <p xml:id="p838" begin="00:46:26.320" end="00:46:27.560" region="bottomCenter">没道理</p>
      <p xml:id="p839" begin="00:46:27.920" end="00:46:28.920" region="bottomCenter">我不信</p>
      <p xml:id="p840" begin="00:46:29.120" end="00:46:31.240" region="bottomCenter">小娃，再跟我打一场</p>
      <p xml:id="p841" begin="00:46:32.440" end="00:46:33.400" region="bottomCenter">装死？</p>
      <p xml:id="p842" begin="00:46:33.760" end="00:46:35.160" region="bottomCenter">我捶扁你</p>
      <p xml:id="p843" begin="00:46:43.560" end="00:46:45.040" region="bottomCenter">多亏哪吒被砸晕了</p>
      <p xml:id="p844" begin="00:46:46.120" end="00:46:49.040" region="bottomCenter">说你菜你还不服</p>
      <p xml:id="p845" begin="00:46:50.200" end="00:46:51.600" region="bottomCenter">看我来替你报仇</p>
      <p xml:id="p846" begin="00:46:51.720" end="00:46:55.360" region="bottomCenter">无敌旋风拳</p>
      <p xml:id="p847" begin="00:47:10.000" end="00:47:11.360" region="bottomCenter">啊</p>
      <p xml:id="p848" begin="00:47:29.160" end="00:47:30.200" region="bottomCenter">全都得抓吗？</p>
      <p xml:id="p849" begin="00:47:30.640" end="00:47:31.840" region="bottomCenter">留下一只</p>
      <p xml:id="p850" begin="00:47:31.960" end="00:47:33.400" region="bottomCenter">也会祸害这里的百姓</p>
      <p xml:id="p851" begin="00:47:33.520" end="00:47:34.920" region="bottomCenter">都带回玉虚宫</p>
      <p xml:id="p852" begin="00:47:35.040" end="00:47:36.800" region="bottomCenter">本教会将它们引入正道</p>
      <p xml:id="p853" begin="00:47:36.920" end="00:47:38.040" region="bottomCenter">改邪归正</p>
      <p xml:id="p854" begin="00:47:39.320" end="00:47:40.480" region="bottomCenter">师弟的样子</p>
      <p xml:id="p855" begin="00:47:40.600" end="00:47:41.680" region="bottomCenter">没事没事哈</p>
      <p xml:id="p856" begin="00:47:41.800" end="00:47:43.200" region="bottomCenter">他就是一会儿丑一会儿帅</p>
      <p xml:id="p857" begin="00:47:43.320" end="00:47:44.160" region="bottomCenter">灵珠嘛</p>
      <p xml:id="p858" begin="00:47:44.280" end="00:47:45.840" region="bottomCenter">肯定跟正常人不一样噻</p>
      <p xml:id="p859" begin="00:47:46.920" end="00:47:48.280" region="bottomCenter">下回稳当点儿</p>
      <p xml:id="p860" begin="00:47:48.800" end="00:47:50.440" region="bottomCenter">魂儿都给我吓没了</p>
      <p xml:id="p861" begin="00:48:02.120" end="00:48:03.160" region="bottomCenter">这小孩儿谁呀？</p>
      <p xml:id="p862" begin="00:48:03.280" end="00:48:04.120" region="bottomCenter">听说叫哪吒</p>
      <p xml:id="p863" begin="00:48:04.240" end="00:48:05.280" region="bottomCenter">金吒木吒的弟弟</p>
      <p xml:id="p864" begin="00:48:05.400" end="00:48:07.920" region="bottomCenter">他是天尊钦定的灵珠转世</p>
      <p xml:id="p865" begin="00:48:10.800" end="00:48:13.000" region="bottomCenter">但形象可不咋样</p>
      <p xml:id="p866" begin="00:48:13.480" end="00:48:15.120" region="bottomCenter">弓腰驼背</p>
      <p xml:id="p867" begin="00:48:15.240" end="00:48:16.360" region="bottomCenter">脚步轻浮</p>
      <p xml:id="p868" begin="00:48:16.480" end="00:48:17.440" region="bottomCenter">低眉垂眼</p>
      <p xml:id="p869" begin="00:48:17.560" end="00:48:18.600" region="bottomCenter">相貌猥琐</p>
      <p xml:id="p870" begin="00:48:18.720" end="00:48:19.640" region="bottomCenter">还带黑眼圈</p>
      <p xml:id="p871" begin="00:48:19.760" end="00:48:21.200" region="bottomCenter">长得跟个鬼似的</p>
      <p xml:id="p872" begin="00:48:28.440" end="00:48:29.520" region="bottomCenter">莫惹事生非哈</p>
      <p xml:id="p873" begin="00:48:38.040" end="00:48:39.320" region="bottomCenter">师弟</p>
      <p xml:id="p874" begin="00:48:39.560" end="00:48:42.280" region="bottomCenter">你瞧今晚是何星象？</p>
      <p xml:id="p875" begin="00:48:42.520" end="00:48:44.160" region="bottomCenter">六星连珠</p>
      <p xml:id="p876" begin="00:48:44.280" end="00:48:45.520" region="bottomCenter">十年一遇哦</p>
      <p xml:id="p877" begin="00:48:45.720" end="00:48:47.920" region="bottomCenter">每逢六星连珠</p>
      <p xml:id="p878" begin="00:48:48.040" end="00:48:52.080" region="bottomCenter">这白玉台便可万里传音送影</p>
      <p xml:id="p879" begin="00:48:52.200" end="00:48:54.280" region="bottomCenter">众师弟天南地北</p>
      <p xml:id="p880" begin="00:48:54.400" end="00:48:55.680" region="bottomCenter">难得一聚</p>
      <p xml:id="p881" begin="00:48:56.000" end="00:48:59.400" region="bottomCenter">今日正好借六星连珠之机</p>
      <p xml:id="p882" begin="00:48:59.520" end="00:49:01.920" region="bottomCenter">开一次金仙大会</p>
      <p xml:id="p883" begin="00:49:02.600" end="00:49:04.280" region="bottomCenter">我尚未晋升十二金仙</p>
      <p xml:id="p884" begin="00:49:04.400" end="00:49:05.720" region="bottomCenter">还是回避的好</p>
      <p xml:id="p885" begin="00:49:06.360" end="00:49:08.040" region="bottomCenter">早晚的事</p>
      <p xml:id="p886" begin="00:49:08.440" end="00:49:09.600" region="bottomCenter">不得行，不得行</p>
      <p xml:id="p887" begin="00:49:09.720" end="00:49:10.760" region="bottomCenter">这怎么要得嘛</p>
      <p xml:id="p888" begin="00:49:10.880" end="00:49:12.040" region="bottomCenter">使不得，使不得</p>
      <p xml:id="p889" begin="00:49:13.120" end="00:49:14.360" region="bottomCenter">那你咋坐上去了？</p>
      <p xml:id="p890" begin="00:49:14.480" end="00:49:15.320" region="bottomCenter">闭嘴</p>
      <p xml:id="p891" begin="00:49:15.440" end="00:49:16.520" region="bottomCenter">见不得你师父好嗦</p>
      <p xml:id="p892" begin="00:49:26.520" end="00:49:27.640" region="bottomCenter">桑拿呀</p>
      <p xml:id="p893" begin="00:49:27.800" end="00:49:28.720" region="bottomCenter">嘘</p>
      <p xml:id="p894" begin="00:49:35.720" end="00:49:38.360" region="bottomCenter">恭迎各位师弟归位</p>
      <p xml:id="p895" begin="00:49:38.720" end="00:49:40.800" region="bottomCenter">参见大师兄</p>
      <p xml:id="p896" begin="00:49:41.240" end="00:49:43.920" region="bottomCenter">给大家引荐一位新成员</p>
      <p xml:id="p897" begin="00:49:44.040" end="00:49:45.920" region="bottomCenter">太乙师弟</p>
      <p xml:id="p898" begin="00:49:46.040" end="00:49:48.320" region="bottomCenter">他不负师尊所托</p>
      <p xml:id="p899" begin="00:49:48.440" end="00:49:50.200" region="bottomCenter">已将灵珠转世</p>
      <p xml:id="p900" begin="00:49:50.320" end="00:49:51.720" region="bottomCenter">培育成才</p>
      <p xml:id="p901" begin="00:49:53.800" end="00:49:55.400" region="bottomCenter">行礼</p>
      <p xml:id="p902" begin="00:49:57.680" end="00:50:00.920" region="bottomCenter">封神大战迫在眉睫</p>
      <p xml:id="p903" begin="00:50:01.040" end="00:50:05.080" region="bottomCenter">此次会议须得商讨备战事宜</p>
      <p xml:id="p904" begin="00:50:05.760" end="00:50:07.880" region="bottomCenter">阐教乃道统正宗</p>
      <p xml:id="p905" begin="00:50:08.000" end="00:50:09.120" region="bottomCenter">此战必胜</p>
      <p xml:id="p906" begin="00:50:09.280" end="00:50:11.880" region="bottomCenter">但近年来截教崛起迅猛</p>
      <p xml:id="p907" begin="00:50:12.000" end="00:50:13.120" region="bottomCenter">不得不防</p>
      <p xml:id="p908" begin="00:50:14.320" end="00:50:15.520" region="bottomCenter">截教</p>
      <p xml:id="p909" begin="00:50:15.640" end="00:50:17.560" region="bottomCenter">尽是披毛带角之人</p>
      <p xml:id="p910" begin="00:50:17.680" end="00:50:19.240" region="bottomCenter">湿生卵化之辈</p>
      <p xml:id="p911" begin="00:50:19.480" end="00:50:21.440" region="bottomCenter">此战关乎本门兴亡</p>
      <p xml:id="p912" begin="00:50:21.560" end="00:50:22.880" region="bottomCenter">不得掉以轻心</p>
      <p xml:id="p913" begin="00:50:23.000" end="00:50:24.760" region="bottomCenter">增强本教实力</p>
      <p xml:id="p914" begin="00:50:24.880" end="00:50:26.120" region="bottomCenter">方是根本</p>
      <p xml:id="p915" begin="00:50:26.240" end="00:50:27.600" region="bottomCenter">正是如此</p>
      <p xml:id="p916" begin="00:50:28.040" end="00:50:31.720" region="bottomCenter">为此老夫早早便开始了准备</p>
      <p xml:id="p917" begin="00:50:32.480" end="00:50:33.480" region="bottomCenter">仙丹</p>
      <p xml:id="p918" begin="00:50:33.600" end="00:50:35.400" region="bottomCenter">共有九千枚</p>
      <p xml:id="p919" begin="00:50:35.520" end="00:50:39.200" region="bottomCenter">可按级别高低分发给众门人</p>
      <p xml:id="p920" begin="00:50:39.320" end="00:50:41.720" region="bottomCenter">本教实力势必大大提升啊</p>
      <p xml:id="p921" begin="00:50:41.840" end="00:50:43.000" region="bottomCenter">怎么有这么多？</p>
      <p xml:id="p922" begin="00:50:43.120" end="00:50:44.360" region="bottomCenter">近百年来</p>
      <p xml:id="p923" begin="00:50:44.480" end="00:50:47.000" region="bottomCenter">恩师一直以天元鼎加紧炼丹</p>
      <p xml:id="p924" begin="00:50:47.120" end="00:50:48.200" region="bottomCenter">日夜不息</p>
      <p xml:id="p925" begin="00:50:48.320" end="00:50:50.280" region="bottomCenter">连自己的修炼都落下了</p>
      <p xml:id="p926" begin="00:50:50.520" end="00:50:54.400" region="bottomCenter">大师兄为阐教兴衰殚精竭虑</p>
      <p xml:id="p927" begin="00:50:54.520" end="00:50:56.080" region="bottomCenter">劳苦功高</p>
      <p xml:id="p928" begin="00:50:56.520" end="00:50:58.920" region="bottomCenter">劳苦功高</p>
      <p xml:id="p929" begin="00:50:59.040" end="00:51:00.520" region="bottomCenter">除了截教</p>
      <p xml:id="p930" begin="00:51:00.640" end="00:51:02.840" region="bottomCenter">可还有无其他妖邪图谋不轨？</p>
      <p xml:id="p931" begin="00:51:02.960" end="00:51:03.920" region="bottomCenter">禀师叔</p>
      <p xml:id="p932" begin="00:51:04.040" end="00:51:05.480" region="bottomCenter">一旦发现厉害妖孽</p>
      <p xml:id="p933" begin="00:51:05.600" end="00:51:07.240" region="bottomCenter">捕妖队便前往收服</p>
      <p xml:id="p934" begin="00:51:07.360" end="00:51:09.600" region="bottomCenter">所以一般散妖都不成气候</p>
      <p xml:id="p935" begin="00:51:09.960" end="00:51:12.240" region="bottomCenter">但还有支妖族除外</p>
      <p xml:id="p936" begin="00:51:12.360" end="00:51:14.320" region="bottomCenter">哦？哪支妖族？</p>
      <p xml:id="p937" begin="00:51:14.720" end="00:51:16.000" region="bottomCenter">东海龙族</p>
      <p xml:id="p938" begin="00:51:16.240" end="00:51:17.840" region="bottomCenter">龙族？</p>
      <p xml:id="p939" begin="00:51:19.360" end="00:51:22.400" region="bottomCenter">龙族不是早已归降天庭了吗？</p>
      <p xml:id="p940" begin="00:51:22.520" end="00:51:24.640" region="bottomCenter">非我族类其心必异</p>
      <p xml:id="p941" begin="00:51:24.760" end="00:51:25.880" region="bottomCenter">在我看来</p>
      <p xml:id="p942" begin="00:51:26.000" end="00:51:27.960" region="bottomCenter">它们的归降只是虚与委蛇</p>
      <p xml:id="p943" begin="00:51:28.080" end="00:51:29.160" region="bottomCenter">等待时机</p>
      <p xml:id="p944" begin="00:51:29.480" end="00:51:30.320" region="bottomCenter">龙族千年来</p>
      <p xml:id="p945" begin="00:51:30.440" end="00:51:32.360" region="bottomCenter">镇压海底妖兽有功</p>
      <p xml:id="p946" begin="00:51:32.480" end="00:51:34.120" region="bottomCenter">何罪之有呢？</p>
      <p xml:id="p947" begin="00:51:34.280" end="00:51:36.000" region="bottomCenter">但它们实力太强</p>
      <p xml:id="p948" begin="00:51:36.120" end="00:51:37.800" region="bottomCenter">若封神之战时倒戈</p>
      <p xml:id="p949" begin="00:51:37.920" end="00:51:39.920" region="bottomCenter">恐会影响整个战局</p>
      <p xml:id="p950" begin="00:51:42.080" end="00:51:43.400" region="bottomCenter">还是不可</p>
      <p xml:id="p951" begin="00:51:43.520" end="00:51:46.640" region="bottomCenter">本教名门正派之名深入人心</p>
      <p xml:id="p952" begin="00:51:46.760" end="00:51:48.040" region="bottomCenter">若师出无名</p>
      <p xml:id="p953" begin="00:51:48.160" end="00:51:49.920" region="bottomCenter">无故讨伐降将</p>
      <p xml:id="p954" begin="00:51:50.040" end="00:51:52.960" region="bottomCenter">将来还靠什么取信天下？</p>
      <p xml:id="p955" begin="00:51:53.080" end="00:51:54.800" region="bottomCenter">嗯，言之有理</p>
      <p xml:id="p956" begin="00:51:54.920" end="00:51:57.560" region="bottomCenter">不可轻举妄动　　此事还需从长计议</p>
      <p xml:id="p957" begin="00:51:59.200" end="00:52:00.920" region="bottomCenter">但是　　行了</p>
      <p xml:id="p958" begin="00:52:01.080" end="00:52:02.960" region="bottomCenter">大家所言在理</p>
      <p xml:id="p959" begin="00:52:03.080" end="00:52:04.880" region="bottomCenter">你也不必执拗了</p>
      <p xml:id="p960" begin="00:52:05.040" end="00:52:05.920" region="bottomCenter">是</p>
      <p xml:id="p961" begin="00:52:06.080" end="00:52:08.840" region="bottomCenter">六星连珠时辰将尽</p>
      <p xml:id="p962" begin="00:52:08.960" end="00:52:11.280" region="bottomCenter">目下也无其他议题</p>
      <p xml:id="p963" begin="00:52:11.560" end="00:52:14.000" region="bottomCenter">那就散会吧</p>
      <p xml:id="p964" begin="00:52:14.160" end="00:52:15.120" region="bottomCenter">师兄</p>
      <p xml:id="p965" begin="00:52:15.240" end="00:52:16.280" region="bottomCenter">金吒，木吒</p>
      <p xml:id="p966" begin="00:52:16.400" end="00:52:19.160" region="bottomCenter">分别拜于我和普贤师弟门下</p>
      <p xml:id="p967" begin="00:52:19.280" end="00:52:22.040" region="bottomCenter">修行多年未曾归乡</p>
      <p xml:id="p968" begin="00:52:22.160" end="00:52:23.800" region="bottomCenter">连哪吒这个三弟</p>
      <p xml:id="p969" begin="00:52:23.920" end="00:52:25.200" region="bottomCenter">也素未谋面</p>
      <p xml:id="p970" begin="00:52:25.320" end="00:52:28.120" region="bottomCenter">六星连珠尚有片刻余暇</p>
      <p xml:id="p971" begin="00:52:28.240" end="00:52:29.600" region="bottomCenter">不如借此机会</p>
      <p xml:id="p972" begin="00:52:29.720" end="00:52:31.960" region="bottomCenter">让他们兄弟三人一聚</p>
      <p xml:id="p973" begin="00:52:33.040" end="00:52:34.800" region="bottomCenter">甚好，甚好</p>
      <p xml:id="p974" begin="00:52:41.120" end="00:52:42.040" region="bottomCenter">怎么办？</p>
      <p xml:id="p975" begin="00:52:42.240" end="00:52:43.960" region="bottomCenter">咋整，咋整？</p>
      <p xml:id="p976" begin="00:52:44.280" end="00:52:45.760" region="bottomCenter">你怎么了？</p>
      <p xml:id="p977" begin="00:52:46.400" end="00:52:47.800" region="bottomCenter">你说就我这形象</p>
      <p xml:id="p978" begin="00:52:47.920" end="00:52:49.040" region="bottomCenter">会不会给人第一印象</p>
      <p xml:id="p979" begin="00:52:49.360" end="00:52:50.760" region="bottomCenter">不太好啊</p>
      <p xml:id="p980" begin="00:52:50.880" end="00:52:51.760" region="bottomCenter">肯定不会呀</p>
      <p xml:id="p981" begin="00:52:51.880" end="00:52:52.800" region="bottomCenter">真的？</p>
      <p xml:id="p982" begin="00:52:52.960" end="00:52:53.920" region="bottomCenter">虽然你仪态懒散</p>
      <p xml:id="p983" begin="00:52:54.040" end="00:52:55.000" region="bottomCenter">但意志坚定</p>
      <p xml:id="p984" begin="00:52:55.120" end="00:52:55.960" region="bottomCenter">虽然你个头矮小</p>
      <p xml:id="p985" begin="00:52:56.080" end="00:52:57.000" region="bottomCenter">但内心强大</p>
      <p xml:id="p986" begin="00:52:57.120" end="00:52:58.080" region="bottomCenter">虽然你相貌丑陋</p>
      <p xml:id="p987" begin="00:52:58.200" end="00:52:59.240" region="bottomCenter">但心地善良啊</p>
      <p xml:id="p988" begin="00:52:59.360" end="00:53:00.800" region="bottomCenter">虽然你眼眶发黑、鼻孔朝天</p>
      <p xml:id="p989" begin="00:53:00.920" end="00:53:01.760" region="bottomCenter">牙还缺了一颗</p>
      <p xml:id="p990" begin="00:53:01.880" end="00:53:02.800" region="bottomCenter">但我觉得</p>
      <p xml:id="p991" begin="00:53:02.960" end="00:53:04.360" region="bottomCenter">你就是很好很好啊</p>
      <p xml:id="p992" begin="00:53:05.440" end="00:53:07.400" region="bottomCenter">你兄长一定也会这么想的</p>
      <p xml:id="p993" begin="00:53:08.920" end="00:53:10.440" region="bottomCenter">谢谢你的夸奖</p>
      <p xml:id="p994" begin="00:53:11.400" end="00:53:12.360" region="bottomCenter">你干嘛？</p>
      <p xml:id="p995" begin="00:53:12.480" end="00:53:13.680" region="bottomCenter">你替我去见哥哥</p>
      <p xml:id="p996" begin="00:53:13.800" end="00:53:15.240" region="bottomCenter">这…这怎么行</p>
      <p xml:id="p997" begin="00:53:15.360" end="00:53:16.280" region="bottomCenter">这种事怎么能替啊？</p>
      <p xml:id="p998" begin="00:53:16.400" end="00:53:17.280" region="bottomCenter">不行啊哪吒</p>
      <p xml:id="p999" begin="00:53:17.520" end="00:53:18.360" region="bottomCenter">哪吒</p>
      <p xml:id="p1000" begin="00:53:24.800" end="00:53:26.080" region="bottomCenter">这娃儿还害羞了</p>
      <p xml:id="p1001" begin="00:53:31.760" end="00:53:32.680" region="bottomCenter">哪吒</p>
      <p xml:id="p1002" begin="00:53:33.200" end="00:53:34.080" region="bottomCenter">三弟</p>
      <p xml:id="p1003" begin="00:54:00.440" end="00:54:01.280" region="bottomCenter">敖丙</p>
      <p xml:id="p1004" begin="00:54:01.840" end="00:54:03.040" region="bottomCenter">你哭了？</p>
      <p xml:id="p1005" begin="00:54:04.920" end="00:54:06.760" region="bottomCenter">我刚才想起了我两个哥哥</p>
      <p xml:id="p1006" begin="00:54:07.120" end="00:54:08.360" region="bottomCenter">你也有哥哥？</p>
      <p xml:id="p1007" begin="00:54:08.760" end="00:54:11.480" region="bottomCenter">嗯，以前</p>
      <p xml:id="p1008" begin="00:54:12.440" end="00:54:14.080" region="bottomCenter">有两个这么好的哥哥</p>
      <p xml:id="p1009" begin="00:54:14.200" end="00:54:15.200" region="bottomCenter">真幸福</p>
      <p xml:id="p1010" begin="00:54:16.600" end="00:54:18.760" region="bottomCenter">刚刚你们聊了些啥呀？</p>
      <p xml:id="p1011" begin="00:54:19.160" end="00:54:20.400" region="bottomCenter">他们说</p>
      <p xml:id="p1012" begin="00:54:20.760" end="00:54:23.040" region="bottomCenter">很抱歉一直没机会回去看看你</p>
      <p xml:id="p1013" begin="00:54:23.840" end="00:54:24.920" region="bottomCenter">他们问</p>
      <p xml:id="p1014" begin="00:54:25.960" end="00:54:27.440" region="bottomCenter">这些年家里怎么样了</p>
      <p xml:id="p1015" begin="00:54:27.560" end="00:54:28.600" region="bottomCenter">父母是否安康</p>
      <p xml:id="p1016" begin="00:54:28.720" end="00:54:29.600" region="bottomCenter">你有什么爱好</p>
      <p xml:id="p1017" begin="00:54:29.720" end="00:54:30.960" region="bottomCenter">有哪些朋友</p>
      <p xml:id="p1018" begin="00:54:31.600" end="00:54:32.800" region="bottomCenter">他们还说</p>
      <p xml:id="p1019" begin="00:54:33.080" end="00:54:34.760" region="bottomCenter">今后无论遇到什么困难</p>
      <p xml:id="p1020" begin="00:54:34.880" end="00:54:36.120" region="bottomCenter">都要告诉他们</p>
      <p xml:id="p1021" begin="00:54:36.360" end="00:54:38.200" region="bottomCenter">让你记得有两个哥哥</p>
      <p xml:id="p1022" begin="00:54:38.800" end="00:54:40.920" region="bottomCenter">永远永远都会帮助你保护你</p>
      <p xml:id="p1023" begin="00:54:41.920" end="00:54:43.160" region="bottomCenter">你怎么也</p>
      <p xml:id="p1024" begin="00:54:43.280" end="00:54:45.560" region="bottomCenter">没有，眼睛里进沙子了</p>
      <p xml:id="p1025" begin="00:54:46.960" end="00:54:48.440" region="bottomCenter">这次不是沙子里进眼睛了</p>
      <p xml:id="p1026" begin="00:54:48.560" end="00:54:50.200" region="bottomCenter">讨厌！都说不是了</p>
      <p xml:id="p1027" begin="00:54:50.960" end="00:54:52.080" region="bottomCenter">你说不是就不是</p>
      <p xml:id="p1028" begin="00:54:56.600" end="00:54:57.600" region="bottomCenter">不理你了</p>
      <p xml:id="p1029" begin="00:54:58.880" end="00:54:59.880" region="bottomCenter">好好好</p>
      <p xml:id="p1030" begin="00:55:00.000" end="00:55:01.120" region="bottomCenter">我不笑了，不笑了</p>
      <p xml:id="p1031" begin="00:55:03.720" end="00:55:05.680" region="bottomCenter">你还在生气吗？哪吒</p>
      <p xml:id="p1032" begin="00:55:06.000" end="00:55:06.920" region="bottomCenter">哪吒</p>
      <p xml:id="p1033" begin="00:55:07.360" end="00:55:08.400" region="bottomCenter">敖丙</p>
      <p xml:id="p1034" begin="00:55:09.800" end="00:55:11.480" region="bottomCenter">我从小就暴戾放纵</p>
      <p xml:id="p1035" begin="00:55:12.000" end="00:55:14.200" region="bottomCenter">爹娘为我操碎了心</p>
      <p xml:id="p1036" begin="00:55:14.960" end="00:55:18.400" region="bottomCenter">你爹虽围困了陈塘关</p>
      <p xml:id="p1037" begin="00:55:18.520" end="00:55:20.600" region="bottomCenter">但我知道他也是为了你</p>
      <p xml:id="p1038" begin="00:55:20.720" end="00:55:21.920" region="bottomCenter">才不顾一切</p>
      <p xml:id="p1039" begin="00:55:22.800" end="00:55:24.200" region="bottomCenter">今天</p>
      <p xml:id="p1040" begin="00:55:24.320" end="00:55:26.520" region="bottomCenter">哥哥们也对我这么好</p>
      <p xml:id="p1041" begin="00:55:28.000" end="00:55:30.000" region="bottomCenter">家人为我们付出了太多</p>
      <p xml:id="p1042" begin="00:55:30.280" end="00:55:31.280" region="bottomCenter">你是妖</p>
      <p xml:id="p1043" begin="00:55:31.400" end="00:55:32.520" region="bottomCenter">我是魔</p>
      <p xml:id="p1044" begin="00:55:32.840" end="00:55:34.520" region="bottomCenter">是我们拖累了他们</p>
      <p xml:id="p1045" begin="00:55:37.840" end="00:55:39.480" region="bottomCenter">天生妖魔又怎样？</p>
      <p xml:id="p1046" begin="00:55:39.600" end="00:55:42.120" region="bottomCenter">是魔是仙今后就得我自己来选</p>
      <p xml:id="p1047" begin="00:55:42.400" end="00:55:43.400" region="bottomCenter">等救了你</p>
      <p xml:id="p1048" begin="00:55:43.520" end="00:55:44.880" region="bottomCenter">我们一定要得道成仙</p>
      <p xml:id="p1049" begin="00:55:45.000" end="00:55:46.160" region="bottomCenter">不再让家人操心</p>
      <p xml:id="p1050" begin="00:55:46.280" end="00:55:47.160" region="bottomCenter">对</p>
      <p xml:id="p1051" begin="00:55:47.280" end="00:55:48.200" region="bottomCenter">成了仙</p>
      <p xml:id="p1052" begin="00:55:48.320" end="00:55:49.600" region="bottomCenter">才能堂堂正正地活下去</p>
      <p xml:id="p1053" begin="00:55:49.720" end="00:55:50.560" region="bottomCenter">说定了</p>
      <p xml:id="p1054" begin="00:55:51.080" end="00:55:53.840" region="bottomCenter">小爷就要当神仙</p>
      <p xml:id="p1055" begin="00:55:59.640" end="00:56:03.800" region="bottomCenter">勇猛精进方能一日千里</p>
      <p xml:id="p1056" begin="00:56:03.920" end="00:56:05.440" region="bottomCenter">照你们这样</p>
      <p xml:id="p1057" begin="00:56:05.560" end="00:56:08.320" region="bottomCenter">再修百年也是枉然</p>
      <p xml:id="p1058" begin="00:56:08.680" end="00:56:10.240" region="bottomCenter">修仙修仙</p>
      <p xml:id="p1059" begin="00:56:10.360" end="00:56:12.800" region="bottomCenter">首先修的就是精气神</p>
      <p xml:id="p1060" begin="00:56:12.920" end="00:56:15.040" region="bottomCenter">觉得苦、觉得累</p>
      <p xml:id="p1061" begin="00:56:15.160" end="00:56:18.880" region="bottomCenter">要恨就恨你们为什么生来就是妖</p>
      <p xml:id="p1062" begin="00:56:19.000" end="00:56:20.640" region="bottomCenter">拼尽全力</p>
      <p xml:id="p1063" begin="00:56:20.760" end="00:56:22.720" region="bottomCenter">才有机会逆天改命</p>
      <p xml:id="p1064" begin="00:56:22.840" end="00:56:24.320" region="bottomCenter">得道成仙</p>
      <p xml:id="p1065" begin="00:56:26.360" end="00:56:29.440" region="bottomCenter">从来生死都看淡</p>
      <p xml:id="p1066" begin="00:56:29.560" end="00:56:32.160" region="bottomCenter">专和老天对着干</p>
      <p xml:id="p1067" begin="00:56:32.280" end="00:56:35.280" region="bottomCenter">我命由我不由天</p>
      <p xml:id="p1068" begin="00:56:35.440" end="00:56:39.120" region="bottomCenter">小爷非要当神仙</p>
      <p xml:id="p1069" begin="00:56:40.280" end="00:56:41.560" region="bottomCenter">好</p>
      <p xml:id="p1070" begin="00:56:43.040" end="00:56:45.360" region="bottomCenter">短短几句便振聋发聩</p>
      <p xml:id="p1071" begin="00:56:45.480" end="00:56:46.720" region="bottomCenter">鼓舞人心</p>
      <p xml:id="p1072" begin="00:56:46.840" end="00:56:48.880" region="bottomCenter">好诗，好诗</p>
      <p xml:id="p1073" begin="00:56:49.080" end="00:56:52.080" region="bottomCenter">这首诗的精神值得你们所有人学习</p>
      <p xml:id="p1074" begin="00:56:54.080" end="00:56:56.040" region="bottomCenter">是吗？有这么好吗？</p>
      <p xml:id="p1075" begin="00:56:56.280" end="00:56:57.360" region="bottomCenter">嘿嘿，我自己瞎编的</p>
      <p xml:id="p1076" begin="00:56:57.480" end="00:56:58.680" region="bottomCenter">非也非也</p>
      <p xml:id="p1077" begin="00:56:58.800" end="00:57:00.560" region="bottomCenter">字字珠玑，催人上进</p>
      <p xml:id="p1078" begin="00:57:00.680" end="00:57:02.600" region="bottomCenter">能作出这样的诗</p>
      <p xml:id="p1079" begin="00:57:02.720" end="00:57:04.960" region="bottomCenter">可见你小小年纪就志存高远</p>
      <p xml:id="p1080" begin="00:57:05.080" end="00:57:06.320" region="bottomCenter">真是少年英雄</p>
      <p xml:id="p1081" begin="00:57:06.440" end="00:57:07.640" region="bottomCenter">前途无量啊</p>
      <p xml:id="p1082" begin="00:57:07.760" end="00:57:09.320" region="bottomCenter">哎呦喂，没那么好啦</p>
      <p xml:id="p1083" begin="00:57:09.600" end="00:57:11.160" region="bottomCenter">其实还是有些小缺陷的啦</p>
      <p xml:id="p1084" begin="00:57:11.280" end="00:57:12.360" region="bottomCenter">你缺陷大了去了</p>
      <p xml:id="p1085" begin="00:57:12.480" end="00:57:13.840" region="bottomCenter">我问你，你那黑眼圈怎么回事儿？</p>
      <p xml:id="p1086" begin="00:57:14.640" end="00:57:17.000" region="bottomCenter">一看便知你时常熬夜</p>
      <p xml:id="p1087" begin="00:57:17.120" end="00:57:18.040" region="bottomCenter">生活没规律</p>
      <p xml:id="p1088" begin="00:57:18.160" end="00:57:19.160" region="bottomCenter">饮食不健康</p>
      <p xml:id="p1089" begin="00:57:19.280" end="00:57:21.080" region="bottomCenter">连起码的自律都做不到</p>
      <p xml:id="p1090" begin="00:57:21.200" end="00:57:23.120" region="bottomCenter">你也配修仙</p>
      <p xml:id="p1091" begin="00:57:23.240" end="00:57:24.400" region="bottomCenter">我黑眼圈天生的</p>
      <p xml:id="p1092" begin="00:57:24.520" end="00:57:26.040" region="bottomCenter">相由心生懂不懂？</p>
      <p xml:id="p1093" begin="00:57:26.160" end="00:57:27.360" region="bottomCenter">自己拿镜子照照</p>
      <p xml:id="p1094" begin="00:57:27.480" end="00:57:28.960" region="bottomCenter">怪模怪样，吊儿郎当</p>
      <p xml:id="p1095" begin="00:57:29.080" end="00:57:29.920" region="bottomCenter">你要是我的徒弟</p>
      <p xml:id="p1096" begin="00:57:30.040" end="00:57:31.760" region="bottomCenter">肯定教你重修人形</p>
      <p xml:id="p1097" begin="00:57:31.880" end="00:57:32.920" region="bottomCenter">可以重修？</p>
      <p xml:id="p1098" begin="00:57:33.120" end="00:57:34.520" region="bottomCenter">那这相貌还有救啰？</p>
      <p xml:id="p1099" begin="00:57:35.040" end="00:57:36.000" region="bottomCenter">你教教我呗</p>
      <p xml:id="p1100" begin="00:57:36.120" end="00:57:37.800" region="bottomCenter">早知道你是来拜师的</p>
      <p xml:id="p1101" begin="00:57:37.920" end="00:57:38.800" region="bottomCenter">这样，小鬼</p>
      <p xml:id="p1102" begin="00:57:38.920" end="00:57:40.360" region="bottomCenter">我看你也是志向远大</p>
      <p xml:id="p1103" begin="00:57:40.480" end="00:57:41.880" region="bottomCenter">就收了你这个徒弟</p>
      <p xml:id="p1104" begin="00:57:42.000" end="00:57:44.040" region="bottomCenter">好啊，师父</p>
      <p xml:id="p1105" begin="00:57:46.040" end="00:57:47.680" region="bottomCenter">来，跟师兄们一起练</p>
      <p xml:id="p1106" begin="00:57:47.800" end="00:57:49.280" region="bottomCenter">練啥？　　修仙呐</p>
      <p xml:id="p1107" begin="00:57:49.400" end="00:57:50.400" region="bottomCenter">修仙不用你教</p>
      <p xml:id="p1108" begin="00:57:50.520" end="00:57:51.360" region="bottomCenter">你教我美颜</p>
      <p xml:id="p1109" begin="00:57:51.480" end="00:57:52.400" region="bottomCenter">混账</p>
      <p xml:id="p1110" begin="00:57:52.520" end="00:57:54.280" region="bottomCenter">修仙不学，你学美颜</p>
      <p xml:id="p1111" begin="00:57:54.400" end="00:57:55.560" region="bottomCenter">舍本逐末</p>
      <p xml:id="p1112" begin="00:57:55.680" end="00:57:57.000" region="bottomCenter">你到底教不教啊？</p>
      <p xml:id="p1113" begin="00:57:57.120" end="00:57:59.240" region="bottomCenter">从此我们断绝师徒关系</p>
      <p xml:id="p1114" begin="00:57:59.360" end="00:58:01.040" region="bottomCenter">活该你当一辈子熊猫眼</p>
      <p xml:id="p1115" begin="00:58:01.160" end="00:58:02.000" region="bottomCenter">过分了啊</p>
      <p xml:id="p1116" begin="00:58:02.120" end="00:58:03.840" region="bottomCenter">本来我还准备下手轻点儿呢</p>
      <p xml:id="p1117" begin="00:58:03.960" end="00:58:05.400" region="bottomCenter">干啥？踢馆啊？</p>
      <p xml:id="p1118" begin="00:58:05.520" end="00:58:06.400" region="bottomCenter">三颗该够了</p>
      <p xml:id="p1119" begin="00:58:06.520" end="00:58:09.160" region="bottomCenter">小鬼，你打哪儿来回哪儿去</p>
      <p xml:id="p1120" begin="00:58:09.280" end="00:58:11.480" region="bottomCenter">再干扰我们正常教学</p>
      <p xml:id="p1121" begin="00:58:11.600" end="00:58:13.040" region="bottomCenter">我可要动粗啦</p>
      <p xml:id="p1122" begin="00:58:14.240" end="00:58:15.200" region="bottomCenter">得罪</p>
      <p xml:id="p1123" begin="00:58:54.880" end="00:58:56.080" region="bottomCenter">你不是我对手</p>
      <p xml:id="p1124" begin="00:58:57.920" end="00:58:59.120" region="bottomCenter">好小子</p>
      <p xml:id="p1125" begin="00:58:59.640" end="00:59:00.880" region="bottomCenter">老夫小看你了</p>
      <p xml:id="p1126" begin="00:59:15.560" end="00:59:16.520" region="bottomCenter">着</p>
      <p xml:id="p1127" begin="00:59:19.520" end="00:59:21.640" region="bottomCenter">好，教训这无知小儿</p>
      <p xml:id="p1128" begin="00:59:21.760" end="00:59:22.880" region="bottomCenter">师父必胜</p>
      <p xml:id="p1129" begin="00:59:23.680" end="00:59:24.880" region="bottomCenter">好快的身法</p>
      <p xml:id="p1130" begin="00:59:25.000" end="00:59:25.960" region="bottomCenter">你看清楚没得？</p>
      <p xml:id="p1131" begin="00:59:28.280" end="00:59:30.120" region="bottomCenter">我们并无深仇大恨</p>
      <p xml:id="p1132" begin="00:59:30.240" end="00:59:31.400" region="bottomCenter">你还是回去吧</p>
      <p xml:id="p1133" begin="00:59:31.840" end="00:59:32.880" region="bottomCenter">我不能败</p>
      <p xml:id="p1134" begin="00:59:44.080" end="00:59:45.640" region="bottomCenter">你碰都碰不到我</p>
      <p xml:id="p1135" begin="00:59:46.000" end="00:59:47.080" region="bottomCenter">怎么跟我斗</p>
      <p xml:id="p1136" begin="01:00:00.440" end="01:00:01.760" region="bottomCenter">聪明！逮到不放</p>
      <p xml:id="p1137" begin="01:00:01.880" end="01:00:03.000" region="bottomCenter">他速度再快也没用</p>
      <p xml:id="p1138" begin="01:00:04.240" end="01:00:05.160" region="bottomCenter">还不降？</p>
      <p xml:id="p1139" begin="01:00:17.760" end="01:00:19.080" region="bottomCenter">原来你是</p>
      <p xml:id="p1140" begin="01:00:20.280" end="01:00:21.280" region="bottomCenter">发现啦</p>
      <p xml:id="p1141" begin="01:00:21.520" end="01:00:23.360" region="bottomCenter">我并非动作快</p>
      <p xml:id="p1142" begin="01:00:23.480" end="01:00:25.080" region="bottomCenter">而是身体能化作电流</p>
      <p xml:id="p1143" begin="01:00:25.200" end="01:00:27.160" region="bottomCenter">瞬间传导到任何位置</p>
      <p xml:id="p1144" begin="01:00:27.280" end="01:00:28.480" region="bottomCenter">在水里</p>
      <p xml:id="p1145" begin="01:00:28.720" end="01:00:30.880" region="bottomCenter">我是无敌的</p>
      <p xml:id="p1146" begin="01:00:45.800" end="01:00:47.120" region="bottomCenter">好厉害的寒气</p>
      <p xml:id="p1147" begin="01:00:50.680" end="01:00:51.680" region="bottomCenter">稳到点儿啊</p>
      <p xml:id="p1148" begin="01:00:51.800" end="01:00:53.800" region="bottomCenter">力使猛了肉身要崩啊</p>
      <p xml:id="p1149" begin="01:00:53.920" end="01:00:55.160" region="bottomCenter">冰不导电</p>
      <p xml:id="p1150" begin="01:00:55.280" end="01:00:56.320" region="bottomCenter">看你还有什么能耐</p>
      <p xml:id="p1151" begin="01:00:58.320" end="01:00:59.880" region="bottomCenter">五湖四海，云漫苍穹</p>
      <p xml:id="p1152" begin="01:01:00.000" end="01:01:01.480" region="bottomCenter">神符命汝，降雨行风</p>
      <p xml:id="p1153" begin="01:01:01.600" end="01:01:03.800" region="bottomCenter">急急如律令</p>
      <p xml:id="p1154" begin="01:01:14.200" end="01:01:15.040" region="bottomCenter">爹</p>
      <p xml:id="p1155" begin="01:01:22.960" end="01:01:23.920" region="bottomCenter">糟了</p>
      <p xml:id="p1156" begin="01:01:24.040" end="01:01:25.040" region="bottomCenter">布雨咒</p>
      <p xml:id="p1157" begin="01:01:25.160" end="01:01:26.000" region="bottomCenter">速战速决</p>
      <p xml:id="p1158" begin="01:01:39.840" end="01:01:40.720" region="bottomCenter">迟了</p>
      <p xml:id="p1159" begin="01:01:56.320" end="01:01:57.640" region="bottomCenter">你完了</p>
      <p xml:id="p1160" begin="01:02:17.280" end="01:02:18.840" region="bottomCenter">师父，师父</p>
      <p xml:id="p1161" begin="01:02:18.960" end="01:02:20.200" region="bottomCenter">师父你怎么了？</p>
      <p xml:id="p1162" begin="01:02:20.600" end="01:02:22.200" region="bottomCenter">我并非取你性命</p>
      <p xml:id="p1163" begin="01:02:22.320" end="01:02:23.760" region="bottomCenter">你又何苦自断一臂</p>
      <p xml:id="p1164" begin="01:02:23.880" end="01:02:25.200" region="bottomCenter">众弟子听令</p>
      <p xml:id="p1165" begin="01:02:25.320" end="01:02:27.120" region="bottomCenter">将妖孽押解回宫</p>
      <p xml:id="p1166" begin="01:02:27.240" end="01:02:28.280" region="bottomCenter">诺</p>
      <p xml:id="p1167" begin="01:02:30.240" end="01:02:31.080" region="bottomCenter">住手</p>
      <p xml:id="p1168" begin="01:02:31.320" end="01:02:33.120" region="bottomCenter">放下，都给我放下</p>
      <p xml:id="p1169" begin="01:02:33.440" end="01:02:36.360" region="bottomCenter">敢问阁下是否阐教门人</p>
      <p xml:id="p1170" begin="01:02:36.480" end="01:02:37.320" region="bottomCenter">正是</p>
      <p xml:id="p1171" begin="01:02:45.080" end="01:02:46.600" region="bottomCenter">这都是玉虚宫的仙长</p>
      <p xml:id="p1172" begin="01:02:46.720" end="01:02:48.280" region="bottomCenter">尔等不得无礼</p>
      <p xml:id="p1173" begin="01:02:48.400" end="01:02:49.800" region="bottomCenter">我等进了玉虚宫</p>
      <p xml:id="p1174" begin="01:02:49.920" end="01:02:51.960" region="bottomCenter">就能接受正道教化</p>
      <p xml:id="p1175" begin="01:02:52.080" end="01:02:53.840" region="bottomCenter">未尝不是好事</p>
      <p xml:id="p1176" begin="01:02:54.000" end="01:02:56.680" region="bottomCenter">尔等都把兵刃给我扔了</p>
      <p xml:id="p1177" begin="01:03:05.160" end="01:03:06.160" region="bottomCenter">爹</p>
      <p xml:id="p1178" begin="01:03:06.280" end="01:03:08.280" region="bottomCenter">小豹，你怎么回来啦？</p>
      <p xml:id="p1179" begin="01:03:14.320" end="01:03:16.240" region="bottomCenter">小豹，不得无礼</p>
      <p xml:id="p1180" begin="01:03:24.480" end="01:03:25.400" region="bottomCenter">小豹</p>
      <p xml:id="p1181" begin="01:03:31.520" end="01:03:32.400" region="bottomCenter">放肆</p>
      <p xml:id="p1182" begin="01:03:32.640" end="01:03:34.000" region="bottomCenter">胆敢伤我门人</p>
      <p xml:id="p1183" begin="01:03:34.960" end="01:03:35.920" region="bottomCenter">不要</p>
      <p xml:id="p1184" begin="01:03:51.080" end="01:03:52.320" region="bottomCenter">爹</p>
      <p xml:id="p1185" begin="01:03:56.320" end="01:03:57.920" region="bottomCenter">哪吒，快封冻河水</p>
      <p xml:id="p1186" begin="01:04:11.360" end="01:04:12.440" region="bottomCenter">哪里逃</p>
      <p xml:id="p1187" begin="01:04:32.520" end="01:04:33.400" region="bottomCenter">爹</p>
      <p xml:id="p1188" begin="01:04:33.520" end="01:04:35.960" region="bottomCenter">走，快走</p>
      <p xml:id="p1189" begin="01:04:37.160" end="01:04:38.360" region="bottomCenter">逃啊</p>
      <p xml:id="p1190" begin="01:04:39.120" end="01:04:40.120" region="bottomCenter">爹</p>
      <p xml:id="p1191" begin="01:04:47.400" end="01:04:48.520" region="bottomCenter">逃不掉的</p>
      <p xml:id="p1192" begin="01:04:51.080" end="01:04:51.960" region="bottomCenter">让开</p>
      <p xml:id="p1193" begin="01:04:52.080" end="01:04:53.440" region="bottomCenter">他只是救父心切</p>
      <p xml:id="p1194" begin="01:04:53.560" end="01:04:54.640" region="bottomCenter">何苦下此重手</p>
      <p xml:id="p1195" begin="01:05:04.680" end="01:05:05.920" region="bottomCenter">三七</p>
      <p xml:id="p1196" begin="01:05:06.800" end="01:05:08.040" region="bottomCenter">蒲黄</p>
      <p xml:id="p1197" begin="01:05:08.720" end="01:05:09.920" region="bottomCenter">茜草</p>
      <p xml:id="p1198" begin="01:05:10.560" end="01:05:11.560" region="bottomCenter">冰片</p>
      <p xml:id="p1199" begin="01:05:12.080" end="01:05:13.240" region="bottomCenter">血竭</p>
      <p xml:id="p1200" begin="01:05:13.360" end="01:05:15.040" region="bottomCenter">再来一筐　　红花</p>
      <p xml:id="p1201" begin="01:05:15.440" end="01:05:16.480" region="bottomCenter">当归</p>
      <p xml:id="p1202" begin="01:05:16.960" end="01:05:18.600" region="bottomCenter">田七粉</p>
      <p xml:id="p1203" begin="01:05:19.000" end="01:05:20.000" region="bottomCenter">苏木</p>
      <p xml:id="p1204" begin="01:05:20.360" end="01:05:21.720" region="bottomCenter">马钱子</p>
      <p xml:id="p1205" begin="01:05:22.200" end="01:05:23.160" region="bottomCenter">大人</p>
      <p xml:id="p1206" begin="01:05:23.280" end="01:05:25.120" region="bottomCenter">清单上的全齐了</p>
      <p xml:id="p1207" begin="01:05:25.400" end="01:05:28.160" region="bottomCenter">另外还多了一百筐鱼虾水产</p>
      <p xml:id="p1208" begin="01:05:28.280" end="01:05:30.280" region="bottomCenter">城里正好缺粮草啊</p>
      <p xml:id="p1209" begin="01:05:33.280" end="01:05:34.400" region="bottomCenter">申道长留步</p>
      <p xml:id="p1210" begin="01:05:35.640" end="01:05:37.280" region="bottomCenter">我们备了些酒菜</p>
      <p xml:id="p1211" begin="01:05:37.400" end="01:05:39.240" region="bottomCenter">道长可否赏脸一聚？</p>
      <p xml:id="p1212" begin="01:05:45.000" end="01:05:45.840" region="bottomCenter">你</p>
      <p xml:id="p1213" begin="01:05:46.880" end="01:05:48.480" region="bottomCenter">承蒙李大人开恩</p>
      <p xml:id="p1214" begin="01:05:48.600" end="01:05:50.640" region="bottomCenter">收留我当了个差役</p>
      <p xml:id="p1215" begin="01:05:51.040" end="01:05:52.320" region="bottomCenter">他虽是妖</p>
      <p xml:id="p1216" begin="01:05:52.440" end="01:05:53.840" region="bottomCenter">但心地不坏</p>
      <p xml:id="p1217" begin="01:05:53.960" end="01:05:55.440" region="bottomCenter">只要安分守己</p>
      <p xml:id="p1218" begin="01:05:55.560" end="01:05:57.280" region="bottomCenter">未尝没有个好的归宿</p>
      <p xml:id="p1219" begin="01:05:58.720" end="01:06:00.320" region="bottomCenter">不知合不合道长口味</p>
      <p xml:id="p1220" begin="01:06:00.440" end="01:06:01.520" region="bottomCenter">不</p>
      <p xml:id="p1221" begin="01:06:02.080" end="01:06:03.040" region="bottomCenter">不错</p>
      <p xml:id="p1222" begin="01:06:03.360" end="01:06:04.520" region="bottomCenter">那您多吃些</p>
      <p xml:id="p1223" begin="01:06:04.640" end="01:06:05.800" region="bottomCenter">这酒您也尝尝</p>
      <p xml:id="p1224" begin="01:06:06.120" end="01:06:07.440" region="bottomCenter">早戒了</p>
      <p xml:id="p1225" begin="01:06:07.560" end="01:06:10.760" region="bottomCenter">修仙者需克…克制欲念</p>
      <p xml:id="p1226" begin="01:06:11.080" end="01:06:12.440" region="bottomCenter">有言道</p>
      <p xml:id="p1227" begin="01:06:12.560" end="01:06:14.800" region="bottomCenter">剪情欲则神全</p>
      <p xml:id="p1228" begin="01:06:14.920" end="01:06:16.240" region="bottomCenter">亦有言道</p>
      <p xml:id="p1229" begin="01:06:16.360" end="01:06:18.840" region="bottomCenter">行善道则德全</p>
      <p xml:id="p1230" begin="01:06:19.960" end="01:06:21.480" region="bottomCenter">多说无用</p>
      <p xml:id="p1231" begin="01:06:21.600" end="01:06:24.120" region="bottomCenter">我早已无…无路可退</p>
      <p xml:id="p1232" begin="01:06:24.360" end="01:06:27.160" region="bottomCenter">隐瞒逃避不是长久之计</p>
      <p xml:id="p1233" begin="01:06:27.280" end="01:06:29.520" region="bottomCenter">终有事情败露的一天</p>
      <p xml:id="p1234" begin="01:06:30.000" end="01:06:31.560" region="bottomCenter">若残害生灵</p>
      <p xml:id="p1235" begin="01:06:31.680" end="01:06:32.840" region="bottomCenter">错上加错</p>
      <p xml:id="p1236" begin="01:06:32.960" end="01:06:34.440" region="bottomCenter">就算瞒天过海</p>
      <p xml:id="p1237" begin="01:06:34.560" end="01:06:36.480" region="bottomCenter">也心障难除</p>
      <p xml:id="p1238" begin="01:06:36.960" end="01:06:39.800" region="bottomCenter">往后的修行更难有寸进</p>
      <p xml:id="p1239" begin="01:06:40.360" end="01:06:41.800" region="bottomCenter">修仙的根本</p>
      <p xml:id="p1240" begin="01:06:41.920" end="01:06:43.160" region="bottomCenter">乃是积善德</p>
      <p xml:id="p1241" begin="01:06:43.280" end="01:06:44.560" region="bottomCenter">行正道　　住口</p>
      <p xml:id="p1242" begin="01:06:44.680" end="01:06:46.040" region="bottomCenter">什么行善积德</p>
      <p xml:id="p1243" begin="01:06:46.160" end="01:06:48.560" region="bottomCenter">你对修仙一无所知</p>
      <p xml:id="p1244" begin="01:06:56.920" end="01:06:57.960" region="bottomCenter">报</p>
      <p xml:id="p1245" begin="01:06:58.720" end="01:07:00.040" region="bottomCenter">有人求见申道长</p>
      <p xml:id="p1246" begin="01:07:08.920" end="01:07:10.160" region="bottomCenter">哥</p>
      <p xml:id="p1247" begin="01:07:11.040" end="01:07:12.200" region="bottomCenter">怎么伤成这样？</p>
      <p xml:id="p1248" begin="01:07:12.320" end="01:07:14.320" region="bottomCenter">一帮道士</p>
      <p xml:id="p1249" begin="01:07:14.440" end="01:07:17.080" region="bottomCenter">围…围攻咱家</p>
      <p xml:id="p1250" begin="01:07:18.400" end="01:07:20.120" region="bottomCenter">爹</p>
      <p xml:id="p1251" begin="01:07:20.240" end="01:07:22.360" region="bottomCenter">还被人砍断了</p>
      <p xml:id="p1252" begin="01:07:23.160" end="01:07:24.880" region="bottomCenter">手臂</p>
      <p xml:id="p1253" begin="01:07:25.000" end="01:07:26.000" region="bottomCenter">谁砍的？</p>
      <p xml:id="p1254" begin="01:07:26.440" end="01:07:29.360" region="bottomCenter">那…那人叫</p>
      <p xml:id="p1255" begin="01:07:30.520" end="01:07:32.880" region="bottomCenter">哪...吒</p>
      <p xml:id="p1256" begin="01:07:50.240" end="01:07:52.440" region="bottomCenter">恭喜师弟过了第二关</p>
      <p xml:id="p1257" begin="01:07:52.680" end="01:07:54.280" region="bottomCenter">还请通禀无量师兄</p>
      <p xml:id="p1258" begin="01:07:54.640" end="01:07:56.880" region="bottomCenter">师父今日闭关炼丹</p>
      <p xml:id="p1259" begin="01:07:57.000" end="01:07:58.120" region="bottomCenter">尚未出关</p>
      <p xml:id="p1260" begin="01:07:58.240" end="01:07:59.920" region="bottomCenter">第三次考核前</p>
      <p xml:id="p1261" begin="01:08:00.040" end="01:08:01.840" region="bottomCenter">师弟不如先休养几日？</p>
      <p xml:id="p1262" begin="01:08:01.960" end="01:08:03.520" region="bottomCenter">我们只剩两天了</p>
      <p xml:id="p1263" begin="01:08:03.680" end="01:08:04.640" region="bottomCenter">不用</p>
      <p xml:id="p1264" begin="01:08:04.760" end="01:08:05.840" region="bottomCenter">我精神得很</p>
      <p xml:id="p1265" begin="01:08:05.960" end="01:08:06.880" region="bottomCenter">接着考</p>
      <p xml:id="p1266" begin="01:08:07.160" end="01:08:09.120" region="bottomCenter">那…也好</p>
      <p xml:id="p1267" begin="01:08:09.280" end="01:08:10.480" region="bottomCenter">最后一只妖王</p>
      <p xml:id="p1268" begin="01:08:10.600" end="01:08:12.480" region="bottomCenter">是骷髅山的</p>
      <p xml:id="p1269" begin="01:08:12.600" end="01:08:13.880" region="bottomCenter">石矶</p>
      <p xml:id="p1270" begin="01:08:16.400" end="01:08:18.280" region="bottomCenter">殿外有人急事求见太乙仙长</p>
      <p xml:id="p1271" begin="01:08:19.160" end="01:08:20.480" region="bottomCenter">不好啦</p>
      <p xml:id="p1272" begin="01:08:20.760" end="01:08:22.440" region="bottomCenter">陈塘关</p>
      <p xml:id="p1273" begin="01:08:22.560" end="01:08:24.120" region="bottomCenter">出事儿啦</p>
      <p xml:id="p1274" begin="01:08:47.480" end="01:08:48.480" region="bottomCenter">爹</p>
      <p xml:id="p1275" begin="01:08:50.240" end="01:08:51.240" region="bottomCenter">娘</p>
      <p xml:id="p1276" begin="01:08:54.240" end="01:08:55.360" region="bottomCenter">爹</p>
      <p xml:id="p1277" begin="01:08:56.920" end="01:08:57.800" region="bottomCenter">娘</p>
      <p xml:id="p1278" begin="01:09:00.240" end="01:09:01.280" region="bottomCenter">爹？</p>
      <p xml:id="p1279" begin="01:09:02.640" end="01:09:03.640" region="bottomCenter">娘？</p>
      <p xml:id="p1280" begin="01:09:13.320" end="01:09:15.200" region="bottomCenter">爹</p>
      <p xml:id="p1281" begin="01:09:16.120" end="01:09:18.640" region="bottomCenter">娘</p>
      <p xml:id="p1282" begin="01:09:39.480" end="01:09:40.960" region="bottomCenter">不要急，不要急</p>
      <p xml:id="p1283" begin="01:09:41.080" end="01:09:42.640" region="bottomCenter">我们再找找，再找找</p>
      <p xml:id="p1284" begin="01:09:45.640" end="01:09:48.240" region="bottomCenter">我刚出关便收到急报</p>
      <p xml:id="p1285" begin="01:09:48.360" end="01:09:51.480" region="bottomCenter">到底是何人犯下如此滔天罪行？</p>
      <p xml:id="p1286" begin="01:09:51.600" end="01:09:52.520" region="bottomCenter">启禀师父</p>
      <p xml:id="p1287" begin="01:09:52.640" end="01:09:53.800" region="bottomCenter">据结界兽所说</p>
      <p xml:id="p1288" begin="01:09:53.920" end="01:09:55.880" region="bottomCenter">事前他们遭受巨大力量冲击</p>
      <p xml:id="p1289" begin="01:09:56.000" end="01:09:57.040" region="bottomCenter">失去知觉</p>
      <p xml:id="p1290" begin="01:09:57.160" end="01:09:58.320" region="bottomCenter">醒来时发现</p>
      <p xml:id="p1291" begin="01:09:58.440" end="01:10:00.320" region="bottomCenter">陈塘关已被屠城</p>
      <p xml:id="p1292" begin="01:10:00.520" end="01:10:02.400" region="bottomCenter">还没得到玉液琼浆啊</p>
      <p xml:id="p1293" begin="01:10:02.520" end="01:10:04.200" region="bottomCenter">他们怎么会动手喃？</p>
      <p xml:id="p1294" begin="01:10:04.320" end="01:10:05.160" region="bottomCenter">师弟</p>
      <p xml:id="p1295" begin="01:10:05.280" end="01:10:06.680" region="bottomCenter">你可有头绪？</p>
      <p xml:id="p1296" begin="01:10:06.800" end="01:10:07.800" region="bottomCenter">没得，没得</p>
      <p xml:id="p1297" begin="01:10:07.920" end="01:10:08.800" region="bottomCenter">我是在想</p>
      <p xml:id="p1298" begin="01:10:08.920" end="01:10:11.160" region="bottomCenter">这些岩浆是从哪儿来的</p>
      <p xml:id="p1299" begin="01:10:11.840" end="01:10:12.960" region="bottomCenter">是啊</p>
      <p xml:id="p1300" begin="01:10:13.080" end="01:10:15.080" region="bottomCenter">方圆千里杳无火山</p>
      <p xml:id="p1301" begin="01:10:15.200" end="01:10:17.080" region="bottomCenter">当真匪夷所思</p>
      <p xml:id="p1302" begin="01:10:17.920" end="01:10:18.920" region="bottomCenter">大家快来</p>
      <p xml:id="p1303" begin="01:10:21.000" end="01:10:22.360" region="bottomCenter">是何妖物？</p>
      <p xml:id="p1304" begin="01:10:23.280" end="01:10:24.560" region="bottomCenter">这是</p>
      <p xml:id="p1305" begin="01:10:26.280" end="01:10:27.440" region="bottomCenter">龙族爪印</p>
      <p xml:id="p1306" begin="01:10:28.280" end="01:10:29.760" region="bottomCenter">不可能</p>
      <p xml:id="p1307" begin="01:10:30.280" end="01:10:33.400" region="bottomCenter">全体龙族都在东海龙宫</p>
      <p xml:id="p1308" begin="01:10:33.520" end="01:10:35.120" region="bottomCenter">镇守锁妖阵</p>
      <p xml:id="p1309" begin="01:10:35.240" end="01:10:37.520" region="bottomCenter">一条都不可能离得开</p>
      <p xml:id="p1310" begin="01:10:37.920" end="01:10:39.960" region="bottomCenter">师父，弟子没记错的话</p>
      <p xml:id="p1311" begin="01:10:40.080" end="01:10:41.960" region="bottomCenter">关押在海底的西海龙王敖闰</p>
      <p xml:id="p1312" begin="01:10:42.080" end="01:10:43.560" region="bottomCenter">是否有种特殊技能</p>
      <p xml:id="p1313" begin="01:10:43.680" end="01:10:44.880" region="bottomCenter">叫做裂</p>
      <p xml:id="p1314" begin="01:10:45.600" end="01:10:46.920" region="bottomCenter">裂空爪</p>
      <p xml:id="p1315" begin="01:10:47.040" end="01:10:48.960" region="bottomCenter">你是说她用裂空爪</p>
      <p xml:id="p1316" begin="01:10:49.080" end="01:10:50.360" region="bottomCenter">穿越到了陈塘关？</p>
      <p xml:id="p1317" begin="01:10:50.640" end="01:10:52.360" region="bottomCenter">这些岩浆便就说得通了</p>
      <p xml:id="p1318" begin="01:10:52.480" end="01:10:55.200" region="bottomCenter">必是从海底炼狱隔空传送而来</p>
      <p xml:id="p1319" begin="01:10:55.320" end="01:10:57.040" region="bottomCenter">但她被东海龙王镇压在狱中</p>
      <p xml:id="p1320" begin="01:10:57.160" end="01:10:58.520" region="bottomCenter">不可能穿越至此啊</p>
      <p xml:id="p1321" begin="01:10:58.800" end="01:11:01.320" region="bottomCenter">那就只剩一种可能啦</p>
      <p xml:id="p1322" begin="01:11:01.800" end="01:11:04.480" region="bottomCenter">弟子最担心的事</p>
      <p xml:id="p1323" begin="01:11:04.600" end="01:11:06.000" region="bottomCenter">还是发生了</p>
      <p xml:id="p1324" begin="01:11:06.400" end="01:11:08.160" region="bottomCenter">东海龙王叛变？</p>
      <p xml:id="p1325" begin="01:11:09.160" end="01:11:11.360" region="bottomCenter">此事牵连重大</p>
      <p xml:id="p1326" begin="01:11:11.480" end="01:11:13.840" region="bottomCenter">会不会是我们猜错了？</p>
      <p xml:id="p1327" begin="01:11:14.080" end="01:11:15.760" region="bottomCenter">不会错</p>
      <p xml:id="p1328" begin="01:11:15.880" end="01:11:17.120" region="bottomCenter">就是他们</p>
      <p xml:id="p1329" begin="01:11:20.480" end="01:11:21.360" region="bottomCenter">你要干什么？</p>
      <p xml:id="p1330" begin="01:11:29.280" end="01:11:30.320" region="bottomCenter">莫冲动</p>
      <p xml:id="p1331" begin="01:11:31.000" end="01:11:32.480" region="bottomCenter">你是要去龙宫吗？</p>
      <p xml:id="p1332" begin="01:11:32.600" end="01:11:33.920" region="bottomCenter">那是骷髅山的方向</p>
      <p xml:id="p1333" begin="01:11:35.080" end="01:11:38.120" region="bottomCenter">龙族屠戮无辜百姓</p>
      <p xml:id="p1334" begin="01:11:38.240" end="01:11:40.760" region="bottomCenter">犯下这滔天恶行</p>
      <p xml:id="p1335" begin="01:11:41.040" end="01:11:43.840" region="bottomCenter">无需再通过金仙大会</p>
      <p xml:id="p1336" begin="01:11:43.960" end="01:11:45.880" region="bottomCenter">老夫要先斩后奏</p>
      <p xml:id="p1337" begin="01:11:46.160" end="01:11:48.360" region="bottomCenter">鹤童，随我回宫</p>
      <p xml:id="p1338" begin="01:11:48.480" end="01:11:51.000" region="bottomCenter">召集捕妖队全体成员</p>
      <p xml:id="p1339" begin="01:11:51.120" end="01:11:51.960" region="bottomCenter">诺</p>
      <p xml:id="p1340" begin="01:11:52.080" end="01:11:53.120" region="bottomCenter">师弟</p>
      <p xml:id="p1341" begin="01:11:53.240" end="01:11:55.440" region="bottomCenter">哪吒父母为妖族所害</p>
      <p xml:id="p1342" begin="01:11:55.560" end="01:11:58.720" region="bottomCenter">不能再让这孩子有个三长两短</p>
      <p xml:id="p1343" begin="01:11:58.840" end="01:12:00.800" region="bottomCenter">你与鹿童赶紧去接应他</p>
      <p xml:id="p1344" begin="01:12:00.920" end="01:12:01.760" region="bottomCenter">诺</p>
      <p xml:id="p1345" begin="01:12:06.120" end="01:12:07.440" region="bottomCenter">我知道你现在很难过</p>
      <p xml:id="p1346" begin="01:12:07.800" end="01:12:10.160" region="bottomCenter">你可不可以先…先冷静一下？</p>
      <p xml:id="p1347" begin="01:12:13.440" end="01:12:15.680" region="bottomCenter">你能不能先带我回龙宫？</p>
      <p xml:id="p1348" begin="01:12:16.240" end="01:12:17.760" region="bottomCenter">我会向父王和师父</p>
      <p xml:id="p1349" begin="01:12:17.880" end="01:12:18.720" region="bottomCenter">问个明白</p>
      <p xml:id="p1350" begin="01:12:18.840" end="01:12:21.600" region="bottomCenter">问明白就能救活我爹娘吗？</p>
      <p xml:id="p1351" begin="01:12:34.520" end="01:12:36.600" region="bottomCenter">铜镜铜镜告诉我</p>
      <p xml:id="p1352" begin="01:12:36.960" end="01:12:39.600" region="bottomCenter">谁是方圆十里最美的女人？</p>
      <p xml:id="p1353" begin="01:12:39.720" end="01:12:41.280" region="bottomCenter">是你，我的主人</p>
      <p xml:id="p1354" begin="01:12:42.440" end="01:12:45.120" region="bottomCenter">那谁是方圆百里最美的女人？</p>
      <p xml:id="p1355" begin="01:12:45.240" end="01:12:46.560" region="bottomCenter">是你，我的主人</p>
      <p xml:id="p1356" begin="01:12:46.680" end="01:12:47.680" region="bottomCenter">那方圆千里呢？</p>
      <p xml:id="p1357" begin="01:12:47.800" end="01:12:49.200" region="bottomCenter">是你　　万里呢？</p>
      <p xml:id="p1358" begin="01:12:49.320" end="01:12:50.320" region="bottomCenter">是你　　全天下呢？</p>
      <p xml:id="p1359" begin="01:12:50.440" end="01:12:52.040" region="bottomCenter">还是你</p>
      <p xml:id="p1360" begin="01:12:52.800" end="01:12:53.760" region="bottomCenter">你敷衍谁呢？</p>
      <p xml:id="p1361" begin="01:12:53.880" end="01:12:54.760" region="bottomCenter">靠点谱行不</p>
      <p xml:id="p1362" begin="01:12:54.880" end="01:12:55.880" region="bottomCenter">没没</p>
      <p xml:id="p1363" begin="01:12:56.000" end="01:12:58.560" region="bottomCenter">这…这不怕您生气吗？</p>
      <p xml:id="p1364" begin="01:12:58.680" end="01:12:59.880" region="bottomCenter">我告诉你</p>
      <p xml:id="p1365" begin="01:13:00.000" end="01:13:01.840" region="bottomCenter">你说真话我反而不生气</p>
      <p xml:id="p1366" begin="01:13:01.960" end="01:13:03.600" region="bottomCenter">真…不生气？</p>
      <p xml:id="p1367" begin="01:13:03.720" end="01:13:06.840" region="bottomCenter">虽然石矶娘娘我貌美如花</p>
      <p xml:id="p1368" begin="01:13:06.960" end="01:13:09.000" region="bottomCenter">但山外有山的道理我岂能不懂</p>
      <p xml:id="p1369" begin="01:13:09.480" end="01:13:10.320" region="bottomCenter">那你问吧</p>
      <p xml:id="p1370" begin="01:13:10.440" end="01:13:11.600" region="bottomCenter">我是不是全天下最美的女人？</p>
      <p xml:id="p1371" begin="01:13:11.720" end="01:13:12.560" region="bottomCenter">不是</p>
      <p xml:id="p1372" begin="01:13:13.120" end="01:13:14.720" region="bottomCenter">这才真实嘛</p>
      <p xml:id="p1373" begin="01:13:14.840" end="01:13:16.400" region="bottomCenter">我是不是方圆万里</p>
      <p xml:id="p1374" begin="01:13:16.520" end="01:13:17.960" region="bottomCenter">最美的女人？　　不是</p>
      <p xml:id="p1375" begin="01:13:18.080" end="01:13:19.800" region="bottomCenter">方圆千里呢？　　不是</p>
      <p xml:id="p1376" begin="01:13:19.920" end="01:13:21.160" region="bottomCenter">百里呢？　　不是</p>
      <p xml:id="p1377" begin="01:13:21.280" end="01:13:22.160" region="bottomCenter">十里？</p>
      <p xml:id="p1378" begin="01:13:22.280" end="01:13:23.120" region="bottomCenter">不是</p>
      <p xml:id="p1379" begin="01:13:23.240" end="01:13:26.360" region="bottomCenter">那我是不是这座山里最美的女人？</p>
      <p xml:id="p1380" begin="01:13:26.480" end="01:13:27.960" region="bottomCenter">不是啊</p>
      <p xml:id="p1381" begin="01:13:28.080" end="01:13:28.920" region="bottomCenter">你骗鬼啊</p>
      <p xml:id="p1382" begin="01:13:29.040" end="01:13:30.920" region="bottomCenter">这座山里除了我根本没其他人</p>
      <p xml:id="p1383" begin="01:13:31.040" end="01:13:32.400" region="bottomCenter">我也是女的</p>
      <p xml:id="p1384" begin="01:13:34.000" end="01:13:35.680" region="bottomCenter">你说过不生气的哦</p>
      <p xml:id="p1385" begin="01:13:37.120" end="01:13:38.800" region="bottomCenter">你哪点比我漂亮？　　救命啊</p>
      <p xml:id="p1386" begin="01:13:38.920" end="01:13:40.560" region="bottomCenter">哪点比我漂亮？</p>
      <p xml:id="p1387" begin="01:13:44.760" end="01:13:46.560" region="bottomCenter">石妖何在</p>
      <p xml:id="p1388" begin="01:13:46.840" end="01:13:48.240" region="bottomCenter">什么石妖不石妖的？</p>
      <p xml:id="p1389" begin="01:13:48.360" end="01:13:49.480" region="bottomCenter">叫我石矶娘娘</p>
      <p xml:id="p1390" begin="01:14:01.840" end="01:14:02.840" region="bottomCenter">臭小子</p>
      <p xml:id="p1391" begin="01:14:02.960" end="01:14:03.840" region="bottomCenter">我们见过吗？</p>
      <p xml:id="p1392" begin="01:14:03.960" end="01:14:05.560" region="bottomCenter">你跟老娘我拼什么命？</p>
      <p xml:id="p1393" begin="01:14:07.240" end="01:14:08.360" region="bottomCenter">你会暴露的</p>
      <p xml:id="p1394" begin="01:14:08.480" end="01:14:09.480" region="bottomCenter">让我来吧</p>
      <p xml:id="p1395" begin="01:14:09.600" end="01:14:10.480" region="bottomCenter">你少管</p>
      <p xml:id="p1396" begin="01:14:34.160" end="01:14:37.640" region="bottomCenter">石矶娘娘我是那么容易被打败的吗？</p>
      <p xml:id="p1397" begin="01:14:59.080" end="01:15:03.360" region="bottomCenter">这整座山都是老娘我的身体</p>
      <p xml:id="p1398" begin="01:15:03.640" end="01:15:06.040" region="bottomCenter">看你怎么灭得了我</p>
      <p xml:id="p1399" begin="01:15:15.640" end="01:15:16.640" region="bottomCenter">再使力</p>
      <p xml:id="p1400" begin="01:15:16.760" end="01:15:17.960" region="bottomCenter">你肉身会崩的</p>
      <p xml:id="p1401" begin="01:15:18.440" end="01:15:19.720" region="bottomCenter">我说</p>
      <p xml:id="p1402" begin="01:15:19.880" end="01:15:23.960" region="bottomCenter">不要你管</p>
      <p xml:id="p1403" begin="01:15:33.560" end="01:15:34.640" region="bottomCenter">已经交手了</p>
      <p xml:id="p1404" begin="01:15:35.520" end="01:15:36.520" region="bottomCenter">糟了糟了</p>
      <p xml:id="p1405" begin="01:15:44.280" end="01:15:46.160" region="bottomCenter">要了命了</p>
      <p xml:id="p1406" begin="01:15:48.000" end="01:15:49.560" region="bottomCenter">还好剩一点点</p>
      <p xml:id="p1407" begin="01:15:49.680" end="01:15:51.840" region="bottomCenter">留得青山在不怕没柴烧</p>
      <p xml:id="p1408" begin="01:15:51.960" end="01:15:54.200" region="bottomCenter">臭小子，给老娘我记着</p>
      <p xml:id="p1409" begin="01:15:55.760" end="01:15:57.200" region="bottomCenter">九龙神火罩</p>
      <p xml:id="p1410" begin="01:16:06.760" end="01:16:08.040" region="bottomCenter">跑不脱</p>
      <p xml:id="p1411" begin="01:16:10.120" end="01:16:12.360" region="bottomCenter">嗨呀，怎么那么冲动嘛</p>
      <p xml:id="p1412" begin="01:16:13.480" end="01:16:14.800" region="bottomCenter">肉身都差点崩了</p>
      <p xml:id="p1413" begin="01:16:14.920" end="01:16:16.040" region="bottomCenter">你不要命了呀？</p>
      <p xml:id="p1414" begin="01:16:16.280" end="01:16:18.280" region="bottomCenter">刚才的火焰是怎么回事？</p>
      <p xml:id="p1415" begin="01:16:18.400" end="01:16:19.760" region="bottomCenter">师弟</p>
      <p xml:id="p1416" begin="01:16:19.960" end="01:16:21.280" region="bottomCenter">不是冰系的吗？</p>
      <p xml:id="p1417" begin="01:16:21.600" end="01:16:23.160" region="bottomCenter">哪…哪个说他是冰系的？</p>
      <p xml:id="p1418" begin="01:16:23.280" end="01:16:24.400" region="bottomCenter">冰啊火啊我都教过</p>
      <p xml:id="p1419" begin="01:16:24.520" end="01:16:25.680" region="bottomCenter">他练的是</p>
      <p xml:id="p1420" begin="01:16:25.800" end="01:16:26.760" region="bottomCenter">冰火两重天</p>
      <p xml:id="p1421" begin="01:16:26.880" end="01:16:28.640" region="bottomCenter">这也行？</p>
      <p xml:id="p1422" begin="01:16:28.760" end="01:16:29.640" region="bottomCenter">灵珠天赋异禀</p>
      <p xml:id="p1423" begin="01:16:29.760" end="01:16:30.800" region="bottomCenter">岂能用常理判断</p>
      <p xml:id="p1424" begin="01:16:31.160" end="01:16:32.560" region="bottomCenter">你是师叔还是我是师叔？</p>
      <p xml:id="p1425" begin="01:16:32.680" end="01:16:33.520" region="bottomCenter">你懂还是我懂？</p>
      <p xml:id="p1426" begin="01:16:33.640" end="01:16:34.560" region="bottomCenter">弟子不敢</p>
      <p xml:id="p1427" begin="01:16:34.680" end="01:16:37.960" region="bottomCenter">但…先前弟子似乎还感受到</p>
      <p xml:id="p1428" begin="01:16:38.080" end="01:16:39.960" region="bottomCenter">一股强大的魔气</p>
      <p xml:id="p1429" begin="01:16:40.080" end="01:16:41.040" region="bottomCenter">那个嘛</p>
      <p xml:id="p1430" begin="01:16:41.360" end="01:16:42.840" region="bottomCenter">当然是这个石矶放出来的</p>
      <p xml:id="p1431" begin="01:16:43.120" end="01:16:44.600" region="bottomCenter">胖子你说什么？</p>
      <p xml:id="p1432" begin="01:16:44.720" end="01:16:45.560" region="bottomCenter">老娘我明明</p>
      <p xml:id="p1433" begin="01:16:45.840" end="01:16:48.080" region="bottomCenter">是不是你？是不是你？是不是你？快说</p>
      <p xml:id="p1434" begin="01:16:48.200" end="01:16:49.320" region="bottomCenter">是我放的，是我放的</p>
      <p xml:id="p1435" begin="01:16:49.440" end="01:16:51.680" region="bottomCenter">别摇啦，要吐啦</p>
      <p xml:id="p1436" begin="01:16:53.120" end="01:16:54.120" region="bottomCenter">你看，我说噻</p>
      <p xml:id="p1437" begin="01:16:57.960" end="01:16:59.040" region="bottomCenter">哪吒</p>
      <p xml:id="p1438" begin="01:16:59.160" end="01:17:01.080" region="bottomCenter">你连过三关</p>
      <p xml:id="p1439" begin="01:17:01.200" end="01:17:02.040" region="bottomCenter">今日</p>
      <p xml:id="p1440" begin="01:17:02.160" end="01:17:04.440" region="bottomCenter">老夫要亲自为你吟诵</p>
      <p xml:id="p1441" begin="01:17:04.560" end="01:17:05.840" region="bottomCenter">升仙咒</p>
      <p xml:id="p1442" begin="01:17:14.240" end="01:17:16.280" region="bottomCenter">遥想当年我也经历过这些</p>
      <p xml:id="p1443" begin="01:17:16.400" end="01:17:18.040" region="bottomCenter">那时候可能太紧张了</p>
      <p xml:id="p1444" begin="01:17:18.160" end="01:17:20.080" region="bottomCenter">咋没觉得升仙咒那么长呢</p>
      <p xml:id="p1445" begin="01:17:30.320" end="01:17:32.360" region="bottomCenter">从今往后</p>
      <p xml:id="p1446" begin="01:17:32.480" end="01:17:34.880" region="bottomCenter">你便也是阐教仙人了</p>
      <p xml:id="p1447" begin="01:17:57.200" end="01:18:00.240" region="bottomCenter">这玉虚宝库中珍藏的</p>
      <p xml:id="p1448" begin="01:18:00.360" end="01:18:02.280" region="bottomCenter">样样都是稀世法宝</p>
      <p xml:id="p1449" begin="01:18:02.400" end="01:18:03.400" region="bottomCenter">玉液琼浆</p>
      <p xml:id="p1450" begin="01:18:04.880" end="01:18:06.480" region="bottomCenter">只能选一样</p>
      <p xml:id="p1451" begin="01:18:06.680" end="01:18:07.920" region="bottomCenter">你不多考虑考虑？</p>
      <p xml:id="p1452" begin="01:18:08.040" end="01:18:09.600" region="bottomCenter">玉液琼浆</p>
      <p xml:id="p1453" begin="01:19:11.280" end="01:19:13.600" region="bottomCenter">玉虚宫已派出信使</p>
      <p xml:id="p1454" begin="01:19:13.720" end="01:19:16.720" region="bottomCenter">向十二金仙通报龙族罪状</p>
      <p xml:id="p1455" begin="01:19:16.920" end="01:19:18.600" region="bottomCenter">但山高路远</p>
      <p xml:id="p1456" begin="01:19:18.720" end="01:19:21.720" region="bottomCenter">仓促间众师弟难以赶来</p>
      <p xml:id="p1457" begin="01:19:22.120" end="01:19:23.160" region="bottomCenter">此次</p>
      <p xml:id="p1458" begin="01:19:23.280" end="01:19:25.360" region="bottomCenter">老夫要亲率捕妖队</p>
      <p xml:id="p1459" begin="01:19:25.480" end="01:19:26.960" region="bottomCenter">讨伐龙族</p>
      <p xml:id="p1460" begin="01:19:27.840" end="01:19:28.960" region="bottomCenter">哪吒</p>
      <p xml:id="p1461" begin="01:19:29.080" end="01:19:31.760" region="bottomCenter">你愿与老夫一同出征否？</p>
      <p xml:id="p1462" begin="01:19:31.920" end="01:19:34.400" region="bottomCenter">我先回陈塘关一趟</p>
      <p xml:id="p1463" begin="01:19:34.520" end="01:19:37.080" region="bottomCenter">之后就去找龙王算账</p>
      <p xml:id="p1464" begin="01:19:37.320" end="01:19:38.560" region="bottomCenter">好</p>
      <p xml:id="p1465" begin="01:19:38.680" end="01:19:40.680" region="bottomCenter">你战力非凡</p>
      <p xml:id="p1466" begin="01:19:40.800" end="01:19:44.160" region="bottomCenter">定可助老夫荡平龙宫</p>
      <p xml:id="p1467" begin="01:20:02.920" end="01:20:04.280" region="bottomCenter">欠你的</p>
      <p xml:id="p1468" begin="01:20:05.480" end="01:20:06.800" region="bottomCenter">都还清了</p>
      <p xml:id="p1469" begin="01:20:07.960" end="01:20:09.040" region="bottomCenter">你等等</p>
      <p xml:id="p1470" begin="01:20:09.320" end="01:20:10.400" region="bottomCenter">等我肉身恢复</p>
      <p xml:id="p1471" begin="01:20:10.520" end="01:20:11.600" region="bottomCenter">我们一起去龙宫好不好？</p>
      <p xml:id="p1472" begin="01:20:11.720" end="01:20:13.240" region="bottomCenter">你知道我会做什么</p>
      <p xml:id="p1473" begin="01:20:14.680" end="01:20:17.080" region="bottomCenter">你去了只会更难受</p>
      <p xml:id="p1474" begin="01:20:18.960" end="01:20:20.480" region="bottomCenter">下次见面</p>
      <p xml:id="p1475" begin="01:20:21.960" end="01:20:23.760" region="bottomCenter">是敌非友</p>
      <p xml:id="p1476" begin="01:20:26.760" end="01:20:27.800" region="bottomCenter">冤孽啊</p>
      <p xml:id="p1477" begin="01:20:32.320" end="01:20:33.280" region="bottomCenter">你走不得，走不得</p>
      <p xml:id="p1478" begin="01:20:34.320" end="01:20:36.080" region="bottomCenter">还没到龙宫你魂儿都散了</p>
      <p xml:id="p1479" begin="01:20:41.320" end="01:20:42.240" region="bottomCenter">九龙神火罩</p>
      <p xml:id="p1480" begin="01:20:50.200" end="01:20:51.760" region="bottomCenter">你冷静下好不好嘛？</p>
      <p xml:id="p1481" begin="01:20:51.880" end="01:20:54.480" region="bottomCenter">你现在去了，也改变不了任何事情啊</p>
      <p xml:id="p1482" begin="01:20:54.880" end="01:20:56.160" region="bottomCenter">你别管我</p>
      <p xml:id="p1483" begin="01:20:56.280" end="01:20:57.360" region="bottomCenter">放我出去</p>
      <p xml:id="p1484" begin="01:20:57.480" end="01:20:59.120" region="bottomCenter">不行！我答应过哪吒</p>
      <p xml:id="p1485" begin="01:20:59.240" end="01:21:00.680" region="bottomCenter">一定要把你救活</p>
      <p xml:id="p1486" begin="01:21:13.560" end="01:21:14.920" region="bottomCenter">憋死我了</p>
      <p xml:id="p1487" begin="01:22:08.320" end="01:22:09.880" region="bottomCenter">何方神圣？</p>
      <p xml:id="p1488" begin="01:22:10.720" end="01:22:13.640" region="bottomCenter">老夫乃阐教无量仙翁</p>
      <p xml:id="p1489" begin="01:22:13.760" end="01:22:15.920" region="bottomCenter">敖光，你可知罪？</p>
      <p xml:id="p1490" begin="01:22:18.040" end="01:22:20.200" region="bottomCenter">你们都知道了？</p>
      <p xml:id="p1491" begin="01:22:20.640" end="01:22:22.680" region="bottomCenter">那敖丙还活着吗？</p>
      <p xml:id="p1492" begin="01:22:23.160" end="01:22:24.640" region="bottomCenter">我任由你们处置</p>
      <p xml:id="p1493" begin="01:22:24.760" end="01:22:26.400" region="bottomCenter">能否放我儿一条生路</p>
      <p xml:id="p1494" begin="01:22:26.720" end="01:22:27.960" region="bottomCenter">不知所谓</p>
      <p xml:id="p1495" begin="01:22:28.320" end="01:22:29.960" region="bottomCenter">天庭令你龙族</p>
      <p xml:id="p1496" begin="01:22:30.080" end="01:22:31.800" region="bottomCenter">镇压海底妖兽</p>
      <p xml:id="p1497" begin="01:22:31.920" end="01:22:33.640" region="bottomCenter">你们却勾结妖兽</p>
      <p xml:id="p1498" begin="01:22:33.760" end="01:22:35.720" region="bottomCenter">屠戮陈塘关</p>
      <p xml:id="p1499" begin="01:22:36.120" end="01:22:37.240" region="bottomCenter">陈塘关？</p>
      <p xml:id="p1500" begin="01:22:37.560" end="01:22:40.120" region="bottomCenter">龙族犯下滔天罪行</p>
      <p xml:id="p1501" begin="01:22:40.240" end="01:22:43.240" region="bottomCenter">今日老夫要替天行道</p>
      <p xml:id="p1502" begin="01:23:00.800" end="01:23:02.440" region="bottomCenter">包罗天地</p>
      <p xml:id="p1503" begin="01:23:02.560" end="01:23:04.040" region="bottomCenter">无量神通</p>
      <p xml:id="p1504" begin="01:23:04.160" end="01:23:06.000" region="bottomCenter">天元现世</p>
      <p xml:id="p1505" begin="01:23:06.120" end="01:23:08.080" region="bottomCenter">傲视群雄</p>
      <p xml:id="p1506" begin="01:23:08.280" end="01:23:09.160" region="bottomCenter">开</p>
      <p xml:id="p1507" begin="01:23:39.960" end="01:23:41.560" region="bottomCenter">给我出来</p>
      <p xml:id="p1508" begin="01:23:44.960" end="01:23:48.120" region="bottomCenter">你们对陈塘关干了什么？</p>
      <p xml:id="p1509" begin="01:23:48.240" end="01:23:50.000" region="bottomCenter">大哥不是叫我等</p>
      <p xml:id="p1510" begin="01:23:50.120" end="01:23:51.880" region="bottomCenter">听申道长的吩咐吗？</p>
      <p xml:id="p1511" begin="01:23:52.000" end="01:23:53.520" region="bottomCenter">申公豹？</p>
      <p xml:id="p1512" begin="01:24:03.960" end="01:24:05.800" region="bottomCenter">火烧眉毛</p>
      <p xml:id="p1513" begin="01:24:06.200" end="01:24:08.400" region="bottomCenter">大哥还是先顾眼前吧</p>
      <p xml:id="p1514" begin="01:24:10.880" end="01:24:11.800" region="bottomCenter">大王</p>
      <p xml:id="p1515" begin="01:24:11.920" end="01:24:12.880" region="bottomCenter">不能坐以待毙啊</p>
      <p xml:id="p1516" begin="01:24:13.000" end="01:24:14.280" region="bottomCenter">我若出战</p>
      <p xml:id="p1517" begin="01:24:14.400" end="01:24:15.560" region="bottomCenter">这锁妖阵</p>
      <p xml:id="p1518" begin="01:24:15.680" end="01:24:16.760" region="bottomCenter">锁妖阵交给我们吧</p>
      <p xml:id="p1519" begin="01:24:16.880" end="01:24:17.760" region="bottomCenter">拼尽全力</p>
      <p xml:id="p1520" begin="01:24:17.880" end="01:24:19.360" region="bottomCenter">我们一炷香还是撑得了的</p>
      <p xml:id="p1521" begin="01:24:19.920" end="01:24:21.080" region="bottomCenter">好</p>
      <p xml:id="p1522" begin="01:24:35.840" end="01:24:38.000" region="bottomCenter">欺人太甚</p>
      <p xml:id="p1523" begin="01:24:48.160" end="01:24:49.440" region="bottomCenter">妖孽大胆</p>
      <p xml:id="p1524" begin="01:25:00.400" end="01:25:03.680" region="bottomCenter">我们报仇雪恨的千载良机到了</p>
      <p xml:id="p1525" begin="01:25:04.160" end="01:25:05.960" region="bottomCenter">杀出炼狱</p>
      <p xml:id="p1526" begin="01:25:06.360" end="01:25:08.360" region="bottomCenter">荡平龙宫</p>
      <p xml:id="p1527" begin="01:26:40.920" end="01:26:42.520" region="bottomCenter">人刀合一</p>
      <p xml:id="p1528" begin="01:27:02.840" end="01:27:04.920" region="bottomCenter">老鬼，看刀</p>
      <p xml:id="p1529" begin="01:27:20.320" end="01:27:21.840" region="bottomCenter">这样释放魔气</p>
      <p xml:id="p1530" begin="01:27:21.960" end="01:27:23.840" region="bottomCenter">你小子不怕暴露身份吗？</p>
      <p xml:id="p1531" begin="01:27:24.200" end="01:27:26.000" region="bottomCenter">我说过</p>
      <p xml:id="p1532" begin="01:27:26.120" end="01:27:28.880" region="bottomCenter">你要是敢动陈塘关</p>
      <p xml:id="p1533" begin="01:27:29.000" end="01:27:32.800" region="bottomCenter">我就把龙宫砸个稀巴烂</p>
      <p xml:id="p1534" begin="01:27:36.920" end="01:27:37.760" region="bottomCenter">说</p>
      <p xml:id="p1535" begin="01:27:37.880" end="01:27:39.560" region="bottomCenter">敖丙是不是死了？</p>
      <p xml:id="p1536" begin="01:28:43.920" end="01:28:45.760" region="bottomCenter">闪开，都闪开</p>
      <p xml:id="p1537" begin="01:29:22.160" end="01:29:23.280" region="bottomCenter">起</p>
      <p xml:id="p1538" begin="01:30:33.880" end="01:30:35.840" region="bottomCenter">你不想活了？</p>
      <p xml:id="p1539" begin="01:30:36.160" end="01:30:39.240" region="bottomCenter">看你肉身撑得了多久</p>
      <p xml:id="p1540" begin="01:30:39.360" end="01:30:40.840" region="bottomCenter">我活不活无所谓</p>
      <p xml:id="p1541" begin="01:30:40.960" end="01:30:42.600" region="bottomCenter">我只要你死</p>
      <p xml:id="p1542" begin="01:31:01.320" end="01:31:02.400" region="bottomCenter">机不可失</p>
      <p xml:id="p1543" begin="01:31:21.600" end="01:31:23.520" region="bottomCenter">看你们干的蠢事</p>
      <p xml:id="p1544" begin="01:31:23.720" end="01:31:27.280" region="bottomCenter">难道同归于尽就是你们想要的结果？</p>
      <p xml:id="p1545" begin="01:31:30.040" end="01:31:31.000" region="bottomCenter">锁链</p>
      <p xml:id="p1546" begin="01:31:37.920" end="01:31:40.920" region="bottomCenter">东海龙王竟也不是你对手</p>
      <p xml:id="p1547" begin="01:31:41.040" end="01:31:43.440" region="bottomCenter">老夫果然没有看错</p>
      <p xml:id="p1548" begin="01:31:43.560" end="01:31:46.960" region="bottomCenter">阐教就需要你这样的栋梁之才</p>
      <p xml:id="p1549" begin="01:31:47.560" end="01:31:50.400" region="bottomCenter">你父母一生嫉恶如仇</p>
      <p xml:id="p1550" begin="01:31:50.520" end="01:31:51.720" region="bottomCenter">今后</p>
      <p xml:id="p1551" begin="01:31:51.840" end="01:31:54.400" region="bottomCenter">你也要继承他们的遗志</p>
      <p xml:id="p1552" begin="01:31:54.520" end="01:31:56.880" region="bottomCenter">斩尽天下妖孽</p>
      <p xml:id="p1553" begin="01:31:58.800" end="01:32:01.720" region="bottomCenter">老夫这就替你主持公道</p>
      <p xml:id="p1554" begin="01:32:01.840" end="01:32:03.800" region="bottomCenter">炼了这帮畜生</p>
      <p xml:id="p1555" begin="01:32:04.040" end="01:32:05.200" region="bottomCenter">替我护法</p>
      <p xml:id="p1556" begin="01:32:05.320" end="01:32:06.160" region="bottomCenter">诺</p>
      <p xml:id="p1557" begin="01:32:48.600" end="01:32:49.760" region="bottomCenter">吒儿</p>
      <p xml:id="p1558" begin="01:32:53.640" end="01:32:54.640" region="bottomCenter">吒儿</p>
      <p xml:id="p1559" begin="01:32:54.800" end="01:32:55.840" region="bottomCenter">吒儿</p>
      <p xml:id="p1560" begin="01:32:56.120" end="01:32:57.160" region="bottomCenter">吒儿</p>
      <p xml:id="p1561" begin="01:32:57.280" end="01:32:58.360" region="bottomCenter">吒儿</p>
      <p xml:id="p1562" begin="01:32:58.760" end="01:32:59.800" region="bottomCenter">吒儿</p>
      <p xml:id="p1563" begin="01:33:00.200" end="01:33:01.160" region="bottomCenter">吒儿</p>
      <p xml:id="p1564" begin="01:33:01.360" end="01:33:02.240" region="bottomCenter">爹</p>
      <p xml:id="p1565" begin="01:33:02.360" end="01:33:03.320" region="bottomCenter">吒儿</p>
      <p xml:id="p1566" begin="01:33:03.440" end="01:33:04.280" region="bottomCenter">娘</p>
      <p xml:id="p1567" begin="01:33:04.400" end="01:33:05.360" region="bottomCenter">吒儿</p>
      <p xml:id="p1568" begin="01:33:06.360" end="01:33:07.600" region="bottomCenter">吒儿</p>
      <p xml:id="p1569" begin="01:33:11.960" end="01:33:13.680" region="bottomCenter">儿啊，你没事吧？</p>
      <p xml:id="p1570" begin="01:33:14.160" end="01:33:15.360" region="bottomCenter">你的肉身</p>
      <p xml:id="p1571" begin="01:33:15.600" end="01:33:18.320" region="bottomCenter">我…我...</p>
      <p xml:id="p1572" begin="01:33:19.080" end="01:33:21.640" region="bottomCenter">他们其实已经知晓你和敖丙的身份</p>
      <p xml:id="p1573" begin="01:33:23.160" end="01:33:27.080" region="bottomCenter">我…我...我以为</p>
      <p xml:id="p1574" begin="01:33:27.760" end="01:33:31.600" region="bottomCenter">再也见不到你们了</p>
      <p xml:id="p1575" begin="01:33:40.560" end="01:33:41.800" region="bottomCenter">师父还在施法</p>
      <p xml:id="p1576" begin="01:33:41.920" end="01:33:43.200" region="bottomCenter">能拖一会儿是一会儿</p>
      <p xml:id="p1577" begin="01:33:45.200" end="01:33:47.880" region="bottomCenter">哪吒，灭陈塘关的不是我父王</p>
      <p xml:id="p1578" begin="01:33:49.040" end="01:33:52.400" region="bottomCenter">真凶就是这无量仙翁</p>
      <p xml:id="p1579" begin="01:34:11.680" end="01:34:12.640" region="bottomCenter">结界兽</p>
      <p xml:id="p1580" begin="01:35:00.520" end="01:35:01.640" region="bottomCenter">龙族</p>
      <p xml:id="p1581" begin="01:35:02.240" end="01:35:03.600" region="bottomCenter">大师兄</p>
      <p xml:id="p1582" begin="01:35:04.120" end="01:35:06.160" region="bottomCenter">别来无恙乎</p>
      <p xml:id="p1583" begin="01:35:06.760" end="01:35:08.000" region="bottomCenter">你怎么在这儿？</p>
      <p xml:id="p1584" begin="01:35:09.520" end="01:35:10.640" region="bottomCenter">申公豹</p>
      <p xml:id="p1585" begin="01:35:10.760" end="01:35:11.920" region="bottomCenter">你勾结龙族</p>
      <p xml:id="p1586" begin="01:35:12.040" end="01:35:13.120" region="bottomCenter">意欲何为？</p>
      <p xml:id="p1587" begin="01:35:13.440" end="01:35:15.880" region="bottomCenter">我倒要问…问问你</p>
      <p xml:id="p1588" begin="01:35:16.000" end="01:35:18.800" region="bottomCenter">你抓我爹，意欲何为？</p>
      <p xml:id="p1589" begin="01:35:19.640" end="01:35:21.760" region="bottomCenter">谁说我抓了你爹？</p>
      <p xml:id="p1590" begin="01:35:21.880" end="01:35:23.920" region="bottomCenter">我家情况只有你清楚</p>
      <p xml:id="p1591" begin="01:35:24.040" end="01:35:25.760" region="bottomCenter">若非你授意</p>
      <p xml:id="p1592" begin="01:35:25.880" end="01:35:29.160" region="bottomCenter">哪吒和捕妖队怎会找上我爹？</p>
      <p xml:id="p1593" begin="01:35:29.520" end="01:35:32.160" region="bottomCenter">而且我弟的箭伤</p>
      <p xml:id="p1594" begin="01:35:32.280" end="01:35:33.960" region="bottomCenter">一看可知</p>
      <p xml:id="p1595" begin="01:35:34.080" end="01:35:37.080" region="bottomCenter">是你徒儿鹿童所为</p>
      <p xml:id="p1596" begin="01:35:41.600" end="01:35:45.480" region="bottomCenter">不愧是老夫引荐入门的人才</p>
      <p xml:id="p1597" begin="01:35:45.600" end="01:35:48.360" region="bottomCenter">什么都逃不过你的眼睛</p>
      <p xml:id="p1598" begin="01:35:50.040" end="01:35:53.400" region="bottomCenter">毕竟替你干过那么多年脏活儿</p>
      <p xml:id="p1599" begin="01:35:53.520" end="01:35:55.120" region="bottomCenter">我还能猜到你来陈塘关</p>
      <p xml:id="p1600" begin="01:35:55.240" end="01:35:56.960" region="bottomCenter">装神弄鬼的目的</p>
      <p xml:id="p1601" begin="01:35:57.360" end="01:36:00.400" region="bottomCenter">是想嫁…嫁祸龙族吧？</p>
      <p xml:id="p1602" begin="01:36:01.160" end="01:36:04.880" region="bottomCenter">你就是这样报答大师兄的栽培？</p>
      <p xml:id="p1603" begin="01:36:05.160" end="01:36:08.080" region="bottomCenter">你一直把…把我当工具</p>
      <p xml:id="p1604" begin="01:36:08.440" end="01:36:09.880" region="bottomCenter">你我之间</p>
      <p xml:id="p1605" begin="01:36:10.000" end="01:36:11.320" region="bottomCenter">有怨无恩</p>
      <p xml:id="p1606" begin="01:36:13.520" end="01:36:17.120" region="bottomCenter">有兴趣做个交易吗？仙长</p>
      <p xml:id="p1607" begin="01:36:18.080" end="01:36:21.000" region="bottomCenter">贵为玉虚宫的主事</p>
      <p xml:id="p1608" begin="01:36:21.120" end="01:36:25.200" region="bottomCenter">想必知道解开这定海锁链的法咒</p>
      <p xml:id="p1609" begin="01:36:25.440" end="01:36:28.480" region="bottomCenter">知道又怎样？</p>
      <p xml:id="p1610" begin="01:36:28.640" end="01:36:30.160" region="bottomCenter">你…你们要叛变？</p>
      <p xml:id="p1611" begin="01:36:30.280" end="01:36:32.760" region="bottomCenter">千年前四弟兄一起对抗仙界</p>
      <p xml:id="p1612" begin="01:36:32.880" end="01:36:34.480" region="bottomCenter">到底是谁先背信弃义</p>
      <p xml:id="p1613" begin="01:36:34.600" end="01:36:35.760" region="bottomCenter">将我们打入炼狱？</p>
      <p xml:id="p1614" begin="01:36:35.960" end="01:36:38.280" region="bottomCenter">无量仙翁要对付敖光</p>
      <p xml:id="p1615" begin="01:36:38.400" end="01:36:39.880" region="bottomCenter">我们求之不得</p>
      <p xml:id="p1616" begin="01:36:40.680" end="01:36:42.360" region="bottomCenter">久闻无量仙翁</p>
      <p xml:id="p1617" begin="01:36:42.480" end="01:36:44.440" region="bottomCenter">用人不拘一格</p>
      <p xml:id="p1618" begin="01:36:44.560" end="01:36:48.040" region="bottomCenter">我等三个的实力想必您也了解</p>
      <p xml:id="p1619" begin="01:36:48.160" end="01:36:50.720" region="bottomCenter">若能解救我等脱离炼狱</p>
      <p xml:id="p1620" begin="01:36:50.840" end="01:36:52.440" region="bottomCenter">得道成仙</p>
      <p xml:id="p1621" begin="01:36:52.560" end="01:36:55.080" region="bottomCenter">我等甘愿为仆为奴</p>
      <p xml:id="p1622" begin="01:36:55.200" end="01:36:58.720" region="bottomCenter">外加奉上灵珠和魔丸的秘密</p>
      <p xml:id="p1623" begin="01:36:58.880" end="01:37:00.280" region="bottomCenter">灵珠和魔丸？</p>
      <p xml:id="p1624" begin="01:37:00.400" end="01:37:01.280" region="bottomCenter">卑贱</p>
      <p xml:id="p1625" begin="01:37:01.400" end="01:37:04.640" region="bottomCenter">你们反…反抗仙界的傲骨呢？</p>
      <p xml:id="p1626" begin="01:37:04.760" end="01:37:06.480" region="bottomCenter">以前年少无知</p>
      <p xml:id="p1627" begin="01:37:08.880" end="01:37:11.360" region="bottomCenter">经过千年牢狱</p>
      <p xml:id="p1628" begin="01:37:11.880" end="01:37:14.360" region="bottomCenter">才明白这世间的规则</p>
      <p xml:id="p1629" begin="01:37:14.960" end="01:37:16.640" region="bottomCenter">是由谁定</p>
      <p xml:id="p1630" begin="01:37:17.960" end="01:37:19.320" region="bottomCenter">聪明</p>
      <p xml:id="p1631" begin="01:37:19.600" end="01:37:21.400" region="bottomCenter">但你们反复无常</p>
      <p xml:id="p1632" begin="01:37:21.520" end="01:37:22.920" region="bottomCenter">我怎信得过？</p>
      <p xml:id="p1633" begin="01:37:23.200" end="01:37:25.800" region="bottomCenter">除非让老夫在你们身上</p>
      <p xml:id="p1634" begin="01:37:25.920" end="01:37:27.400" region="bottomCenter">我等愿意</p>
      <p xml:id="p1635" begin="01:37:37.520" end="01:37:39.080" region="bottomCenter">三个龙王自愿接受</p>
      <p xml:id="p1636" begin="01:37:39.200" end="01:37:41.600" region="bottomCenter">无量仙翁在他们身上下咒</p>
      <p xml:id="p1637" begin="01:37:41.720" end="01:37:43.200" region="bottomCenter">今后若敢抗命</p>
      <p xml:id="p1638" begin="01:37:43.320" end="01:37:46.360" region="bottomCenter">无量仙翁随时可取他们性命</p>
      <p xml:id="p1639" begin="01:37:47.160" end="01:37:49.560" region="bottomCenter">而无量仙翁则履行承诺</p>
      <p xml:id="p1640" begin="01:37:49.680" end="01:37:52.400" region="bottomCenter">解开了他们身上的定海锁链</p>
      <p xml:id="p1641" begin="01:37:53.480" end="01:37:55.520" region="bottomCenter">一旦发现强大势力</p>
      <p xml:id="p1642" begin="01:37:55.640" end="01:37:56.720" region="bottomCenter">便制造惨案</p>
      <p xml:id="p1643" begin="01:37:56.840" end="01:37:57.760" region="bottomCenter">栽赃陷害</p>
      <p xml:id="p1644" begin="01:37:57.880" end="01:37:59.240" region="bottomCenter">再派兵抓捕</p>
      <p xml:id="p1645" begin="01:38:00.000" end="01:38:01.520" region="bottomCenter">据申公豹所述</p>
      <p xml:id="p1646" begin="01:38:01.640" end="01:38:04.720" region="bottomCenter">他曾替无量仙翁干过不少这等勾当</p>
      <p xml:id="p1647" begin="01:38:04.840" end="01:38:07.360" region="bottomCenter">才换得加入阐教的机会</p>
      <p xml:id="p1648" begin="01:38:08.080" end="01:38:11.120" region="bottomCenter">此次无量仙翁本是为屠灭陈塘关</p>
      <p xml:id="p1649" begin="01:38:11.240" end="01:38:13.520" region="bottomCenter">栽赃东海龙族而来</p>
      <p xml:id="p1650" begin="01:38:13.640" end="01:38:15.120" region="bottomCenter">哪知却阴差阳错</p>
      <p xml:id="p1651" begin="01:38:15.240" end="01:38:16.880" region="bottomCenter">收编了三大龙王</p>
      <p xml:id="p1652" begin="01:38:17.000" end="01:38:18.160" region="bottomCenter">并从他们口中</p>
      <p xml:id="p1653" begin="01:38:18.280" end="01:38:21.160" region="bottomCenter">获悉了魔丸和灵珠的秘密</p>
      <p xml:id="p1654" begin="01:38:22.400" end="01:38:23.560" region="bottomCenter">事后</p>
      <p xml:id="p1655" begin="01:38:23.680" end="01:38:26.960" region="bottomCenter">他们故意留下两个不明真相的活口</p>
      <p xml:id="p1656" begin="01:38:27.080" end="01:38:29.800" region="bottomCenter">放回玉虚宫通风报信</p>
      <p xml:id="p1657" begin="01:38:51.920" end="01:38:53.760" region="bottomCenter">眼看突围无望</p>
      <p xml:id="p1658" begin="01:38:53.880" end="01:38:55.560" region="bottomCenter">申公豹想出一计</p>
      <p xml:id="p1659" begin="01:38:55.680" end="01:38:58.040" region="bottomCenter">让夜叉先将我俩石化</p>
      <p xml:id="p1660" begin="01:38:58.160" end="01:39:00.320" region="bottomCenter">再潜入下水道躲藏起来</p>
      <p xml:id="p1661" begin="01:39:00.440" end="01:39:03.720" region="bottomCenter">之后静待时机将我二人救活</p>
      <p xml:id="p1662" begin="01:39:04.240" end="01:39:05.240" region="bottomCenter">那你呢？</p>
      <p xml:id="p1663" begin="01:39:05.560" end="01:39:08.040" region="bottomCenter">家人已逝</p>
      <p xml:id="p1664" begin="01:39:08.160" end="01:39:09.600" region="bottomCenter">我没什么好留恋的了</p>
      <p xml:id="p1665" begin="01:39:13.440" end="01:39:14.480" region="bottomCenter">在那里</p>
      <p xml:id="p1666" begin="01:39:31.080" end="01:39:32.840" region="bottomCenter">捕妖队捉去的妖</p>
      <p xml:id="p1667" begin="01:39:32.960" end="01:39:34.840" region="bottomCenter">并非如外界传言</p>
      <p xml:id="p1668" begin="01:39:34.960" end="01:39:38.040" region="bottomCenter">在玉虚宫接受正道感化</p>
      <p xml:id="p1669" begin="01:39:38.160" end="01:39:41.720" region="bottomCenter">而是都被无量仙翁投入这天元鼎</p>
      <p xml:id="p1670" begin="01:39:41.840" end="01:39:43.320" region="bottomCenter">炼成了仙丹</p>
      <p xml:id="p1671" begin="01:39:43.440" end="01:39:45.760" region="bottomCenter">提升阐教实力</p>
      <p xml:id="p1672" begin="01:39:45.880" end="01:39:47.120" region="bottomCenter">师兄啊</p>
      <p xml:id="p1673" begin="01:39:47.240" end="01:39:49.760" region="bottomCenter">你怎么能犯下这等罪行？</p>
      <p xml:id="p1674" begin="01:39:49.880" end="01:39:51.760" region="bottomCenter">你…你怎么对得起师尊</p>
      <p xml:id="p1675" begin="01:39:51.880" end="01:39:53.800" region="bottomCenter">对我们的教诲嘛？</p>
      <p xml:id="p1676" begin="01:39:53.960" end="01:39:57.000" region="bottomCenter">现在你们既已知晓无量仙翁的罪行</p>
      <p xml:id="p1677" begin="01:39:57.120" end="01:39:58.800" region="bottomCenter">就应悬崖勒马</p>
      <p xml:id="p1678" begin="01:39:58.920" end="01:40:00.360" region="bottomCenter">将他押解回宫</p>
      <p xml:id="p1679" begin="01:40:00.480" end="01:40:02.360" region="bottomCenter">等待天尊降罪</p>
      <p xml:id="p1680" begin="01:40:09.200" end="01:40:12.720" region="bottomCenter">捕妖队由无量仙翁亲手栽培</p>
      <p xml:id="p1681" begin="01:40:12.840" end="01:40:15.680" region="bottomCenter">岂能三言两语就被你们策反</p>
      <p xml:id="p1682" begin="01:40:16.560" end="01:40:17.720" region="bottomCenter">那</p>
      <p xml:id="p1683" begin="01:40:17.960" end="01:40:19.680" region="bottomCenter">是我错怪了龙族</p>
      <p xml:id="p1684" begin="01:40:24.240" end="01:40:25.360" region="bottomCenter">放了龙族</p>
      <p xml:id="p1685" begin="01:40:43.120" end="01:40:44.160" region="bottomCenter">我来帮你</p>
      <p xml:id="p1686" begin="01:41:09.080" end="01:41:10.440" region="bottomCenter">你们叛变？</p>
      <p xml:id="p1687" begin="01:41:10.840" end="01:41:12.520" region="bottomCenter">跟大哥您学的</p>
      <p xml:id="p1688" begin="01:41:12.640" end="01:41:15.040" region="bottomCenter">当初为了保全整个龙族</p>
      <p xml:id="p1689" begin="01:41:15.160" end="01:41:16.480" region="bottomCenter">我没得选</p>
      <p xml:id="p1690" begin="01:41:16.600" end="01:41:18.920" region="bottomCenter">那现在为了保全自己</p>
      <p xml:id="p1691" begin="01:41:20.080" end="01:41:21.160" region="bottomCenter">我也没得选</p>
      <p xml:id="p1692" begin="01:41:22.600" end="01:41:23.840" region="bottomCenter">大王，等等我们</p>
      <p xml:id="p1693" begin="01:41:23.960" end="01:41:24.920" region="bottomCenter">不要丢下我们啊</p>
      <p xml:id="p1694" begin="01:41:25.040" end="01:41:26.480" region="bottomCenter">大王，带上我们</p>
      <p xml:id="p1695" begin="01:41:28.480" end="01:41:30.480" region="bottomCenter">大王，大王</p>
      <p xml:id="p1696" begin="01:41:33.280" end="01:41:35.120" region="bottomCenter">你们都被卖啦</p>
      <p xml:id="p1697" begin="01:41:44.200" end="01:41:45.720" region="bottomCenter">南海龙王</p>
      <p xml:id="p1698" begin="01:41:49.840" end="01:41:51.200" region="bottomCenter">北海龙王</p>
      <p xml:id="p1699" begin="01:41:55.520" end="01:41:56.920" region="bottomCenter">西海龙王</p>
      <p xml:id="p1700" begin="01:42:08.000" end="01:42:09.040" region="bottomCenter">侄儿</p>
      <p xml:id="p1701" begin="01:42:09.400" end="01:42:11.160" region="bottomCenter">二叔陪你玩儿玩儿</p>
      <p xml:id="p1702" begin="01:42:22.160" end="01:42:23.080" region="bottomCenter">看枪</p>
      <p xml:id="p1703" begin="01:42:30.200" end="01:42:32.240" region="bottomCenter">吃本王一斧</p>
      <p xml:id="p1704" begin="01:42:33.680" end="01:42:34.840" region="bottomCenter">吃小爷一轮儿</p>
      <p xml:id="p1705" begin="01:43:08.600" end="01:43:09.760" region="bottomCenter">吃小爷一百轮儿</p>
      <p xml:id="p1706" begin="01:43:09.880" end="01:43:11.360" region="bottomCenter">两百轮儿，三百轮儿</p>
      <p xml:id="p1707" begin="01:43:17.880" end="01:43:19.200" region="bottomCenter">饱了没？</p>
      <p xml:id="p1708" begin="01:43:19.480" end="01:43:21.160" region="bottomCenter">你乱数！哪有那么多</p>
      <p xml:id="p1709" begin="01:43:21.920" end="01:43:23.680" region="bottomCenter">你肉身不稳，别用力过度</p>
      <p xml:id="p1710" begin="01:43:23.800" end="01:43:25.240" region="bottomCenter">我犯的错</p>
      <p xml:id="p1711" begin="01:43:25.360" end="01:43:28.560" region="bottomCenter">哪怕死我也要帮你把龙族救出来</p>
      <p xml:id="p1712" begin="01:43:29.520" end="01:43:31.680" region="bottomCenter">后生可畏啊</p>
      <p xml:id="p1713" begin="01:43:32.920" end="01:43:35.080" region="bottomCenter">姑姑也来凑凑热闹</p>
      <p xml:id="p1714" begin="01:44:06.560" end="01:44:08.280" region="bottomCenter">大欺小，癞蛤蟆</p>
      <p xml:id="p1715" begin="01:44:18.960" end="01:44:21.000" region="bottomCenter">嗨呀，师叔都敢打</p>
      <p xml:id="p1716" begin="01:44:21.160" end="01:44:22.880" region="bottomCenter">小欺大，没文化</p>
      <p xml:id="p1717" begin="01:45:01.800" end="01:45:03.600" region="bottomCenter">不行啊，太乱了</p>
      <p xml:id="p1718" begin="01:45:03.920" end="01:45:05.080" region="bottomCenter">那就再乱些</p>
      <p xml:id="p1719" begin="01:45:05.200" end="01:45:06.320" region="bottomCenter">来些水汽咋样？</p>
      <p xml:id="p1720" begin="01:45:07.200" end="01:45:08.040" region="bottomCenter">好</p>
      <p xml:id="p1721" begin="01:45:11.480" end="01:45:12.320" region="bottomCenter">拿下</p>
      <p xml:id="p1722" begin="01:45:20.000" end="01:45:21.640" region="bottomCenter">小心俩小子偷袭</p>
      <p xml:id="p1723" begin="01:45:28.480" end="01:45:30.160" region="bottomCenter">原来在这儿</p>
      <p xml:id="p1724" begin="01:45:32.640" end="01:45:33.920" region="bottomCenter">看着点儿，是我</p>
      <p xml:id="p1725" begin="01:45:34.040" end="01:45:34.880" region="bottomCenter">二哥啊</p>
      <p xml:id="p1726" begin="01:45:35.000" end="01:45:35.920" region="bottomCenter">对不住，对不住</p>
      <p xml:id="p1727" begin="01:45:36.600" end="01:45:37.440" region="bottomCenter">哪吒</p>
      <p xml:id="p1728" begin="01:45:43.320" end="01:45:44.600" region="bottomCenter">惊不惊喜</p>
      <p xml:id="p1729" begin="01:45:45.400" end="01:45:46.640" region="bottomCenter">变身术</p>
      <p xml:id="p1730" begin="01:45:53.440" end="01:45:54.320" region="bottomCenter">你疯了？</p>
      <p xml:id="p1731" begin="01:45:54.440" end="01:45:55.520" region="bottomCenter">你骗不了我</p>
      <p xml:id="p1732" begin="01:45:59.440" end="01:46:00.360" region="bottomCenter">你们到底</p>
      <p xml:id="p1733" begin="01:46:00.480" end="01:46:02.280" region="bottomCenter">暗号，红凤凰黄凤凰</p>
      <p xml:id="p1734" begin="01:46:02.640" end="01:46:03.480" region="bottomCenter">啥？</p>
      <p xml:id="p1735" begin="01:46:03.680" end="01:46:05.120" region="bottomCenter">说不出暗号﹐假的</p>
      <p xml:id="p1736" begin="01:46:07.360" end="01:46:08.920" region="bottomCenter">原来你真是冒牌货</p>
      <p xml:id="p1737" begin="01:46:14.080" end="01:46:15.400" region="bottomCenter">岂有此理</p>
      <p xml:id="p1738" begin="01:46:21.680" end="01:46:23.040" region="bottomCenter">呸，活该</p>
      <p xml:id="p1739" begin="01:46:24.920" end="01:46:25.760" region="bottomCenter">暗号</p>
      <p xml:id="p1740" begin="01:46:26.000" end="01:46:31.600" region="bottomCenter">啊那个那个…粉凤房，房凤房…行</p>
      <p xml:id="p1741" begin="01:46:31.720" end="01:46:32.600" region="bottomCenter">错</p>
      <p xml:id="p1742" begin="01:46:33.560" end="01:46:35.280" region="bottomCenter">是红凤凰黄凤凰</p>
      <p xml:id="p1743" begin="01:46:35.400" end="01:46:36.720" region="bottomCenter">粉红房上飞凤凰</p>
      <p xml:id="p1744" begin="01:46:37.040" end="01:46:38.760" region="bottomCenter">我是真的呀</p>
      <p xml:id="p1745" begin="01:46:38.880" end="01:46:40.960" region="bottomCenter">为什么这暗号我不会啊？</p>
      <p xml:id="p1746" begin="01:46:41.080" end="01:46:42.560" region="bottomCenter">我们刚编的呀</p>
      <p xml:id="p1747" begin="01:46:44.480" end="01:46:46.240" region="bottomCenter">就不能编简单些吗？</p>
      <p xml:id="p1748" begin="01:46:46.360" end="01:46:48.640" region="bottomCenter">太难了</p>
      <p xml:id="p1749" begin="01:46:49.840" end="01:46:51.520" region="bottomCenter">你白痴啊</p>
      <p xml:id="p1750" begin="01:46:51.640" end="01:46:53.200" region="bottomCenter">别过来，冒牌货</p>
      <p xml:id="p1751" begin="01:46:53.320" end="01:46:54.440" region="bottomCenter">我是真敖顺</p>
      <p xml:id="p1752" begin="01:46:54.560" end="01:46:55.920" region="bottomCenter">我呸！你不会暗号</p>
      <p xml:id="p1753" begin="01:46:56.040" end="01:46:57.560" region="bottomCenter">你还不会呢</p>
      <p xml:id="p1754" begin="01:46:58.240" end="01:46:59.080" region="bottomCenter">对啊</p>
      <p xml:id="p1755" begin="01:46:59.600" end="01:47:00.800" region="bottomCenter">难道我也是假的？</p>
      <p xml:id="p1756" begin="01:47:02.240" end="01:47:03.560" region="bottomCenter">我的天呐</p>
      <p xml:id="p1757" begin="01:47:03.920" end="01:47:04.920" region="bottomCenter">太极天然</p>
      <p xml:id="p1758" begin="01:47:05.040" end="01:47:06.000" region="bottomCenter">五行顺行</p>
      <p xml:id="p1759" begin="01:47:06.120" end="01:47:07.480" region="bottomCenter">三昧真火</p>
      <p xml:id="p1760" begin="01:47:07.600" end="01:47:08.840" region="bottomCenter">炼就金丹</p>
      <p xml:id="p1761" begin="01:47:08.960" end="01:47:11.280" region="bottomCenter">急急如律令</p>
      <p xml:id="p1762" begin="01:47:39.280" end="01:47:40.720" region="bottomCenter">怕个毛啊？</p>
      <p xml:id="p1763" begin="01:47:40.840" end="01:47:43.960" region="bottomCenter">岩浆泡澡咱是家常便饭</p>
      <p xml:id="p1764" begin="01:47:44.880" end="01:47:46.720" region="bottomCenter">烫烫烫烫烫</p>
      <p xml:id="p1765" begin="01:47:48.760" end="01:47:49.680" region="bottomCenter">妈呀</p>
      <p xml:id="p1766" begin="01:47:49.800" end="01:47:51.440" region="bottomCenter">是三昧真火</p>
      <p xml:id="p1767" begin="01:47:53.720" end="01:47:54.800" region="bottomCenter">看什么看？</p>
      <p xml:id="p1768" begin="01:47:55.040" end="01:47:57.400" region="bottomCenter">要吃也只有我自己吃</p>
      <p xml:id="p1769" begin="01:48:01.200" end="01:48:02.120" region="bottomCenter">香</p>
      <p xml:id="p1770" begin="01:48:06.760" end="01:48:07.880" region="bottomCenter">放了我父王</p>
      <p xml:id="p1771" begin="01:48:09.640" end="01:48:10.480" region="bottomCenter">定</p>
      <p xml:id="p1772" begin="01:48:21.960" end="01:48:23.760" region="bottomCenter">好个灵珠</p>
      <p xml:id="p1773" begin="01:48:23.880" end="01:48:26.880" region="bottomCenter">也和魔丸般惊才绝艳</p>
      <p xml:id="p1774" begin="01:48:28.080" end="01:48:29.080" region="bottomCenter">敖丙</p>
      <p xml:id="p1775" begin="01:48:32.480" end="01:48:33.400" region="bottomCenter">定</p>
      <p xml:id="p1776" begin="01:48:45.760" end="01:48:46.800" region="bottomCenter">穿心咒</p>
      <p xml:id="p1777" begin="01:48:47.200" end="01:48:50.760" region="bottomCenter">既然早已知晓你们真实身份</p>
      <p xml:id="p1778" begin="01:48:51.000" end="01:48:53.760" region="bottomCenter">老夫岂能不留后手</p>
      <p xml:id="p1779" begin="01:48:56.520" end="01:48:57.360" region="bottomCenter">不可能，不可能</p>
      <p xml:id="p1780" begin="01:48:57.480" end="01:48:58.480" region="bottomCenter">这个咒语很复杂的</p>
      <p xml:id="p1781" begin="01:48:58.680" end="01:49:00.160" region="bottomCenter">你啥时候下的咒呢？</p>
      <p xml:id="p1782" begin="01:49:01.800" end="01:49:05.720" region="bottomCenter">哦…我说你念个升仙咒怎么那么长</p>
      <p xml:id="p1783" begin="01:49:05.840" end="01:49:06.840" region="bottomCenter">你夹带私货啊</p>
      <p xml:id="p1784" begin="01:49:37.960" end="01:49:39.400" region="bottomCenter">老匹夫</p>
      <p xml:id="p1785" begin="01:49:44.000" end="01:49:45.960" region="bottomCenter">即便魔丸</p>
      <p xml:id="p1786" begin="01:49:46.080" end="01:49:50.680" region="bottomCenter">三个时辰内也休想冲破这穿心咒</p>
      <p xml:id="p1787" begin="01:49:51.000" end="01:49:55.280" region="bottomCenter">千针万刺已穿透全身经脉</p>
      <p xml:id="p1788" begin="01:49:55.640" end="01:49:57.240" region="bottomCenter">若强行活动</p>
      <p xml:id="p1789" begin="01:49:57.360" end="01:49:59.120" region="bottomCenter">只会千刀万剐</p>
      <p xml:id="p1790" begin="01:49:59.240" end="01:50:00.800" region="bottomCenter">四分五裂</p>
      <p xml:id="p1791" begin="01:50:02.040" end="01:50:06.520" region="bottomCenter">难怪彼时老夫察觉不到活人气息</p>
      <p xml:id="p1792" begin="01:50:06.640" end="01:50:09.000" region="bottomCenter">原来石化了</p>
      <p xml:id="p1793" begin="01:50:09.440" end="01:50:10.760" region="bottomCenter">但你们没死</p>
      <p xml:id="p1794" begin="01:50:10.880" end="01:50:12.720" region="bottomCenter">可就害了哪吒</p>
      <p xml:id="p1795" begin="01:50:14.680" end="01:50:15.840" region="bottomCenter">灵珠</p>
      <p xml:id="p1796" begin="01:50:17.880" end="01:50:19.040" region="bottomCenter">魔丸</p>
      <p xml:id="p1797" begin="01:50:20.000" end="01:50:21.840" region="bottomCenter">都是宝啊</p>
      <p xml:id="p1798" begin="01:50:22.640" end="01:50:26.200" region="bottomCenter">老夫本想好好栽培栽培</p>
      <p xml:id="p1799" begin="01:50:29.280" end="01:50:31.760" region="bottomCenter">现在只能拿来炼丹了</p>
      <p xml:id="p1800" begin="01:50:47.120" end="01:50:47.960" region="bottomCenter">敖丙</p>
      <p xml:id="p1801" begin="01:50:48.240" end="01:50:49.080" region="bottomCenter">父王</p>
      <p xml:id="p1802" begin="01:50:49.200" end="01:50:50.880" region="bottomCenter">你…你还活着</p>
      <p xml:id="p1803" begin="01:50:52.560" end="01:50:54.160" region="bottomCenter">无量仙翁下的穿心咒</p>
      <p xml:id="p1804" begin="01:50:54.400" end="01:50:55.640" region="bottomCenter">屠戮陈塘关栽赃龙族的</p>
      <p xml:id="p1805" begin="01:50:55.760" end="01:50:56.600" region="bottomCenter">也是他</p>
      <p xml:id="p1806" begin="01:51:00.200" end="01:51:01.040" region="bottomCenter">父王</p>
      <p xml:id="p1807" begin="01:51:01.160" end="01:51:02.920" region="bottomCenter">哪吒也是受了蒙骗，不怪他</p>
      <p xml:id="p1808" begin="01:51:03.040" end="01:51:04.520" region="bottomCenter">你想怎样都冲我来</p>
      <p xml:id="p1809" begin="01:51:04.640" end="01:51:06.080" region="bottomCenter">和我爹娘无关</p>
      <p xml:id="p1810" begin="01:51:12.000" end="01:51:14.520" region="bottomCenter">杀了你们也于事无补</p>
      <p xml:id="p1811" begin="01:51:28.520" end="01:51:31.080" region="bottomCenter">大家都已难逃一死</p>
      <p xml:id="p1812" begin="01:51:31.200" end="01:51:34.080" region="bottomCenter">若还有放不下的恩怨</p>
      <p xml:id="p1813" begin="01:51:34.720" end="01:51:35.880" region="bottomCenter">自便吧</p>
      <p xml:id="p1814" begin="01:51:44.880" end="01:51:46.320" region="bottomCenter">大师兄啊</p>
      <p xml:id="p1815" begin="01:51:46.440" end="01:51:48.560" region="bottomCenter">阐教乃名门正派</p>
      <p xml:id="p1816" begin="01:51:48.680" end="01:51:52.600" region="bottomCenter">你怎能做出这等伤天害理之事啊？</p>
      <p xml:id="p1817" begin="01:51:52.720" end="01:51:53.880" region="bottomCenter">你莫要一错再错啊</p>
      <p xml:id="p1818" begin="01:51:54.000" end="01:51:55.560" region="bottomCenter">回去跟师父认个错不好吗？</p>
      <p xml:id="p1819" begin="01:51:55.840" end="01:51:57.640" region="bottomCenter">我替你求情噻</p>
      <p xml:id="p1820" begin="01:51:57.760" end="01:51:58.640" region="bottomCenter">你</p>
      <p xml:id="p1821" begin="01:51:59.080" end="01:52:01.400" region="bottomCenter">敌我不分的蠢货</p>
      <p xml:id="p1822" begin="01:52:01.520" end="01:52:04.840" region="bottomCenter">要是仙家地位稳如磐石</p>
      <p xml:id="p1823" begin="01:52:04.960" end="01:52:07.560" region="bottomCenter">要是你们这帮养尊处优的小辈</p>
      <p xml:id="p1824" begin="01:52:07.680" end="01:52:09.840" region="bottomCenter">有妖族一半努力</p>
      <p xml:id="p1825" begin="01:52:09.960" end="01:52:12.280" region="bottomCenter">还用得着我费这劲</p>
      <p xml:id="p1826" begin="01:52:12.680" end="01:52:14.640" region="bottomCenter">哪怕我粉身碎骨</p>
      <p xml:id="p1827" begin="01:52:14.760" end="01:52:16.200" region="bottomCenter">背负骂名</p>
      <p xml:id="p1828" begin="01:52:16.320" end="01:52:19.760" region="bottomCenter">一切都是为了阐教霸业永恒</p>
      <p xml:id="p1829" begin="01:52:19.880" end="01:52:21.040" region="bottomCenter">我问心</p>
      <p xml:id="p1830" begin="01:52:21.840" end="01:52:23.120" region="bottomCenter">问心</p>
      <p xml:id="p1831" begin="01:52:23.240" end="01:52:24.080" region="bottomCenter">问心</p>
      <p xml:id="p1832" begin="01:52:27.480" end="01:52:29.480" region="bottomCenter">我问心无愧</p>
      <p xml:id="p1833" begin="01:52:32.640" end="01:52:34.200" region="bottomCenter">又烤好了一条</p>
      <p xml:id="p1834" begin="01:52:34.360" end="01:52:35.840" region="bottomCenter">我是吃不下了</p>
      <p xml:id="p1835" begin="01:52:35.960" end="01:52:37.120" region="bottomCenter">你要不来点儿</p>
      <p xml:id="p1836" begin="01:52:37.240" end="01:52:38.080" region="bottomCenter">谢谢啊</p>
      <p xml:id="p1837" begin="01:52:38.200" end="01:52:40.680" region="bottomCenter">等我的鱼翅烤熟了你也尝尝</p>
      <p xml:id="p1838" begin="01:52:40.880" end="01:52:42.120" region="bottomCenter">蟹钳也好了</p>
      <p xml:id="p1839" begin="01:52:42.240" end="01:52:43.560" region="bottomCenter">大家换着吃吧</p>
      <p xml:id="p1840" begin="01:52:44.600" end="01:52:45.440" region="bottomCenter">怎么回事？</p>
      <p xml:id="p1841" begin="01:52:46.360" end="01:52:48.280" region="bottomCenter">身体…我的</p>
      <p xml:id="p1842" begin="01:52:50.880" end="01:52:52.280" region="bottomCenter">炼成丹了</p>
      <p xml:id="p1843" begin="01:52:52.400" end="01:52:53.640" region="bottomCenter">我还年轻</p>
      <p xml:id="p1844" begin="01:52:53.760" end="01:52:55.000" region="bottomCenter">不想死啊</p>
      <p xml:id="p1845" begin="01:52:55.120" end="01:52:56.440" region="bottomCenter">妈呀，放我出去</p>
      <p xml:id="p1846" begin="01:52:56.560" end="01:52:58.080" region="bottomCenter">救命啊，救命啊</p>
      <p xml:id="p1847" begin="01:52:58.440" end="01:52:59.760" region="bottomCenter">冷静</p>
      <p xml:id="p1848" begin="01:52:59.880" end="01:53:01.720" region="bottomCenter">调动全部功力护体</p>
      <p xml:id="p1849" begin="01:53:02.040" end="01:53:04.520" region="bottomCenter">能挨一刻是一刻</p>
      <p xml:id="p1850" begin="01:53:11.840" end="01:53:12.880" region="bottomCenter">儿啊</p>
      <p xml:id="p1851" begin="01:53:13.000" end="01:53:14.480" region="bottomCenter">你功力强过我</p>
      <p xml:id="p1852" begin="01:53:14.600" end="01:53:16.040" region="bottomCenter">定能撑得更久</p>
      <p xml:id="p1853" begin="01:53:16.160" end="01:53:18.240" region="bottomCenter">若能撑到穿心咒失效</p>
      <p xml:id="p1854" begin="01:53:18.360" end="01:53:19.880" region="bottomCenter">就有逃生机会</p>
      <p xml:id="p1855" begin="01:53:20.080" end="01:53:22.760" region="bottomCenter">这穿心咒至少三个时辰才冲得破</p>
      <p xml:id="p1856" begin="01:53:22.880" end="01:53:24.360" region="bottomCenter">孩儿怕</p>
      <p xml:id="p1857" begin="01:53:24.480" end="01:53:25.640" region="bottomCenter">撑不了那么久</p>
      <p xml:id="p1858" begin="01:53:31.680" end="01:53:32.680" region="bottomCenter">夫人　　娘</p>
      <p xml:id="p1859" begin="01:53:32.800" end="01:53:33.800" region="bottomCenter">醒醒啊，娘</p>
      <p xml:id="p1860" begin="01:53:33.920" end="01:53:36.640" region="bottomCenter">吒儿，吒儿呢？</p>
      <p xml:id="p1861" begin="01:53:37.840" end="01:53:38.680" region="bottomCenter">吒儿</p>
      <p xml:id="p1862" begin="01:53:38.920" end="01:53:40.200" region="bottomCenter">娘，我在这儿</p>
      <p xml:id="p1863" begin="01:53:40.320" end="01:53:41.960" region="bottomCenter">你和爹都坚持住啊</p>
      <p xml:id="p1864" begin="01:53:42.080" end="01:53:43.200" region="bottomCenter">不用管我们</p>
      <p xml:id="p1865" begin="01:53:43.480" end="01:53:46.320" region="bottomCenter">你自己守住心神</p>
      <p xml:id="p1866" begin="01:53:46.440" end="01:53:47.680" region="bottomCenter">我还好，娘</p>
      <p xml:id="p1867" begin="01:53:47.800" end="01:53:49.040" region="bottomCenter">我对这火没感觉</p>
      <p xml:id="p1868" begin="01:53:49.320" end="01:53:51.400" region="bottomCenter">你小子命大呀</p>
      <p xml:id="p1869" begin="01:53:51.640" end="01:53:54.120" region="bottomCenter">若本王没猜错的话</p>
      <p xml:id="p1870" begin="01:53:54.240" end="01:53:56.680" region="bottomCenter">魔丸的魔焰和这三昧真火</p>
      <p xml:id="p1871" begin="01:53:56.800" end="01:53:58.120" region="bottomCenter">同宗同源</p>
      <p xml:id="p1872" begin="01:53:58.520" end="01:54:01.280" region="bottomCenter">那这天元鼎就奈何不了你</p>
      <p xml:id="p1873" begin="01:54:01.720" end="01:54:02.800" region="bottomCenter">不错</p>
      <p xml:id="p1874" begin="01:54:02.920" end="01:54:04.480" region="bottomCenter">是老夫疏忽了</p>
      <p xml:id="p1875" begin="01:54:07.760" end="01:54:09.120" region="bottomCenter">没用</p>
      <p xml:id="p1876" begin="01:54:09.320" end="01:54:12.000" region="bottomCenter">这是我的化身而已</p>
      <p xml:id="p1877" begin="01:54:13.360" end="01:54:15.320" region="bottomCenter">不愧是魔丸</p>
      <p xml:id="p1878" begin="01:54:15.440" end="01:54:16.720" region="bottomCenter">坚不可摧</p>
      <p xml:id="p1879" begin="01:54:16.840" end="01:54:21.880" region="bottomCenter">难怪天尊要大费周章引天劫灭你</p>
      <p xml:id="p1880" begin="01:54:26.040" end="01:54:27.560" region="bottomCenter">哪吒呀</p>
      <p xml:id="p1881" begin="01:54:28.120" end="01:54:31.240" region="bottomCenter">老夫看你是个孝子</p>
      <p xml:id="p1882" begin="01:54:31.360" end="01:54:33.920" region="bottomCenter">不如给你个尽孝的机会</p>
      <p xml:id="p1883" begin="01:54:34.240" end="01:54:35.400" region="bottomCenter">灭魂丹</p>
      <p xml:id="p1884" begin="01:54:36.160" end="01:54:38.000" region="bottomCenter">你若吞了它</p>
      <p xml:id="p1885" begin="01:54:38.120" end="01:54:40.360" region="bottomCenter">老夫便放了你父母</p>
      <p xml:id="p1886" begin="01:54:40.480" end="01:54:41.320" region="bottomCenter">如何？</p>
      <p xml:id="p1887" begin="01:54:41.480" end="01:54:43.960" region="bottomCenter">老夫虽行事冷酷</p>
      <p xml:id="p1888" begin="01:54:44.080" end="01:54:46.400" region="bottomCenter">但向来信守承诺</p>
      <p xml:id="p1889" begin="01:54:46.520" end="01:54:50.400" region="bottomCenter">不然也不会有那么多妖族能人异士</p>
      <p xml:id="p1890" begin="01:54:50.520" end="01:54:52.120" region="bottomCenter">效忠老夫</p>
      <p xml:id="p1891" begin="01:54:52.400" end="01:54:54.600" region="bottomCenter">只要你吞了它</p>
      <p xml:id="p1892" begin="01:54:54.720" end="01:54:57.120" region="bottomCenter">老夫对天发誓</p>
      <p xml:id="p1893" begin="01:54:57.280" end="01:54:59.120" region="bottomCenter">绝不为难你父母</p>
      <p xml:id="p1894" begin="01:55:13.800" end="01:55:15.040" region="bottomCenter">你要干什么？</p>
      <p xml:id="p1895" begin="01:55:15.600" end="01:55:18.080" region="bottomCenter">用父母性命来要挟孩子自杀</p>
      <p xml:id="p1896" begin="01:55:18.560" end="01:55:19.840" region="bottomCenter">你算神仙吗？</p>
      <p xml:id="p1897" begin="01:55:20.360" end="01:55:22.040" region="bottomCenter">你连做人都不配</p>
      <p xml:id="p1898" begin="01:55:24.400" end="01:55:25.240" region="bottomCenter">吒儿</p>
      <p xml:id="p1899" begin="01:55:25.440" end="01:55:26.680" region="bottomCenter">不要管我们</p>
      <p xml:id="p1900" begin="01:55:26.800" end="01:55:28.840" region="bottomCenter">你一定要活下去</p>
      <p xml:id="p1901" begin="01:55:28.960" end="01:55:30.680" region="bottomCenter">撑到穿心咒解开</p>
      <p xml:id="p1902" begin="01:55:30.800" end="01:55:32.840" region="bottomCenter">撑到两个哥哥找到你</p>
      <p xml:id="p1903" begin="01:55:33.120" end="01:55:36.160" region="bottomCenter">真以为老夫奈何不了魔丸？</p>
      <p xml:id="p1904" begin="01:55:36.280" end="01:55:38.720" region="bottomCenter">只是多费些功夫罢了</p>
      <p xml:id="p1905" begin="01:55:38.840" end="01:55:40.160" region="bottomCenter">等你们死了</p>
      <p xml:id="p1906" begin="01:55:40.280" end="01:55:43.640" region="bottomCenter">我有一百种方法整死他</p>
      <p xml:id="p1907" begin="01:55:48.360" end="01:55:52.680" region="bottomCenter">我只想最后死得有点价值</p>
      <p xml:id="p1908" begin="01:55:52.800" end="01:55:56.080" region="bottomCenter">你们为什么不让我死？</p>
      <p xml:id="p1909" begin="01:55:56.280" end="01:55:59.480" region="bottomCenter">为什么不让我死？</p>
      <p xml:id="p1910" begin="01:55:59.680" end="01:56:02.760" region="bottomCenter">如果用你的命换爹娘的命</p>
      <p xml:id="p1911" begin="01:56:02.880" end="01:56:06.720" region="bottomCenter">你以为爹娘会心安理得地活下去吗？</p>
      <p xml:id="p1912" begin="01:56:08.600" end="01:56:09.680" region="bottomCenter">吒儿</p>
      <p xml:id="p1913" begin="01:56:09.800" end="01:56:12.080" region="bottomCenter">不要啊娘</p>
      <p xml:id="p1914" begin="01:56:12.560" end="01:56:13.920" region="bottomCenter">会扎着你</p>
      <p xml:id="p1915" begin="01:56:14.040" end="01:56:15.000" region="bottomCenter">不要紧</p>
      <p xml:id="p1916" begin="01:56:15.440" end="01:56:16.760" region="bottomCenter">最后了</p>
      <p xml:id="p1917" begin="01:56:18.360" end="01:56:20.880" region="bottomCenter">娘只想再抱抱你</p>
      <p xml:id="p1918" begin="01:56:21.680" end="01:56:23.720" region="bottomCenter">娘</p>
      <p xml:id="p1919" begin="01:56:24.480" end="01:56:27.280" region="bottomCenter">娘不能陪伴你长大了</p>
      <p xml:id="p1920" begin="01:56:28.280" end="01:56:29.840" region="bottomCenter">今后的路</p>
      <p xml:id="p1921" begin="01:56:30.840" end="01:56:33.440" region="bottomCenter">你要自己走</p>
      <p xml:id="p1922" begin="01:57:41.720" end="01:57:44.440" region="bottomCenter">我…我没用</p>
      <p xml:id="p1923" begin="01:57:45.160" end="01:57:47.040" region="bottomCenter">我好没用</p>
      <p xml:id="p1924" begin="01:57:47.840" end="01:57:50.160" region="bottomCenter">我生来就是魔</p>
      <p xml:id="p1925" begin="01:57:50.560" end="01:57:53.160" region="bottomCenter">一直都让你们受苦</p>
      <p xml:id="p1926" begin="01:57:54.360" end="01:57:56.080" region="bottomCenter">我也好想</p>
      <p xml:id="p1927" begin="01:57:56.200" end="01:57:58.600" region="bottomCenter">好想成为你们的骄傲</p>
      <p xml:id="p1928" begin="01:58:04.320" end="01:58:07.000" region="bottomCenter">是我连累了你们</p>
      <p xml:id="p1929" begin="01:58:07.680" end="01:58:10.960" region="bottomCenter">对不起，娘</p>
      <p xml:id="p1930" begin="01:58:11.720" end="01:58:14.080" region="bottomCenter">对不起</p>
      <p xml:id="p1931" begin="01:58:15.280" end="01:58:18.480" region="bottomCenter">和你度过的每一天</p>
      <p xml:id="p1932" begin="01:58:18.840" end="01:58:21.480" region="bottomCenter">娘都很开心</p>
      <p xml:id="p1933" begin="01:58:22.080" end="01:58:25.000" region="bottomCenter">娘从没在乎过</p>
      <p xml:id="p1934" begin="01:58:25.760" end="01:58:29.040" region="bottomCenter">你是仙是魔</p>
      <p xml:id="p1935" begin="01:58:30.240" end="01:58:32.080" region="bottomCenter">娘只知道</p>
      <p xml:id="p1936" begin="01:58:32.720" end="01:58:35.560" region="bottomCenter">你是娘的儿</p>
      <p xml:id="p1937" begin="01:58:37.600" end="01:58:38.720" region="bottomCenter">娘</p>
      <p xml:id="p1938" begin="01:58:39.240" end="01:58:40.560" region="bottomCenter">永远</p>
      <p xml:id="p1939" begin="01:58:41.840" end="01:58:42.920" region="bottomCenter">爱</p>
      <p xml:id="p1940" begin="01:59:23.400" end="01:59:24.680" region="bottomCenter">吒儿，不要冲动</p>
      <p xml:id="p1941" begin="01:59:24.800" end="01:59:25.680" region="bottomCenter">停下</p>
      <p xml:id="p1942" begin="01:59:25.800" end="01:59:27.160" region="bottomCenter">你骨肉会被撕裂的</p>
      <p xml:id="p1943" begin="02:00:10.520" end="02:00:13.680" region="bottomCenter">三昧真火竟然补全了重塑肉身时</p>
      <p xml:id="p1944" begin="02:00:13.800" end="02:00:15.080" region="bottomCenter">不足的火候</p>
      <p xml:id="p1945" begin="02:00:16.280" end="02:00:17.800" region="bottomCenter">哪吒的肉身</p>
      <p xml:id="p1946" begin="02:00:19.120" end="02:00:21.040" region="bottomCenter">完成了</p>
      <p xml:id="p1947" begin="02:00:36.320" end="02:00:37.360" region="bottomCenter">爹</p>
      <p xml:id="p1948" begin="02:00:38.280" end="02:00:39.360" region="bottomCenter">照顾好娘</p>
      <p xml:id="p1949" begin="02:00:52.280" end="02:00:53.840" region="bottomCenter">助我破鼎</p>
      <p xml:id="p1950" begin="02:01:27.000" end="02:01:27.880" region="bottomCenter">不好</p>
      <p xml:id="p1951" begin="02:01:28.000" end="02:01:30.000" region="bottomCenter">他们在吸收天元鼎的能量</p>
      <p xml:id="p1952" begin="02:01:31.640" end="02:01:34.760" region="bottomCenter">根深蒂固</p>
      <p xml:id="p1953" begin="02:01:58.760" end="02:02:00.920" region="bottomCenter">全体捕妖队听令</p>
      <p xml:id="p1954" begin="02:02:01.080" end="02:02:02.080" region="bottomCenter">上</p>
      <p xml:id="p1955" begin="02:02:57.040" end="02:02:57.880" region="bottomCenter">父王</p>
      <p xml:id="p1956" begin="02:02:58.000" end="02:02:59.560" region="bottomCenter">你们得留着功力护体啊</p>
      <p xml:id="p1957" begin="02:02:59.680" end="02:03:02.720" region="bottomCenter">我们一直在退、一直在退</p>
      <p xml:id="p1958" begin="02:03:02.840" end="02:03:04.320" region="bottomCenter">原以为什么都给了</p>
      <p xml:id="p1959" begin="02:03:04.440" end="02:03:06.640" region="bottomCenter">仙翁会让我们活下去</p>
      <p xml:id="p1960" begin="02:03:06.760" end="02:03:09.320" region="bottomCenter">结果他们还要我们的命</p>
      <p xml:id="p1961" begin="02:03:09.440" end="02:03:11.360" region="bottomCenter">既然他们要我们的命</p>
      <p xml:id="p1962" begin="02:03:12.000" end="02:03:15.560" region="bottomCenter">那我们就用这条命跟他们拼了</p>
      <p xml:id="p1963" begin="02:03:15.680" end="02:03:17.600" region="bottomCenter">对，跟他们拼了</p>
      <p xml:id="p1964" begin="02:03:17.720" end="02:03:21.720" region="bottomCenter">拼了，拼了，拼了</p>
      <p xml:id="p1965" begin="02:03:31.280" end="02:03:33.720" region="bottomCenter">绝不能放他们出来</p>
      <p xml:id="p1966" begin="02:04:20.120" end="02:04:21.800" region="bottomCenter">不要放弃</p>
      <p xml:id="p1967" begin="02:04:21.920" end="02:04:24.400" region="bottomCenter">坚持住</p>
      <p xml:id="p1968" begin="02:04:47.880" end="02:04:49.320" region="bottomCenter">给我</p>
      <p xml:id="p1969" begin="02:04:50.120" end="02:04:52.760" region="bottomCenter">破</p>
      <p xml:id="p1970" begin="02:05:43.240" end="02:05:44.360" region="bottomCenter">鼎</p>
      <p xml:id="p1971" begin="02:05:44.480" end="02:05:45.760" region="bottomCenter">我的鼎</p>
      <p xml:id="p1972" begin="02:05:45.960" end="02:05:48.680" region="bottomCenter">阐教的根基啊</p>
      <p xml:id="p1973" begin="02:06:44.200" end="02:06:47.760" region="bottomCenter">给我杀光这帮畜生</p>
      <p xml:id="p1974" begin="02:06:53.240" end="02:06:54.320" region="bottomCenter">杀</p>
      <p xml:id="p1975" begin="02:07:29.120" end="02:07:32.240" region="bottomCenter">你们这帮为虎作伥的小辈</p>
      <p xml:id="p1976" begin="02:07:32.360" end="02:07:33.480" region="bottomCenter">黑白不分</p>
      <p xml:id="p1977" begin="02:07:46.800" end="02:07:48.560" region="bottomCenter">海啸龙吟</p>
      <p xml:id="p1978" begin="02:07:58.600" end="02:08:01.720" region="bottomCenter">原来仙翁手下竟也是俩禽兽</p>
      <p xml:id="p1979" begin="02:08:01.840" end="02:08:03.480" region="bottomCenter">什么妖什么仙</p>
      <p xml:id="p1980" begin="02:08:03.600" end="02:08:06.040" region="bottomCenter">都是你们糊弄人的把戏</p>
      <p xml:id="p1981" begin="02:08:07.000" end="02:08:08.760" region="bottomCenter">下贱的妖孽</p>
      <p xml:id="p1982" begin="02:08:08.880" end="02:08:11.240" region="bottomCenter">也敢和本仙作对</p>
      <p xml:id="p1983" begin="02:08:34.480" end="02:08:37.920" region="bottomCenter">见识下老夫的手段</p>
      <p xml:id="p1984" begin="02:10:32.120" end="02:10:33.840" region="bottomCenter">老夫惜才</p>
      <p xml:id="p1985" begin="02:10:33.960" end="02:10:35.880" region="bottomCenter">再给你二人一次机会</p>
      <p xml:id="p1986" begin="02:10:36.000" end="02:10:37.280" region="bottomCenter">若肯归降</p>
      <p xml:id="p1987" begin="02:10:37.400" end="02:10:39.280" region="bottomCenter">保你们得道成仙</p>
      <p xml:id="p1988" begin="02:10:39.680" end="02:10:40.920" region="bottomCenter">去你个鸟仙</p>
      <p xml:id="p1989" begin="02:10:41.840" end="02:10:43.280" region="bottomCenter">小爷是魔</p>
      <p xml:id="p1990" begin="02:10:43.960" end="02:10:45.000" region="bottomCenter">那又如何？</p>
      <p xml:id="p1991" begin="02:10:48.480" end="02:10:50.280" region="bottomCenter">自诩照世明灯</p>
      <p xml:id="p1992" begin="02:10:50.560" end="02:10:52.040" region="bottomCenter">干的却是恃强凌弱</p>
      <p xml:id="p1993" begin="02:10:52.160" end="02:10:53.640" region="bottomCenter">祸乱人间的勾当</p>
      <p xml:id="p1994" begin="02:10:54.720" end="02:10:57.280" region="bottomCenter">你们才是邪魔歪道</p>
      <p xml:id="p1995" begin="02:11:05.120" end="02:11:06.760" region="bottomCenter">无知小儿</p>
      <p xml:id="p1996" begin="02:11:06.880" end="02:11:08.680" region="bottomCenter">仙家雄霸天下</p>
      <p xml:id="p1997" begin="02:11:08.800" end="02:11:11.680" region="bottomCenter">依附强者才是唯一出路</p>
      <p xml:id="p1998" begin="02:11:11.800" end="02:11:13.880" region="bottomCenter">否则天地虽大</p>
      <p xml:id="p1999" begin="02:11:14.000" end="02:11:16.080" region="bottomCenter">也让你们无路可走</p>
      <p xml:id="p2000" begin="02:11:16.200" end="02:11:17.560" region="bottomCenter">若前方无路</p>
      <p xml:id="p2001" begin="02:11:18.160" end="02:11:20.440" region="bottomCenter">我就踏出一条路</p>
      <p xml:id="p2002" begin="02:11:23.840" end="02:11:25.800" region="bottomCenter">若天地不容</p>
      <p xml:id="p2003" begin="02:11:26.200" end="02:11:30.120" region="bottomCenter">我就扭转这乾坤</p>
      <p xml:id="p2004" begin="02:11:40.000" end="02:11:40.920" region="bottomCenter">师父</p>
      <p xml:id="p2005" begin="02:11:42.640" end="02:11:44.720" region="bottomCenter">我的脸，我的脸</p>
      <p xml:id="p2006" begin="02:11:44.960" end="02:11:49.120" region="bottomCenter">你们…你们胆敢破我不老神功</p>
      <p xml:id="p2007" begin="02:11:49.480" end="02:11:51.960" region="bottomCenter">老匹夫</p>
      <p xml:id="p2008" begin="02:12:03.440" end="02:12:06.920" region="bottomCenter">回…回宫</p>
      <p xml:id="p2009" begin="02:12:18.120" end="02:12:19.400" region="bottomCenter">等等我</p>
      <p xml:id="p2010" begin="02:13:02.920" end="02:13:04.560" region="bottomCenter">父王打算带领龙族</p>
      <p xml:id="p2011" begin="02:13:04.680" end="02:13:06.120" region="bottomCenter">前往大海深处隐匿起来</p>
      <p xml:id="p2012" begin="02:13:06.320" end="02:13:07.760" region="bottomCenter">你身份也已暴露</p>
      <p xml:id="p2013" begin="02:13:07.880" end="02:13:09.320" region="bottomCenter">不如随我们一同去吧</p>
      <p xml:id="p2014" begin="02:13:09.720" end="02:13:10.760" region="bottomCenter">不了</p>
      <p xml:id="p2015" begin="02:13:11.720" end="02:13:14.760" region="bottomCenter">以前我一直在躲、在藏</p>
      <p xml:id="p2016" begin="02:13:15.320" end="02:13:16.720" region="bottomCenter">直到无路可走</p>
      <p xml:id="p2017" begin="02:13:17.320" end="02:13:20.080" region="bottomCenter">我才明白该如何面对这个世界</p>
      <p xml:id="p2018" begin="02:13:20.240" end="02:13:22.240" region="bottomCenter">无量仙翁位高权重</p>
      <p xml:id="p2019" begin="02:13:22.360" end="02:13:24.200" region="bottomCenter">又深得天尊信任</p>
      <p xml:id="p2020" begin="02:13:24.480" end="02:13:26.160" region="bottomCenter">未必就会倒台</p>
      <p xml:id="p2021" begin="02:13:26.280" end="02:13:28.480" region="bottomCenter">而且仙魔殊途</p>
      <p xml:id="p2022" begin="02:13:28.600" end="02:13:30.080" region="bottomCenter">水火不容</p>
      <p xml:id="p2023" begin="02:13:30.480" end="02:13:32.400" region="bottomCenter">什么神仙妖魔</p>
      <p xml:id="p2024" begin="02:13:32.520" end="02:13:35.480" region="bottomCenter">不过是他们禁锢异族命运的枷锁</p>
      <p xml:id="p2025" begin="02:13:36.920" end="02:13:38.560" region="bottomCenter">那又怎样？</p>
      <p xml:id="p2026" begin="02:13:38.680" end="02:13:40.960" region="bottomCenter">难道你还想改变这世界？</p>
      <p xml:id="p2027" begin="02:13:45.200" end="02:13:46.320" region="bottomCenter">我想试试</p>
      <p xml:id="p2028" begin="02:13:49.320" end="02:13:51.320" region="bottomCenter">可能是我老了</p>
      <p xml:id="p2029" begin="02:13:51.520" end="02:13:54.280" region="bottomCenter">没力气再去和这个世界碰撞</p>
      <p xml:id="p2030" begin="02:13:54.760" end="02:13:55.760" region="bottomCenter">敖丙</p>
      <p xml:id="p2031" begin="02:14:31.600" end="02:14:33.200" region="bottomCenter">父王知道</p>
      <p xml:id="p2032" begin="02:14:33.320" end="02:14:35.120" region="bottomCenter">一旦决定的事</p>
      <p xml:id="p2033" begin="02:14:35.240" end="02:14:36.520" region="bottomCenter">你始终会去做</p>
      <p xml:id="p2034" begin="02:14:37.800" end="02:14:39.040" region="bottomCenter">儿啊</p>
      <p xml:id="p2035" begin="02:14:39.160" end="02:14:40.600" region="bottomCenter">以前父王</p>
      <p xml:id="p2036" begin="02:14:40.720" end="02:14:42.680" region="bottomCenter">让你肩负了太多的期望</p>
      <p xml:id="p2037" begin="02:14:42.800" end="02:14:45.320" region="bottomCenter">却不曾倾听你的想法</p>
      <p xml:id="p2038" begin="02:14:45.760" end="02:14:47.600" region="bottomCenter">父王对不起你</p>
      <p xml:id="p2039" begin="02:14:48.280" end="02:14:52.200" region="bottomCenter">父王只是想用自己的经验为你谋个幸福</p>
      <p xml:id="p2040" begin="02:14:53.000" end="02:14:54.640" region="bottomCenter">但现在看来</p>
      <p xml:id="p2041" begin="02:14:54.760" end="02:14:56.040" region="bottomCenter">父辈的经验</p>
      <p xml:id="p2042" begin="02:14:56.160" end="02:14:57.480" region="bottomCenter">毕竟是过往</p>
      <p xml:id="p2043" begin="02:14:57.600" end="02:14:59.280" region="bottomCenter">未必全对</p>
      <p xml:id="p2044" begin="02:15:00.920" end="02:15:04.080" region="bottomCenter">你的路还需你去闯</p>
      <p xml:id="p2045" begin="02:15:04.560" end="02:15:05.960" region="bottomCenter">今后</p>
      <p xml:id="p2046" begin="02:15:06.680" end="02:15:09.200" region="bottomCenter">忠于自己内心的选择吧</p>
      <p xml:id="p2047" begin="02:15:40.400" end="02:15:41.880" region="bottomCenter">我知道你会回来的</p>
      <p xml:id="p2048" begin="02:15:42.240" end="02:15:43.360" region="bottomCenter">为什么？</p>
      <p xml:id="p2049" begin="02:15:44.400" end="02:15:45.760" region="bottomCenter">因为我们都太年轻</p>
      <p xml:id="p2050" begin="02:15:49.360" end="02:15:50.640" region="bottomCenter">不知天高地厚</p>
      <p xml:id="p2051" begin="02:17:45.040" end="02:17:47.120" region="bottomCenter">师父，您的脸</p>
      <p xml:id="p2052" begin="02:17:47.280" end="02:17:48.360" region="bottomCenter">不要紧</p>
      <p xml:id="p2053" begin="02:17:48.880" end="02:17:50.960" region="bottomCenter">鹤童给老夫敷过药了</p>
      <p xml:id="p2054" begin="02:17:51.320" end="02:17:52.480" region="bottomCenter">鼎被毁</p>
      <p xml:id="p2055" begin="02:17:52.600" end="02:17:54.480" region="bottomCenter">阐教已无必胜把握</p>
      <p xml:id="p2056" begin="02:17:54.600" end="02:17:57.120" region="bottomCenter">我们可是犯了弥天大罪啊</p>
      <p xml:id="p2057" begin="02:17:57.240" end="02:18:01.200" region="bottomCenter">务必赶在师尊出关前马上行动</p>
      <p xml:id="p2058" begin="02:18:01.320" end="02:18:03.320" region="bottomCenter">走，去见见他</p>
      <p xml:id="p2059" begin="02:18:04.160" end="02:18:06.600" region="bottomCenter">关押的地方够隐秘吗？</p>
      <p xml:id="p2060" begin="02:18:06.720" end="02:18:08.280" region="bottomCenter">不会有其他人到这里来</p>
      <p xml:id="p2061" begin="02:18:08.400" end="02:18:10.200" region="bottomCenter">牢房内还屏蔽了仙术</p>
      <p xml:id="p2062" begin="02:18:10.320" end="02:18:11.280" region="bottomCenter">大门也只有您</p>
      <p xml:id="p2063" begin="02:18:11.400" end="02:18:13.160" region="bottomCenter">和唯一一个守卫才开得了</p>
      <p xml:id="p2064" begin="02:18:21.360" end="02:18:24.080" region="bottomCenter">开小差，打瞌睡</p>
      <p xml:id="p2065" begin="02:18:29.280" end="02:18:30.440" region="bottomCenter">怎么回事？</p>
      <p xml:id="p2066" begin="02:18:30.560" end="02:18:32.600" region="bottomCenter">这门认容貌</p>
      <p xml:id="p2067" begin="02:18:32.720" end="02:18:34.680" region="bottomCenter">您…容貌有变</p>
      <p xml:id="p2068" begin="02:18:34.880" end="02:18:36.200" region="bottomCenter">需重新录入</p>
      <p xml:id="p2069" begin="02:18:36.760" end="02:18:37.920" region="bottomCenter">录吧</p>
      <p xml:id="p2070" begin="02:19:05.160" end="02:19:07.280" region="bottomCenter">敢嘲笑老夫？</p>
      <p xml:id="p2071" begin="02:19:07.400" end="02:19:08.680" region="bottomCenter">咒你睡十年</p>
      <p xml:id="p2072" begin="02:19:16.520" end="02:19:18.920" region="bottomCenter">受罪啦，师弟</p>
      <p xml:id="p2073" begin="02:19:21.400" end="02:19:23.760" region="bottomCenter">师兄才是受罪</p>
      <p xml:id="p2074" begin="02:19:23.880" end="02:19:27.040" region="bottomCenter">谁把…把您打成这样？</p>
      <p xml:id="p2075" begin="02:19:28.080" end="02:19:32.040" region="bottomCenter">你可知老夫当年为何要引荐你入教？</p>
      <p xml:id="p2076" begin="02:19:32.680" end="02:19:35.760" region="bottomCenter">要的就是你这妖族身份</p>
      <p xml:id="p2077" begin="02:19:36.320" end="02:19:38.520" region="bottomCenter">封神大战时</p>
      <p xml:id="p2078" begin="02:19:38.640" end="02:19:42.160" region="bottomCenter">老夫可会对你委以重任哦</p>
      <p xml:id="p2079" begin="02:19:42.320" end="02:19:43.400" region="bottomCenter">妄想</p>
      <p xml:id="p2080" begin="02:19:46.000" end="02:19:48.080" region="bottomCenter">爹，爹</p>
      <p xml:id="p2081" begin="02:19:48.320" end="02:19:49.640" region="bottomCenter">放心</p>
      <p xml:id="p2082" begin="02:19:49.760" end="02:19:51.400" region="bottomCenter">还有气儿</p>
      <p xml:id="p2083" begin="02:19:51.880" end="02:19:55.160" region="bottomCenter">若你让老夫在你身上下个咒</p>
      <p xml:id="p2084" begin="02:19:55.280" end="02:19:57.680" region="bottomCenter">你爹便可在玉虚宫</p>
      <p xml:id="p2085" begin="02:19:57.800" end="02:20:00.160" region="bottomCenter">尽享清福</p>
      <p xml:id="p2086" begin="02:20:03.560" end="02:20:05.200" region="bottomCenter">您要的那两人到了</p>
      <p xml:id="p2087" begin="02:20:05.400" end="02:20:07.160" region="bottomCenter">好好考虑考虑吧</p>
      <p xml:id="p2088" begin="02:20:16.800" end="02:20:18.600" region="bottomCenter">先前敷的药起效了</p>
      <p xml:id="p2089" begin="02:20:19.280" end="02:20:20.440" region="bottomCenter">那怎么办？</p>
      <p xml:id="p2090" begin="02:20:20.600" end="02:20:21.960" region="bottomCenter">还有谁能开门？</p>
      <p xml:id="p2091" begin="02:20:28.520" end="02:20:29.960" region="bottomCenter">十年</p>
      <p xml:id="p2092" begin="02:20:37.640" end="02:20:39.600" region="bottomCenter">五龙山云霄洞金吒</p>
      <p xml:id="p2093" begin="02:20:39.800" end="02:20:41.960" region="bottomCenter">九宫山白鹤洞木吒</p>
      <p xml:id="p2094" begin="02:20:42.080" end="02:20:43.360" region="bottomCenter">应召回宫</p>
      <p xml:id="p2095" begin="02:20:49.080" end="02:20:51.080" region="bottomCenter">师父，忍着点啊</p>
      <p xml:id="p2096" begin="02:20:56.080" end="02:20:57.600" region="bottomCenter">差不多了吧</p>
      <p xml:id="p2097" begin="02:21:04.360" end="02:21:05.400" region="bottomCenter">好像</p>
      <p xml:id="p2098" begin="02:21:05.520" end="02:21:06.440" region="bottomCenter">左眼还不够肿</p>
      <p xml:id="p2099" begin="02:21:06.960" end="02:21:08.000" region="bottomCenter">右腮也补点儿</p>
      <p xml:id="p2100" begin="02:21:11.320" end="02:21:12.280" region="bottomCenter">等等</p>
      <p xml:id="p2101" begin="02:21:12.440" end="02:21:14.240" region="bottomCenter">你们刚才是不是在笑？</p>
      <p xml:id="p2102" begin="02:21:14.400" end="02:21:15.280" region="bottomCenter">徒儿岂敢</p>
      <p xml:id="p2103" begin="02:21:15.400" end="02:21:16.240" region="bottomCenter">师父受苦</p>
      <p xml:id="p2104" begin="02:21:16.360" end="02:21:18.040" region="bottomCenter">徒儿心中只会难受百倍</p>
      <p xml:id="p2105" begin="02:21:18.160" end="02:21:19.800" region="bottomCenter">真的？　　绝无虚言</p>
      <p xml:id="p2106" begin="02:21:19.920" end="02:21:21.160" region="bottomCenter">天地可鉴</p>
      <p xml:id="p2107" begin="02:21:26.320" end="02:21:27.880" region="bottomCenter">行了，行了，行了</p>
      <p xml:id="p2108" begin="02:21:38.880" end="02:21:41.200" region="bottomCenter">好像…打多了</p>
      <p xml:id="p2109" begin="02:21:41.320" end="02:21:42.160" region="bottomCenter">什么？</p>
      <p xml:id="p2110" begin="02:21:42.280" end="02:21:43.120" region="bottomCenter">没事儿，没事儿</p>
      <p xml:id="p2111" begin="02:21:43.240" end="02:21:44.400" region="bottomCenter">敷上药一会儿好了再来</p>
      <p xml:id="p2112" begin="02:21:45.600" end="02:21:47.400" region="bottomCenter">师父，您是干大事儿的人</p>
      <p xml:id="p2113" begin="02:21:47.520" end="02:21:49.080" region="bottomCenter">这都是为了阐教兴亡啊</p>
      <p xml:id="p2114" begin="02:21:49.200" end="02:21:50.080" region="bottomCenter">我们多试几次</p>
      <p xml:id="p2115" begin="02:21:50.200" end="02:21:51.200" region="bottomCenter">总会碰对一次的</p>
      <p xml:id="p2116" begin="02:21:51.320" end="02:21:52.680" region="bottomCenter">抓住他，别让他跑了</p>
      <p xml:id="p2117" begin="02:21:52.800" end="02:21:53.800" region="bottomCenter">快！快上药</p>
      <p xml:id="p2118" begin="02:21:53.920" end="02:21:55.200" region="bottomCenter">上药</p>
      <p xml:id="p2119" begin="02:21:55.320" end="02:21:56.800" region="bottomCenter">放开我</p>
    </div>
  </body>
</tt>