<?xml version="1.0" encoding="utf-8"?>
<tt xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:ttp="http://www.w3.org/ns/ttml#parameter" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xml:lang="en-US" ttp:frameRate="25" ttp:frameRateMultiplier="1 1" ttp:timeBase="media" xmlns="http://www.w3.org/ns/ttml">
  <head>
    <metadata>
      <ttm:title>ENG-Ne Zha 2_FA011623_LowRes_25F-TMP-Terry-TMP-Sora</ttm:title>
    </metadata>
    <styling>
      <style xml:id="s1" tts:fontFamily="default" tts:fontSize="100%" tts:fontStyle="normal" tts:fontWeight="normal" tts:color="white" />
    </styling>
    <layout>
      <region xml:id="bottomCenter" tts:origin="10% 10%" tts:extent="80% 80%" tts:displayAlign="after" tts:textAlign="center" />
      <region xml:id="topCenter" tts:origin="10% 10%" tts:extent="80% 80%" tts:displayAlign="before" tts:textAlign="center" />
    </layout>
  </head>
  <body>
    <div xml:id="d1" style="s1" xml:lang="en-US">
      <p xml:id="p1" begin="00:00:47.040" end="00:00:48.720" region="bottomCenter">Blessed by heaven and earth</p>
      <p xml:id="p2" begin="00:00:48.840" end="00:00:51.920" region="bottomCenter">the Chaos Pearl was born</p>
      <p xml:id="p3" begin="00:00:52.600" end="00:00:55.840" region="bottomCenter">The Supreme Lord split it into two</p>
      <p xml:id="p4" begin="00:00:55.960" end="00:00:57.880" region="bottomCenter">The celestial energy within<br/>became the Spirit Pearl</p>
      <p xml:id="p5" begin="00:00:58.000" end="00:01:00.480" region="bottomCenter">while the demonic energy<br/>formed the Demon Orb</p>
      <p xml:id="p6" begin="00:01:01.000" end="00:01:04.640" region="bottomCenter">A Wrath of Heaven curse<br/>was cast on the Demon Orb</p>
      <p xml:id="p7" begin="00:01:05.000" end="00:01:09.560" region="bottomCenter">set to destroy it with lightning<br/>in three years</p>
      <p xml:id="p8" begin="00:01:10.120" end="00:01:13.720" region="bottomCenter">Later,<br/>due to Shen Gongbao's intervention</p>
      <p xml:id="p9" begin="00:01:13.840" end="00:01:17.960" region="bottomCenter">the Demon Orb reincarnated as Nezha,<br/>the third son of Li Jing in Chentang Pass</p>
      <p xml:id="p10" begin="00:01:18.080" end="00:01:22.480" region="bottomCenter">The Spirit Pearl became Ao Bing,<br/>also the third son of the Loong King</p>
      <p xml:id="p11" begin="00:01:22.800" end="00:01:25.120" region="bottomCenter">By fate</p>
      <p xml:id="p12" begin="00:01:25.240" end="00:01:28.280" region="bottomCenter">the two became best friends</p>
      <p xml:id="p13" begin="00:01:29.080" end="00:01:32.400" region="bottomCenter">Nezha, influenced by his parents</p>
      <p xml:id="p14" begin="00:01:32.520" end="00:01:34.000" region="bottomCenter">shed his demonic nature</p>
      <p xml:id="p15" begin="00:01:34.120" end="00:01:36.480" region="bottomCenter">and saved Chentang Pass</p>
      <p xml:id="p16" begin="00:01:36.600" end="00:01:38.640" region="bottomCenter">Together with Ao Bing</p>
      <p xml:id="p17" begin="00:01:38.760" end="00:01:40.880" region="bottomCenter">they faced the Wrath of Heaven</p>
      <p xml:id="p18" begin="00:01:41.280" end="00:01:42.480" region="bottomCenter">and at last</p>
      <p xml:id="p19" begin="00:01:42.640" end="00:01:46.160" region="bottomCenter">changed their destinies</p>
      <p xml:id="p20" begin="00:02:02.400" end="00:02:04.880" region="bottomCenter">Though you survived the wrath</p>
      <p xml:id="p21" begin="00:02:05.000" end="00:02:07.080" region="bottomCenter">your bodies were destroyed...</p>
      <p xml:id="p22" begin="00:02:07.200" end="00:02:09.000" region="bottomCenter">without which</p>
      <p xml:id="p23" begin="00:02:09.120" end="00:02:12.600" region="bottomCenter">your souls will soon fade<br/>into oblivion</p>
      <p xml:id="p24" begin="00:02:12.720" end="00:02:14.760" region="bottomCenter">The Sacred Lotus protects<br/>and nurtures spirit</p>
      <p xml:id="p25" begin="00:02:14.880" end="00:02:17.280" region="bottomCenter">I will now use it to recreate</p>
      <p xml:id="p26" begin="00:02:17.400" end="00:02:19.920" region="bottomCenter">your physical forms</p>
      <p xml:id="p27" begin="00:02:48.920" end="00:02:50.920" region="bottomCenter">- Wow<br/>- Stunning</p>
      <p xml:id="p28" begin="00:02:51.280" end="00:02:52.360" region="bottomCenter">Let's start!</p>
      <p xml:id="p29" begin="00:03:26.840" end="00:03:27.760" region="bottomCenter">Something's off...</p>
      <p xml:id="p30" begin="00:03:27.920" end="00:03:29.520" region="bottomCenter">Is there?<br/>The lotus root must be powdered</p>
      <p xml:id="p31" begin="00:03:29.640" end="00:03:31.120" region="bottomCenter">to make your bodies</p>
      <p xml:id="p32" begin="00:03:32.040" end="00:03:32.880" region="bottomCenter">Did you just scratch your feet</p>
      <p xml:id="p33" begin="00:03:33.000" end="00:03:34.360" region="bottomCenter">with that hand?</p>
      <p xml:id="p34" begin="00:03:34.480" end="00:03:35.960" region="bottomCenter">Oh, don't worry</p>
      <p xml:id="p35" begin="00:03:36.080" end="00:03:38.240" region="bottomCenter">I don't mind sticky foot,<br/>a quick wash will fix it</p>
      <p xml:id="p36" begin="00:03:38.480" end="00:03:41.040" region="bottomCenter">It's not your foot that I care</p>
      <p xml:id="p37" begin="00:03:41.920" end="00:03:43.680" region="bottomCenter">Did you just blow your nose<br/>with that hand?</p>
      <p xml:id="p38" begin="00:03:44.120" end="00:03:45.840" region="bottomCenter">No, nothing</p>
      <p xml:id="p39" begin="00:03:45.960" end="00:03:46.880" region="bottomCenter">It's just lotus powder</p>
      <p xml:id="p40" begin="00:03:47.000" end="00:03:48.520" region="bottomCenter">See?<br/>Lotus powder</p>
      <p xml:id="p41" begin="00:03:50.360" end="00:03:52.040" region="bottomCenter">It's ready to go</p>
      <p xml:id="p42" begin="00:03:52.520" end="00:03:53.720" region="bottomCenter">Here, come on</p>
      <p xml:id="p43" begin="00:03:53.840" end="00:03:55.040" region="bottomCenter">One booger for each of you</p>
      <p xml:id="p44" begin="00:03:55.160" end="00:03:56.720" region="bottomCenter">I mean one serving</p>
      <p xml:id="p45" begin="00:03:57.640" end="00:03:59.680" region="bottomCenter">Chop-chop! To save your souls</p>
      <p xml:id="p46" begin="00:03:59.800" end="00:04:00.960" region="bottomCenter">I'd rather...</p>
      <p xml:id="p47" begin="00:04:01.080" end="00:04:02.760" region="bottomCenter">Pain in the ass, little jerk!</p>
      <p xml:id="p48" begin="00:04:09.480" end="00:04:10.480" region="bottomCenter">It works!</p>
      <p xml:id="p49" begin="00:04:10.920" end="00:04:11.760" region="bottomCenter">Hang on</p>
      <p xml:id="p50" begin="00:04:13.320" end="00:04:14.160" region="bottomCenter">What is this?</p>
      <p xml:id="p51" begin="00:04:14.280" end="00:04:15.200" region="bottomCenter">Thank you</p>
      <p xml:id="p52" begin="00:04:15.320" end="00:04:16.920" region="bottomCenter">I've been looking all over for it</p>
      <p xml:id="p53" begin="00:04:21.160" end="00:04:22.120" region="bottomCenter">Time for shaping</p>
      <p xml:id="p54" begin="00:04:24.440" end="00:04:27.440" region="bottomCenter">Flying Pig's memory is unmatched</p>
      <p xml:id="p55" begin="00:04:27.560" end="00:04:30.640" region="bottomCenter">so is his carving skills</p>
      <p xml:id="p56" begin="00:04:32.160" end="00:04:33.880" region="bottomCenter">It's perfect, right?</p>
      <p xml:id="p57" begin="00:04:37.640" end="00:04:38.800" region="bottomCenter">Thanks, Piggy</p>
      <p xml:id="p58" begin="00:04:39.600" end="00:04:41.840" region="bottomCenter">Don't move,<br/>the body has not been fixed yet</p>
      <p xml:id="p59" begin="00:04:44.320" end="00:04:45.160" region="bottomCenter">Master Immortal</p>
      <p xml:id="p60" begin="00:04:45.280" end="00:04:47.040" region="bottomCenter">I've mobilized all<br/>of Chentang's forces</p>
      <p xml:id="p61" begin="00:04:47.160" end="00:04:49.240" region="bottomCenter">to fend off Shen Gongbao<br/>and the Eastern Sea Loongs</p>
      <p xml:id="p62" begin="00:04:49.360" end="00:04:50.600" region="bottomCenter">Take it easy</p>
      <p xml:id="p63" begin="00:04:50.720" end="00:04:51.920" region="bottomCenter">The Loongs are watching<br/>the Abyss monsters</p>
      <p xml:id="p64" begin="00:04:52.040" end="00:04:53.880" region="bottomCenter">none of which would escape</p>
      <p xml:id="p65" begin="00:04:54.000" end="00:04:55.680" region="bottomCenter">Shen Gongbao alone is no threat</p>
      <p xml:id="p66" begin="00:04:56.000" end="00:04:57.920" region="bottomCenter">You should check this out</p>
      <p xml:id="p67" begin="00:04:58.520" end="00:05:00.120" region="bottomCenter">Isn't this impeccable?</p>
      <p xml:id="p68" begin="00:05:02.160" end="00:05:03.560" region="bottomCenter">He learned from the best</p>
      <p xml:id="p69" begin="00:05:03.680" end="00:05:04.560" region="bottomCenter">But</p>
      <p xml:id="p70" begin="00:05:04.680" end="00:05:05.960" region="bottomCenter">does it have to be exactly the same?</p>
      <p xml:id="p71" begin="00:05:06.080" end="00:05:07.240" region="bottomCenter">Can't you make me look better?</p>
      <p xml:id="p72" begin="00:05:07.360" end="00:05:08.200" region="bottomCenter">Huh?</p>
      <p xml:id="p73" begin="00:05:10.800" end="00:05:11.640" region="bottomCenter">That's right</p>
      <p xml:id="p74" begin="00:05:11.760" end="00:05:13.720" region="bottomCenter">Parents always want<br/>the best for kids, huh?</p>
      <p xml:id="p75" begin="00:05:13.840" end="00:05:14.680" region="bottomCenter">Right</p>
      <p xml:id="p76" begin="00:05:15.200" end="00:05:16.320" region="bottomCenter">Make me tall and hunky</p>
      <p xml:id="p77" begin="00:05:17.560" end="00:05:19.120" region="bottomCenter">Also hauntingly handsome</p>
      <p xml:id="p78" begin="00:05:19.520" end="00:05:21.640" region="bottomCenter">A man must be strong and lofty</p>
      <p xml:id="p79" begin="00:05:22.640" end="00:05:23.800" region="bottomCenter">As well as demure and mindful</p>
      <p xml:id="p80" begin="00:05:24.280" end="00:05:25.800" region="bottomCenter">But also cute and lovable</p>
      <p xml:id="p81" begin="00:05:27.040" end="00:05:29.480" region="bottomCenter">Can you all make up your mind?</p>
      <p xml:id="p82" begin="00:05:29.600" end="00:05:30.640" region="bottomCenter">Tall and hunky</p>
      <p xml:id="p83" begin="00:05:30.760" end="00:05:32.600" region="bottomCenter">With a touch of handsomeness</p>
      <p xml:id="p84" begin="00:05:32.720" end="00:05:33.760" region="bottomCenter">Strong and lofty</p>
      <p xml:id="p85" begin="00:05:33.880" end="00:05:35.720" region="bottomCenter">Yet super adorable</p>
      <p xml:id="p86" begin="00:05:39.960" end="00:05:40.800" region="bottomCenter">What's this?</p>
      <p xml:id="p87" begin="00:05:40.920" end="00:05:42.280" region="bottomCenter">Start your performance</p>
      <p xml:id="p88" begin="00:05:42.480" end="00:05:44.480" region="bottomCenter">Come on!<br/>I should've taken over earlier</p>
      <p xml:id="p89" begin="00:05:44.600" end="00:05:45.680" region="bottomCenter">DIY is always the best</p>
      <p xml:id="p90" begin="00:05:46.760" end="00:05:47.960" region="bottomCenter">This could take a while</p>
      <p xml:id="p91" begin="00:05:48.200" end="00:05:49.880" region="bottomCenter">Let's do you first</p>
      <p xml:id="p92" begin="00:05:50.720" end="00:05:52.400" region="bottomCenter">You were born of the water element</p>
      <p xml:id="p93" begin="00:05:52.520" end="00:05:54.000" region="bottomCenter">so you must be tempered<br/>by pure water</p>
      <p xml:id="p94" begin="00:06:12.280" end="00:06:13.200" region="bottomCenter">Open Lotus!</p>
      <p xml:id="p95" begin="00:06:20.800" end="00:06:22.400" region="bottomCenter">Here we go</p>
      <p xml:id="p96" begin="00:06:23.160" end="00:06:24.200" region="bottomCenter">Are you done?</p>
      <p xml:id="p97" begin="00:06:26.280" end="00:06:27.640" region="bottomCenter">Almost</p>
      <p xml:id="p98" begin="00:06:31.800" end="00:06:34.520" region="bottomCenter">This version is surely<br/>the most dazzling</p>
      <p xml:id="p99" begin="00:06:34.640" end="00:06:37.640" region="bottomCenter">but fine-tuning will<br/>take a long time</p>
      <p xml:id="p100" begin="00:06:37.760" end="00:06:38.920" region="bottomCenter">How about we just use<br/>the first one for now?</p>
      <p xml:id="p101" begin="00:06:39.040" end="00:06:41.360" region="bottomCenter">Yeah, the first version will do</p>
      <p xml:id="p102" begin="00:06:41.480" end="00:06:43.600" region="bottomCenter">I agree</p>
      <p xml:id="p103" begin="00:06:45.000" end="00:06:46.200" region="bottomCenter">Right</p>
      <p xml:id="p104" begin="00:06:47.240" end="00:06:49.440" region="bottomCenter">You were born of the fire element</p>
      <p xml:id="p105" begin="00:06:49.560" end="00:06:51.400" region="bottomCenter">so you must be refined<br/>in pure flames</p>
      <p xml:id="p106" begin="00:07:00.480" end="00:07:01.800" region="bottomCenter">Sir!</p>
      <p xml:id="p107" begin="00:07:02.120" end="00:07:03.320" region="bottomCenter">Enemy has been spotted at sea</p>
      <p xml:id="p108" begin="00:07:03.440" end="00:07:04.360" region="bottomCenter">It seems to be Shen Gongbao</p>
      <p xml:id="p109" begin="00:07:04.560" end="00:07:06.600" region="bottomCenter">- How many?<br/>- Just him</p>
      <p xml:id="p110" begin="00:07:06.840" end="00:07:08.360" region="bottomCenter">How come?</p>
      <p xml:id="p111" begin="00:07:08.520" end="00:07:09.600" region="bottomCenter">Carry on with your spell</p>
      <p xml:id="p112" begin="00:07:09.720" end="00:07:10.800" region="bottomCenter">We'll handle the intruder</p>
      <p xml:id="p113" begin="00:07:11.240" end="00:07:12.960" region="bottomCenter">Master Immortal<br/>let me go plead with my master</p>
      <p xml:id="p114" begin="00:07:13.080" end="00:07:15.040" region="bottomCenter">Don't move! Before another<br/>incense stick is fully burnt</p>
      <p xml:id="p115" begin="00:07:15.160" end="00:07:16.520" region="bottomCenter">your body won't be fixed</p>
      <p xml:id="p116" begin="00:07:45.520" end="00:07:46.560" region="bottomCenter">Shen Gongbao</p>
      <p xml:id="p117" begin="00:07:46.680" end="00:07:48.760" region="bottomCenter">to what do we owe this honor?</p>
      <p xml:id="p118" begin="00:07:49.080" end="00:07:52.840" region="bottomCenter">Now that you know<br/>of my plan with the Loongs</p>
      <p xml:id="p119" begin="00:07:52.960" end="00:07:56.560" region="bottomCenter">I can't help but feel un...uneasy</p>
      <p xml:id="p120" begin="00:07:56.680" end="00:07:58.880" region="bottomCenter">Chentang Pass is heavily guarded</p>
      <p xml:id="p121" begin="00:07:59.000" end="00:08:00.720" region="bottomCenter">and Master Taiyi is within the city</p>
      <p xml:id="p122" begin="00:08:00.840" end="00:08:03.480" region="bottomCenter">You, alone, won't accomplish much</p>
      <p xml:id="p123" begin="00:08:03.720" end="00:08:08.920" region="bottomCenter">Who... who said I'm alone?</p>
      <p xml:id="p124" begin="00:08:13.280" end="00:08:16.160" region="bottomCenter">If they find out<br/>about the Spirit Pearl</p>
      <p xml:id="p125" begin="00:08:16.680" end="00:08:19.000" region="bottomCenter">not only will you fail<br/>to avenge your son</p>
      <p xml:id="p126" begin="00:08:19.680" end="00:08:22.160" region="bottomCenter">but the entire Eastern Loong Clan</p>
      <p xml:id="p127" begin="00:08:22.600" end="00:08:24.960" region="bottomCenter">will bear the blame</p>
      <p xml:id="p128" begin="00:08:25.360" end="00:08:26.400" region="bottomCenter">When the truth comes out</p>
      <p xml:id="p129" begin="00:08:26.520" end="00:08:28.280" region="bottomCenter">you'll be cast<br/>into the abyss purgatory</p>
      <p xml:id="p130" begin="00:08:28.400" end="00:08:30.200" region="bottomCenter">surrounded by all your old "fellows"</p>
      <p xml:id="p131" begin="00:08:30.320" end="00:08:31.840" region="bottomCenter">Let's see how we welcome you</p>
      <p xml:id="p132" begin="00:08:32.080" end="00:08:33.920" region="bottomCenter">Being stuck in Loong Palace...</p>
      <p xml:id="p133" begin="00:08:34.040" end="00:08:36.480" region="bottomCenter">How could you avenge your son?</p>
      <p xml:id="p134" begin="00:08:36.600" end="00:08:38.360" region="bottomCenter">Even I feel nervous for you</p>
      <p xml:id="p135" begin="00:08:47.800" end="00:08:51.600" region="bottomCenter">You fools are in no place to gloat</p>
      <p xml:id="p136" begin="00:08:51.800" end="00:08:54.040" region="bottomCenter">I was simply trying to help</p>
      <p xml:id="p137" begin="00:08:54.520" end="00:08:58.320" region="bottomCenter">But it seems that you<br/>don't appreciate it</p>
      <p xml:id="p138" begin="00:09:07.440" end="00:09:10.520" region="bottomCenter">You must've forgotten<br/>what I'm capable of</p>
      <p xml:id="p139" begin="00:09:13.920" end="00:09:15.960" region="bottomCenter">Ah! I know this one</p>
      <p xml:id="p140" begin="00:09:16.160" end="00:09:19.240" region="bottomCenter">The Sky... Sky... Sky...</p>
      <p xml:id="p141" begin="00:09:19.360" end="00:09:21.560" region="bottomCenter">Sky-Splitting Claw</p>
      <p xml:id="p142" begin="00:09:21.680" end="00:09:22.880" region="bottomCenter">Thank you</p>
      <p xml:id="p143" begin="00:09:25.440" end="00:09:29.240" region="bottomCenter">Master Shen can take this claw<br/>to Chentang Pass</p>
      <p xml:id="p144" begin="00:09:29.360" end="00:09:32.320" region="bottomCenter">and use it to tear open a rift<br/>leading back to me</p>
      <p xml:id="p145" begin="00:09:32.440" end="00:09:38.440" region="bottomCenter">The Abyss Monsters can then<br/>help you destroy your enemy</p>
      <p xml:id="p146" begin="00:10:28.320" end="00:10:29.640" region="bottomCenter">The Abyss Monsters?</p>
      <p xml:id="p147" begin="00:10:30.440" end="00:10:32.040" region="bottomCenter">How... is that possible?</p>
      <p xml:id="p148" begin="00:10:32.160" end="00:10:33.000" region="bottomCenter">They were trapped</p>
      <p xml:id="p149" begin="00:10:33.120" end="00:10:34.200" region="bottomCenter">by the Suppression Seal<br/>for a thousand years</p>
      <p xml:id="p150" begin="00:10:34.320" end="00:10:35.240" region="bottomCenter">How could they possibly escape?</p>
      <p xml:id="p151" begin="00:10:35.360" end="00:10:37.160" region="bottomCenter">The Loongs...<br/>have they already released them?</p>
      <p xml:id="p152" begin="00:10:37.840" end="00:10:40.440" region="bottomCenter">With the Sea-Stabilizing Chains<br/>binding us</p>
      <p xml:id="p153" begin="00:10:40.560" end="00:10:43.000" region="bottomCenter">there's no chance for escape</p>
      <p xml:id="p154" begin="00:10:43.600" end="00:10:46.840" region="bottomCenter">This is a win-win tactic</p>
      <p xml:id="p155" begin="00:10:47.080" end="00:10:48.680" region="bottomCenter">What do you say, my brother?</p>
      <p xml:id="p156" begin="00:10:49.000" end="00:10:51.080" region="bottomCenter">You wouldn't be so generous</p>
      <p xml:id="p157" begin="00:10:52.480" end="00:10:55.240" region="bottomCenter">Get to the point<br/>What's your price?</p>
      <p xml:id="p158" begin="00:10:57.160" end="00:10:59.240" region="bottomCenter">In this purgatory</p>
      <p xml:id="p159" begin="00:10:59.360" end="00:11:00.840" region="bottomCenter">where flames burn our bodies</p>
      <p xml:id="p160" begin="00:11:00.960" end="00:11:02.440" region="bottomCenter">every day feels like a year</p>
      <p xml:id="p161" begin="00:11:02.680" end="00:11:05.440" region="bottomCenter">If you could<br/>slightly lower the lava's heat</p>
      <p xml:id="p162" begin="00:11:05.560" end="00:11:07.760" region="bottomCenter">easing our suffering</p>
      <p xml:id="p163" begin="00:11:08.560" end="00:11:11.600" region="bottomCenter">we'd be willing to serve you<br/>with all our might</p>
      <p xml:id="p164" begin="00:11:13.520" end="00:11:14.400" region="bottomCenter">What's going on?</p>
      <p xml:id="p165" begin="00:11:14.520" end="00:11:16.400" region="bottomCenter">What is Shen Gongbao up to now?</p>
      <p xml:id="p166" begin="00:11:24.440" end="00:11:27.240" region="bottomCenter">Finally, we're out! Yay!</p>
      <p xml:id="p167" begin="00:11:28.160" end="00:11:29.800" region="bottomCenter">Bye-bye!</p>
      <p xml:id="p168" begin="00:11:33.400" end="00:11:35.480" region="bottomCenter">Vile</p>
      <p xml:id="p169" begin="00:11:35.600" end="00:11:36.440" region="bottomCenter">We're doomed</p>
      <p xml:id="p170" begin="00:11:36.560" end="00:11:38.720" region="bottomCenter">How will we explain this<br/>to General Li now?</p>
      <p xml:id="p171" begin="00:11:38.920" end="00:11:40.240" region="bottomCenter">Luckily no one saw us</p>
      <p xml:id="p172" begin="00:11:40.520" end="00:11:42.240" region="bottomCenter">- Here<br/>- What for?</p>
      <p xml:id="p173" begin="00:11:42.360" end="00:11:44.040" region="bottomCenter">I'll break your arms<br/>and then you break my legs</p>
      <p xml:id="p174" begin="00:11:44.160" end="00:11:45.280" region="bottomCenter">We'll say the Yaksha did it</p>
      <p xml:id="p175" begin="00:11:45.440" end="00:11:48.280" region="bottomCenter">Oh! When the general sees<br/>how badly we're hurt</p>
      <p xml:id="p176" begin="00:11:48.400" end="00:11:49.760" region="bottomCenter">he won't blame us anymore</p>
      <p xml:id="p177" begin="00:11:49.880" end="00:11:50.720" region="bottomCenter">Try your best</p>
      <p xml:id="p178" begin="00:11:50.960" end="00:11:52.000" region="bottomCenter">Hit harder!</p>
      <p xml:id="p179" begin="00:11:55.400" end="00:11:57.800" region="bottomCenter">Hey! Hey!</p>
      <p xml:id="p180" begin="00:12:00.080" end="00:12:01.200" region="bottomCenter">Hey, you two!</p>
      <p xml:id="p181" begin="00:12:03.920" end="00:12:05.720" region="bottomCenter">Master Immortal, you're here!</p>
      <p xml:id="p182" begin="00:12:08.440" end="00:12:09.560" region="bottomCenter">He let the Yaksha get away!</p>
      <p xml:id="p183" begin="00:12:09.680" end="00:12:13.000" region="bottomCenter">Huh? It was all your fault</p>
      <p xml:id="p184" begin="00:12:13.120" end="00:12:14.000" region="bottomCenter">Who are you to point fingers?</p>
      <p xml:id="p185" begin="00:12:14.120" end="00:12:15.120" region="bottomCenter">Who are you to play innocent?</p>
      <p xml:id="p186" begin="00:12:18.280" end="00:12:19.320" region="bottomCenter">Oh my</p>
      <p xml:id="p187" begin="00:12:19.440" end="00:12:20.760" region="bottomCenter">Dumb and Dumber!</p>
      <p xml:id="p188" begin="00:12:20.880" end="00:12:21.720" region="bottomCenter">Hey!</p>
      <p xml:id="p189" begin="00:12:21.840" end="00:12:23.520" region="bottomCenter">You two boneheads!</p>
      <p xml:id="p190" begin="00:12:23.640" end="00:12:25.400" region="bottomCenter">Get over here and guard me!</p>
      <p xml:id="p191" begin="00:12:25.760" end="00:12:27.440" region="bottomCenter">- Yes, Sir!<br/>- Right away!</p>
      <p xml:id="p192" begin="00:13:38.160" end="00:13:40.200" region="bottomCenter">Show no mercy</p>
      <p xml:id="p193" begin="00:14:34.160" end="00:14:36.200" region="bottomCenter">Shen Gongbao!<br/>Ao Bing is not dead</p>
      <p xml:id="p194" begin="00:14:36.320" end="00:14:38.800" region="bottomCenter">Chentang Pass and the Loongs have<br/>no reason to fight</p>
      <p xml:id="p195" begin="00:14:38.920" end="00:14:40.920" region="bottomCenter">Taiyi is rebuilding<br/>Ao Bing's body right now</p>
      <p xml:id="p196" begin="00:14:44.160" end="00:14:45.960" region="bottomCenter">Liar!</p>
      <p xml:id="p197" begin="00:14:47.720" end="00:14:48.600" region="bottomCenter">The shield...</p>
      <p xml:id="p198" begin="00:14:50.640" end="00:14:51.480" region="bottomCenter">No!</p>
      <p xml:id="p199" begin="00:15:08.040" end="00:15:09.960" region="bottomCenter">Master! Master!</p>
      <p xml:id="p200" begin="00:15:10.680" end="00:15:11.680" region="bottomCenter">Ao Bing!</p>
      <p xml:id="p201" begin="00:15:11.840" end="00:15:13.520" region="bottomCenter">Master Taiyi has built me a new body</p>
      <p xml:id="p202" begin="00:15:13.640" end="00:15:14.520" region="bottomCenter">Please, ceasefire</p>
      <p xml:id="p203" begin="00:15:14.720" end="00:15:15.800" region="bottomCenter">Shen Gongbao</p>
      <p xml:id="p204" begin="00:15:15.920" end="00:15:17.520" region="bottomCenter">I saved your disciple<br/>How will you thank me?</p>
      <p xml:id="p205" begin="00:15:17.720" end="00:15:21.720" region="bottomCenter">So... that's Nezha in there?</p>
      <p xml:id="p206" begin="00:15:24.080" end="00:15:26.240" region="bottomCenter">Why, you ungrateful jerk!</p>
      <p xml:id="p207" begin="00:15:26.360" end="00:15:28.720" region="bottomCenter">- Master!<br/>- They must die!</p>
      <p xml:id="p208" begin="00:15:36.120" end="00:15:37.880" region="bottomCenter">Ha ha ha!<br/>You think you can break this shield?</p>
      <p xml:id="p209" begin="00:15:38.000" end="00:15:39.960" region="bottomCenter">Hit me! Come on!</p>
      <p xml:id="p210" begin="00:16:06.280" end="00:16:07.440" region="bottomCenter">No!</p>
      <p xml:id="p211" begin="00:16:40.840" end="00:16:42.360" region="bottomCenter">The aura...</p>
      <p xml:id="p212" begin="00:16:51.440" end="00:16:52.400" region="bottomCenter">Ao Bing!</p>
      <p xml:id="p213" begin="00:16:52.520" end="00:16:53.520" region="bottomCenter">Father!</p>
      <p xml:id="p214" begin="00:17:05.960" end="00:17:06.920" region="bottomCenter">Father!</p>
      <p xml:id="p215" begin="00:17:07.520" end="00:17:09.320" region="bottomCenter">I failed the mission<br/>to save our kind</p>
      <p xml:id="p216" begin="00:17:09.440" end="00:17:11.280" region="bottomCenter">No. None of that matters</p>
      <p xml:id="p217" begin="00:17:11.400" end="00:17:13.160" region="bottomCenter">I just want you to be safe</p>
      <p xml:id="p218" begin="00:17:13.280" end="00:17:15.840" region="bottomCenter">As long as you're here<br/>it's enough for me</p>
      <p xml:id="p219" begin="00:17:23.960" end="00:17:24.800" region="bottomCenter">Open Lotus!</p>
      <p xml:id="p220" begin="00:17:32.920" end="00:17:33.920" region="bottomCenter">Your body, what is...</p>
      <p xml:id="p221" begin="00:17:34.040" end="00:17:35.200" region="bottomCenter">Please, he's literally a newborn</p>
      <p xml:id="p222" begin="00:17:35.320" end="00:17:37.320" region="bottomCenter">How could he take a hit like that?</p>
      <p xml:id="p223" begin="00:17:37.440" end="00:17:38.280" region="bottomCenter">Ao Bing!</p>
      <p xml:id="p224" begin="00:17:38.720" end="00:17:39.960" region="bottomCenter">Hey! It's not ready yet!</p>
      <p xml:id="p225" begin="00:17:40.080" end="00:17:41.360" region="bottomCenter">Don't move! Don't move!</p>
      <p xml:id="p226" begin="00:17:41.480" end="00:17:42.400" region="bottomCenter">Ao Bing, what's going on?</p>
      <p xml:id="p227" begin="00:17:42.520" end="00:17:45.240" region="bottomCenter">Don't move before your body is fixed</p>
      <p xml:id="p228" begin="00:17:45.360" end="00:17:46.400" region="bottomCenter">If your body exceeds its limit</p>
      <p xml:id="p229" begin="00:17:46.520" end="00:17:47.840" region="bottomCenter">it will collapse!</p>
      <p xml:id="p230" begin="00:17:47.960" end="00:17:49.440" region="bottomCenter">For heaven's sake...</p>
      <p xml:id="p231" begin="00:17:49.560" end="00:17:50.400" region="bottomCenter">Fatty!</p>
      <p xml:id="p232" begin="00:17:50.520" end="00:17:53.000" region="bottomCenter">Make another bod...<br/>body for Ao Bing now!</p>
      <p xml:id="p233" begin="00:17:54.080" end="00:17:55.360" region="bottomCenter">Making two bodies back-to-back</p>
      <p xml:id="p234" begin="00:17:55.480" end="00:17:57.080" region="bottomCenter">has completely drained<br/>the Sacred Lotus's energy</p>
      <p xml:id="p235" begin="00:17:57.200" end="00:17:58.680" region="bottomCenter">Without a body,<br/>won't his soul scatter?</p>
      <p xml:id="p236" begin="00:17:58.800" end="00:18:00.080" region="bottomCenter">Master, do something!</p>
      <p xml:id="p237" begin="00:18:00.200" end="00:18:01.200" region="bottomCenter">Without the Sacred Lotus</p>
      <p xml:id="p238" begin="00:18:01.320" end="00:18:02.920" region="bottomCenter">there's nothing I can do</p>
      <p xml:id="p239" begin="00:18:03.120" end="00:18:04.160" region="bottomCenter">It's okay</p>
      <p xml:id="p240" begin="00:18:04.720" end="00:18:06.960" region="bottomCenter">I took your place<br/>as the Spirit Pearl, I deserve this</p>
      <p xml:id="p241" begin="00:18:07.680" end="00:18:09.400" region="bottomCenter">If my sacrifice</p>
      <p xml:id="p242" begin="00:18:09.520" end="00:18:10.920" region="bottomCenter">can bring you back to life</p>
      <p xml:id="p243" begin="00:18:11.480" end="00:18:13.120" region="bottomCenter">then it's a fair price to pay</p>
      <p xml:id="p244" begin="00:18:13.240" end="00:18:14.480" region="bottomCenter">Who asked you to?</p>
      <p xml:id="p245" begin="00:18:14.600" end="00:18:16.200" region="bottomCenter">I am happy being the Demon Orb</p>
      <p xml:id="p246" begin="00:18:16.320" end="00:18:17.560" region="bottomCenter">Don't you dare die!</p>
      <p xml:id="p247" begin="00:18:18.480" end="00:18:19.600" region="bottomCenter">Father</p>
      <p xml:id="p248" begin="00:18:20.400" end="00:18:22.360" region="bottomCenter">please spare Chentang Pass</p>
      <p xml:id="p249" begin="00:18:23.400" end="00:18:25.720" region="bottomCenter">We should stop our mistakes</p>
      <p xml:id="p250" begin="00:18:26.640" end="00:18:29.320" region="bottomCenter">This is my final wish</p>
      <p xml:id="p251" begin="00:18:34.880" end="00:18:35.960" region="bottomCenter">There has to be other ways</p>
      <p xml:id="p252" begin="00:18:36.200" end="00:18:37.600" region="bottomCenter">There has to</p>
      <p xml:id="p253" begin="00:18:37.720" end="00:18:39.520" region="bottomCenter">You! Try harder!</p>
      <p xml:id="p254" begin="00:18:39.640" end="00:18:41.200" region="bottomCenter">Let Ao Bing share your body for now</p>
      <p xml:id="p255" begin="00:18:41.320" end="00:18:42.440" region="bottomCenter">Share your body</p>
      <p xml:id="p256" begin="00:18:42.760" end="00:18:45.480" region="bottomCenter">Two souls sharing one body</p>
      <p xml:id="p257" begin="00:18:45.600" end="00:18:47.440" region="bottomCenter">rejection is inevitable</p>
      <p xml:id="p258" begin="00:18:47.560" end="00:18:49.400" region="bottomCenter">The Spirit Pearl and Demon Orb come<br/>from the same source</p>
      <p xml:id="p259" begin="00:18:49.520" end="00:18:50.400" region="bottomCenter">Sharing one body</p>
      <p xml:id="p260" begin="00:18:50.520" end="00:18:52.800" region="bottomCenter">for seven days<br/>shouldn't be a problem</p>
      <p xml:id="p261" begin="00:18:52.920" end="00:18:53.760" region="bottomCenter">That's it!</p>
      <p xml:id="p262" begin="00:18:53.880" end="00:18:55.320" region="bottomCenter">Ao Bing, come on up! Quick!</p>
      <p xml:id="p263" begin="00:18:56.720" end="00:18:57.600" region="bottomCenter">Okay</p>
      <p xml:id="p264" begin="00:19:04.320" end="00:19:06.120" region="bottomCenter">This feels... strange...</p>
      <p xml:id="p265" begin="00:19:06.320" end="00:19:07.400" region="bottomCenter">Ao Bing, are you here?</p>
      <p xml:id="p266" begin="00:19:07.680" end="00:19:08.560" region="bottomCenter">Yes, I am</p>
      <p xml:id="p267" begin="00:19:08.680" end="00:19:10.560" region="bottomCenter">I can hear your voice in my head!</p>
      <p xml:id="p268" begin="00:19:10.680" end="00:19:12.080" region="bottomCenter">This is fun!</p>
      <p xml:id="p269" begin="00:19:12.200" end="00:19:14.320" region="bottomCenter">But this is only a temporary fix</p>
      <p xml:id="p270" begin="00:19:14.440" end="00:19:16.560" region="bottomCenter">What happens after seven days?</p>
      <p xml:id="p271" begin="00:19:16.680" end="00:19:18.240" region="bottomCenter">There's some potion<br/>in the vault of Yu Xu Palace</p>
      <p xml:id="p272" begin="00:19:18.360" end="00:19:20.880" region="bottomCenter">Elixir Reparo</p>
      <p xml:id="p273" begin="00:19:21.000" end="00:19:23.120" region="bottomCenter">It can restore the divine power<br/>of magical items</p>
      <p xml:id="p274" begin="00:19:23.240" end="00:19:24.200" region="bottomCenter">With it</p>
      <p xml:id="p275" begin="00:19:24.320" end="00:19:27.240" region="bottomCenter">the Sacred Lotus will bloom again</p>
      <p xml:id="p276" begin="00:19:27.400" end="00:19:29.760" region="bottomCenter">But how will you obtain it?</p>
      <p xml:id="p277" begin="00:19:29.880" end="00:19:31.480" region="bottomCenter">I'll go to the Supreme Lord himself<br/>and beg for it</p>
      <p xml:id="p278" begin="00:19:32.200" end="00:19:33.280" region="bottomCenter">Or are you planning to</p>
      <p xml:id="p279" begin="00:19:33.400" end="00:19:35.400" region="bottomCenter">report on me and the Loongs?</p>
      <p xml:id="p280" begin="00:19:35.520" end="00:19:39.440" region="bottomCenter">The Supreme Lord wouldn't sa...<br/>save a son of the Loongs</p>
      <p xml:id="p281" begin="00:19:39.560" end="00:19:40.760" region="bottomCenter">If asking doesn't work</p>
      <p xml:id="p282" begin="00:19:40.880" end="00:19:41.960" region="bottomCenter">then we'll snatch</p>
      <p xml:id="p283" begin="00:19:42.400" end="00:19:44.360" region="bottomCenter">Yu Xu Palace is<br/>at the core of the Chan Sect</p>
      <p xml:id="p284" begin="00:19:44.480" end="00:19:45.480" region="bottomCenter">protected by formidable powers</p>
      <p xml:id="p285" begin="00:19:45.600" end="00:19:46.840" region="bottomCenter">For my son</p>
      <p xml:id="p286" begin="00:19:46.960" end="00:19:49.440" region="bottomCenter">I'll break into the Court of Heaven<br/>if I have to</p>
      <p xml:id="p287" begin="00:19:49.560" end="00:19:51.000" region="bottomCenter">Your Majesty, calm down</p>
      <p xml:id="p288" begin="00:19:51.120" end="00:19:53.080" region="bottomCenter">I might have a plan</p>
      <p xml:id="p289" begin="00:19:53.200" end="00:19:55.320" region="bottomCenter">Chan disciples<br/>who excel in their training</p>
      <p xml:id="p290" begin="00:19:55.440" end="00:19:58.160" region="bottomCenter">can participate<br/>in the Ascension Trial</p>
      <p xml:id="p291" begin="00:19:58.280" end="00:20:01.400" region="bottomCenter">Passing the trial grants<br/>not only immortality</p>
      <p xml:id="p292" begin="00:20:01.520" end="00:20:03.680" region="bottomCenter">but also the right to choose one</p>
      <p xml:id="p293" begin="00:20:03.800" end="00:20:06.920" region="bottomCenter">ma... magic item<br/>from the Yu Xu Vault as a reward</p>
      <p xml:id="p294" begin="00:20:07.040" end="00:20:08.920" region="bottomCenter">Are you suggesting<br/>that Nezha participate in the trial</p>
      <p xml:id="p295" begin="00:20:09.040" end="00:20:10.080" region="bottomCenter">to obtain the elixir?</p>
      <p xml:id="p296" begin="00:20:10.200" end="00:20:11.200" region="bottomCenter">No, no, no!</p>
      <p xml:id="p297" begin="00:20:11.320" end="00:20:12.160" region="bottomCenter">He's beaming with demonic energy!</p>
      <p xml:id="p298" begin="00:20:12.280" end="00:20:14.280" region="bottomCenter">As soon as he uses his powers,<br/>he'll be exposed!</p>
      <p xml:id="p299" begin="00:20:14.400" end="00:20:16.080" region="bottomCenter">Isn't Ao Bing already sharing<br/>Nezha's body?</p>
      <p xml:id="p300" begin="00:20:16.200" end="00:20:18.080" region="bottomCenter">His divine aura can mask<br/>the demonic energy perfectly</p>
      <p xml:id="p301" begin="00:20:19.280" end="00:20:21.800" region="bottomCenter">As long as he passes the trial<br/>within seven days</p>
      <p xml:id="p302" begin="00:20:21.920" end="00:20:24.720" region="bottomCenter">not only will we<br/>have the el... elixir...</p>
      <p xml:id="p303" begin="00:20:24.840" end="00:20:25.840" region="bottomCenter">But he can also</p>
      <p xml:id="p304" begin="00:20:25.960" end="00:20:26.920" region="bottomCenter">achieve immortality!</p>
      <p xml:id="p305" begin="00:20:27.640" end="00:20:29.600" region="bottomCenter">Does that mean I won't be<br/>a demon anymore?</p>
      <p xml:id="p306" begin="00:20:29.720" end="00:20:33.040" region="bottomCenter">This will save<br/>both Ao Bing and Nezha</p>
      <p xml:id="p307" begin="00:20:33.160" end="00:20:35.680" region="bottomCenter">Eve... everyone is happy</p>
      <p xml:id="p308" begin="00:20:35.840" end="00:20:37.760" region="bottomCenter">This isn't the right thing to do</p>
      <p xml:id="p309" begin="00:20:38.200" end="00:20:40.360" region="bottomCenter">Then what do you suggest?</p>
      <p xml:id="p310" begin="00:20:40.480" end="00:20:42.200" region="bottomCenter">Follow the rules</p>
      <p xml:id="p311" begin="00:20:42.520" end="00:20:43.840" region="bottomCenter">Come clean with the Supreme Lord</p>
      <p xml:id="p312" begin="00:20:43.960" end="00:20:45.880" region="bottomCenter">and trust his judgement</p>
      <p xml:id="p313" begin="00:20:46.000" end="00:20:48.120" region="bottomCenter">My wife and I will<br/>also plead for mercy</p>
      <p xml:id="p314" begin="00:20:48.240" end="00:20:51.720" region="bottomCenter">so the sins of the parents<br/>don't affect the children</p>
      <p xml:id="p315" begin="00:20:51.880" end="00:20:53.880" region="bottomCenter">Mere mortals</p>
      <p xml:id="p316" begin="00:20:54.000" end="00:20:56.160" region="bottomCenter">you have only decades<br/>of life experience</p>
      <p xml:id="p317" begin="00:20:56.280" end="00:20:59.080" region="bottomCenter">how dare you lecture me<br/>about morality?</p>
      <p xml:id="p318" begin="00:21:06.400" end="00:21:08.480" region="bottomCenter">Longer than I could remember</p>
      <p xml:id="p319" begin="00:21:08.600" end="00:21:10.800" region="bottomCenter">I've lived for thousands of years</p>
      <p xml:id="p320" begin="00:21:10.920" end="00:21:14.200" region="bottomCenter">Let me tell you one truth<br/>and one truth only</p>
      <p xml:id="p321" begin="00:21:14.320" end="00:21:16.560" region="bottomCenter">If my son die</p>
      <p xml:id="p322" begin="00:21:16.680" end="00:21:19.840" region="bottomCenter">I'll have Chentang Pass<br/>sink with him</p>
      <p xml:id="p323" begin="00:21:27.120" end="00:21:28.320" region="bottomCenter">Stop!</p>
      <p xml:id="p324" begin="00:21:29.160" end="00:21:30.880" region="bottomCenter">Ao Bing is my friend</p>
      <p xml:id="p325" begin="00:21:31.000" end="00:21:32.920" region="bottomCenter">I will save him for sure</p>
      <p xml:id="p326" begin="00:21:33.040" end="00:21:35.040" region="bottomCenter">But if you dare<br/>to harm Chentang Pass</p>
      <p xml:id="p327" begin="00:21:35.160" end="00:21:36.840" region="bottomCenter">I'll smash your Loong Palace</p>
      <p xml:id="p328" begin="00:21:36.960" end="00:21:38.640" region="bottomCenter">into P-I-E-C-E-S!</p>
      <p xml:id="p329" begin="00:21:44.040" end="00:21:45.880" region="bottomCenter">Except for Nezha and Taiyi</p>
      <p xml:id="p330" begin="00:21:46.000" end="00:21:49.400" region="bottomCenter">no one leaves Chentang Pass<br/>from now on</p>
      <p xml:id="p331" begin="00:21:49.520" end="00:21:51.880" region="bottomCenter">If in seven days<br/>I don't see Elixir Reparo</p>
      <p xml:id="p332" begin="00:21:52.000" end="00:21:54.960" region="bottomCenter">or the news of my clan gets out</p>
      <p xml:id="p333" begin="00:21:55.080" end="00:21:57.240" region="bottomCenter">I'll let Chentang Pass</p>
      <p xml:id="p334" begin="00:21:57.360" end="00:21:58.720" region="bottomCenter">sink forever</p>
      <p xml:id="p335" begin="00:21:59.920" end="00:22:02.040" region="bottomCenter">I don't trust my siblings</p>
      <p xml:id="p336" begin="00:22:02.160" end="00:22:04.640" region="bottomCenter">and I can't stay<br/>out of my body for long</p>
      <p xml:id="p337" begin="00:22:04.760" end="00:22:06.440" region="bottomCenter">The fate of Chentang Pass</p>
      <p xml:id="p338" begin="00:22:06.560" end="00:22:07.960" region="bottomCenter">is in your hands</p>
      <p xml:id="p339" begin="00:22:12.600" end="00:22:13.440" region="bottomCenter">Yes</p>
      <p xml:id="p340" begin="00:22:13.640" end="00:22:14.720" region="bottomCenter">Exactly</p>
      <p xml:id="p341" begin="00:22:14.840" end="00:22:16.560" region="bottomCenter">There's no message<br/>that can't be conveyed</p>
      <p xml:id="p342" begin="00:22:16.680" end="00:22:18.160" region="bottomCenter">with just a nod</p>
      <p xml:id="p343" begin="00:22:25.440" end="00:22:26.920" region="bottomCenter">Lord Li</p>
      <p xml:id="p344" begin="00:22:27.040" end="00:22:29.840" region="bottomCenter">we're all here to say goodbye<br/>to Young Master Nezha</p>
      <p xml:id="p345" begin="00:22:29.960" end="00:22:33.680" region="bottomCenter">We want to thank him<br/>for saving the entire city</p>
      <p xml:id="p346" begin="00:22:33.840" end="00:22:35.000" region="bottomCenter">You're too kind</p>
      <p xml:id="p347" begin="00:22:35.120" end="00:22:36.400" region="bottomCenter">My son has caused enough troubles</p>
      <p xml:id="p348" begin="00:22:36.520" end="00:22:37.720" region="bottomCenter">over the years</p>
      <p xml:id="p349" begin="00:22:38.240" end="00:22:42.560" region="bottomCenter">I always knew the Young Master<br/>was destined for greatness</p>
      <p xml:id="p350" begin="00:22:42.680" end="00:22:43.680" region="bottomCenter">Look at him</p>
      <p xml:id="p351" begin="00:22:43.800" end="00:22:45.120" region="bottomCenter">a wide forehead</p>
      <p xml:id="p352" begin="00:22:45.240" end="00:22:46.480" region="bottomCenter">broad face</p>
      <p xml:id="p353" begin="00:22:46.600" end="00:22:47.960" region="bottomCenter">prominent nose</p>
      <p xml:id="p354" begin="00:22:48.080" end="00:22:49.640" region="bottomCenter">full cheeks and thick lips</p>
      <p xml:id="p355" begin="00:22:49.760" end="00:22:53.160" region="bottomCenter">All signs of a true hero!</p>
      <p xml:id="p356" begin="00:22:53.280" end="00:22:54.480" region="bottomCenter">I've never been wrong<br/>in reading faces</p>
      <p xml:id="p357" begin="00:22:59.480" end="00:23:02.400" region="bottomCenter">Young Master, remember to brush<br/>your teeth after meals!</p>
      <p xml:id="p358" begin="00:23:03.720" end="00:23:04.720" region="bottomCenter">Boss</p>
      <p xml:id="p359" begin="00:23:05.360" end="00:23:07.640" region="bottomCenter">the Demon Slayers is now rebranded<br/>as the Nezha Gang</p>
      <p xml:id="p360" begin="00:23:07.760" end="00:23:10.600" region="bottomCenter">All members will follow your orders</p>
      <p xml:id="p361" begin="00:23:11.480" end="00:23:12.520" region="bottomCenter">Young Master,<br/>want to practice calligraphy?</p>
      <p xml:id="p362" begin="00:23:12.640" end="00:23:13.480" region="bottomCenter">I'm here for you!</p>
      <p xml:id="p363" begin="00:23:13.600" end="00:23:14.600" region="bottomCenter">Young Master,<br/>you're three years old now</p>
      <p xml:id="p364" begin="00:23:14.720" end="00:23:15.840" region="bottomCenter">It's time to get a girlfriend</p>
      <p xml:id="p365" begin="00:23:15.960" end="00:23:16.840" region="bottomCenter">Any interests in instrument?</p>
      <p xml:id="p366" begin="00:23:16.960" end="00:23:17.880" region="bottomCenter">We're proficient in all of them</p>
      <p xml:id="p367" begin="00:23:20.920" end="00:23:22.120" region="bottomCenter">I want to</p>
      <p xml:id="p368" begin="00:23:22.480" end="00:23:23.480" region="bottomCenter">play shuttlecock</p>
      <p xml:id="p369" begin="00:23:25.160" end="00:23:26.000" region="bottomCenter">What?</p>
      <p xml:id="p370" begin="00:23:26.120" end="00:23:26.960" region="bottomCenter">It's fun</p>
      <p xml:id="p371" begin="00:23:27.560" end="00:23:28.520" region="bottomCenter">Anyone?</p>
      <p xml:id="p372" begin="00:23:32.560" end="00:23:33.600" region="bottomCenter">I'll play with you</p>
      <p xml:id="p373" begin="00:23:34.360" end="00:23:36.800" region="bottomCenter">Didn't you always want to play<br/>shuttlecock with me?</p>
      <p xml:id="p374" begin="00:23:37.160" end="00:23:39.240" region="bottomCenter">Well...<br/>he's a bit hard on the kicks</p>
      <p xml:id="p375" begin="00:23:40.800" end="00:23:42.440" region="bottomCenter">I'm a general of war!</p>
      <p xml:id="p376" begin="00:23:44.560" end="00:23:45.400" region="bottomCenter">Dad</p>
      <p xml:id="p377" begin="00:23:45.520" end="00:23:46.760" region="bottomCenter">That's my boy!</p>
      <p xml:id="p378" begin="00:23:48.440" end="00:23:50.400" region="bottomCenter">How about...<br/>we play it another day?</p>
      <p xml:id="p379" begin="00:23:50.520" end="00:23:51.800" region="bottomCenter">Nonsense!</p>
      <p xml:id="p380" begin="00:23:51.920" end="00:23:53.600" region="bottomCenter">Why stop when you're having fun?</p>
      <p xml:id="p381" begin="00:23:53.920" end="00:23:54.960" region="bottomCenter">It's fine. I'm fine</p>
      <p xml:id="p382" begin="00:23:55.400" end="00:23:56.480" region="bottomCenter">I'll join too!</p>
      <p xml:id="p383" begin="00:23:56.600" end="00:23:58.160" region="bottomCenter">My lady, you don't have to do this</p>
      <p xml:id="p384" begin="00:23:58.280" end="00:23:59.360" region="bottomCenter">Are you looking down on me?</p>
      <p xml:id="p385" begin="00:23:59.480" end="00:24:00.680" region="bottomCenter">I'm also a general of war!</p>
      <p xml:id="p386" begin="00:24:01.520" end="00:24:02.920" region="bottomCenter">Nezha, catch this!</p>
      <p xml:id="p387" begin="00:24:05.440" end="00:24:06.400" region="bottomCenter">Kiddo</p>
      <p xml:id="p388" begin="00:24:06.520" end="00:24:07.640" region="bottomCenter">how did you miss that?</p>
      <p xml:id="p389" begin="00:24:08.320" end="00:24:10.000" region="bottomCenter">If only I weren't the Demon Orb...</p>
      <p xml:id="p390" begin="00:24:10.200" end="00:24:11.160" region="bottomCenter">What was that?</p>
      <p xml:id="p391" begin="00:24:11.280" end="00:24:12.360" region="bottomCenter">Nothing</p>
      <p xml:id="p392" begin="00:24:12.480" end="00:24:13.680" region="bottomCenter">It's time to go</p>
      <p xml:id="p393" begin="00:24:14.040" end="00:24:15.360" region="bottomCenter">Before you go</p>
      <p xml:id="p394" begin="00:24:15.480" end="00:24:16.640" region="bottomCenter">will you give your mother</p>
      <p xml:id="p395" begin="00:24:17.040" end="00:24:18.120" region="bottomCenter">a big hug?</p>
      <p xml:id="p396" begin="00:24:21.600" end="00:24:23.200" region="bottomCenter">Please, people are watching</p>
      <p xml:id="p397" begin="00:24:25.720" end="00:24:26.640" region="bottomCenter">Wait</p>
      <p xml:id="p398" begin="00:24:28.240" end="00:24:30.040" region="bottomCenter">Here are some snacks I made</p>
      <p xml:id="p399" begin="00:24:30.280" end="00:24:31.520" region="bottomCenter">For you and your master on the road</p>
      <p xml:id="p400" begin="00:24:31.640" end="00:24:33.040" region="bottomCenter">Okay, okay<br/>We need to go</p>
      <p xml:id="p401" begin="00:24:33.200" end="00:24:35.160" region="bottomCenter">Hey! I'm not on board yet!</p>
      <p xml:id="p402" begin="00:24:41.160" end="00:24:42.600" region="bottomCenter">Your body isn't fully fixed</p>
      <p xml:id="p403" begin="00:24:42.720" end="00:24:44.080" region="bottomCenter">Don't use too much force</p>
      <p xml:id="p404" begin="00:24:44.200" end="00:24:45.040" region="bottomCenter">Alright, alright</p>
      <p xml:id="p405" begin="00:24:45.560" end="00:24:47.040" region="bottomCenter">And watch your temper</p>
      <p xml:id="p406" begin="00:24:47.160" end="00:24:49.160" region="bottomCenter">Try to stay calm out there</p>
      <p xml:id="p407" begin="00:24:49.800" end="00:24:51.840" region="bottomCenter">Without me and your father<br/>by your side</p>
      <p xml:id="p408" begin="00:24:51.960" end="00:24:54.520" region="bottomCenter">learn to take care of yourself</p>
      <p xml:id="p409" begin="00:24:55.480" end="00:24:57.040" region="bottomCenter">You silly child</p>
      <p xml:id="p410" begin="00:24:57.160" end="00:24:58.800" region="bottomCenter">What's wrong with just a hug?</p>
      <p xml:id="p411" begin="00:24:59.200" end="00:25:00.960" region="bottomCenter">That's too much<br/>It's not a farewell anyway</p>
      <p xml:id="p412" begin="00:25:01.080" end="00:25:02.000" region="bottomCenter">Let's move</p>
      <p xml:id="p413" begin="00:25:19.400" end="00:25:21.400" region="bottomCenter">Why are you sighing?<br/>Taste bad?</p>
      <p xml:id="p414" begin="00:25:21.520" end="00:25:23.000" region="bottomCenter">Food, food, food<br/>All you know is food</p>
      <p xml:id="p415" begin="00:25:23.240" end="00:25:24.240" region="bottomCenter">Look at me</p>
      <p xml:id="p416" begin="00:25:24.360" end="00:25:25.320" region="bottomCenter">I'm too worried to even eat!</p>
      <p xml:id="p417" begin="00:25:25.440" end="00:25:27.280" region="bottomCenter">Have you thought<br/>about how to pass the trial?</p>
      <p xml:id="p418" begin="00:25:28.840" end="00:25:30.600" region="bottomCenter">What is the trial about?</p>
      <p xml:id="p419" begin="00:25:30.720" end="00:25:32.680" region="bottomCenter">It'll test the progress<br/>of your cultivation</p>
      <p xml:id="p420" begin="00:25:33.080" end="00:25:34.480" region="bottomCenter">In front of the judges</p>
      <p xml:id="p421" begin="00:25:34.600" end="00:25:37.080" region="bottomCenter">you must defeat, barehanded three<br/>demon kings of earth-monster level</p>
      <p xml:id="p422" begin="00:25:37.200" end="00:25:39.120" region="bottomCenter">Fighting...<br/>That's my specialty!</p>
      <p xml:id="p423" begin="00:25:39.640" end="00:25:40.560" region="bottomCenter">But as soon as you<br/>give off demonic energy</p>
      <p xml:id="p424" begin="00:25:40.680" end="00:25:41.520" region="bottomCenter">your identity will be exposed</p>
      <p xml:id="p425" begin="00:25:41.640" end="00:25:43.040" region="bottomCenter">Just let Ao Bing control my body</p>
      <p xml:id="p426" begin="00:25:43.160" end="00:25:44.200" region="bottomCenter">His divine energy</p>
      <p xml:id="p427" begin="00:25:44.320" end="00:25:45.240" region="bottomCenter">will be just as powerful</p>
      <p xml:id="p428" begin="00:25:45.920" end="00:25:47.520" region="bottomCenter">Sounds easy<br/>Let's try</p>
      <p xml:id="p429" begin="00:25:48.600" end="00:25:51.200" region="bottomCenter">Nezha, fully relax your body</p>
      <p xml:id="p430" begin="00:25:51.320" end="00:25:54.480" region="bottomCenter">Let Ao Bing take control<br/>and fight me</p>
      <p xml:id="p431" begin="00:25:57.600" end="00:25:58.960" region="bottomCenter">Ao Bing, what are you doing?</p>
      <p xml:id="p432" begin="00:25:59.080" end="00:25:59.920" region="bottomCenter">Keep steady!</p>
      <p xml:id="p433" begin="00:26:00.040" end="00:26:01.680" region="bottomCenter">When a soul inhabits another body</p>
      <p xml:id="p434" begin="00:26:01.800" end="00:26:04.000" region="bottomCenter">unless your willpower is<br/>much stronger than the host's</p>
      <p xml:id="p435" begin="00:26:04.120" end="00:26:06.240" region="bottomCenter">you won't be able<br/>to fully control it</p>
      <p xml:id="p436" begin="00:26:09.240" end="00:26:10.520" region="bottomCenter">Nezha, step back</p>
      <p xml:id="p437" begin="00:26:10.680" end="00:26:12.200" region="bottomCenter">The harder you push</p>
      <p xml:id="p438" begin="00:26:12.320" end="00:26:13.720" region="bottomCenter">the less Ao Bing can control</p>
      <p xml:id="p439" begin="00:26:14.640" end="00:26:15.600" region="bottomCenter">Use your leg!</p>
      <p xml:id="p440" begin="00:26:15.880" end="00:26:17.480" region="bottomCenter">Sweep him, sweep him!</p>
      <p xml:id="p441" begin="00:26:25.960" end="00:26:28.400" region="bottomCenter">Don't panic! I'm coming...</p>
      <p xml:id="p442" begin="00:26:30.760" end="00:26:31.800" region="bottomCenter">for you</p>
      <p xml:id="p443" begin="00:26:38.680" end="00:26:39.960" region="bottomCenter">Having fun, huh?</p>
      <p xml:id="p444" begin="00:26:40.240" end="00:26:42.280" region="bottomCenter">We're almost at Yu Xu Palace<br/>and you're still messing around</p>
      <p xml:id="p445" begin="00:26:42.520" end="00:26:44.720" region="bottomCenter">Look at yourself<br/>what kind of mentor are you?</p>
      <p xml:id="p446" begin="00:26:44.840" end="00:26:46.320" region="bottomCenter">Stand here<br/>and reflect on your mistakes</p>
      <p xml:id="p447" begin="00:26:46.440" end="00:26:47.800" region="bottomCenter">No meals until you figure it out!</p>
      <p xml:id="p448" begin="00:26:48.400" end="00:26:49.240" region="bottomCenter">You're a grown man</p>
      <p xml:id="p449" begin="00:26:49.360" end="00:26:50.800" region="bottomCenter">Stop acting like a reckless teenager</p>
      <p xml:id="p450" begin="00:26:52.920" end="00:26:53.760" region="bottomCenter">I got it!</p>
      <p xml:id="p451" begin="00:26:53.880" end="00:26:56.040" region="bottomCenter">The Sleepy-Slumber Pill</p>
      <p xml:id="p452" begin="00:26:56.800" end="00:26:57.680" region="bottomCenter">What's that?</p>
      <p xml:id="p453" begin="00:26:57.840" end="00:26:59.800" region="bottomCenter">Take this,<br/>and you'll fall asleep immediately</p>
      <p xml:id="p454" begin="00:26:59.920" end="00:27:01.080" region="bottomCenter">Once you're asleep</p>
      <p xml:id="p455" begin="00:27:01.200" end="00:27:03.480" region="bottomCenter">Ao Bing can fully control your body</p>
      <p xml:id="p456" begin="00:27:03.640" end="00:27:04.640" region="bottomCenter">Brilliant!</p>
      <p xml:id="p457" begin="00:27:06.360" end="00:27:07.360" region="bottomCenter">One is enough</p>
      <p xml:id="p458" begin="00:27:07.720" end="00:27:09.840" region="bottomCenter">Should've told me...earlier</p>
      <p xml:id="p459" begin="00:27:12.120" end="00:27:13.160" region="bottomCenter">Perfect</p>
      <p xml:id="p460" begin="00:27:20.600" end="00:27:21.640" region="bottomCenter">Master Taiyi?</p>
      <p xml:id="p461" begin="00:27:23.080" end="00:27:25.440" region="bottomCenter">Now this feels like the real deal</p>
      <p xml:id="p462" begin="00:27:25.800" end="00:27:26.760" region="bottomCenter">What's wrong?</p>
      <p xml:id="p463" begin="00:27:28.000" end="00:27:29.400" region="bottomCenter">Don't worry</p>
      <p xml:id="p464" begin="00:27:29.520" end="00:27:32.760" region="bottomCenter">I see you've completely<br/>taken over Nezha's body</p>
      <p xml:id="p465" begin="00:27:32.880" end="00:27:33.960" region="bottomCenter">Let's go again</p>
      <p xml:id="p466" begin="00:27:35.600" end="00:27:38.080" region="bottomCenter">This time, I won't hold back</p>
      <p xml:id="p467" begin="00:27:38.320" end="00:27:40.960" region="bottomCenter">You'd better give it your all, too</p>
      <p xml:id="p468" begin="00:27:51.480" end="00:27:53.000" region="bottomCenter">I humbly seek your guidance</p>
      <p xml:id="p469" begin="00:27:53.600" end="00:27:54.760" region="bottomCenter">Not bad</p>
      <p xml:id="p470" begin="00:27:54.880" end="00:27:56.480" region="bottomCenter">Barely able to match my skills</p>
      <p xml:id="p471" begin="00:27:56.600" end="00:27:58.280" region="bottomCenter">Master Taiyi, your nose is bleeding</p>
      <p xml:id="p472" begin="00:27:59.480" end="00:28:01.080" region="bottomCenter">Too heaty recently<br/>Need more water</p>
      <p xml:id="p473" begin="00:28:01.200" end="00:28:02.280" region="bottomCenter">No big deal</p>
      <p xml:id="p474" begin="00:28:10.440" end="00:28:12.920" region="bottomCenter">Kunlun Mountain! We're here</p>
      <p xml:id="p475" begin="00:28:13.360" end="00:28:14.360" region="bottomCenter">I heard a day here</p>
      <p xml:id="p476" begin="00:28:14.480" end="00:28:15.680" region="bottomCenter">equals a year in the mortal world</p>
      <p xml:id="p477" begin="00:28:15.920" end="00:28:18.040" region="bottomCenter">Don't worry,<br/>we're not in the celestial realm yet</p>
      <p xml:id="p478" begin="00:28:18.160" end="00:28:19.000" region="bottomCenter">But this many people?</p>
      <p xml:id="p479" begin="00:28:19.120" end="00:28:20.640" region="bottomCenter">They've all come to seek immortality</p>
      <p xml:id="p480" begin="00:28:20.760" end="00:28:21.920" region="bottomCenter">Chan Sect is famous across the world</p>
      <p xml:id="p481" begin="00:28:22.040" end="00:28:23.800" region="bottomCenter">and everyone wants to join</p>
      <p xml:id="p482" begin="00:28:24.680" end="00:28:26.960" region="bottomCenter">Look at this. The jasper</p>
      <p xml:id="p483" begin="00:28:27.080" end="00:28:28.720" region="bottomCenter">It's the credential<br/>of a Chan Sect immortal</p>
      <p xml:id="p484" begin="00:28:28.840" end="00:28:29.680" region="bottomCenter">With it</p>
      <p xml:id="p485" begin="00:28:29.800" end="00:28:32.560" region="bottomCenter">you'll receive respect<br/>everywhere you go, I'm telling ya</p>
      <p xml:id="p486" begin="00:28:32.680" end="00:28:34.040" region="bottomCenter">Being an immortal is amazing</p>
      <p xml:id="p487" begin="00:28:34.400" end="00:28:35.520" region="bottomCenter">Both of your brothers have ascended</p>
      <p xml:id="p488" begin="00:28:35.640" end="00:28:36.760" region="bottomCenter">You'll have no problem either</p>
      <p xml:id="p489" begin="00:28:37.160" end="00:28:38.360" region="bottomCenter">I mean Nezha's brothers</p>
      <p xml:id="p490" begin="00:28:38.560" end="00:28:39.880" region="bottomCenter">His two brothers</p>
      <p xml:id="p491" begin="00:28:40.000" end="00:28:42.160" region="bottomCenter">are among the best<br/>of the third-generation disciples</p>
      <p xml:id="p492" begin="00:28:42.280" end="00:28:43.400" region="bottomCenter">You know</p>
      <p xml:id="p493" begin="00:28:43.520" end="00:28:44.960" region="bottomCenter">how Nezha always misbehaves, right?</p>
      <p xml:id="p494" begin="00:28:45.080" end="00:28:47.960" region="bottomCenter">So, I often tell stories<br/>about his brothers</p>
      <p xml:id="p495" begin="00:28:48.080" end="00:28:49.600" region="bottomCenter">to set a good example for him</p>
      <p xml:id="p496" begin="00:28:49.720" end="00:28:50.800" region="bottomCenter">Let me tell you something</p>
      <p xml:id="p497" begin="00:28:50.920" end="00:28:52.720" region="bottomCenter">Nezha idolizes his brothers</p>
      <p xml:id="p498" begin="00:29:15.480" end="00:29:16.640" region="bottomCenter">Oh wow, you're lucky...</p>
      <p xml:id="p499" begin="00:29:16.760" end="00:29:18.760" region="bottomCenter">to meet the well-known Demon Hunters</p>
      <p xml:id="p500" begin="00:29:19.120" end="00:29:20.160" region="bottomCenter">Demon Hunters?</p>
      <p xml:id="p501" begin="00:29:20.280" end="00:29:23.120" region="bottomCenter">They roam the land, hunting down<br/>demons that wreak havoc on humanity</p>
      <p xml:id="p502" begin="00:29:23.240" end="00:29:25.400" region="bottomCenter">keeping the world at peace</p>
      <p xml:id="p503" begin="00:29:26.320" end="00:29:28.040" region="bottomCenter">The current leader<br/>of the Demon Hunters</p>
      <p xml:id="p504" begin="00:29:28.160" end="00:29:30.160" region="bottomCenter">is the top disciple<br/>of Immortal Wuliang</p>
      <p xml:id="p505" begin="00:29:30.640" end="00:29:32.960" region="bottomCenter">Isn't his predecessor Shen Gongbao?</p>
      <p xml:id="p506" begin="00:29:47.560" end="00:29:49.520" region="bottomCenter">Master Taiyi<br/>what's that smoke over there?</p>
      <p xml:id="p507" begin="00:29:49.760" end="00:29:52.720" region="bottomCenter">Oh, that's the most<br/>precious treasure of Yu Xu Palace</p>
      <p xml:id="p508" begin="00:29:52.840" end="00:29:54.760" region="bottomCenter">The Tianyuan Cauldron</p>
      <p xml:id="p509" begin="00:30:03.400" end="00:30:06.480" region="bottomCenter">Brother Taiyi<br/>it's been forever</p>
      <p xml:id="p510" begin="00:30:07.400" end="00:30:08.480" region="bottomCenter">Brother Wuliang!</p>
      <p xml:id="p511" begin="00:30:08.680" end="00:30:10.160" region="bottomCenter">I heard that<br/>during Master's seclusion</p>
      <p xml:id="p512" begin="00:30:10.280" end="00:30:12.160" region="bottomCenter">you've been in charge<br/>of Yu Xu Palace</p>
      <p xml:id="p513" begin="00:30:12.280" end="00:30:14.240" region="bottomCenter">I've brought my disciple to<br/>participate in the Ascension Trial</p>
      <p xml:id="p514" begin="00:30:14.480" end="00:30:16.640" region="bottomCenter">Nezha, come meet Master Wuliang</p>
      <p xml:id="p515" begin="00:30:16.840" end="00:30:17.960" region="bottomCenter">Master Wuliang</p>
      <p xml:id="p516" begin="00:30:18.240" end="00:30:19.720" region="bottomCenter">So, you're Nezha?</p>
      <p xml:id="p517" begin="00:30:19.840" end="00:30:21.160" region="bottomCenter">The reincarnation<br/>of the Spirit Pearl?</p>
      <p xml:id="p518" begin="00:30:21.560" end="00:30:23.400" region="bottomCenter">Oh my!</p>
      <p xml:id="p519" begin="00:30:23.520" end="00:30:25.200" region="bottomCenter">How remarkable!</p>
      <p xml:id="p520" begin="00:30:25.320" end="00:30:29.000" region="bottomCenter">The Supreme Lord holds<br/>great expectations for you</p>
      <p xml:id="p521" begin="00:30:29.120" end="00:30:30.560" region="bottomCenter">And you sure don't disappoint</p>
      <p xml:id="p522" begin="00:30:30.680" end="00:30:31.720" region="bottomCenter">Look at him</p>
      <p xml:id="p523" begin="00:30:31.920" end="00:30:34.040" region="bottomCenter">so full of robust vitality</p>
      <p xml:id="p524" begin="00:30:34.160" end="00:30:36.000" region="bottomCenter">giving off a righteous vibe</p>
      <p xml:id="p525" begin="00:30:44.560" end="00:30:46.080" region="bottomCenter">The boy's been over training lately</p>
      <p xml:id="p526" begin="00:30:46.200" end="00:30:47.480" region="bottomCenter">His state is a bit unstable</p>
      <p xml:id="p527" begin="00:30:50.680" end="00:30:52.120" region="bottomCenter">What do you think you're doing?</p>
      <p xml:id="p528" begin="00:30:52.240" end="00:30:53.720" region="bottomCenter">This is Yu Xu Palace!</p>
      <p xml:id="p529" begin="00:30:53.840" end="00:30:55.320" region="bottomCenter">I need to pee</p>
      <p xml:id="p530" begin="00:30:55.560" end="00:30:57.280" region="bottomCenter">- Crana!<br/>- Here!</p>
      <p xml:id="p531" begin="00:30:57.440" end="00:30:59.720" region="bottomCenter">Take the child to the restroom</p>
      <p xml:id="p532" begin="00:31:00.000" end="00:31:01.840" region="bottomCenter">Restroom?<br/>I didn't say anything about resting</p>
      <p xml:id="p533" begin="00:31:01.960" end="00:31:03.120" region="bottomCenter">Idiot!</p>
      <p xml:id="p534" begin="00:31:03.800" end="00:31:04.960" region="bottomCenter">Restroom</p>
      <p xml:id="p535" begin="00:31:05.080" end="00:31:07.480" region="bottomCenter">is where you pee</p>
      <p xml:id="p536" begin="00:31:08.360" end="00:31:09.840" region="bottomCenter">The boy's a bit rough</p>
      <p xml:id="p537" begin="00:31:09.960" end="00:31:10.960" region="bottomCenter">Please forgive him</p>
      <p xml:id="p538" begin="00:31:18.360" end="00:31:20.320" region="bottomCenter">Wow! So white!</p>
      <p xml:id="p539" begin="00:31:22.000" end="00:31:23.520" region="bottomCenter">Wow! So white!</p>
      <p xml:id="p540" begin="00:31:25.160" end="00:31:26.520" region="bottomCenter">Wow! So white!</p>
      <p xml:id="p541" begin="00:31:27.920" end="00:31:29.640" region="bottomCenter">Is the entire palace made of jade?</p>
      <p xml:id="p542" begin="00:31:29.880" end="00:31:31.760" region="bottomCenter">Where did they get<br/>so much money to buy jade?</p>
      <p xml:id="p543" begin="00:31:31.960" end="00:31:34.360" region="bottomCenter">The "Yu" in Yu Xu Palace<br/>means jade, right?</p>
      <p xml:id="p544" begin="00:31:34.480" end="00:31:35.960" region="bottomCenter">Then what does the "Xu" mean?</p>
      <p xml:id="p545" begin="00:31:36.120" end="00:31:37.320" region="bottomCenter">Humble?</p>
      <p xml:id="p546" begin="00:31:37.440" end="00:31:38.840" region="bottomCenter">Guilty? Or emptiness?</p>
      <p xml:id="p547" begin="00:31:40.000" end="00:31:41.360" region="bottomCenter">Is the restroom also made of jade?</p>
      <p xml:id="p548" begin="00:31:41.680" end="00:31:43.200" region="bottomCenter">Even immortals need to pee?</p>
      <p xml:id="p549" begin="00:31:44.360" end="00:31:46.000" region="bottomCenter">Does Master Wuliang also... poop?</p>
      <p xml:id="p550" begin="00:31:47.280" end="00:31:49.160" region="bottomCenter">This is a place of seclusion<br/>Lower your voice</p>
      <p xml:id="p551" begin="00:31:50.240" end="00:31:51.520" region="bottomCenter">How much further is the restroom?</p>
      <p xml:id="p552" begin="00:31:51.640" end="00:31:52.600" region="bottomCenter">I can't hold it anymore!</p>
      <p xml:id="p553" begin="00:31:52.760" end="00:31:53.720" region="bottomCenter">Hey, sister, wait for me!</p>
      <p xml:id="p554" begin="00:31:55.520" end="00:31:56.440" region="bottomCenter">You...</p>
      <p xml:id="p555" begin="00:31:57.880" end="00:31:58.920" region="bottomCenter">I didn't mean it</p>
      <p xml:id="p556" begin="00:31:59.120" end="00:32:00.040" region="bottomCenter">I need to change my skirt</p>
      <p xml:id="p557" begin="00:32:00.160" end="00:32:01.040" region="bottomCenter">Go by yourself</p>
      <p xml:id="p558" begin="00:32:01.360" end="00:32:02.680" region="bottomCenter">But I don't know<br/>where the restroom is</p>
      <p xml:id="p559" begin="00:32:02.800" end="00:32:04.320" region="bottomCenter">Go through the corridor,<br/>turn right, then left</p>
      <p xml:id="p560" begin="00:32:06.160" end="00:32:07.360" region="bottomCenter">Oh</p>
      <p xml:id="p561" begin="00:32:21.360" end="00:32:24.000" region="bottomCenter">Wow! How fancy it is!</p>
      <p xml:id="p562" begin="00:32:24.120" end="00:32:25.960" region="bottomCenter">Radical!</p>
      <p xml:id="p563" begin="00:32:50.360" end="00:32:52.600" region="bottomCenter">Emm... Am I lost?</p>
      <p xml:id="p564" begin="00:32:53.800" end="00:32:54.880" region="bottomCenter">Where are you going?</p>
      <p xml:id="p565" begin="00:32:55.120" end="00:32:56.680" region="bottomCenter">Oh, I got lost</p>
      <p xml:id="p566" begin="00:32:57.640" end="00:32:58.560" region="bottomCenter">Follow me</p>
      <p xml:id="p567" begin="00:33:00.480" end="00:33:03.240" region="bottomCenter">Brother, good job<br/>on raising the Spirit Pearl</p>
      <p xml:id="p568" begin="00:33:03.360" end="00:33:06.720" region="bottomCenter">Another great achievement<br/>for the Sect</p>
      <p xml:id="p569" begin="00:33:06.840" end="00:33:09.320" region="bottomCenter">Not at all<br/>It's all thanks to Master's guidance</p>
      <p xml:id="p570" begin="00:33:09.840" end="00:33:13.320" region="bottomCenter">This Kunlun Dew is a rare elixir</p>
      <p xml:id="p571" begin="00:33:13.440" end="00:33:16.040" region="bottomCenter">Normally, it takes six months<br/>to fill a basin</p>
      <p xml:id="p572" begin="00:33:16.160" end="00:33:17.720" region="bottomCenter">But today,<br/>when I sent someone to check</p>
      <p xml:id="p573" begin="00:33:17.840" end="00:33:19.200" region="bottomCenter">it's already full!</p>
      <p xml:id="p574" begin="00:33:20.080" end="00:33:22.960" region="bottomCenter">Your timing couldn't be better</p>
      <p xml:id="p575" begin="00:33:23.080" end="00:33:24.040" region="bottomCenter">Brother</p>
      <p xml:id="p576" begin="00:33:24.160" end="00:33:26.720" region="bottomCenter">luck sure favors you, doesn't it?</p>
      <p xml:id="p577" begin="00:33:30.480" end="00:33:32.800" region="bottomCenter">What's wrong with you?<br/>Can't even drink water properly</p>
      <p xml:id="p578" begin="00:33:33.240" end="00:33:34.680" region="bottomCenter">My disciple is a bit crude</p>
      <p xml:id="p579" begin="00:33:34.800" end="00:33:35.720" region="bottomCenter">Please forgive him</p>
      <p xml:id="p580" begin="00:33:37.400" end="00:33:39.200" region="bottomCenter">My pee is in the water</p>
      <p xml:id="p581" begin="00:33:43.320" end="00:33:44.720" region="bottomCenter">My master is a bit crude, too</p>
      <p xml:id="p582" begin="00:33:44.840" end="00:33:45.720" region="bottomCenter">Please forgive him</p>
      <p xml:id="p583" begin="00:33:46.280" end="00:33:47.840" region="bottomCenter">Brother<br/>time is of the essence</p>
      <p xml:id="p584" begin="00:33:47.960" end="00:33:50.240" region="bottomCenter">I think Nezha should go<br/>through the trial immediately</p>
      <p xml:id="p585" begin="00:33:50.480" end="00:33:52.000" region="bottomCenter">Why the rush?</p>
      <p xml:id="p586" begin="00:33:52.120" end="00:33:53.560" region="bottomCenter">Let's have a few more drinks first</p>
      <p xml:id="p587" begin="00:33:53.840" end="00:33:55.040" region="bottomCenter">No more, please</p>
      <p xml:id="p588" begin="00:33:56.400" end="00:33:57.800" region="bottomCenter">Alright then</p>
      <p xml:id="p589" begin="00:33:58.400" end="00:34:01.360" region="bottomCenter">My disciple Deero will be the judge</p>
      <p xml:id="p590" begin="00:34:01.480" end="00:34:03.200" region="bottomCenter">The next target of Demon Hunters</p>
      <p xml:id="p591" begin="00:34:03.320" end="00:34:04.960" region="bottomCenter">could go to Nezha</p>
      <p xml:id="p592" begin="00:34:05.080" end="00:34:06.080" region="bottomCenter">Brother, excuse us</p>
      <p xml:id="p593" begin="00:34:10.000" end="00:34:13.120" region="bottomCenter">Taiyi, my brother<br/>is always so impatient</p>
      <p xml:id="p594" begin="00:34:16.840" end="00:34:19.680" region="bottomCenter">The taste of the Dew this year</p>
      <p xml:id="p595" begin="00:34:22.600" end="00:34:24.120" region="bottomCenter">is especially rich</p>
      <p xml:id="p596" begin="00:34:24.960" end="00:34:27.760" region="bottomCenter">Keep using this method in the future</p>
      <p xml:id="p597" begin="00:34:27.920" end="00:34:28.920" region="bottomCenter">Yes, master</p>
      <p xml:id="p598" begin="00:35:11.200" end="00:35:12.240" region="bottomCenter">Why stop?</p>
      <p xml:id="p599" begin="00:35:12.640" end="00:35:14.520" region="bottomCenter">It's been six hours, Master Shen</p>
      <p xml:id="p600" begin="00:35:14.640" end="00:35:15.760" region="bottomCenter">We're too tired to continue</p>
      <p xml:id="p601" begin="00:35:15.880" end="00:35:18.600" region="bottomCenter">Rubbish!<br/>Cultivation allows no laziness</p>
      <p xml:id="p602" begin="00:35:18.720" end="00:35:20.160" region="bottomCenter">Without my permission</p>
      <p xml:id="p603" begin="00:35:20.280" end="00:35:21.360" region="bottomCenter">you're not allowed to stop</p>
      <p xml:id="p604" begin="00:35:28.520" end="00:35:29.840" region="bottomCenter">General Li Jing of Chentang Pass<br/>is here to see you</p>
      <p xml:id="p605" begin="00:35:30.400" end="00:35:31.520" region="bottomCenter">Master Shen</p>
      <p xml:id="p606" begin="00:35:31.640" end="00:35:32.600" region="bottomCenter">yesterday's battle</p>
      <p xml:id="p607" begin="00:35:32.720" end="00:35:34.880" region="bottomCenter">left many soldiers and civilians<br/>of Chentang Pass injured</p>
      <p xml:id="p608" begin="00:35:35.000" end="00:35:36.440" region="bottomCenter">We've run out of medicine</p>
      <p xml:id="p609" begin="00:35:36.920" end="00:35:39.400" region="bottomCenter">I humbly ask you to open a path</p>
      <p xml:id="p610" begin="00:35:39.520" end="00:35:42.040" region="bottomCenter">so that a few doctors can leave<br/>the city to buy supplies</p>
      <p xml:id="p611" begin="00:35:46.800" end="00:35:48.200" region="bottomCenter">How bold!</p>
      <p xml:id="p612" begin="00:35:48.360" end="00:35:49.240" region="bottomCenter">No wonder you're...</p>
      <p xml:id="p613" begin="00:35:49.840" end="00:35:50.680" region="bottomCenter">Who did that?</p>
      <p xml:id="p614" begin="00:35:51.160" end="00:35:52.360" region="bottomCenter">You son of a...</p>
      <p xml:id="p615" begin="00:35:52.840" end="00:35:53.720" region="bottomCenter">I...</p>
      <p xml:id="p616" begin="00:35:55.360" end="00:35:57.200" region="bottomCenter">St... stop, stop, stop!</p>
      <p xml:id="p617" begin="00:36:03.440" end="00:36:06.000" region="bottomCenter">Bring me the one<br/>you've caught earlier</p>
      <p xml:id="p618" begin="00:36:06.760" end="00:36:09.520" region="bottomCenter">He escaped the city<br/>during the battle</p>
      <p xml:id="p619" begin="00:36:09.640" end="00:36:11.080" region="bottomCenter">General Li, please</p>
      <p xml:id="p620" begin="00:36:11.200" end="00:36:13.240" region="bottomCenter">take him ba... back with you</p>
      <p xml:id="p621" begin="00:36:13.360" end="00:36:14.880" region="bottomCenter">This is a misunderstanding,<br/>Master Shen!</p>
      <p xml:id="p622" begin="00:36:15.000" end="00:36:16.600" region="bottomCenter">I'm a demon too!</p>
      <p xml:id="p623" begin="00:36:16.720" end="00:36:17.800" region="bottomCenter">I captured this Yaksha</p>
      <p xml:id="p624" begin="00:36:17.920" end="00:36:20.560" region="bottomCenter">to clear my son's name</p>
      <p xml:id="p625" begin="00:36:20.680" end="00:36:22.000" region="bottomCenter">Now that it's settled</p>
      <p xml:id="p626" begin="00:36:22.120" end="00:36:24.520" region="bottomCenter">and since he hasn't done<br/>anything worse</p>
      <p xml:id="p627" begin="00:36:24.640" end="00:36:25.760" region="bottomCenter">just let him go</p>
      <p xml:id="p628" begin="00:36:26.240" end="00:36:27.120" region="bottomCenter">Yes, exactly</p>
      <p xml:id="p629" begin="00:36:27.240" end="00:36:29.800" region="bottomCenter">I'm just a small role<br/>Insignificant</p>
      <p xml:id="p630" begin="00:36:30.800" end="00:36:32.920" region="bottomCenter">I don't think you understood me</p>
      <p xml:id="p631" begin="00:36:33.040" end="00:36:36.200" region="bottomCenter">No one leaves here, not even a demon</p>
      <p xml:id="p632" begin="00:36:36.320" end="00:36:37.800" region="bottomCenter">Let alone humans</p>
      <p xml:id="p633" begin="00:36:38.560" end="00:36:40.240" region="bottomCenter">Master Shen, please have mercy</p>
      <p xml:id="p634" begin="00:36:40.360" end="00:36:42.360" region="bottomCenter">I'm a demon, too</p>
      <p xml:id="p635" begin="00:36:42.720" end="00:36:44.800" region="bottomCenter">We are both villains!</p>
      <p xml:id="p636" begin="00:36:44.920" end="00:36:47.280" region="bottomCenter">Pfft! I'm n... not a villain</p>
      <p xml:id="p637" begin="00:36:47.400" end="00:36:48.760" region="bottomCenter">Everyone who knows the secret<br/>of the Spirit Pearl</p>
      <p xml:id="p638" begin="00:36:48.880" end="00:36:50.040" region="bottomCenter">must stay here</p>
      <p xml:id="p639" begin="00:36:50.160" end="00:36:51.520" region="bottomCenter">Without medicine</p>
      <p xml:id="p640" begin="00:36:51.640" end="00:36:54.200" region="bottomCenter">the injured won't survive</p>
      <p xml:id="p641" begin="00:36:55.880" end="00:36:57.400" region="bottomCenter">Master Shen, please</p>
      <p xml:id="p642" begin="00:36:58.680" end="00:37:00.040" region="bottomCenter">I'm only asking to save lives</p>
      <p xml:id="p643" begin="00:37:01.800" end="00:37:02.720" region="bottomCenter">Sir!</p>
      <p xml:id="p644" begin="00:37:02.840" end="00:37:03.960" region="bottomCenter">We caught a spy</p>
      <p xml:id="p645" begin="00:37:04.280" end="00:37:05.480" region="bottomCenter">This man came from outside the city</p>
      <p xml:id="p646" begin="00:37:05.600" end="00:37:06.920" region="bottomCenter">and he injured some of our soldiers</p>
      <p xml:id="p647" begin="00:37:07.040" end="00:37:08.240" region="bottomCenter">Lock... lock him up too</p>
      <p xml:id="p648" begin="00:37:08.560" end="00:37:09.480" region="bottomCenter">Brother</p>
      <p xml:id="p649" begin="00:37:10.120" end="00:37:11.200" region="bottomCenter">Brother, is that you?</p>
      <p xml:id="p650" begin="00:37:11.640" end="00:37:12.840" region="bottomCenter">You...</p>
      <p xml:id="p651" begin="00:37:12.960" end="00:37:14.080" region="bottomCenter">Brother, it's me!</p>
      <p xml:id="p652" begin="00:37:17.800" end="00:37:19.120" region="bottomCenter">Xiaobao?</p>
      <p xml:id="p653" begin="00:37:21.360" end="00:37:22.720" region="bottomCenter">You haven't been home for centuries</p>
      <p xml:id="p654" begin="00:37:22.840" end="00:37:24.120" region="bottomCenter">I miss you so much</p>
      <p xml:id="p655" begin="00:37:25.200" end="00:37:26.280" region="bottomCenter">What are you doing here?</p>
      <p xml:id="p656" begin="00:37:26.400" end="00:37:27.680" region="bottomCenter">Father sent me to find you</p>
      <p xml:id="p657" begin="00:37:27.800" end="00:37:28.640" region="bottomCenter">Look</p>
      <p xml:id="p658" begin="00:37:28.760" end="00:37:29.720" region="bottomCenter">the compass you gave me</p>
      <p xml:id="p659" begin="00:37:29.840" end="00:37:31.160" region="bottomCenter">It tells me where you are</p>
      <p xml:id="p660" begin="00:37:32.600" end="00:37:35.720" region="bottomCenter">Father... how is he doing?</p>
      <p xml:id="p661" begin="00:37:35.840" end="00:37:36.680" region="bottomCenter">He's great</p>
      <p xml:id="p662" begin="00:37:36.800" end="00:37:38.000" region="bottomCenter">Ever since you entered Yu Xu Palace</p>
      <p xml:id="p663" begin="00:37:38.120" end="00:37:40.040" region="bottomCenter">father's been full of energy</p>
      <p xml:id="p664" begin="00:37:40.160" end="00:37:41.760" region="bottomCenter">like he took some miracle tonic</p>
      <p xml:id="p665" begin="00:37:41.880" end="00:37:43.240" region="bottomCenter">You are the only one<br/>from our village ever</p>
      <p xml:id="p666" begin="00:37:43.360" end="00:37:45.160" region="bottomCenter">made it as a Chan Sect immortal</p>
      <p xml:id="p667" begin="00:37:45.280" end="00:37:46.400" region="bottomCenter">Now, fellow demons from miles around</p>
      <p xml:id="p668" begin="00:37:46.520" end="00:37:47.840" region="bottomCenter">are pouring in to train with father</p>
      <p xml:id="p669" begin="00:37:50.440" end="00:37:51.440" region="bottomCenter">By the way</p>
      <p xml:id="p670" begin="00:37:52.200" end="00:37:53.360" region="bottomCenter">why are you here?</p>
      <p xml:id="p671" begin="00:37:54.640" end="00:37:55.880" region="bottomCenter">Didn't you promise me before</p>
      <p xml:id="p672" begin="00:37:56.000" end="00:37:57.360" region="bottomCenter">that once I've achieved human form</p>
      <p xml:id="p673" begin="00:37:57.480" end="00:37:59.040" region="bottomCenter">you'd get me into Yu Xu Palace?</p>
      <p xml:id="p674" begin="00:37:59.160" end="00:38:00.520" region="bottomCenter">Look! I can turn into a human now!</p>
      <p xml:id="p675" begin="00:38:07.480" end="00:38:09.360" region="bottomCenter">All these years,<br/>I've trained so hard</p>
      <p xml:id="p676" begin="00:38:09.480" end="00:38:10.880" region="bottomCenter">never rested a day</p>
      <p xml:id="p677" begin="00:38:11.000" end="00:38:12.640" region="bottomCenter">You're my role model, big brother</p>
      <p xml:id="p678" begin="00:38:12.760" end="00:38:15.440" region="bottomCenter">Glory to Yu Xu,<br/>answering heaven's call</p>
      <p xml:id="p679" begin="00:38:15.560" end="00:38:18.880" region="bottomCenter">Travel the world,<br/>bringing justice to all</p>
      <p xml:id="p680" begin="00:38:21.680" end="00:38:22.720" region="bottomCenter">Say, brother</p>
      <p xml:id="p681" begin="00:38:22.840" end="00:38:23.720" region="bottomCenter">what are you doing here?</p>
      <p xml:id="p682" begin="00:38:23.840" end="00:38:25.520" region="bottomCenter">I... I...</p>
      <p xml:id="p683" begin="00:38:25.640" end="00:38:27.200" region="bottomCenter">Are these sea monsters<br/>your subordinates?</p>
      <p xml:id="p684" begin="00:38:27.480" end="00:38:29.240" region="bottomCenter">Why are you<br/>surrounding Chentang Pass?</p>
      <p xml:id="p685" begin="00:38:29.360" end="00:38:30.440" region="bottomCenter">Well, about that...</p>
      <p xml:id="p686" begin="00:38:30.560" end="00:38:32.400" region="bottomCenter">Th...this is...</p>
      <p xml:id="p687" begin="00:38:32.680" end="00:38:35.040" region="bottomCenter">Master Shen is<br/>defending Chentang Pass</p>
      <p xml:id="p688" begin="00:38:35.280" end="00:38:36.120" region="bottomCenter">Huh?</p>
      <p xml:id="p689" begin="00:38:36.360" end="00:38:38.160" region="bottomCenter">Evil forces invaded the city</p>
      <p xml:id="p690" begin="00:38:38.280" end="00:38:41.440" region="bottomCenter">Master Shen and the sea clan<br/>came to our aid</p>
      <p xml:id="p691" begin="00:38:41.560" end="00:38:45.440" region="bottomCenter">On behalf of my people,<br/>I thank you for this noble act</p>
      <p xml:id="p692" begin="00:38:47.520" end="00:38:49.480" region="bottomCenter">Don't mention it</p>
      <p xml:id="p693" begin="00:38:51.080" end="00:38:52.800" region="bottomCenter">Brother, you're incredible!</p>
      <p xml:id="p694" begin="00:38:53.280" end="00:38:55.280" region="bottomCenter">Is this the demon<br/>attacking Chentang Pass?</p>
      <p xml:id="p695" begin="00:38:57.080" end="00:38:58.000" region="bottomCenter">Ah!</p>
      <p xml:id="p696" begin="00:38:58.120" end="00:38:59.920" region="bottomCenter">You are a disgrace to all demons!</p>
      <p xml:id="p697" begin="00:39:00.040" end="00:39:01.040" region="bottomCenter">Shame on you!</p>
      <p xml:id="p698" begin="00:39:01.920" end="00:39:03.880" region="bottomCenter">Hey, Xiaobao</p>
      <p xml:id="p699" begin="00:39:04.080" end="00:39:09.280" region="bottomCenter">can you wait a few more years<br/>before going to Yu Xu Palace?</p>
      <p xml:id="p700" begin="00:39:09.400" end="00:39:11.720" region="bottomCenter">Huh?Why?</p>
      <p xml:id="p701" begin="00:39:11.840" end="00:39:13.480" region="bottomCenter">I can transform into a human now!</p>
      <p xml:id="p702" begin="00:39:14.240" end="00:39:15.520" region="bottomCenter">It's just that...</p>
      <p xml:id="p703" begin="00:39:15.640" end="00:39:18.240" region="bottomCenter">I'm preparing for my promotion<br/>to the Twelve Golden Immortals</p>
      <p xml:id="p704" begin="00:39:18.360" end="00:39:19.320" region="bottomCenter">so I can't be distracted</p>
      <p xml:id="p705" begin="00:39:19.480" end="00:39:20.920" region="bottomCenter">Twelve Golden Immortals?</p>
      <p xml:id="p706" begin="00:39:21.280" end="00:39:22.760" region="bottomCenter">Once it's done</p>
      <p xml:id="p707" begin="00:39:22.880" end="00:39:24.000" region="bottomCenter">I'll take you there</p>
      <p xml:id="p708" begin="00:39:24.560" end="00:39:25.800" region="bottomCenter">okay?</p>
      <p xml:id="p709" begin="00:39:28.520" end="00:39:29.440" region="bottomCenter">No problem, brother!</p>
      <p xml:id="p710" begin="00:39:29.560" end="00:39:30.600" region="bottomCenter">Your promotion is more important</p>
      <p xml:id="p711" begin="00:39:30.720" end="00:39:32.920" region="bottomCenter">I can go to Yu Xu Palace anytime</p>
      <p xml:id="p712" begin="00:39:33.920" end="00:39:35.160" region="bottomCenter">Besides</p>
      <p xml:id="p713" begin="00:39:35.560" end="00:39:37.600" region="bottomCenter">I haven't quite mastered<br/>the shape-shifting</p>
      <p xml:id="p714" begin="00:39:37.840" end="00:39:38.920" region="bottomCenter">I'll go back and practice more</p>
      <p xml:id="p715" begin="00:39:39.680" end="00:39:40.720" region="bottomCenter">Practice more</p>
      <p xml:id="p716" begin="00:39:43.960" end="00:39:44.960" region="bottomCenter">Xiaobao</p>
      <p xml:id="p717" begin="00:39:45.360" end="00:39:47.000" region="bottomCenter">this is what I've saved up<br/>since I entered the palace</p>
      <p xml:id="p718" begin="00:39:47.480" end="00:39:48.560" region="bottomCenter">What is it?</p>
      <p xml:id="p719" begin="00:39:48.760" end="00:39:51.600" region="bottomCenter">Yu Xu Palace gives all disciples<br/>these immortality pills</p>
      <p xml:id="p720" begin="00:39:51.720" end="00:39:54.360" region="bottomCenter">Take one and you ga...<br/>gain ten years' worth of cultivation</p>
      <p xml:id="p721" begin="00:39:54.480" end="00:39:57.080" region="bottomCenter">But... this is too precious</p>
      <p xml:id="p722" begin="00:39:57.200" end="00:39:58.880" region="bottomCenter">Brother, you're training<br/>for a promotion</p>
      <p xml:id="p723" begin="00:39:59.000" end="00:40:00.160" region="bottomCenter">You should keep them</p>
      <p xml:id="p724" begin="00:40:00.280" end="00:40:01.640" region="bottomCenter">I don't like how it tastes</p>
      <p xml:id="p725" begin="00:40:01.760" end="00:40:03.440" region="bottomCenter">I prefer cultivating on my own</p>
      <p xml:id="p726" begin="00:40:03.560" end="00:40:04.760" region="bottomCenter">You... you should bring them back</p>
      <p xml:id="p727" begin="00:40:04.880" end="00:40:06.000" region="bottomCenter">Share them with the family</p>
      <p xml:id="p728" begin="00:40:07.120" end="00:40:09.040" region="bottomCenter">No, I can't. Father will blame me</p>
      <p xml:id="p729" begin="00:40:09.160" end="00:40:11.200" region="bottomCenter">Xiaobao, are you not<br/>obeying your big brother?</p>
      <p xml:id="p730" begin="00:40:11.320" end="00:40:12.520" region="bottomCenter">Take the pills and leave now</p>
      <p xml:id="p731" begin="00:40:12.640" end="00:40:14.240" region="bottomCenter">This is the front line</p>
      <p xml:id="p732" begin="00:40:14.360" end="00:40:15.480" region="bottomCenter">If... if you stay</p>
      <p xml:id="p733" begin="00:40:15.600" end="00:40:16.800" region="bottomCenter">I'll be distracted</p>
      <p xml:id="p734" begin="00:40:17.640" end="00:40:19.680" region="bottomCenter">Then... I...</p>
      <p xml:id="p735" begin="00:40:20.560" end="00:40:21.680" region="bottomCenter">I'll leave</p>
      <p xml:id="p736" begin="00:40:25.480" end="00:40:26.440" region="bottomCenter">Brother</p>
      <p xml:id="p737" begin="00:40:26.560" end="00:40:28.920" region="bottomCenter">You must make it<br/>into the Twelve Golden Immortals</p>
      <p xml:id="p738" begin="00:40:30.680" end="00:40:32.600" region="bottomCenter">I'll keep on training too</p>
      <p xml:id="p739" begin="00:40:37.760" end="00:40:39.440" region="bottomCenter">I appreciate your help</p>
      <p xml:id="p740" begin="00:40:39.560" end="00:40:40.480" region="bottomCenter">but the stake is too high</p>
      <p xml:id="p741" begin="00:40:40.600" end="00:40:42.200" region="bottomCenter">for me to let anyone through</p>
      <p xml:id="p742" begin="00:40:42.320" end="00:40:43.400" region="bottomCenter">This Yaksha...</p>
      <p xml:id="p743" begin="00:40:43.520" end="00:40:44.960" region="bottomCenter">you... you bring him back, too</p>
      <p xml:id="p744" begin="00:40:45.080" end="00:40:46.600" region="bottomCenter">I wasn't helping you</p>
      <p xml:id="p745" begin="00:40:46.720" end="00:40:48.200" region="bottomCenter">I was helping the young one</p>
      <p xml:id="p746" begin="00:40:48.440" end="00:40:50.160" region="bottomCenter">A good role model</p>
      <p xml:id="p747" begin="00:40:50.680" end="00:40:52.440" region="bottomCenter">can change his life</p>
      <p xml:id="p748" begin="00:40:54.720" end="00:40:55.760" region="bottomCenter">Wait</p>
      <p xml:id="p749" begin="00:40:57.680" end="00:40:59.760" region="bottomCenter">Le... leave me a list<br/>of medicines you need</p>
      <p xml:id="p750" begin="00:41:41.880" end="00:41:45.080" region="bottomCenter">I am Nezha, the Third Prince bold</p>
      <p xml:id="p751" begin="00:41:45.200" end="00:41:48.080" region="bottomCenter">I slay the demons,<br/>I write in rhyme untold</p>
      <p xml:id="p752" begin="00:41:48.200" end="00:41:50.800" region="bottomCenter">Today I come<br/>to rid the evil's breath</p>
      <p xml:id="p753" begin="00:41:50.920" end="00:41:54.480" region="bottomCenter">You wicked fiends,<br/>prepare for death!</p>
      <p xml:id="p754" begin="00:41:58.520" end="00:41:59.680" region="bottomCenter">Still eating?</p>
      <p xml:id="p755" begin="00:41:59.800" end="00:42:01.560" region="bottomCenter">You are doomed</p>
      <p xml:id="p756" begin="00:42:04.200" end="00:42:05.920" region="bottomCenter">Ahhh!</p>
      <p xml:id="p757" begin="00:42:06.800" end="00:42:09.920" region="bottomCenter">Who do you think you are?</p>
      <p xml:id="p758" begin="00:42:10.280" end="00:42:13.200" region="bottomCenter">Barging into our Bandits Hill?</p>
      <p xml:id="p759" begin="00:42:14.080" end="00:42:15.080" region="bottomCenter">So, you're in charge?</p>
      <p xml:id="p760" begin="00:42:15.200" end="00:42:17.240" region="bottomCenter">Come forward<br/>and have a taste of my power</p>
      <p xml:id="p761" begin="00:42:17.360" end="00:42:20.040" region="bottomCenter">You arrogant spoilt brat</p>
      <p xml:id="p762" begin="00:42:20.160" end="00:42:22.200" region="bottomCenter">Boss, teach him a lesson</p>
      <p xml:id="p763" begin="00:42:41.160" end="00:42:42.040" region="bottomCenter">Show me what you got</p>
      <p xml:id="p764" begin="00:42:44.120" end="00:42:45.120" region="bottomCenter">You go</p>
      <p xml:id="p765" begin="00:42:45.440" end="00:42:47.360" region="bottomCenter">No, but, boss...</p>
      <p xml:id="p766" begin="00:42:47.480" end="00:42:49.400" region="bottomCenter">how dare I steal your thunder?</p>
      <p xml:id="p767" begin="00:42:49.520" end="00:42:51.480" region="bottomCenter">Fighting a child is<br/>just embarrassing</p>
      <p xml:id="p768" begin="00:42:51.600" end="00:42:52.960" region="bottomCenter">When I say go, you go</p>
      <p xml:id="p769" begin="00:42:53.800" end="00:42:55.160" region="bottomCenter">Hey, kid</p>
      <p xml:id="p770" begin="00:42:55.280" end="00:42:56.760" region="bottomCenter">Too young, too naive</p>
      <p xml:id="p771" begin="00:42:56.880" end="00:42:58.320" region="bottomCenter">So, I'm willing to let this slide</p>
      <p xml:id="p772" begin="00:42:58.440" end="00:42:59.840" region="bottomCenter">You, you...</p>
      <p xml:id="p773" begin="00:42:59.960" end="00:43:02.040" region="bottomCenter">It's still not too late<br/>to run home to mommy</p>
      <p xml:id="p774" begin="00:43:02.280" end="00:43:03.120" region="bottomCenter">What's wrong?</p>
      <p xml:id="p775" begin="00:43:03.240" end="00:43:04.920" region="bottomCenter">- Why are you awake again?<br/>- I don't know</p>
      <p xml:id="p776" begin="00:43:05.040" end="00:43:05.880" region="bottomCenter">I'm a light sleeper</p>
      <p xml:id="p777" begin="00:43:06.000" end="00:43:07.440" region="bottomCenter">All that shaking has jolted me awake</p>
      <p xml:id="p778" begin="00:43:08.160" end="00:43:09.440" region="bottomCenter">Darn it</p>
      <p xml:id="p779" begin="00:43:09.560" end="00:43:11.520" region="bottomCenter">He took too much of that pills<br/>and now he's immune</p>
      <p xml:id="p780" begin="00:43:12.000" end="00:43:12.920" region="bottomCenter">Increase the dose then</p>
      <p xml:id="p781" begin="00:43:13.160" end="00:43:15.920" region="bottomCenter">If you insist to stay<br/>you might get hurt</p>
      <p xml:id="p782" begin="00:43:20.640" end="00:43:22.040" region="bottomCenter">I was going to dodge to the right</p>
      <p xml:id="p783" begin="00:43:22.160" end="00:43:23.680" region="bottomCenter">Sorry, I thought it was left</p>
      <p xml:id="p784" begin="00:43:26.320" end="00:43:27.560" region="bottomCenter">So weak</p>
      <p xml:id="p785" begin="00:43:27.680" end="00:43:29.960" region="bottomCenter">Master Taiyi<br/>Maybe I should cut in</p>
      <p xml:id="p786" begin="00:43:30.080" end="00:43:31.240" region="bottomCenter">He could use<br/>a few more years' training</p>
      <p xml:id="p787" begin="00:43:31.360" end="00:43:32.400" region="bottomCenter">Not so fast</p>
      <p xml:id="p788" begin="00:43:32.520" end="00:43:34.360" region="bottomCenter">He was just teasing the demon</p>
      <p xml:id="p789" begin="00:43:34.480" end="00:43:36.360" region="bottomCenter">The boy likes to...<br/>play dumb</p>
      <p xml:id="p790" begin="00:43:37.200" end="00:43:39.960" region="bottomCenter">Pills... I need pills</p>
      <p xml:id="p791" begin="00:43:40.080" end="00:43:42.400" region="bottomCenter">I gave you a warning</p>
      <p xml:id="p792" begin="00:43:42.520" end="00:43:45.160" region="bottomCenter">Now you know who you're messing with</p>
      <p xml:id="p793" begin="00:43:45.280" end="00:43:46.800" region="bottomCenter">Oh no! The pills have<br/>dissolved in the soup!</p>
      <p xml:id="p794" begin="00:43:47.560" end="00:43:49.240" region="bottomCenter">Then I'll drink the soup</p>
      <p xml:id="p795" begin="00:43:51.960" end="00:43:53.760" region="bottomCenter">And you're trying to steal our soup?</p>
      <p xml:id="p796" begin="00:43:53.880" end="00:43:54.960" region="bottomCenter">This calls for a beating</p>
      <p xml:id="p797" begin="00:43:56.440" end="00:43:57.600" region="bottomCenter">Let me</p>
      <p xml:id="p798" begin="00:44:00.920" end="00:44:01.760" region="bottomCenter">So gross</p>
      <p xml:id="p799" begin="00:44:01.880" end="00:44:05.520" region="bottomCenter">Super Mighty Club Strike!</p>
      <p xml:id="p800" begin="00:44:09.640" end="00:44:11.520" region="bottomCenter">See?<br/>I told you he was pretending</p>
      <p xml:id="p801" begin="00:44:12.160" end="00:44:14.280" region="bottomCenter">I wasn't paying attention</p>
      <p xml:id="p802" begin="00:44:14.400" end="00:44:15.240" region="bottomCenter">That didn't count</p>
      <p xml:id="p803" begin="00:44:32.120" end="00:44:34.840" region="bottomCenter">Not possible!</p>
      <p xml:id="p804" begin="00:44:40.280" end="00:44:42.520" region="bottomCenter">You suck!</p>
      <p xml:id="p805" begin="00:44:42.800" end="00:44:43.680" region="bottomCenter">Step aside!</p>
      <p xml:id="p806" begin="00:44:43.800" end="00:44:44.960" region="bottomCenter">Watch me kick his butt</p>
      <p xml:id="p807" begin="00:44:45.200" end="00:44:46.400" region="bottomCenter">Why did you spit it all out?</p>
      <p xml:id="p808" begin="00:44:46.520" end="00:44:48.080" region="bottomCenter">The taste is too strong<br/>I couldn't help it</p>
      <p xml:id="p809" begin="00:44:48.200" end="00:44:49.680" region="bottomCenter">Check this out!</p>
      <p xml:id="p810" begin="00:44:53.440" end="00:44:54.400" region="bottomCenter">Funny!</p>
      <p xml:id="p811" begin="00:44:54.720" end="00:44:55.680" region="bottomCenter">This isn't working</p>
      <p xml:id="p812" begin="00:44:55.800" end="00:44:56.960" region="bottomCenter">We can't win without the pill</p>
      <p xml:id="p813" begin="00:45:05.920" end="00:45:06.840" region="bottomCenter">Deero is watching</p>
      <p xml:id="p814" begin="00:45:06.960" end="00:45:08.600" region="bottomCenter">I can't give you the pill</p>
      <p xml:id="p815" begin="00:45:08.720" end="00:45:09.600" region="bottomCenter">What do we do now?</p>
      <p xml:id="p816" begin="00:45:09.720" end="00:45:10.920" region="bottomCenter">I got it</p>
      <p xml:id="p817" begin="00:45:11.040" end="00:45:12.920" region="bottomCenter">There is another way</p>
      <p xml:id="p818" begin="00:45:13.520" end="00:45:14.680" region="bottomCenter">You're not suggesting...</p>
      <p xml:id="p819" begin="00:45:14.800" end="00:45:16.960" region="bottomCenter">We can eat the puke</p>
      <p xml:id="p820" begin="00:45:17.120" end="00:45:18.640" region="bottomCenter">But... it's disgusting</p>
      <p xml:id="p821" begin="00:45:20.000" end="00:45:21.000" region="bottomCenter">What's the big deal?</p>
      <p xml:id="p822" begin="00:45:21.120" end="00:45:22.600" region="bottomCenter">Remember when I drank Yaksha booger?</p>
      <p xml:id="p823" begin="00:45:23.600" end="00:45:25.200" region="bottomCenter">This explains a lot</p>
      <p xml:id="p824" begin="00:45:25.320" end="00:45:27.080" region="bottomCenter">No pain</p>
      <p xml:id="p825" begin="00:45:27.200" end="00:45:28.880" region="bottomCenter">No gain</p>
      <p xml:id="p826" begin="00:45:29.000" end="00:45:31.560" region="bottomCenter">That's how Nezha defeat fate</p>
      <p xml:id="p827" begin="00:45:32.000" end="00:45:35.800" region="bottomCenter">Lives of my parents<br/>and friends are at stake</p>
      <p xml:id="p828" begin="00:45:36.400" end="00:45:39.280" region="bottomCenter">and the people of Chentang Pass</p>
      <p xml:id="p829" begin="00:45:39.400" end="00:45:43.360" region="bottomCenter">E-A-S-Y P-E-A-S-Y!</p>
      <p xml:id="p830" begin="00:45:51.280" end="00:45:53.440" region="bottomCenter">By ignoring prejudice</p>
      <p xml:id="p831" begin="00:45:53.560" end="00:45:55.600" region="bottomCenter">and overcoming inner fears</p>
      <p xml:id="p832" begin="00:45:55.720" end="00:45:58.320" region="bottomCenter">I will change my destiny</p>
      <p xml:id="p833" begin="00:46:17.640" end="00:46:19.920" region="bottomCenter">I kept low-key</p>
      <p xml:id="p834" begin="00:46:20.040" end="00:46:21.840" region="bottomCenter">until today's show</p>
      <p xml:id="p835" begin="00:46:21.960" end="00:46:22.960" region="bottomCenter">Master Taiyi</p>
      <p xml:id="p836" begin="00:46:23.520" end="00:46:24.480" region="bottomCenter">Save Nezha first</p>
      <p xml:id="p837" begin="00:46:24.600" end="00:46:26.200" region="bottomCenter">Then we'll figure out<br/>a way for Elixir Reparo</p>
      <p xml:id="p838" begin="00:46:26.320" end="00:46:27.560" region="bottomCenter">No way</p>
      <p xml:id="p839" begin="00:46:27.920" end="00:46:28.920" region="bottomCenter">I don't believe this</p>
      <p xml:id="p840" begin="00:46:29.120" end="00:46:31.240" region="bottomCenter">Kid, let's fight another round</p>
      <p xml:id="p841" begin="00:46:32.440" end="00:46:33.400" region="bottomCenter">Playing dead?</p>
      <p xml:id="p842" begin="00:46:33.760" end="00:46:35.160" region="bottomCenter">I'll smash you!</p>
      <p xml:id="p843" begin="00:46:43.560" end="00:46:45.040" region="bottomCenter">Good thing Nezha got knocked out</p>
      <p xml:id="p844" begin="00:46:46.120" end="00:46:49.040" region="bottomCenter">You do suck!</p>
      <p xml:id="p845" begin="00:46:50.200" end="00:46:51.600" region="bottomCenter">Let me avenge you!</p>
      <p xml:id="p846" begin="00:46:51.720" end="00:46:55.360" region="bottomCenter">Invincible Whirlwind Punch!</p>
      <p xml:id="p847" begin="00:47:10.000" end="00:47:11.360" region="bottomCenter">Ahhh!</p>
      <p xml:id="p848" begin="00:47:29.160" end="00:47:30.200" region="bottomCenter">Do we have to catch them all?</p>
      <p xml:id="p849" begin="00:47:30.640" end="00:47:31.840" region="bottomCenter">Even leaving one behind</p>
      <p xml:id="p850" begin="00:47:31.960" end="00:47:33.400" region="bottomCenter">could harm the people here</p>
      <p xml:id="p851" begin="00:47:33.520" end="00:47:34.920" region="bottomCenter">Take them all back to Yu Xu Palace</p>
      <p xml:id="p852" begin="00:47:35.040" end="00:47:36.800" region="bottomCenter">The Sect will guide them<br/>to the right path</p>
      <p xml:id="p853" begin="00:47:36.920" end="00:47:38.040" region="bottomCenter">turning evil to good</p>
      <p xml:id="p854" begin="00:47:39.320" end="00:47:40.480" region="bottomCenter">What's with the face?</p>
      <p xml:id="p855" begin="00:47:40.600" end="00:47:41.680" region="bottomCenter">No biggy</p>
      <p xml:id="p856" begin="00:47:41.800" end="00:47:43.200" region="bottomCenter">His look switches from time to time</p>
      <p xml:id="p857" begin="00:47:43.320" end="00:47:44.160" region="bottomCenter">Spirit Pearl, you know</p>
      <p xml:id="p858" begin="00:47:44.280" end="00:47:45.840" region="bottomCenter">not like normal people</p>
      <p xml:id="p859" begin="00:47:46.920" end="00:47:48.280" region="bottomCenter">Be more careful next time</p>
      <p xml:id="p860" begin="00:47:48.800" end="00:47:50.440" region="bottomCenter">You scared the life out of me</p>
      <p xml:id="p861" begin="00:48:02.120" end="00:48:03.160" region="bottomCenter">Who's this kid?</p>
      <p xml:id="p862" begin="00:48:03.280" end="00:48:04.120" region="bottomCenter">Nezha, possibly</p>
      <p xml:id="p863" begin="00:48:04.240" end="00:48:05.280" region="bottomCenter">Younger brother of Jinzha and Muzha</p>
      <p xml:id="p864" begin="00:48:05.400" end="00:48:07.920" region="bottomCenter">He's the Spirit Pearl reincarnation<br/>appointed by the Supreme Lord</p>
      <p xml:id="p865" begin="00:48:10.800" end="00:48:13.000" region="bottomCenter">Not likely, huh?</p>
      <p xml:id="p866" begin="00:48:13.480" end="00:48:15.120" region="bottomCenter">Hunched back</p>
      <p xml:id="p867" begin="00:48:15.240" end="00:48:16.360" region="bottomCenter">Wobbly pace</p>
      <p xml:id="p868" begin="00:48:16.480" end="00:48:17.440" region="bottomCenter">Sinking brows and drooping eyes</p>
      <p xml:id="p869" begin="00:48:17.560" end="00:48:18.600" region="bottomCenter">Disgusting face</p>
      <p xml:id="p870" begin="00:48:18.720" end="00:48:19.640" region="bottomCenter">Not to mention the dark eye circles</p>
      <p xml:id="p871" begin="00:48:19.760" end="00:48:21.200" region="bottomCenter">Looks more like a ghost</p>
      <p xml:id="p872" begin="00:48:28.440" end="00:48:29.520" region="bottomCenter">Not now</p>
      <p xml:id="p873" begin="00:48:38.040" end="00:48:39.320" region="bottomCenter">Brother</p>
      <p xml:id="p874" begin="00:48:39.560" end="00:48:42.280" region="bottomCenter">what's the star sign tonight?</p>
      <p xml:id="p875" begin="00:48:42.520" end="00:48:44.160" region="bottomCenter">Six stars in alignment</p>
      <p xml:id="p876" begin="00:48:44.280" end="00:48:45.520" region="bottomCenter">once in a decade</p>
      <p xml:id="p877" begin="00:48:45.720" end="00:48:47.920" region="bottomCenter">Whenever six stars align</p>
      <p xml:id="p878" begin="00:48:48.040" end="00:48:52.080" region="bottomCenter">this Jade Podium can transmit sound<br/>and images across thousands of miles</p>
      <p xml:id="p879" begin="00:48:52.200" end="00:48:54.280" region="bottomCenter">Our brothers scatter<br/>all over the world</p>
      <p xml:id="p880" begin="00:48:54.400" end="00:48:55.680" region="bottomCenter">can finally get together</p>
      <p xml:id="p881" begin="00:48:56.000" end="00:48:59.400" region="bottomCenter">Tonight is the night</p>
      <p xml:id="p882" begin="00:48:59.520" end="00:49:01.920" region="bottomCenter">the Golden Immortals shall meet</p>
      <p xml:id="p883" begin="00:49:02.600" end="00:49:04.280" region="bottomCenter">I haven't ascended to the Twelve yet</p>
      <p xml:id="p884" begin="00:49:04.400" end="00:49:05.720" region="bottomCenter">Maybe I shouldn't be included</p>
      <p xml:id="p885" begin="00:49:06.360" end="00:49:08.040" region="bottomCenter">It's only a matter of time</p>
      <p xml:id="p886" begin="00:49:08.440" end="00:49:09.600" region="bottomCenter">No...</p>
      <p xml:id="p887" begin="00:49:09.720" end="00:49:10.760" region="bottomCenter">It's not appropriate at all</p>
      <p xml:id="p888" begin="00:49:10.880" end="00:49:12.040" region="bottomCenter">I can't do it, really</p>
      <p xml:id="p889" begin="00:49:13.120" end="00:49:14.360" region="bottomCenter">Then why are you sitting up there?</p>
      <p xml:id="p890" begin="00:49:14.480" end="00:49:15.320" region="bottomCenter">Shut up!</p>
      <p xml:id="p891" begin="00:49:15.440" end="00:49:16.520" region="bottomCenter">Would it kill you<br/>to see your master thrive?</p>
      <p xml:id="p892" begin="00:49:26.520" end="00:49:27.640" region="bottomCenter">A Sauna!</p>
      <p xml:id="p893" begin="00:49:27.800" end="00:49:28.720" region="bottomCenter">Shh!</p>
      <p xml:id="p894" begin="00:49:35.720" end="00:49:38.360" region="bottomCenter">Brothers and sisters, I humbly<br/>welcome you back to your places</p>
      <p xml:id="p895" begin="00:49:38.720" end="00:49:40.800" region="bottomCenter">Greetings, Brother Wuliang!</p>
      <p xml:id="p896" begin="00:49:41.240" end="00:49:43.920" region="bottomCenter">Allow me to introduce a new member</p>
      <p xml:id="p897" begin="00:49:44.040" end="00:49:45.920" region="bottomCenter">Brother Taiyi</p>
      <p xml:id="p898" begin="00:49:46.040" end="00:49:48.320" region="bottomCenter">He has fulfilled<br/>the master's expectations</p>
      <p xml:id="p899" begin="00:49:48.440" end="00:49:50.200" region="bottomCenter">and successfully nurtured</p>
      <p xml:id="p900" begin="00:49:50.320" end="00:49:51.720" region="bottomCenter">the Spirit Pearl reincarnation</p>
      <p xml:id="p901" begin="00:49:53.800" end="00:49:55.400" region="bottomCenter">Pay your respect</p>
      <p xml:id="p902" begin="00:49:57.680" end="00:50:00.920" region="bottomCenter">The Deification War is imminent</p>
      <p xml:id="p903" begin="00:50:01.040" end="00:50:05.080" region="bottomCenter">We are here<br/>to discuss the preparation</p>
      <p xml:id="p904" begin="00:50:05.760" end="00:50:07.880" region="bottomCenter">Chan Sect is the orthodox of Tao</p>
      <p xml:id="p905" begin="00:50:08.000" end="00:50:09.120" region="bottomCenter">so we're destined to win</p>
      <p xml:id="p906" begin="00:50:09.280" end="00:50:11.880" region="bottomCenter">But as Jie Sect has<br/>risen rapidly these years</p>
      <p xml:id="p907" begin="00:50:12.000" end="00:50:13.120" region="bottomCenter">we must remain vigilant</p>
      <p xml:id="p908" begin="00:50:14.320" end="00:50:15.520" region="bottomCenter">Jie Sect</p>
      <p xml:id="p909" begin="00:50:15.640" end="00:50:17.560" region="bottomCenter">is where furry<br/>and horned beasts gather</p>
      <p xml:id="p910" begin="00:50:17.680" end="00:50:19.240" region="bottomCenter">and creatures born of mucus and eggs</p>
      <p xml:id="p911" begin="00:50:19.480" end="00:50:21.440" region="bottomCenter">This war concerns<br/>the survival of our sect</p>
      <p xml:id="p912" begin="00:50:21.560" end="00:50:22.880" region="bottomCenter">We must be careful</p>
      <p xml:id="p913" begin="00:50:23.000" end="00:50:24.760" region="bottomCenter">Strengthening our power</p>
      <p xml:id="p914" begin="00:50:24.880" end="00:50:26.120" region="bottomCenter">is the key</p>
      <p xml:id="p915" begin="00:50:26.240" end="00:50:27.600" region="bottomCenter">Precisely</p>
      <p xml:id="p916" begin="00:50:28.040" end="00:50:31.720" region="bottomCenter">That's why I began preparing early</p>
      <p xml:id="p917" begin="00:50:32.480" end="00:50:33.480" region="bottomCenter">Immortality pills</p>
      <p xml:id="p918" begin="00:50:33.600" end="00:50:35.400" region="bottomCenter">a total of nine thousands</p>
      <p xml:id="p919" begin="00:50:35.520" end="00:50:39.200" region="bottomCenter">could be allocated<br/>according to grades</p>
      <p xml:id="p920" begin="00:50:39.320" end="00:50:41.720" region="bottomCenter">This will definitely<br/>boost our strength</p>
      <p xml:id="p921" begin="00:50:41.840" end="00:50:43.000" region="bottomCenter">How could there be so many?</p>
      <p xml:id="p922" begin="00:50:43.120" end="00:50:44.360" region="bottomCenter">For a hundred years</p>
      <p xml:id="p923" begin="00:50:44.480" end="00:50:47.000" region="bottomCenter">our master has tirelessly refined<br/>pills with the Tianyuan Cauldron</p>
      <p xml:id="p924" begin="00:50:47.120" end="00:50:48.200" region="bottomCenter">working day and night</p>
      <p xml:id="p925" begin="00:50:48.320" end="00:50:50.280" region="bottomCenter">at the cost of his own cultivation</p>
      <p xml:id="p926" begin="00:50:50.520" end="00:50:54.400" region="bottomCenter">Brother Wuliang has dedicated<br/>himself to building our sect</p>
      <p xml:id="p927" begin="00:50:54.520" end="00:50:56.080" region="bottomCenter">his contributions are to be praised</p>
      <p xml:id="p928" begin="00:50:56.520" end="00:50:58.920" region="bottomCenter">Aye, aye</p>
      <p xml:id="p929" begin="00:50:59.040" end="00:51:00.520" region="bottomCenter">Besides the Jie Sect</p>
      <p xml:id="p930" begin="00:51:00.640" end="00:51:02.840" region="bottomCenter">are there other evil forces<br/>plotting against us?</p>
      <p xml:id="p931" begin="00:51:02.960" end="00:51:03.920" region="bottomCenter">Master Cihang</p>
      <p xml:id="p932" begin="00:51:04.040" end="00:51:05.480" region="bottomCenter">as soon as menacing demons<br/>are discovered</p>
      <p xml:id="p933" begin="00:51:05.600" end="00:51:07.240" region="bottomCenter">The Demon Hunters will be<br/>immediately sent out</p>
      <p xml:id="p934" begin="00:51:07.360" end="00:51:09.600" region="bottomCenter">So, most stray demons pose no threat</p>
      <p xml:id="p935" begin="00:51:09.960" end="00:51:12.240" region="bottomCenter">But there is one exception</p>
      <p xml:id="p936" begin="00:51:12.360" end="00:51:14.320" region="bottomCenter">Oh? Who is that?</p>
      <p xml:id="p937" begin="00:51:14.720" end="00:51:16.000" region="bottomCenter">The Eastern Sea Loongs</p>
      <p xml:id="p938" begin="00:51:16.240" end="00:51:17.840" region="bottomCenter">Loongs?</p>
      <p xml:id="p939" begin="00:51:19.360" end="00:51:22.400" region="bottomCenter">Didn't they surrender<br/>to the Court of Heaven long ago?</p>
      <p xml:id="p940" begin="00:51:22.520" end="00:51:24.640" region="bottomCenter">No kind could be trusted<br/>except for our own</p>
      <p xml:id="p941" begin="00:51:24.760" end="00:51:25.880" region="bottomCenter">To me</p>
      <p xml:id="p942" begin="00:51:26.000" end="00:51:27.960" region="bottomCenter">Their surrender is merely a facade</p>
      <p xml:id="p943" begin="00:51:28.080" end="00:51:29.160" region="bottomCenter">hibernating for the moment</p>
      <p xml:id="p944" begin="00:51:29.480" end="00:51:30.320" region="bottomCenter">The Loongs have helped</p>
      <p xml:id="p945" begin="00:51:30.440" end="00:51:32.360" region="bottomCenter">subdue the abyss monsters<br/>for thousands of years</p>
      <p xml:id="p946" begin="00:51:32.480" end="00:51:34.120" region="bottomCenter">What's their crime?</p>
      <p xml:id="p947" begin="00:51:34.280" end="00:51:36.000" region="bottomCenter">But they own great strength</p>
      <p xml:id="p948" begin="00:51:36.120" end="00:51:37.800" region="bottomCenter">If they betray us in the war</p>
      <p xml:id="p949" begin="00:51:37.920" end="00:51:39.920" region="bottomCenter">the whole situation<br/>could be overturned</p>
      <p xml:id="p950" begin="00:51:42.080" end="00:51:43.400" region="bottomCenter">But we still can't do that</p>
      <p xml:id="p951" begin="00:51:43.520" end="00:51:46.640" region="bottomCenter">Our reputation of righteous<br/>and just is known to all</p>
      <p xml:id="p952" begin="00:51:46.760" end="00:51:48.040" region="bottomCenter">If we gratuitously</p>
      <p xml:id="p953" begin="00:51:48.160" end="00:51:49.920" region="bottomCenter">attack the surrendered</p>
      <p xml:id="p954" begin="00:51:50.040" end="00:51:52.960" region="bottomCenter">how will anyone ever trust us?</p>
      <p xml:id="p955" begin="00:51:53.080" end="00:51:54.800" region="bottomCenter">Aye</p>
      <p xml:id="p956" begin="00:51:54.920" end="00:51:57.560" region="bottomCenter">- We must not act rashly<br/>- Further deliberation is necessary</p>
      <p xml:id="p957" begin="00:51:59.200" end="00:52:00.920" region="bottomCenter">- But...<br/>- Enough</p>
      <p xml:id="p958" begin="00:52:01.080" end="00:52:02.960" region="bottomCenter">They made their points</p>
      <p xml:id="p959" begin="00:52:03.080" end="00:52:04.880" region="bottomCenter">And you don't have to be bigoted</p>
      <p xml:id="p960" begin="00:52:05.040" end="00:52:05.920" region="bottomCenter">OK</p>
      <p xml:id="p961" begin="00:52:06.080" end="00:52:08.840" region="bottomCenter">The time of the six-star alignment<br/>is almost over</p>
      <p xml:id="p962" begin="00:52:08.960" end="00:52:11.280" region="bottomCenter">Since there are no other topics</p>
      <p xml:id="p963" begin="00:52:11.560" end="00:52:14.000" region="bottomCenter">let's adjourn the meeting</p>
      <p xml:id="p964" begin="00:52:14.160" end="00:52:15.120" region="bottomCenter">Brother</p>
      <p xml:id="p965" begin="00:52:15.240" end="00:52:16.280" region="bottomCenter">Jinzha and Muzha</p>
      <p xml:id="p966" begin="00:52:16.400" end="00:52:19.160" region="bottomCenter">are disciples of myself<br/>and Brother Puxian</p>
      <p xml:id="p967" begin="00:52:19.280" end="00:52:22.040" region="bottomCenter">They have been cultivating here<br/>for many years away from home</p>
      <p xml:id="p968" begin="00:52:22.160" end="00:52:23.800" region="bottomCenter">and have never even met Nezha</p>
      <p xml:id="p969" begin="00:52:23.920" end="00:52:25.200" region="bottomCenter">their younger brother</p>
      <p xml:id="p970" begin="00:52:25.320" end="00:52:28.120" region="bottomCenter">Since there's still time left<br/>in the six-star alignment</p>
      <p xml:id="p971" begin="00:52:28.240" end="00:52:29.600" region="bottomCenter">why not let them</p>
      <p xml:id="p972" begin="00:52:29.720" end="00:52:31.960" region="bottomCenter">meet for a while?</p>
      <p xml:id="p973" begin="00:52:33.040" end="00:52:34.800" region="bottomCenter">Great idea</p>
      <p xml:id="p974" begin="00:52:41.120" end="00:52:42.040" region="bottomCenter">OMG!</p>
      <p xml:id="p975" begin="00:52:42.240" end="00:52:43.960" region="bottomCenter">What should I do?</p>
      <p xml:id="p976" begin="00:52:44.280" end="00:52:45.760" region="bottomCenter">What?</p>
      <p xml:id="p977" begin="00:52:46.400" end="00:52:47.800" region="bottomCenter">Speaking of my look...</p>
      <p xml:id="p978" begin="00:52:47.920" end="00:52:49.040" region="bottomCenter">Will my first impression...</p>
      <p xml:id="p979" begin="00:52:49.360" end="00:52:50.760" region="bottomCenter">Be bad?</p>
      <p xml:id="p980" begin="00:52:50.880" end="00:52:51.760" region="bottomCenter">Of course not!</p>
      <p xml:id="p981" begin="00:52:51.880" end="00:52:52.800" region="bottomCenter">Really?</p>
      <p xml:id="p982" begin="00:52:52.960" end="00:52:53.920" region="bottomCenter">Though slovenly</p>
      <p xml:id="p983" begin="00:52:54.040" end="00:52:55.000" region="bottomCenter">you've got strong will</p>
      <p xml:id="p984" begin="00:52:55.120" end="00:52:55.960" region="bottomCenter">Though short</p>
      <p xml:id="p985" begin="00:52:56.080" end="00:52:57.000" region="bottomCenter">you've got a big heart</p>
      <p xml:id="p986" begin="00:52:57.120" end="00:52:58.080" region="bottomCenter">Though ugly</p>
      <p xml:id="p987" begin="00:52:58.200" end="00:52:59.240" region="bottomCenter">you're kind inside</p>
      <p xml:id="p988" begin="00:52:59.360" end="00:53:00.800" region="bottomCenter">Though you have dark eye circles<br/>piggy nose</p>
      <p xml:id="p989" begin="00:53:00.920" end="00:53:01.760" region="bottomCenter">and a missing tooth</p>
      <p xml:id="p990" begin="00:53:01.880" end="00:53:02.800" region="bottomCenter">I still think</p>
      <p xml:id="p991" begin="00:53:02.960" end="00:53:04.360" region="bottomCenter">you're truly incredibly great</p>
      <p xml:id="p992" begin="00:53:05.440" end="00:53:07.400" region="bottomCenter">And I'm sure<br/>your brothers would agree</p>
      <p xml:id="p993" begin="00:53:08.920" end="00:53:10.440" region="bottomCenter">Thanks for the compliment</p>
      <p xml:id="p994" begin="00:53:11.400" end="00:53:12.360" region="bottomCenter">What are you doing?</p>
      <p xml:id="p995" begin="00:53:12.480" end="00:53:13.680" region="bottomCenter">You go meet my brothers for me</p>
      <p xml:id="p996" begin="00:53:13.800" end="00:53:15.240" region="bottomCenter">Seriously?</p>
      <p xml:id="p997" begin="00:53:15.360" end="00:53:16.280" region="bottomCenter">How can I do this for you?</p>
      <p xml:id="p998" begin="00:53:16.400" end="00:53:17.280" region="bottomCenter">No, Nezha</p>
      <p xml:id="p999" begin="00:53:17.520" end="00:53:18.360" region="bottomCenter">Nezha!</p>
      <p xml:id="p1000" begin="00:53:24.800" end="00:53:26.080" region="bottomCenter">The boy is a bit shy</p>
      <p xml:id="p1001" begin="00:53:31.760" end="00:53:32.680" region="bottomCenter">Nezha!</p>
      <p xml:id="p1002" begin="00:53:33.200" end="00:53:34.080" region="bottomCenter">Brother!</p>
      <p xml:id="p1003" begin="00:54:00.440" end="00:54:01.280" region="bottomCenter">Ao Bing</p>
      <p xml:id="p1004" begin="00:54:01.840" end="00:54:03.040" region="bottomCenter">you cried?</p>
      <p xml:id="p1005" begin="00:54:04.920" end="00:54:06.760" region="bottomCenter">This reminded me of my two brothers</p>
      <p xml:id="p1006" begin="00:54:07.120" end="00:54:08.360" region="bottomCenter">You have brothers too?</p>
      <p xml:id="p1007" begin="00:54:08.760" end="00:54:11.480" region="bottomCenter">Mm. I used to</p>
      <p xml:id="p1008" begin="00:54:12.440" end="00:54:14.080" region="bottomCenter">Having two such wonderful brothers</p>
      <p xml:id="p1009" begin="00:54:14.200" end="00:54:15.200" region="bottomCenter">You're so lucky</p>
      <p xml:id="p1010" begin="00:54:16.600" end="00:54:18.760" region="bottomCenter">What were you talking<br/>about just now?</p>
      <p xml:id="p1011" begin="00:54:19.160" end="00:54:20.400" region="bottomCenter">They said</p>
      <p xml:id="p1012" begin="00:54:20.760" end="00:54:23.040" region="bottomCenter">they're sorry for not<br/>checking on you all these years</p>
      <p xml:id="p1013" begin="00:54:23.840" end="00:54:24.920" region="bottomCenter">They asked</p>
      <p xml:id="p1014" begin="00:54:25.960" end="00:54:27.440" region="bottomCenter">how things have been at home</p>
      <p xml:id="p1015" begin="00:54:27.560" end="00:54:28.600" region="bottomCenter">if your parents are well</p>
      <p xml:id="p1016" begin="00:54:28.720" end="00:54:29.600" region="bottomCenter">what hobbies you have</p>
      <p xml:id="p1017" begin="00:54:29.720" end="00:54:30.960" region="bottomCenter">and who your friends are</p>
      <p xml:id="p1018" begin="00:54:31.600" end="00:54:32.800" region="bottomCenter">They also said</p>
      <p xml:id="p1019" begin="00:54:33.080" end="00:54:34.760" region="bottomCenter">that whatever problems<br/>you may have in the future</p>
      <p xml:id="p1020" begin="00:54:34.880" end="00:54:36.120" region="bottomCenter">go to them</p>
      <p xml:id="p1021" begin="00:54:36.360" end="00:54:38.200" region="bottomCenter">And remember, you have two brothers</p>
      <p xml:id="p1022" begin="00:54:38.800" end="00:54:40.920" region="bottomCenter">who will always help and protect you</p>
      <p xml:id="p1023" begin="00:54:41.920" end="00:54:43.160" region="bottomCenter">Why are you...</p>
      <p xml:id="p1024" begin="00:54:43.280" end="00:54:45.560" region="bottomCenter">Nothing.<br/>It's just sand in my eyes</p>
      <p xml:id="p1025" begin="00:54:46.960" end="00:54:48.440" region="bottomCenter">You sure<br/>it's not the other way around?</p>
      <p xml:id="p1026" begin="00:54:48.560" end="00:54:50.200" region="bottomCenter">Shut up! I said it's nothing</p>
      <p xml:id="p1027" begin="00:54:50.960" end="00:54:52.080" region="bottomCenter">OK. You are the boss here</p>
      <p xml:id="p1028" begin="00:54:56.600" end="00:54:57.600" region="bottomCenter">I'm not talking to you</p>
      <p xml:id="p1029" begin="00:54:58.880" end="00:54:59.880" region="bottomCenter">Fine</p>
      <p xml:id="p1030" begin="00:55:00.000" end="00:55:01.120" region="bottomCenter">I'll stop</p>
      <p xml:id="p1031" begin="00:55:03.720" end="00:55:05.680" region="bottomCenter">Are you still mad? Nezha?</p>
      <p xml:id="p1032" begin="00:55:06.000" end="00:55:06.920" region="bottomCenter">Nezha!</p>
      <p xml:id="p1033" begin="00:55:07.360" end="00:55:08.400" region="bottomCenter">Ao Bing</p>
      <p xml:id="p1034" begin="00:55:09.800" end="00:55:11.480" region="bottomCenter">I've been violent and unruly<br/>since I was young</p>
      <p xml:id="p1035" begin="00:55:12.000" end="00:55:14.200" region="bottomCenter">making my parents worry all day</p>
      <p xml:id="p1036" begin="00:55:14.960" end="00:55:18.400" region="bottomCenter">Your father<br/>though he attacked Chentang Pass</p>
      <p xml:id="p1037" begin="00:55:18.520" end="00:55:20.600" region="bottomCenter">I know he only risk everything</p>
      <p xml:id="p1038" begin="00:55:20.720" end="00:55:21.920" region="bottomCenter">for your sake</p>
      <p xml:id="p1039" begin="00:55:22.800" end="00:55:24.200" region="bottomCenter">And today</p>
      <p xml:id="p1040" begin="00:55:24.320" end="00:55:26.520" region="bottomCenter">my brothers were so kind to me</p>
      <p xml:id="p1041" begin="00:55:28.000" end="00:55:30.000" region="bottomCenter">Our families have<br/>sacrificed so much for us</p>
      <p xml:id="p1042" begin="00:55:30.280" end="00:55:31.280" region="bottomCenter">You're a monster</p>
      <p xml:id="p1043" begin="00:55:31.400" end="00:55:32.520" region="bottomCenter">and I'm a demon</p>
      <p xml:id="p1044" begin="00:55:32.840" end="00:55:34.520" region="bottomCenter">We're both burdens for our families</p>
      <p xml:id="p1045" begin="00:55:37.840" end="00:55:39.480" region="bottomCenter">So what if we were born as demons?</p>
      <p xml:id="p1046" begin="00:55:39.600" end="00:55:42.120" region="bottomCenter">Immortal or demon, I make the choice</p>
      <p xml:id="p1047" begin="00:55:42.400" end="00:55:43.400" region="bottomCenter">Once you are saved</p>
      <p xml:id="p1048" begin="00:55:43.520" end="00:55:44.880" region="bottomCenter">we must win ourselves<br/>a place among the immortals</p>
      <p xml:id="p1049" begin="00:55:45.000" end="00:55:46.160" region="bottomCenter">so our families won't<br/>have to worry anymore</p>
      <p xml:id="p1050" begin="00:55:46.280" end="00:55:47.160" region="bottomCenter">Yes!</p>
      <p xml:id="p1051" begin="00:55:47.280" end="00:55:48.200" region="bottomCenter">Only by becoming immortals</p>
      <p xml:id="p1052" begin="00:55:48.320" end="00:55:49.600" region="bottomCenter">can we have everyone's respect</p>
      <p xml:id="p1053" begin="00:55:49.720" end="00:55:50.560" region="bottomCenter">Deal!</p>
      <p xml:id="p1054" begin="00:55:51.080" end="00:55:53.840" region="bottomCenter">I'm going to become an immortal!</p>
      <p xml:id="p1055" begin="00:55:59.640" end="00:56:03.800" region="bottomCenter">Only with courage and diligence can<br/>great progress be made</p>
      <p xml:id="p1056" begin="00:56:03.920" end="00:56:05.440" region="bottomCenter">At this speed</p>
      <p xml:id="p1057" begin="00:56:05.560" end="00:56:08.320" region="bottomCenter">hundred years would still be in vain</p>
      <p xml:id="p1058" begin="00:56:08.680" end="00:56:10.240" region="bottomCenter">About cultivating</p>
      <p xml:id="p1059" begin="00:56:10.360" end="00:56:12.800" region="bottomCenter">The priorities are vitality,<br/>energy, and spirit</p>
      <p xml:id="p1060" begin="00:56:12.920" end="00:56:15.040" region="bottomCenter">If you feel it's hard<br/>or exhausting</p>
      <p xml:id="p1061" begin="00:56:15.160" end="00:56:18.880" region="bottomCenter">that's because you were born demons</p>
      <p xml:id="p1062" begin="00:56:19.000" end="00:56:20.640" region="bottomCenter">Only by giving it all</p>
      <p xml:id="p1063" begin="00:56:20.760" end="00:56:22.720" region="bottomCenter">You'll have a chance<br/>to change your destiny</p>
      <p xml:id="p1064" begin="00:56:22.840" end="00:56:24.320" region="bottomCenter">and achieve immortality</p>
      <p xml:id="p1065" begin="00:56:26.360" end="00:56:29.440" region="bottomCenter">Life or death, of none I'm scared</p>
      <p xml:id="p1066" begin="00:56:29.560" end="00:56:32.160" region="bottomCenter">defying authority is<br/>what I've revered</p>
      <p xml:id="p1067" begin="00:56:32.280" end="00:56:35.280" region="bottomCenter">My fate is mine, not heaven's plan</p>
      <p xml:id="p1068" begin="00:56:35.440" end="00:56:39.120" region="bottomCenter">This bad boy will<br/>become a godly man!</p>
      <p xml:id="p1069" begin="00:56:40.280" end="00:56:41.560" region="bottomCenter">Bravo!</p>
      <p xml:id="p1070" begin="00:56:43.040" end="00:56:45.360" region="bottomCenter">Just a few lines, yet so powerful</p>
      <p xml:id="p1071" begin="00:56:45.480" end="00:56:46.720" region="bottomCenter">truly inspiring</p>
      <p xml:id="p1072" begin="00:56:46.840" end="00:56:48.880" region="bottomCenter">A great poem, indeed</p>
      <p xml:id="p1073" begin="00:56:49.080" end="00:56:52.080" region="bottomCenter">This is something<br/>all of you should learn from</p>
      <p xml:id="p1074" begin="00:56:54.080" end="00:56:56.040" region="bottomCenter">Really? Is it that good?</p>
      <p xml:id="p1075" begin="00:56:56.280" end="00:56:57.360" region="bottomCenter">I just made it up</p>
      <p xml:id="p1076" begin="00:56:57.480" end="00:56:58.680" region="bottomCenter">It is good</p>
      <p xml:id="p1077" begin="00:56:58.800" end="00:57:00.560" region="bottomCenter">Every word counts<br/>and encouraging</p>
      <p xml:id="p1078" begin="00:57:00.680" end="00:57:02.600" region="bottomCenter">A poem like this</p>
      <p xml:id="p1079" begin="00:57:02.720" end="00:57:04.960" region="bottomCenter">shows the ambition of you, young man</p>
      <p xml:id="p1080" begin="00:57:05.080" end="00:57:06.320" region="bottomCenter">A true young hero</p>
      <p xml:id="p1081" begin="00:57:06.440" end="00:57:07.640" region="bottomCenter">with a bright future ahead!</p>
      <p xml:id="p1082" begin="00:57:07.760" end="00:57:09.320" region="bottomCenter">Oh, come on. It's just fine</p>
      <p xml:id="p1083" begin="00:57:09.600" end="00:57:11.160" region="bottomCenter">Actually,<br/>it still has some tiny flaws</p>
      <p xml:id="p1084" begin="00:57:11.280" end="00:57:12.360" region="bottomCenter">More like plenty of flaws</p>
      <p xml:id="p1085" begin="00:57:12.480" end="00:57:13.840" region="bottomCenter">Let me ask you<br/>what's with those dark eye circles?</p>
      <p xml:id="p1086" begin="00:57:14.640" end="00:57:17.000" region="bottomCenter">It's obvious<br/>you stay up late all the time</p>
      <p xml:id="p1087" begin="00:57:17.120" end="00:57:18.040" region="bottomCenter">Your life is undisciplined</p>
      <p xml:id="p1088" begin="00:57:18.160" end="00:57:19.160" region="bottomCenter">your diet unhealthy</p>
      <p xml:id="p1089" begin="00:57:19.280" end="00:57:21.080" region="bottomCenter">and you can't even manage<br/>basic self-control</p>
      <p xml:id="p1090" begin="00:57:21.200" end="00:57:23.120" region="bottomCenter">How dare you dream<br/>of becoming an immortal?</p>
      <p xml:id="p1091" begin="00:57:23.240" end="00:57:24.400" region="bottomCenter">I was born with dark eye circles</p>
      <p xml:id="p1092" begin="00:57:24.520" end="00:57:26.040" region="bottomCenter">Appearance reflects the heart,<br/>don't you know?</p>
      <p xml:id="p1093" begin="00:57:26.160" end="00:57:27.360" region="bottomCenter">Take a look at yourself<br/>in the mirror</p>
      <p xml:id="p1094" begin="00:57:27.480" end="00:57:28.960" region="bottomCenter">Ridiculous<br/>reckless and sloppy</p>
      <p xml:id="p1095" begin="00:57:29.080" end="00:57:29.920" region="bottomCenter">If you were my disciple</p>
      <p xml:id="p1096" begin="00:57:30.040" end="00:57:31.760" region="bottomCenter">I'd make you rebuild your human form</p>
      <p xml:id="p1097" begin="00:57:31.880" end="00:57:32.920" region="bottomCenter">It can be rebuilt?</p>
      <p xml:id="p1098" begin="00:57:33.120" end="00:57:34.520" region="bottomCenter">Then there's hope<br/>for my looks, right?</p>
      <p xml:id="p1099" begin="00:57:35.040" end="00:57:36.000" region="bottomCenter">Teach me, please</p>
      <p xml:id="p1100" begin="00:57:36.120" end="00:57:37.800" region="bottomCenter">I knew you came<br/>to find yourself a master</p>
      <p xml:id="p1101" begin="00:57:37.920" end="00:57:38.800" region="bottomCenter">Listen, kid</p>
      <p xml:id="p1102" begin="00:57:38.920" end="00:57:40.360" region="bottomCenter">I see you have great ambition</p>
      <p xml:id="p1103" begin="00:57:40.480" end="00:57:41.880" region="bottomCenter">so I'll take you as my disciple</p>
      <p xml:id="p1104" begin="00:57:42.000" end="00:57:44.040" region="bottomCenter">Cool! Master!</p>
      <p xml:id="p1105" begin="00:57:46.040" end="00:57:47.680" region="bottomCenter">Come train with your brothers</p>
      <p xml:id="p1106" begin="00:57:47.800" end="00:57:49.280" region="bottomCenter">- Train for what?<br/>- Immortality, of course</p>
      <p xml:id="p1107" begin="00:57:49.400" end="00:57:50.400" region="bottomCenter">I don't need you to teach me that</p>
      <p xml:id="p1108" begin="00:57:50.520" end="00:57:51.360" region="bottomCenter">Show me how to be prettier</p>
      <p xml:id="p1109" begin="00:57:51.480" end="00:57:52.400" region="bottomCenter">Ridiculous!</p>
      <p xml:id="p1110" begin="00:57:52.520" end="00:57:54.280" region="bottomCenter">You're putting looks<br/>before cultivation?</p>
      <p xml:id="p1111" begin="00:57:54.400" end="00:57:55.560" region="bottomCenter">Get your priorities straight</p>
      <p xml:id="p1112" begin="00:57:55.680" end="00:57:57.000" region="bottomCenter">Are you teaching me or not?</p>
      <p xml:id="p1113" begin="00:57:57.120" end="00:57:59.240" region="bottomCenter">We're no longer master and disciple</p>
      <p xml:id="p1114" begin="00:57:59.360" end="00:58:01.040" region="bottomCenter">You deserve to have<br/>panda eyes for life</p>
      <p xml:id="p1115" begin="00:58:01.160" end="00:58:02.000" region="bottomCenter">That's too much</p>
      <p xml:id="p1116" begin="00:58:02.120" end="00:58:03.840" region="bottomCenter">I was going to go easy on you!</p>
      <p xml:id="p1117" begin="00:58:03.960" end="00:58:05.400" region="bottomCenter">What is this?<br/>Are you challenging me?</p>
      <p xml:id="p1118" begin="00:58:05.520" end="00:58:06.400" region="bottomCenter">Three pills should be enough</p>
      <p xml:id="p1119" begin="00:58:06.520" end="00:58:09.160" region="bottomCenter">Kid, go back where you came from</p>
      <p xml:id="p1120" begin="00:58:09.280" end="00:58:11.480" region="bottomCenter">If you keep disrupting our class</p>
      <p xml:id="p1121" begin="00:58:11.600" end="00:58:13.040" region="bottomCenter">this could end badly for you</p>
      <p xml:id="p1122" begin="00:58:14.240" end="00:58:15.200" region="bottomCenter">Apologies</p>
      <p xml:id="p1123" begin="00:58:54.880" end="00:58:56.080" region="bottomCenter">You're no match for me</p>
      <p xml:id="p1124" begin="00:58:57.920" end="00:58:59.120" region="bottomCenter">Impressive, kid</p>
      <p xml:id="p1125" begin="00:58:59.640" end="00:59:00.880" region="bottomCenter">I underestimated you</p>
      <p xml:id="p1126" begin="00:59:15.560" end="00:59:16.520" region="bottomCenter">Try this!</p>
      <p xml:id="p1127" begin="00:59:19.520" end="00:59:21.640" region="bottomCenter">Yeah, teach this ignorant brat<br/>a lesson</p>
      <p xml:id="p1128" begin="00:59:21.760" end="00:59:22.880" region="bottomCenter">Master will surely win!</p>
      <p xml:id="p1129" begin="00:59:23.680" end="00:59:24.880" region="bottomCenter">So fast!</p>
      <p xml:id="p1130" begin="00:59:25.000" end="00:59:25.960" region="bottomCenter">You saw it?</p>
      <p xml:id="p1131" begin="00:59:28.280" end="00:59:30.120" region="bottomCenter">We have no grudges between us</p>
      <p xml:id="p1132" begin="00:59:30.240" end="00:59:31.400" region="bottomCenter">You'd better go</p>
      <p xml:id="p1133" begin="00:59:31.840" end="00:59:32.880" region="bottomCenter">I cannot lose</p>
      <p xml:id="p1134" begin="00:59:44.080" end="00:59:45.640" region="bottomCenter">You can't even touch me</p>
      <p xml:id="p1135" begin="00:59:46.000" end="00:59:47.080" region="bottomCenter">Let alone fight</p>
      <p xml:id="p1136" begin="01:00:00.440" end="01:00:01.760" region="bottomCenter">Smart move!<br/>Hold him tight</p>
      <p xml:id="p1137" begin="01:00:01.880" end="01:00:03.000" region="bottomCenter">Speedy is junky</p>
      <p xml:id="p1138" begin="01:00:04.240" end="01:00:05.160" region="bottomCenter">Surrender?</p>
      <p xml:id="p1139" begin="01:00:17.760" end="01:00:19.080" region="bottomCenter">Wait, you are...</p>
      <p xml:id="p1140" begin="01:00:20.280" end="01:00:21.280" region="bottomCenter">You've finally figured it out</p>
      <p xml:id="p1141" begin="01:00:21.520" end="01:00:23.360" region="bottomCenter">I'm not fast</p>
      <p xml:id="p1142" begin="01:00:23.480" end="01:00:25.080" region="bottomCenter">I just transform<br/>into electric currents</p>
      <p xml:id="p1143" begin="01:00:25.200" end="01:00:27.160" region="bottomCenter">traveling instantly to any location</p>
      <p xml:id="p1144" begin="01:00:27.280" end="01:00:28.480" region="bottomCenter">In water</p>
      <p xml:id="p1145" begin="01:00:28.720" end="01:00:30.880" region="bottomCenter">I am invincible!</p>
      <p xml:id="p1146" begin="01:00:45.800" end="01:00:47.120" region="bottomCenter">Impressive cryo power</p>
      <p xml:id="p1147" begin="01:00:50.680" end="01:00:51.680" region="bottomCenter">Stay calm</p>
      <p xml:id="p1148" begin="01:00:51.800" end="01:00:53.800" region="bottomCenter">Try too hard<br/>and your body will collapse!</p>
      <p xml:id="p1149" begin="01:00:53.920" end="01:00:55.160" region="bottomCenter">Ice doesn't conduct electricity</p>
      <p xml:id="p1150" begin="01:00:55.280" end="01:00:56.320" region="bottomCenter">Let's see what else you've got</p>
      <p xml:id="p1151" begin="01:00:58.320" end="01:00:59.880" region="bottomCenter">Lakes and seas...<br/>Clouds and sky...</p>
      <p xml:id="p1152" begin="01:01:00.000" end="01:01:01.480" region="bottomCenter">By this divine talisman in my hand<br/>Wind is to rise and rain is to fall</p>
      <p xml:id="p1153" begin="01:01:01.600" end="01:01:03.800" region="bottomCenter">Swift and Uplift!</p>
      <p xml:id="p1154" begin="01:01:14.200" end="01:01:15.040" region="bottomCenter">Father!</p>
      <p xml:id="p1155" begin="01:01:22.960" end="01:01:23.920" region="bottomCenter">Darn it</p>
      <p xml:id="p1156" begin="01:01:24.040" end="01:01:25.040" region="bottomCenter">The Rain Summoning Spell</p>
      <p xml:id="p1157" begin="01:01:25.160" end="01:01:26.000" region="bottomCenter">End this now!</p>
      <p xml:id="p1158" begin="01:01:39.840" end="01:01:40.720" region="bottomCenter">Too late</p>
      <p xml:id="p1159" begin="01:01:56.320" end="01:01:57.640" region="bottomCenter">You're doomed</p>
      <p xml:id="p1160" begin="01:02:17.280" end="01:02:18.840" region="bottomCenter">Master!</p>
      <p xml:id="p1161" begin="01:02:18.960" end="01:02:20.200" region="bottomCenter">Master, are you all right?</p>
      <p xml:id="p1162" begin="01:02:20.600" end="01:02:22.200" region="bottomCenter">I wasn't going to take your life</p>
      <p xml:id="p1163" begin="01:02:22.320" end="01:02:23.760" region="bottomCenter">You didn't have to sacrifice an arm</p>
      <p xml:id="p1164" begin="01:02:23.880" end="01:02:25.200" region="bottomCenter">All disciples, listen</p>
      <p xml:id="p1165" begin="01:02:25.320" end="01:02:27.120" region="bottomCenter">take the demons back to the palace</p>
      <p xml:id="p1166" begin="01:02:27.240" end="01:02:28.280" region="bottomCenter">Yes!</p>
      <p xml:id="p1167" begin="01:02:30.240" end="01:02:31.080" region="bottomCenter">Stop!</p>
      <p xml:id="p1168" begin="01:02:31.320" end="01:02:33.120" region="bottomCenter">Put them down<br/>All of you, put them down!</p>
      <p xml:id="p1169" begin="01:02:33.440" end="01:02:36.360" region="bottomCenter">May I ask if you are a member<br/>of the Chan Sect?</p>
      <p xml:id="p1170" begin="01:02:36.480" end="01:02:37.320" region="bottomCenter">That's correct</p>
      <p xml:id="p1171" begin="01:02:45.080" end="01:02:46.600" region="bottomCenter">These are all immortals<br/>from Yu Xu Palace</p>
      <p xml:id="p1172" begin="01:02:46.720" end="01:02:48.280" region="bottomCenter">You must not be disrespectful</p>
      <p xml:id="p1173" begin="01:02:48.400" end="01:02:49.800" region="bottomCenter">Entering Yu Xu Palace</p>
      <p xml:id="p1174" begin="01:02:49.920" end="01:02:51.960" region="bottomCenter">and receiving the teachings<br/>of the righteous path</p>
      <p xml:id="p1175" begin="01:02:52.080" end="01:02:53.840" region="bottomCenter">may not be a bad thing</p>
      <p xml:id="p1176" begin="01:02:54.000" end="01:02:56.680" region="bottomCenter">All of you, drop your weapons!</p>
      <p xml:id="p1177" begin="01:03:05.160" end="01:03:06.160" region="bottomCenter">Father!</p>
      <p xml:id="p1178" begin="01:03:06.280" end="01:03:08.280" region="bottomCenter">Xiaobao?<br/>How come you're back?</p>
      <p xml:id="p1179" begin="01:03:14.320" end="01:03:16.240" region="bottomCenter">Xiaobao, stand down!</p>
      <p xml:id="p1180" begin="01:03:24.480" end="01:03:25.400" region="bottomCenter">Xiaobao!</p>
      <p xml:id="p1181" begin="01:03:31.520" end="01:03:32.400" region="bottomCenter">Demon!</p>
      <p xml:id="p1182" begin="01:03:32.640" end="01:03:34.000" region="bottomCenter">How dare you!</p>
      <p xml:id="p1183" begin="01:03:34.960" end="01:03:35.920" region="bottomCenter">No!</p>
      <p xml:id="p1184" begin="01:03:51.080" end="01:03:52.320" region="bottomCenter">Father!</p>
      <p xml:id="p1185" begin="01:03:56.320" end="01:03:57.920" region="bottomCenter">Nezha, freeze the river now!</p>
      <p xml:id="p1186" begin="01:04:11.360" end="01:04:12.440" region="bottomCenter">You can't escape!</p>
      <p xml:id="p1187" begin="01:04:32.520" end="01:04:33.400" region="bottomCenter">Father!<br/>Go!</p>
      <p xml:id="p1188" begin="01:04:33.520" end="01:04:35.960" region="bottomCenter">Go now!</p>
      <p xml:id="p1189" begin="01:04:37.160" end="01:04:38.360" region="bottomCenter">Run!</p>
      <p xml:id="p1190" begin="01:04:39.120" end="01:04:40.120" region="bottomCenter">Father...</p>
      <p xml:id="p1191" begin="01:04:47.400" end="01:04:48.520" region="bottomCenter">There's no escape</p>
      <p xml:id="p1192" begin="01:04:51.080" end="01:04:51.960" region="bottomCenter">Step aside</p>
      <p xml:id="p1193" begin="01:04:52.080" end="01:04:53.440" region="bottomCenter">He's just trying to save his father</p>
      <p xml:id="p1194" begin="01:04:53.560" end="01:04:54.640" region="bottomCenter">You didn't have to be so brutal</p>
      <p xml:id="p1195" begin="01:05:04.680" end="01:05:05.920" region="bottomCenter">Panax notoginseng</p>
      <p xml:id="p1196" begin="01:05:06.800" end="01:05:08.040" region="bottomCenter">cattail pollen</p>
      <p xml:id="p1197" begin="01:05:08.720" end="01:05:09.920" region="bottomCenter">munjeet</p>
      <p xml:id="p1198" begin="01:05:10.560" end="01:05:11.560" region="bottomCenter">borneol</p>
      <p xml:id="p1199" begin="01:05:12.080" end="01:05:13.240" region="bottomCenter">Loong's blood</p>
      <p xml:id="p1200" begin="01:05:13.360" end="01:05:15.040" region="bottomCenter">- One more basket<br/>- Safflower</p>
      <p xml:id="p1201" begin="01:05:15.440" end="01:05:16.480" region="bottomCenter">angelica</p>
      <p xml:id="p1202" begin="01:05:16.960" end="01:05:18.600" region="bottomCenter">pseudo-ginseng powder</p>
      <p xml:id="p1203" begin="01:05:19.000" end="01:05:20.000" region="bottomCenter">sappanwood</p>
      <p xml:id="p1204" begin="01:05:20.360" end="01:05:21.720" region="bottomCenter">poison nut</p>
      <p xml:id="p1205" begin="01:05:22.200" end="01:05:23.160" region="bottomCenter">My lord</p>
      <p xml:id="p1206" begin="01:05:23.280" end="01:05:25.120" region="bottomCenter">we now have everything on the list</p>
      <p xml:id="p1207" begin="01:05:25.400" end="01:05:28.160" region="bottomCenter">along with a hundred baskets<br/>of sea products</p>
      <p xml:id="p1208" begin="01:05:28.280" end="01:05:30.280" region="bottomCenter">We happen to be short<br/>on food supplies</p>
      <p xml:id="p1209" begin="01:05:33.280" end="01:05:34.400" region="bottomCenter">Master Shen, a moment, please</p>
      <p xml:id="p1210" begin="01:05:35.640" end="01:05:37.280" region="bottomCenter">We've prepared a meal</p>
      <p xml:id="p1211" begin="01:05:37.400" end="01:05:39.240" region="bottomCenter">Would you honor us<br/>with your presence?</p>
      <p xml:id="p1212" begin="01:05:45.000" end="01:05:45.840" region="bottomCenter">You...</p>
      <p xml:id="p1213" begin="01:05:46.880" end="01:05:48.480" region="bottomCenter">Thanks to Lord Li's kindness</p>
      <p xml:id="p1214" begin="01:05:48.600" end="01:05:50.640" region="bottomCenter">I've been taken in as a servant</p>
      <p xml:id="p1215" begin="01:05:51.040" end="01:05:52.320" region="bottomCenter">He may be a demon</p>
      <p xml:id="p1216" begin="01:05:52.440" end="01:05:53.840" region="bottomCenter">but he has a good heart</p>
      <p xml:id="p1217" begin="01:05:53.960" end="01:05:55.440" region="bottomCenter">As long as he behaves</p>
      <p xml:id="p1218" begin="01:05:55.560" end="01:05:57.280" region="bottomCenter">there's no reason<br/>he can't have a future</p>
      <p xml:id="p1219" begin="01:05:58.720" end="01:06:00.320" region="bottomCenter">I wonder if the dishes<br/>suit your taste</p>
      <p xml:id="p1220" begin="01:06:00.440" end="01:06:01.520" region="bottomCenter">Not...</p>
      <p xml:id="p1221" begin="01:06:02.080" end="01:06:03.040" region="bottomCenter">Not bad</p>
      <p xml:id="p1222" begin="01:06:03.360" end="01:06:04.520" region="bottomCenter">Then have some more</p>
      <p xml:id="p1223" begin="01:06:04.640" end="01:06:05.800" region="bottomCenter">Try this liquor as well</p>
      <p xml:id="p1224" begin="01:06:06.120" end="01:06:07.440" region="bottomCenter">I quit long ago</p>
      <p xml:id="p1225" begin="01:06:07.560" end="01:06:10.760" region="bottomCenter">Cultivators must sup...<br/>suppress desires</p>
      <p xml:id="p1226" begin="01:06:11.080" end="01:06:12.440" region="bottomCenter">As the saying goes</p>
      <p xml:id="p1227" begin="01:06:12.560" end="01:06:14.800" region="bottomCenter">one must cut off urges<br/>to perfect the spirit</p>
      <p xml:id="p1228" begin="01:06:14.920" end="01:06:16.240" region="bottomCenter">Another saying goes</p>
      <p xml:id="p1229" begin="01:06:16.360" end="01:06:18.840" region="bottomCenter">one must practice kindness<br/>to polish virtue</p>
      <p xml:id="p1230" begin="01:06:19.960" end="01:06:21.480" region="bottomCenter">Talking won't help</p>
      <p xml:id="p1231" begin="01:06:21.600" end="01:06:24.120" region="bottomCenter">I've already re...<br/>reached the point of no return</p>
      <p xml:id="p1232" begin="01:06:24.360" end="01:06:27.160" region="bottomCenter">You can't hide forever</p>
      <p xml:id="p1233" begin="01:06:27.280" end="01:06:29.520" region="bottomCenter">The truth will come out one day</p>
      <p xml:id="p1234" begin="01:06:30.000" end="01:06:31.560" region="bottomCenter">If you continue to harm lives</p>
      <p xml:id="p1235" begin="01:06:31.680" end="01:06:32.840" region="bottomCenter">and make more mistakes</p>
      <p xml:id="p1236" begin="01:06:32.960" end="01:06:34.440" region="bottomCenter">even if you can deceive everyone</p>
      <p xml:id="p1237" begin="01:06:34.560" end="01:06:36.480" region="bottomCenter">you won't be able to fool yourself</p>
      <p xml:id="p1238" begin="01:06:36.960" end="01:06:39.800" region="bottomCenter">And you will not improve<br/>further on your cultivation</p>
      <p xml:id="p1239" begin="01:06:40.360" end="01:06:41.800" region="bottomCenter">the essence of which</p>
      <p xml:id="p1240" begin="01:06:41.920" end="01:06:43.160" region="bottomCenter">is doing good deeds</p>
      <p xml:id="p1241" begin="01:06:43.280" end="01:06:44.560" region="bottomCenter">- and walking the righteous path<br/>- Enough!</p>
      <p xml:id="p1242" begin="01:06:44.680" end="01:06:46.040" region="bottomCenter">What nonsense!</p>
      <p xml:id="p1243" begin="01:06:46.160" end="01:06:48.560" region="bottomCenter">You know nothing about cultivation</p>
      <p xml:id="p1244" begin="01:06:56.920" end="01:06:57.960" region="bottomCenter">Sir!</p>
      <p xml:id="p1245" begin="01:06:58.720" end="01:07:00.040" region="bottomCenter">Someone is here to see Master Shen</p>
      <p xml:id="p1246" begin="01:07:08.920" end="01:07:10.160" region="bottomCenter">Brother</p>
      <p xml:id="p1247" begin="01:07:11.040" end="01:07:12.200" region="bottomCenter">Who did this to you?</p>
      <p xml:id="p1248" begin="01:07:12.320" end="01:07:14.320" region="bottomCenter">Some Taoists</p>
      <p xml:id="p1249" begin="01:07:14.440" end="01:07:17.080" region="bottomCenter">They attacked</p>
      <p xml:id="p1250" begin="01:07:18.400" end="01:07:20.120" region="bottomCenter">Father...</p>
      <p xml:id="p1251" begin="01:07:20.240" end="01:07:22.360" region="bottomCenter">had one of his arms</p>
      <p xml:id="p1252" begin="01:07:23.160" end="01:07:24.880" region="bottomCenter">cut off</p>
      <p xml:id="p1253" begin="01:07:25.000" end="01:07:26.000" region="bottomCenter">Who did it?</p>
      <p xml:id="p1254" begin="01:07:26.440" end="01:07:29.360" region="bottomCenter">His name is...</p>
      <p xml:id="p1255" begin="01:07:30.520" end="01:07:32.880" region="bottomCenter">Ne... Zha</p>
      <p xml:id="p1256" begin="01:07:50.240" end="01:07:52.440" region="bottomCenter">Congratulations on passing Level 2</p>
      <p xml:id="p1257" begin="01:07:52.680" end="01:07:54.280" region="bottomCenter">Please inform Brother Wuliang</p>
      <p xml:id="p1258" begin="01:07:54.640" end="01:07:56.880" region="bottomCenter">Master is in seclusion<br/>refining pills</p>
      <p xml:id="p1259" begin="01:07:57.000" end="01:07:58.120" region="bottomCenter">and has not emerged yet</p>
      <p xml:id="p1260" begin="01:07:58.240" end="01:07:59.920" region="bottomCenter">Before Level 3</p>
      <p xml:id="p1261" begin="01:08:00.040" end="01:08:01.840" region="bottomCenter">why don't you rest for a few days?</p>
      <p xml:id="p1262" begin="01:08:01.960" end="01:08:03.520" region="bottomCenter">We only have two days left</p>
      <p xml:id="p1263" begin="01:08:03.680" end="01:08:04.640" region="bottomCenter">No need</p>
      <p xml:id="p1264" begin="01:08:04.760" end="01:08:05.840" region="bottomCenter">I'm fine</p>
      <p xml:id="p1265" begin="01:08:05.960" end="01:08:06.880" region="bottomCenter">Let's continue the test</p>
      <p xml:id="p1266" begin="01:08:07.160" end="01:08:09.120" region="bottomCenter">Well, as you wish</p>
      <p xml:id="p1267" begin="01:08:09.280" end="01:08:10.480" region="bottomCenter">The final test</p>
      <p xml:id="p1268" begin="01:08:10.600" end="01:08:12.480" region="bottomCenter">is the demon Queen of Skull Mountain</p>
      <p xml:id="p1269" begin="01:08:12.600" end="01:08:13.880" region="bottomCenter">Shi Ji</p>
      <p xml:id="p1270" begin="01:08:16.400" end="01:08:18.280" region="bottomCenter">Someone is requesting an urgent<br/>meeting with Master Taiyi</p>
      <p xml:id="p1271" begin="01:08:19.160" end="01:08:20.480" region="bottomCenter">Please help us!</p>
      <p xml:id="p1272" begin="01:08:20.760" end="01:08:22.440" region="bottomCenter">It's Chentang Pass</p>
      <p xml:id="p1273" begin="01:08:22.560" end="01:08:24.120" region="bottomCenter">Something happened!</p>
      <p xml:id="p1274" begin="01:08:47.480" end="01:08:48.480" region="bottomCenter">Dad</p>
      <p xml:id="p1275" begin="01:08:50.240" end="01:08:51.240" region="bottomCenter">Mom</p>
      <p xml:id="p1276" begin="01:08:54.240" end="01:08:55.360" region="bottomCenter">Dad</p>
      <p xml:id="p1277" begin="01:08:56.920" end="01:08:57.800" region="bottomCenter">Mom</p>
      <p xml:id="p1278" begin="01:09:00.240" end="01:09:01.280" region="bottomCenter">Dad?</p>
      <p xml:id="p1279" begin="01:09:02.640" end="01:09:03.640" region="bottomCenter">Mom?</p>
      <p xml:id="p1280" begin="01:09:13.320" end="01:09:15.200" region="bottomCenter">Dad!</p>
      <p xml:id="p1281" begin="01:09:16.120" end="01:09:18.640" region="bottomCenter">Mom!</p>
      <p xml:id="p1282" begin="01:09:39.480" end="01:09:40.960" region="bottomCenter">Calm down</p>
      <p xml:id="p1283" begin="01:09:41.080" end="01:09:42.640" region="bottomCenter">Let's keep looking<br/>Keep looking</p>
      <p xml:id="p1284" begin="01:09:45.640" end="01:09:48.240" region="bottomCenter">I received an urgent report as soon<br/>as I ended seclusion</p>
      <p xml:id="p1285" begin="01:09:48.360" end="01:09:51.480" region="bottomCenter">Who could have committed<br/>such a horrendous crime?</p>
      <p xml:id="p1286" begin="01:09:51.600" end="01:09:52.520" region="bottomCenter">Master</p>
      <p xml:id="p1287" begin="01:09:52.640" end="01:09:53.800" region="bottomCenter">according to Shieldos</p>
      <p xml:id="p1288" begin="01:09:53.920" end="01:09:55.880" region="bottomCenter">they were struck<br/>by a tremendous force</p>
      <p xml:id="p1289" begin="01:09:56.000" end="01:09:57.040" region="bottomCenter">and lost consciousness</p>
      <p xml:id="p1290" begin="01:09:57.160" end="01:09:58.320" region="bottomCenter">When they woke up</p>
      <p xml:id="p1291" begin="01:09:58.440" end="01:10:00.320" region="bottomCenter">people of Chentang Pass had<br/>already been slaughtered</p>
      <p xml:id="p1292" begin="01:10:00.520" end="01:10:02.400" region="bottomCenter">We haven't obtained the elixir yet</p>
      <p xml:id="p1293" begin="01:10:02.520" end="01:10:04.200" region="bottomCenter">Why would they do that?</p>
      <p xml:id="p1294" begin="01:10:04.320" end="01:10:05.160" region="bottomCenter">Brother</p>
      <p xml:id="p1295" begin="01:10:05.280" end="01:10:06.680" region="bottomCenter">any clue?</p>
      <p xml:id="p1296" begin="01:10:06.800" end="01:10:07.800" region="bottomCenter">No, no</p>
      <p xml:id="p1297" begin="01:10:07.920" end="01:10:08.800" region="bottomCenter">I was just thinking</p>
      <p xml:id="p1298" begin="01:10:08.920" end="01:10:11.160" region="bottomCenter">where did all this lava come from?</p>
      <p xml:id="p1299" begin="01:10:11.840" end="01:10:12.960" region="bottomCenter">Exactly</p>
      <p xml:id="p1300" begin="01:10:13.080" end="01:10:15.080" region="bottomCenter">There are no volcanoes<br/>for hundreds of miles around</p>
      <p xml:id="p1301" begin="01:10:15.200" end="01:10:17.080" region="bottomCenter">This is truly bizarre</p>
      <p xml:id="p1302" begin="01:10:17.920" end="01:10:18.920" region="bottomCenter">Everyone, come quick!</p>
      <p xml:id="p1303" begin="01:10:21.000" end="01:10:22.360" region="bottomCenter">What demon is this?</p>
      <p xml:id="p1304" begin="01:10:23.280" end="01:10:24.560" region="bottomCenter">This is...</p>
      <p xml:id="p1305" begin="01:10:26.280" end="01:10:27.440" region="bottomCenter">left by a Loong's claw</p>
      <p xml:id="p1306" begin="01:10:28.280" end="01:10:29.760" region="bottomCenter">Impossible!</p>
      <p xml:id="p1307" begin="01:10:30.280" end="01:10:33.400" region="bottomCenter">The Loongs are all in Eastern Sea</p>
      <p xml:id="p1308" begin="01:10:33.520" end="01:10:35.120" region="bottomCenter">guarding the Suppression Seal</p>
      <p xml:id="p1309" begin="01:10:35.240" end="01:10:37.520" region="bottomCenter">Not a single one could have left</p>
      <p xml:id="p1310" begin="01:10:37.920" end="01:10:39.960" region="bottomCenter">Master, if I remember correctly</p>
      <p xml:id="p1311" begin="01:10:40.080" end="01:10:41.960" region="bottomCenter">Queen Ao Run of Western Sea</p>
      <p xml:id="p1312" begin="01:10:42.080" end="01:10:43.560" region="bottomCenter">has a special skill</p>
      <p xml:id="p1313" begin="01:10:43.680" end="01:10:44.880" region="bottomCenter">called the Sky...</p>
      <p xml:id="p1314" begin="01:10:45.600" end="01:10:46.920" region="bottomCenter">Sky-Splitting Claw</p>
      <p xml:id="p1315" begin="01:10:47.040" end="01:10:48.960" region="bottomCenter">Are you saying<br/>she used the Sky-Splitting Claw</p>
      <p xml:id="p1316" begin="01:10:49.080" end="01:10:50.360" region="bottomCenter">to cross into Chentang Pass?</p>
      <p xml:id="p1317" begin="01:10:50.640" end="01:10:52.360" region="bottomCenter">That explains the lava</p>
      <p xml:id="p1318" begin="01:10:52.480" end="01:10:55.200" region="bottomCenter">It must have been transported<br/>from the purgatory remotely</p>
      <p xml:id="p1319" begin="01:10:55.320" end="01:10:57.040" region="bottomCenter">But she's watched<br/>by the Loong King of Eastern Sea</p>
      <p xml:id="p1320" begin="01:10:57.160" end="01:10:58.520" region="bottomCenter">It's impossible<br/>for her to cross over</p>
      <p xml:id="p1321" begin="01:10:58.800" end="01:11:01.320" region="bottomCenter">Then there's only<br/>one possibility left</p>
      <p xml:id="p1322" begin="01:11:01.800" end="01:11:04.480" region="bottomCenter">The thing I worried the most</p>
      <p xml:id="p1323" begin="01:11:04.600" end="01:11:06.000" region="bottomCenter">happened</p>
      <p xml:id="p1324" begin="01:11:06.400" end="01:11:08.160" region="bottomCenter">The King of Eastern Sea<br/>has betrayed us?</p>
      <p xml:id="p1325" begin="01:11:09.160" end="01:11:11.360" region="bottomCenter">This is too serious an accusation</p>
      <p xml:id="p1326" begin="01:11:11.480" end="01:11:13.840" region="bottomCenter">Could we be wrong?</p>
      <p xml:id="p1327" begin="01:11:14.080" end="01:11:15.760" region="bottomCenter">No</p>
      <p xml:id="p1328" begin="01:11:15.880" end="01:11:17.120" region="bottomCenter">It's them!</p>
      <p xml:id="p1329" begin="01:11:20.480" end="01:11:21.360" region="bottomCenter">What are you doing?</p>
      <p xml:id="p1330" begin="01:11:29.280" end="01:11:30.320" region="bottomCenter">Don't be impulsive</p>
      <p xml:id="p1331" begin="01:11:31.000" end="01:11:32.480" region="bottomCenter">Are you heading to the Loong Palace?</p>
      <p xml:id="p1332" begin="01:11:32.600" end="01:11:33.920" region="bottomCenter">That's the direction<br/>of Skull Mountain</p>
      <p xml:id="p1333" begin="01:11:35.080" end="01:11:38.120" region="bottomCenter">The Loongs slaughtered<br/>innocent civilians</p>
      <p xml:id="p1334" begin="01:11:38.240" end="01:11:40.760" region="bottomCenter">committing this<br/>unforgivable atrocity</p>
      <p xml:id="p1335" begin="01:11:41.040" end="01:11:43.840" region="bottomCenter">No need to consult<br/>with fellow Golden Immortals</p>
      <p xml:id="p1336" begin="01:11:43.960" end="01:11:45.880" region="bottomCenter">I'll strike first and explain later</p>
      <p xml:id="p1337" begin="01:11:46.160" end="01:11:48.360" region="bottomCenter">Crana, back to the palace with me</p>
      <p xml:id="p1338" begin="01:11:48.480" end="01:11:51.000" region="bottomCenter">Summon all the Demon Hunters</p>
      <p xml:id="p1339" begin="01:11:51.120" end="01:11:51.960" region="bottomCenter">Roger</p>
      <p xml:id="p1340" begin="01:11:52.080" end="01:11:53.120" region="bottomCenter">Brother</p>
      <p xml:id="p1341" begin="01:11:53.240" end="01:11:55.440" region="bottomCenter">Nezha's parents were<br/>killed by demons</p>
      <p xml:id="p1342" begin="01:11:55.560" end="01:11:58.720" region="bottomCenter">We can't let anything<br/>happen to the child</p>
      <p xml:id="p1343" begin="01:11:58.840" end="01:12:00.800" region="bottomCenter">Go with Deero for him now</p>
      <p xml:id="p1344" begin="01:12:00.920" end="01:12:01.760" region="bottomCenter">Yes</p>
      <p xml:id="p1345" begin="01:12:06.120" end="01:12:07.440" region="bottomCenter">I know you're heartbroken right now</p>
      <p xml:id="p1346" begin="01:12:07.800" end="01:12:10.160" region="bottomCenter">but can you please<br/>calm down for a moment?</p>
      <p xml:id="p1347" begin="01:12:13.440" end="01:12:15.680" region="bottomCenter">Can you take me<br/>to the Loong Palace first?</p>
      <p xml:id="p1348" begin="01:12:16.240" end="01:12:17.760" region="bottomCenter">I'll confront my father and master</p>
      <p xml:id="p1349" begin="01:12:17.880" end="01:12:18.720" region="bottomCenter">to get to the bottom of this</p>
      <p xml:id="p1350" begin="01:12:18.840" end="01:12:21.600" region="bottomCenter">Will that bring my parents back?</p>
      <p xml:id="p1351" begin="01:12:34.520" end="01:12:36.600" region="bottomCenter">Mirror mirror on the wall</p>
      <p xml:id="p1352" begin="01:12:36.960" end="01:12:39.600" region="bottomCenter">who's the fairest<br/>within ten miles and more?</p>
      <p xml:id="p1353" begin="01:12:39.720" end="01:12:41.280" region="bottomCenter">It's you, my lady</p>
      <p xml:id="p1354" begin="01:12:42.440" end="01:12:45.120" region="bottomCenter">And who is the fairest<br/>within a hundred miles?</p>
      <p xml:id="p1355" begin="01:12:45.240" end="01:12:46.560" region="bottomCenter">It's you, my lady</p>
      <p xml:id="p1356" begin="01:12:46.680" end="01:12:47.680" region="bottomCenter">What about a thousand miles?</p>
      <p xml:id="p1357" begin="01:12:47.800" end="01:12:49.200" region="bottomCenter">- It's you<br/>- And ten thousand miles?</p>
      <p xml:id="p1358" begin="01:12:49.320" end="01:12:50.320" region="bottomCenter">- It's you<br/>- And in the whole world?</p>
      <p xml:id="p1359" begin="01:12:50.440" end="01:12:52.040" region="bottomCenter">Still you</p>
      <p xml:id="p1360" begin="01:12:52.800" end="01:12:53.760" region="bottomCenter">Do you think I'm stupid?</p>
      <p xml:id="p1361" begin="01:12:53.880" end="01:12:54.760" region="bottomCenter">Lie better, at least</p>
      <p xml:id="p1362" begin="01:12:54.880" end="01:12:55.880" region="bottomCenter">No, no</p>
      <p xml:id="p1363" begin="01:12:56.000" end="01:12:58.560" region="bottomCenter">I was just trying<br/>not to piss you off</p>
      <p xml:id="p1364" begin="01:12:58.680" end="01:12:59.880" region="bottomCenter">You know what?</p>
      <p xml:id="p1365" begin="01:13:00.000" end="01:13:01.840" region="bottomCenter">Telling the truth won't make me mad</p>
      <p xml:id="p1366" begin="01:13:01.960" end="01:13:03.600" region="bottomCenter">Seriously?</p>
      <p xml:id="p1367" begin="01:13:03.720" end="01:13:06.840" region="bottomCenter">I, Lady Shi Ji,<br/>am indeed a stunning beauty</p>
      <p xml:id="p1368" begin="01:13:06.960" end="01:13:09.000" region="bottomCenter">but I know<br/>there's always someone better</p>
      <p xml:id="p1369" begin="01:13:09.480" end="01:13:10.320" region="bottomCenter">Go on and ask then</p>
      <p xml:id="p1370" begin="01:13:10.440" end="01:13:11.600" region="bottomCenter">Am I the fairest of them all?</p>
      <p xml:id="p1371" begin="01:13:11.720" end="01:13:12.560" region="bottomCenter">No</p>
      <p xml:id="p1372" begin="01:13:13.120" end="01:13:14.720" region="bottomCenter">Fair enough</p>
      <p xml:id="p1373" begin="01:13:14.840" end="01:13:16.400" region="bottomCenter">Am I the fairest</p>
      <p xml:id="p1374" begin="01:13:16.520" end="01:13:17.960" region="bottomCenter">- within ten thousand miles?<br/>- No</p>
      <p xml:id="p1375" begin="01:13:18.080" end="01:13:19.800" region="bottomCenter">- What about a thousand miles?<br/>- No</p>
      <p xml:id="p1376" begin="01:13:19.920" end="01:13:21.160" region="bottomCenter">- What about a hundred miles?<br/>- No</p>
      <p xml:id="p1377" begin="01:13:21.280" end="01:13:22.160" region="bottomCenter">Ten miles?</p>
      <p xml:id="p1378" begin="01:13:22.280" end="01:13:23.120" region="bottomCenter">Nope</p>
      <p xml:id="p1379" begin="01:13:23.240" end="01:13:26.360" region="bottomCenter">Am I even the fairest<br/>on this mountain?</p>
      <p xml:id="p1380" begin="01:13:26.480" end="01:13:27.960" region="bottomCenter">Nope</p>
      <p xml:id="p1381" begin="01:13:28.080" end="01:13:28.920" region="bottomCenter">Screw you!</p>
      <p xml:id="p1382" begin="01:13:29.040" end="01:13:30.920" region="bottomCenter">There isn't any other female<br/>in this mountain</p>
      <p xml:id="p1383" begin="01:13:31.040" end="01:13:32.400" region="bottomCenter">I'm female, too</p>
      <p xml:id="p1384" begin="01:13:34.000" end="01:13:35.680" region="bottomCenter">You promised you won't get mad</p>
      <p xml:id="p1385" begin="01:13:37.120" end="01:13:38.800" region="bottomCenter">- You are prettier than me?<br/>- Help!</p>
      <p xml:id="p1386" begin="01:13:38.920" end="01:13:40.560" region="bottomCenter">How the hell!</p>
      <p xml:id="p1387" begin="01:13:44.760" end="01:13:46.560" region="bottomCenter">Demon, show yourself!</p>
      <p xml:id="p1388" begin="01:13:46.840" end="01:13:48.240" region="bottomCenter">Who are you calling demon?</p>
      <p xml:id="p1389" begin="01:13:48.360" end="01:13:49.480" region="bottomCenter">It's Lady Shi Ji</p>
      <p xml:id="p1390" begin="01:14:01.840" end="01:14:02.840" region="bottomCenter">Darn kid</p>
      <p xml:id="p1391" begin="01:14:02.960" end="01:14:03.840" region="bottomCenter">Have we even met?</p>
      <p xml:id="p1392" begin="01:14:03.960" end="01:14:05.560" region="bottomCenter">What the hell are you up to?</p>
      <p xml:id="p1393" begin="01:14:07.240" end="01:14:08.360" region="bottomCenter">You will be exposed</p>
      <p xml:id="p1394" begin="01:14:08.480" end="01:14:09.480" region="bottomCenter">Let me</p>
      <p xml:id="p1395" begin="01:14:09.600" end="01:14:10.480" region="bottomCenter">Stay out of it</p>
      <p xml:id="p1396" begin="01:14:34.160" end="01:14:37.640" region="bottomCenter">You think you can defeat me?</p>
      <p xml:id="p1397" begin="01:14:59.080" end="01:15:03.360" region="bottomCenter">The entire mountain is my body</p>
      <p xml:id="p1398" begin="01:15:03.640" end="01:15:06.040" region="bottomCenter">I'll see how you can destroy me</p>
      <p xml:id="p1399" begin="01:15:15.640" end="01:15:16.640" region="bottomCenter">If you use more force</p>
      <p xml:id="p1400" begin="01:15:16.760" end="01:15:17.960" region="bottomCenter">your body will collapse!</p>
      <p xml:id="p1401" begin="01:15:18.440" end="01:15:19.720" region="bottomCenter">I said</p>
      <p xml:id="p1402" begin="01:15:19.880" end="01:15:23.960" region="bottomCenter">stay out of it!</p>
      <p xml:id="p1403" begin="01:15:33.560" end="01:15:34.640" region="bottomCenter">It has already started!</p>
      <p xml:id="p1404" begin="01:15:35.520" end="01:15:36.520" region="bottomCenter">Crap!</p>
      <p xml:id="p1405" begin="01:15:44.280" end="01:15:46.160" region="bottomCenter">I'm so screwed</p>
      <p xml:id="p1406" begin="01:15:48.000" end="01:15:49.560" region="bottomCenter">Luckily there's some left</p>
      <p xml:id="p1407" begin="01:15:49.680" end="01:15:51.840" region="bottomCenter">I shall live to fight another day</p>
      <p xml:id="p1408" begin="01:15:51.960" end="01:15:54.200" region="bottomCenter">Darn kid<br/>Just you wait</p>
      <p xml:id="p1409" begin="01:15:55.760" end="01:15:57.200" region="bottomCenter">Nine-Loong Fire Trap!</p>
      <p xml:id="p1410" begin="01:16:06.760" end="01:16:08.040" region="bottomCenter">No escape!</p>
      <p xml:id="p1411" begin="01:16:10.120" end="01:16:12.360" region="bottomCenter">Oh my! Reckless child</p>
      <p xml:id="p1412" begin="01:16:13.480" end="01:16:14.800" region="bottomCenter">You body has almost gone</p>
      <p xml:id="p1413" begin="01:16:14.920" end="01:16:16.040" region="bottomCenter">Are you trying to kill yourself?</p>
      <p xml:id="p1414" begin="01:16:16.280" end="01:16:18.280" region="bottomCenter">What's that fire earlier?</p>
      <p xml:id="p1415" begin="01:16:18.400" end="01:16:19.760" region="bottomCenter">Isn't Nezha</p>
      <p xml:id="p1416" begin="01:16:19.960" end="01:16:21.280" region="bottomCenter">a frost mage?</p>
      <p xml:id="p1417" begin="01:16:21.600" end="01:16:23.160" region="bottomCenter">Who... who said that?</p>
      <p xml:id="p1418" begin="01:16:23.280" end="01:16:24.400" region="bottomCenter">Frost, flame,<br/>I taught him everything</p>
      <p xml:id="p1419" begin="01:16:24.520" end="01:16:25.680" region="bottomCenter">His powers are</p>
      <p xml:id="p1420" begin="01:16:25.800" end="01:16:26.760" region="bottomCenter">a combination of ice and fire</p>
      <p xml:id="p1421" begin="01:16:26.880" end="01:16:28.640" region="bottomCenter">Is that possible?</p>
      <p xml:id="p1422" begin="01:16:28.760" end="01:16:29.640" region="bottomCenter">The Spirit Pearl is endowed<br/>with unparalleled talents</p>
      <p xml:id="p1423" begin="01:16:29.760" end="01:16:30.800" region="bottomCenter">Can't judge him by normal standards</p>
      <p xml:id="p1424" begin="01:16:31.160" end="01:16:32.560" region="bottomCenter">Which one of us is the teacher?</p>
      <p xml:id="p1425" begin="01:16:32.680" end="01:16:33.520" region="bottomCenter">You think you know better than me?</p>
      <p xml:id="p1426" begin="01:16:33.640" end="01:16:34.560" region="bottomCenter">I wouldn't dare</p>
      <p xml:id="p1427" begin="01:16:34.680" end="01:16:37.960" region="bottomCenter">However<br/>I did sense a strong presence</p>
      <p xml:id="p1428" begin="01:16:38.080" end="01:16:39.960" region="bottomCenter">of demonic energy earlier</p>
      <p xml:id="p1429" begin="01:16:40.080" end="01:16:41.040" region="bottomCenter">About that...</p>
      <p xml:id="p1430" begin="01:16:41.360" end="01:16:42.840" region="bottomCenter">Shi Ji must have released it</p>
      <p xml:id="p1431" begin="01:16:43.120" end="01:16:44.600" region="bottomCenter">What are you saying, fatty?</p>
      <p xml:id="p1432" begin="01:16:44.720" end="01:16:45.560" region="bottomCenter">I did not...</p>
      <p xml:id="p1433" begin="01:16:45.840" end="01:16:48.080" region="bottomCenter">Was it you? Just tell me, was it?<br/>Say it!</p>
      <p xml:id="p1434" begin="01:16:48.200" end="01:16:49.320" region="bottomCenter">Yes, it was me</p>
      <p xml:id="p1435" begin="01:16:49.440" end="01:16:51.680" region="bottomCenter">Stop shaking<br/>I'm about to throw up!</p>
      <p xml:id="p1436" begin="01:16:53.120" end="01:16:54.120" region="bottomCenter">See? I told you</p>
      <p xml:id="p1437" begin="01:16:57.960" end="01:16:59.040" region="bottomCenter">Nezha</p>
      <p xml:id="p1438" begin="01:16:59.160" end="01:17:01.080" region="bottomCenter">you've passed three levels</p>
      <p xml:id="p1439" begin="01:17:01.200" end="01:17:02.040" region="bottomCenter">Today</p>
      <p xml:id="p1440" begin="01:17:02.160" end="01:17:04.440" region="bottomCenter">I will personally cast</p>
      <p xml:id="p1441" begin="01:17:04.560" end="01:17:05.840" region="bottomCenter">the Ascension Spell for you</p>
      <p xml:id="p1442" begin="01:17:14.240" end="01:17:16.280" region="bottomCenter">I've been through<br/>all of this back then</p>
      <p xml:id="p1443" begin="01:17:16.400" end="01:17:18.040" region="bottomCenter">I was probably too nervous</p>
      <p xml:id="p1444" begin="01:17:18.160" end="01:17:20.080" region="bottomCenter">The Ascension Spell is longer<br/>than I remember</p>
      <p xml:id="p1445" begin="01:17:30.320" end="01:17:32.360" region="bottomCenter">From now on</p>
      <p xml:id="p1446" begin="01:17:32.480" end="01:17:34.880" region="bottomCenter">you're an Immortal of the Chan Sect</p>
      <p xml:id="p1447" begin="01:17:57.200" end="01:18:00.240" region="bottomCenter">This Yu Xu Treasure Vault</p>
      <p xml:id="p1448" begin="01:18:00.360" end="01:18:02.280" region="bottomCenter">houses all sorts of rare magic items</p>
      <p xml:id="p1449" begin="01:18:02.400" end="01:18:03.400" region="bottomCenter">Elixir Reparo</p>
      <p xml:id="p1450" begin="01:18:04.880" end="01:18:06.480" region="bottomCenter">You can only pick one</p>
      <p xml:id="p1451" begin="01:18:06.680" end="01:18:07.920" region="bottomCenter">Don't you need more time?</p>
      <p xml:id="p1452" begin="01:18:08.040" end="01:18:09.600" region="bottomCenter">Elixir Reparo</p>
      <p xml:id="p1453" begin="01:19:11.280" end="01:19:13.600" region="bottomCenter">Yu Xu Palace has sent messengers</p>
      <p xml:id="p1454" begin="01:19:13.720" end="01:19:16.720" region="bottomCenter">to inform the Twelve about<br/>what the Loongs did</p>
      <p xml:id="p1455" begin="01:19:16.920" end="01:19:18.600" region="bottomCenter">However, due to the great distance</p>
      <p xml:id="p1456" begin="01:19:18.720" end="01:19:21.720" region="bottomCenter">my brothers and sisters can't<br/>make it here sooner</p>
      <p xml:id="p1457" begin="01:19:22.120" end="01:19:23.160" region="bottomCenter">This time</p>
      <p xml:id="p1458" begin="01:19:23.280" end="01:19:25.360" region="bottomCenter">I myself will lead the hunt</p>
      <p xml:id="p1459" begin="01:19:25.480" end="01:19:26.960" region="bottomCenter">on the Loongs</p>
      <p xml:id="p1460" begin="01:19:27.840" end="01:19:28.960" region="bottomCenter">Nezha</p>
      <p xml:id="p1461" begin="01:19:29.080" end="01:19:31.760" region="bottomCenter">will you fight alongside me?</p>
      <p xml:id="p1462" begin="01:19:31.920" end="01:19:34.400" region="bottomCenter">Let me go back<br/>to Chentang Pass first</p>
      <p xml:id="p1463" begin="01:19:34.520" end="01:19:37.080" region="bottomCenter">Then we'll seek revenge<br/>on the Loong King</p>
      <p xml:id="p1464" begin="01:19:37.320" end="01:19:38.560" region="bottomCenter">OK</p>
      <p xml:id="p1465" begin="01:19:38.680" end="01:19:40.680" region="bottomCenter">With your extraordinary<br/>combat skills</p>
      <p xml:id="p1466" begin="01:19:40.800" end="01:19:44.160" region="bottomCenter">you'd be a great help<br/>in destroying the Loong Palace</p>
      <p xml:id="p1467" begin="01:20:02.920" end="01:20:04.280" region="bottomCenter">I've paid back</p>
      <p xml:id="p1468" begin="01:20:05.480" end="01:20:06.800" region="bottomCenter">everything I owed you</p>
      <p xml:id="p1469" begin="01:20:07.960" end="01:20:09.040" region="bottomCenter">Wait</p>
      <p xml:id="p1470" begin="01:20:09.320" end="01:20:10.400" region="bottomCenter">When I get my body back</p>
      <p xml:id="p1471" begin="01:20:10.520" end="01:20:11.600" region="bottomCenter">I will go with you<br/>to the Loong Palace, okay?</p>
      <p xml:id="p1472" begin="01:20:11.720" end="01:20:13.240" region="bottomCenter">You know well what I'm going to do</p>
      <p xml:id="p1473" begin="01:20:14.680" end="01:20:17.080" region="bottomCenter">You being there<br/>will only make it harder</p>
      <p xml:id="p1474" begin="01:20:18.960" end="01:20:20.480" region="bottomCenter">Next time we meet</p>
      <p xml:id="p1475" begin="01:20:21.960" end="01:20:23.760" region="bottomCenter">we're foes instead of friends</p>
      <p xml:id="p1476" begin="01:20:26.760" end="01:20:27.800" region="bottomCenter">Karma it is</p>
      <p xml:id="p1477" begin="01:20:32.320" end="01:20:33.280" region="bottomCenter">No, you can't leave!</p>
      <p xml:id="p1478" begin="01:20:34.320" end="01:20:36.080" region="bottomCenter">Your soul will scatter<br/>before you get to the Loong Palace</p>
      <p xml:id="p1479" begin="01:20:41.320" end="01:20:42.240" region="bottomCenter">Nine-Loong Fire Trap!</p>
      <p xml:id="p1480" begin="01:20:50.200" end="01:20:51.760" region="bottomCenter">Calm down, will you?</p>
      <p xml:id="p1481" begin="01:20:51.880" end="01:20:54.480" region="bottomCenter">Going now won't change anything</p>
      <p xml:id="p1482" begin="01:20:54.880" end="01:20:56.160" region="bottomCenter">Leave me alone</p>
      <p xml:id="p1483" begin="01:20:56.280" end="01:20:57.360" region="bottomCenter">Let me out!</p>
      <p xml:id="p1484" begin="01:20:57.480" end="01:20:59.120" region="bottomCenter">No!<br/>I promised Nezha</p>
      <p xml:id="p1485" begin="01:20:59.240" end="01:21:00.680" region="bottomCenter">I'd save you no matter what</p>
      <p xml:id="p1486" begin="01:21:13.560" end="01:21:14.920" region="bottomCenter">Suffocating!</p>
      <p xml:id="p1487" begin="01:22:08.320" end="01:22:09.880" region="bottomCenter">Who's there?</p>
      <p xml:id="p1488" begin="01:22:10.720" end="01:22:13.640" region="bottomCenter">I'm Immortal Wuliang<br/>of the Chan Sect</p>
      <p xml:id="p1489" begin="01:22:13.760" end="01:22:15.920" region="bottomCenter">Ao Guang, do you admit your guilt?</p>
      <p xml:id="p1490" begin="01:22:18.040" end="01:22:20.200" region="bottomCenter">So you've found out?</p>
      <p xml:id="p1491" begin="01:22:20.640" end="01:22:22.680" region="bottomCenter">Is Ao Bing still alive?</p>
      <p xml:id="p1492" begin="01:22:23.160" end="01:22:24.640" region="bottomCenter">I'll accept<br/>whatever punishment you give me</p>
      <p xml:id="p1493" begin="01:22:24.760" end="01:22:26.400" region="bottomCenter">but please spare my son</p>
      <p xml:id="p1494" begin="01:22:26.720" end="01:22:27.960" region="bottomCenter">Nonsense!</p>
      <p xml:id="p1495" begin="01:22:28.320" end="01:22:29.960" region="bottomCenter">The Court of Heaven<br/>ordered your clan</p>
      <p xml:id="p1496" begin="01:22:30.080" end="01:22:31.800" region="bottomCenter">to suppress the sea monsters</p>
      <p xml:id="p1497" begin="01:22:31.920" end="01:22:33.640" region="bottomCenter">Instead, you colluded with them</p>
      <p xml:id="p1498" begin="01:22:33.760" end="01:22:35.720" region="bottomCenter">and slaughtered Chentang Pass</p>
      <p xml:id="p1499" begin="01:22:36.120" end="01:22:37.240" region="bottomCenter">What?</p>
      <p xml:id="p1500" begin="01:22:37.560" end="01:22:40.120" region="bottomCenter">The Loongs have committed<br/>an unforgivable crime</p>
      <p xml:id="p1501" begin="01:22:40.240" end="01:22:43.240" region="bottomCenter">Today justice shall be served</p>
      <p xml:id="p1502" begin="01:23:00.800" end="01:23:02.440" region="bottomCenter">Encompassed are<br/>the earth and the skies</p>
      <p xml:id="p1503" begin="01:23:02.560" end="01:23:04.040" region="bottomCenter">Unleash the power<br/>with boundless might</p>
      <p xml:id="p1504" begin="01:23:04.160" end="01:23:06.000" region="bottomCenter">Let the Tianyuan rise and stand tall</p>
      <p xml:id="p1505" begin="01:23:06.120" end="01:23:08.080" region="bottomCenter">Reign supreme above them all</p>
      <p xml:id="p1506" begin="01:23:08.280" end="01:23:09.160" region="bottomCenter">Open Cauldron!</p>
      <p xml:id="p1507" begin="01:23:39.960" end="01:23:41.560" region="bottomCenter">Show yourselves!</p>
      <p xml:id="p1508" begin="01:23:44.960" end="01:23:48.120" region="bottomCenter">What have you done to Chentang Pass?</p>
      <p xml:id="p1509" begin="01:23:48.240" end="01:23:50.000" region="bottomCenter">Didn't big brother tell us</p>
      <p xml:id="p1510" begin="01:23:50.120" end="01:23:51.880" region="bottomCenter">to follow Master Shen's orders?</p>
      <p xml:id="p1511" begin="01:23:52.000" end="01:23:53.520" region="bottomCenter">Shen Gongbao?!</p>
      <p xml:id="p1512" begin="01:24:03.960" end="01:24:05.800" region="bottomCenter">Speaking of the emergency</p>
      <p xml:id="p1513" begin="01:24:06.200" end="01:24:08.400" region="bottomCenter">you should focus on present</p>
      <p xml:id="p1514" begin="01:24:10.880" end="01:24:11.800" region="bottomCenter">My King</p>
      <p xml:id="p1515" begin="01:24:11.920" end="01:24:12.880" region="bottomCenter">we can't sit here and wait to die!</p>
      <p xml:id="p1516" begin="01:24:13.000" end="01:24:14.280" region="bottomCenter">If I go into battle</p>
      <p xml:id="p1517" begin="01:24:14.400" end="01:24:15.560" region="bottomCenter">the Suppression Seal will...</p>
      <p xml:id="p1518" begin="01:24:15.680" end="01:24:16.760" region="bottomCenter">Leave that to us</p>
      <p xml:id="p1519" begin="01:24:16.880" end="01:24:17.760" region="bottomCenter">Joining all our powers</p>
      <p xml:id="p1520" begin="01:24:17.880" end="01:24:19.360" region="bottomCenter">we can hold it for long enough</p>
      <p xml:id="p1521" begin="01:24:19.920" end="01:24:21.080" region="bottomCenter">Fine</p>
      <p xml:id="p1522" begin="01:24:35.840" end="01:24:38.000" region="bottomCenter">I've had enough!</p>
      <p xml:id="p1523" begin="01:24:48.160" end="01:24:49.440" region="bottomCenter">You wretched demon!</p>
      <p xml:id="p1524" begin="01:25:00.400" end="01:25:03.680" region="bottomCenter">This is an once-in-a-millennium<br/>chance for revenge</p>
      <p xml:id="p1525" begin="01:25:04.160" end="01:25:05.960" region="bottomCenter">Break out of the purgatory!</p>
      <p xml:id="p1526" begin="01:25:06.360" end="01:25:08.360" region="bottomCenter">Destroy the Loong Palace!</p>
      <p xml:id="p1527" begin="01:26:40.920" end="01:26:42.520" region="bottomCenter">Soul Blade!</p>
      <p xml:id="p1528" begin="01:27:02.840" end="01:27:04.920" region="bottomCenter">Old fool! Taste my sword!</p>
      <p xml:id="p1529" begin="01:27:20.320" end="01:27:21.840" region="bottomCenter">Releasing demonic energy<br/>like this...</p>
      <p xml:id="p1530" begin="01:27:21.960" end="01:27:23.840" region="bottomCenter">aren't you afraid<br/>of exposing your identity?</p>
      <p xml:id="p1531" begin="01:27:24.200" end="01:27:26.000" region="bottomCenter">I told you</p>
      <p xml:id="p1532" begin="01:27:26.120" end="01:27:28.880" region="bottomCenter">if you dared to harm Chentang Pass</p>
      <p xml:id="p1533" begin="01:27:29.000" end="01:27:32.800" region="bottomCenter">I would smash your palace<br/>into PIECES!</p>
      <p xml:id="p1534" begin="01:27:36.920" end="01:27:37.760" region="bottomCenter">Tell me!</p>
      <p xml:id="p1535" begin="01:27:37.880" end="01:27:39.560" region="bottomCenter">Is Ao Bing dead?</p>
      <p xml:id="p1536" begin="01:28:43.920" end="01:28:45.760" region="bottomCenter">Move! Out of my way!</p>
      <p xml:id="p1537" begin="01:29:22.160" end="01:29:23.280" region="bottomCenter">Rise!</p>
      <p xml:id="p1538" begin="01:30:33.880" end="01:30:35.840" region="bottomCenter">Do you have a death wish?</p>
      <p xml:id="p1539" begin="01:30:36.160" end="01:30:39.240" region="bottomCenter">Let's see how long<br/>your body can take it</p>
      <p xml:id="p1540" begin="01:30:39.360" end="01:30:40.840" region="bottomCenter">I don't care if I live or die</p>
      <p xml:id="p1541" begin="01:30:40.960" end="01:30:42.600" region="bottomCenter">As long as you're dead!</p>
      <p xml:id="p1542" begin="01:31:01.320" end="01:31:02.400" region="bottomCenter">Now is the time!</p>
      <p xml:id="p1543" begin="01:31:21.600" end="01:31:23.520" region="bottomCenter">Look what you've done!</p>
      <p xml:id="p1544" begin="01:31:23.720" end="01:31:27.280" region="bottomCenter">Is annihilation<br/>for all really what you want?</p>
      <p xml:id="p1545" begin="01:31:30.040" end="01:31:31.000" region="bottomCenter">The chains</p>
      <p xml:id="p1546" begin="01:31:37.920" end="01:31:40.920" region="bottomCenter">Even the Eastern Sea Loong King<br/>can't match your power</p>
      <p xml:id="p1547" begin="01:31:41.040" end="01:31:43.440" region="bottomCenter">I was right after all</p>
      <p xml:id="p1548" begin="01:31:43.560" end="01:31:46.960" region="bottomCenter">You're exactly<br/>what the Chan Sect needs</p>
      <p xml:id="p1549" begin="01:31:47.560" end="01:31:50.400" region="bottomCenter">Your parents spent<br/>their lives fighting evil</p>
      <p xml:id="p1550" begin="01:31:50.520" end="01:31:51.720" region="bottomCenter">From now on</p>
      <p xml:id="p1551" begin="01:31:51.840" end="01:31:54.400" region="bottomCenter">you must carry on their legacy</p>
      <p xml:id="p1552" begin="01:31:54.520" end="01:31:56.880" region="bottomCenter">and eliminate all the demons</p>
      <p xml:id="p1553" begin="01:31:58.800" end="01:32:01.720" region="bottomCenter">Let me avenge your loss</p>
      <p xml:id="p1554" begin="01:32:01.840" end="01:32:03.800" region="bottomCenter">by turning these jerks into pills</p>
      <p xml:id="p1555" begin="01:32:04.040" end="01:32:05.200" region="bottomCenter">Escort me!</p>
      <p xml:id="p1556" begin="01:32:05.320" end="01:32:06.160" region="bottomCenter">Yes, master!</p>
      <p xml:id="p1557" begin="01:32:48.600" end="01:32:49.760" region="bottomCenter">Nezha!</p>
      <p xml:id="p1558" begin="01:32:53.640" end="01:32:54.640" region="bottomCenter">Nezha!</p>
      <p xml:id="p1559" begin="01:32:54.800" end="01:32:55.840" region="bottomCenter">Nezha!</p>
      <p xml:id="p1560" begin="01:32:56.120" end="01:32:57.160" region="bottomCenter">Nezha!</p>
      <p xml:id="p1561" begin="01:32:57.280" end="01:32:58.360" region="bottomCenter">Nezha!</p>
      <p xml:id="p1562" begin="01:32:58.760" end="01:32:59.800" region="bottomCenter">Nezha!</p>
      <p xml:id="p1563" begin="01:33:00.200" end="01:33:01.160" region="bottomCenter">Nezha!</p>
      <p xml:id="p1564" begin="01:33:01.360" end="01:33:02.240" region="bottomCenter">Dad!</p>
      <p xml:id="p1565" begin="01:33:02.360" end="01:33:03.320" region="bottomCenter">Nezha!</p>
      <p xml:id="p1566" begin="01:33:03.440" end="01:33:04.280" region="bottomCenter">Mom!</p>
      <p xml:id="p1567" begin="01:33:04.400" end="01:33:05.360" region="bottomCenter">Nezha!</p>
      <p xml:id="p1568" begin="01:33:06.360" end="01:33:07.600" region="bottomCenter">Nezha!</p>
      <p xml:id="p1569" begin="01:33:11.960" end="01:33:13.680" region="bottomCenter">Son, are you alright?</p>
      <p xml:id="p1570" begin="01:33:14.160" end="01:33:15.360" region="bottomCenter">Your body...</p>
      <p xml:id="p1571" begin="01:33:15.600" end="01:33:18.320" region="bottomCenter">I... I...</p>
      <p xml:id="p1572" begin="01:33:19.080" end="01:33:21.640" region="bottomCenter">They already know<br/>about you and Ao Bing</p>
      <p xml:id="p1573" begin="01:33:23.160" end="01:33:27.080" region="bottomCenter">I... I... I thought...</p>
      <p xml:id="p1574" begin="01:33:27.760" end="01:33:31.600" region="bottomCenter">I'd never see you again</p>
      <p xml:id="p1575" begin="01:33:40.560" end="01:33:41.800" region="bottomCenter">Master is still casting the spell</p>
      <p xml:id="p1576" begin="01:33:41.920" end="01:33:43.200" region="bottomCenter">We need to buy<br/>as much time as we can</p>
      <p xml:id="p1577" begin="01:33:45.200" end="01:33:47.880" region="bottomCenter">Nezha, it wasn't my father<br/>who slaughtered Chentang Pass</p>
      <p xml:id="p1578" begin="01:33:49.040" end="01:33:52.400" region="bottomCenter">The real culprit<br/>is him, the Immortal Wuliang!</p>
      <p xml:id="p1579" begin="01:34:11.680" end="01:34:12.640" region="bottomCenter">Shieldos!</p>
      <p xml:id="p1580" begin="01:35:00.520" end="01:35:01.640" region="bottomCenter">Loongs</p>
      <p xml:id="p1581" begin="01:35:02.240" end="01:35:03.600" region="bottomCenter">Brother</p>
      <p xml:id="p1582" begin="01:35:04.120" end="01:35:06.160" region="bottomCenter">it's been a while</p>
      <p xml:id="p1583" begin="01:35:06.760" end="01:35:08.000" region="bottomCenter">Why are you here?</p>
      <p xml:id="p1584" begin="01:35:09.520" end="01:35:10.640" region="bottomCenter">Shen Gongbao</p>
      <p xml:id="p1585" begin="01:35:10.760" end="01:35:11.920" region="bottomCenter">you collude with the Loongs</p>
      <p xml:id="p1586" begin="01:35:12.040" end="01:35:13.120" region="bottomCenter">What are you up to?</p>
      <p xml:id="p1587" begin="01:35:13.440" end="01:35:15.880" region="bottomCenter">I should be ask... asking you</p>
      <p xml:id="p1588" begin="01:35:16.000" end="01:35:18.800" region="bottomCenter">You captured my father<br/>What are you up to?</p>
      <p xml:id="p1589" begin="01:35:19.640" end="01:35:21.760" region="bottomCenter">Who said I captured your father?</p>
      <p xml:id="p1590" begin="01:35:21.880" end="01:35:23.920" region="bottomCenter">Only you know my family's situation</p>
      <p xml:id="p1591" begin="01:35:24.040" end="01:35:25.760" region="bottomCenter">If you didn't give the order</p>
      <p xml:id="p1592" begin="01:35:25.880" end="01:35:29.160" region="bottomCenter">why would Nezha and the Demon<br/>Hunters hunt my father down?</p>
      <p xml:id="p1593" begin="01:35:29.520" end="01:35:32.160" region="bottomCenter">And my little brother's<br/>arrow wound...</p>
      <p xml:id="p1594" begin="01:35:32.280" end="01:35:33.960" region="bottomCenter">It's obviously</p>
      <p xml:id="p1595" begin="01:35:34.080" end="01:35:37.080" region="bottomCenter">caused by your disciple, Deero!</p>
      <p xml:id="p1596" begin="01:35:41.600" end="01:35:45.480" region="bottomCenter">There's the talent<br/>I recruited myself</p>
      <p xml:id="p1597" begin="01:35:45.600" end="01:35:48.360" region="bottomCenter">Nothing slips past you</p>
      <p xml:id="p1598" begin="01:35:50.040" end="01:35:53.400" region="bottomCenter">After all, I've done your dirty work<br/>for so many years</p>
      <p xml:id="p1599" begin="01:35:53.520" end="01:35:55.120" region="bottomCenter">I can also guess your purpose here</p>
      <p xml:id="p1600" begin="01:35:55.240" end="01:35:56.960" region="bottomCenter">putting up a show in Chentang Pass</p>
      <p xml:id="p1601" begin="01:35:57.360" end="01:36:00.400" region="bottomCenter">You are trying to fram...<br/>frame the Loongs, aren't you?</p>
      <p xml:id="p1602" begin="01:36:01.160" end="01:36:04.880" region="bottomCenter">Is this how you repay me,<br/>your brother and mentor?</p>
      <p xml:id="p1603" begin="01:36:05.160" end="01:36:08.080" region="bottomCenter">You've always use...<br/>used me for your benefit</p>
      <p xml:id="p1604" begin="01:36:08.440" end="01:36:09.880" region="bottomCenter">Between you and me</p>
      <p xml:id="p1605" begin="01:36:10.000" end="01:36:11.320" region="bottomCenter">there's only grudge, not gratitude</p>
      <p xml:id="p1606" begin="01:36:13.520" end="01:36:17.120" region="bottomCenter">May I interest you in a deal?<br/>Master Immortal</p>
      <p xml:id="p1607" begin="01:36:18.080" end="01:36:21.000" region="bottomCenter">As the overseer of Yu Xu Palace</p>
      <p xml:id="p1608" begin="01:36:21.120" end="01:36:25.200" region="bottomCenter">you must know the spell to unhinge<br/>the Sea-Stabilizing Chains</p>
      <p xml:id="p1609" begin="01:36:25.440" end="01:36:28.480" region="bottomCenter">I do. So what?</p>
      <p xml:id="p1610" begin="01:36:28.640" end="01:36:30.160" region="bottomCenter">You... you are going to rebel?</p>
      <p xml:id="p1611" begin="01:36:30.280" end="01:36:32.760" region="bottomCenter">A thousand years ago, the four of us<br/>fought the celestial realm together</p>
      <p xml:id="p1612" begin="01:36:32.880" end="01:36:34.480" region="bottomCenter">Who betrayed us and</p>
      <p xml:id="p1613" begin="01:36:34.600" end="01:36:35.760" region="bottomCenter">cast us into the purgatory?</p>
      <p xml:id="p1614" begin="01:36:35.960" end="01:36:38.280" region="bottomCenter">Now Wuliang is targeting Ao Guang</p>
      <p xml:id="p1615" begin="01:36:38.400" end="01:36:39.880" region="bottomCenter">that's exactly what we want</p>
      <p xml:id="p1616" begin="01:36:40.680" end="01:36:42.360" region="bottomCenter">I've long heard that</p>
      <p xml:id="p1617" begin="01:36:42.480" end="01:36:44.440" region="bottomCenter">Immortal Wuliang<br/>recruit talents without bias</p>
      <p xml:id="p1618" begin="01:36:44.560" end="01:36:48.040" region="bottomCenter">I trust it you know well<br/>what we can do</p>
      <p xml:id="p1619" begin="01:36:48.160" end="01:36:50.720" region="bottomCenter">If you can free us<br/>from the purgatory</p>
      <p xml:id="p1620" begin="01:36:50.840" end="01:36:52.440" region="bottomCenter">and help us achieve immortality</p>
      <p xml:id="p1621" begin="01:36:52.560" end="01:36:55.080" region="bottomCenter">we are willing to offer<br/>our humble service</p>
      <p xml:id="p1622" begin="01:36:55.200" end="01:36:58.720" region="bottomCenter">Plus the secret of the Spirit Pearl<br/>and the Demon Orb</p>
      <p xml:id="p1623" begin="01:36:58.880" end="01:37:00.280" region="bottomCenter">The Spirit Pearl and the Demon Orb?</p>
      <p xml:id="p1624" begin="01:37:00.400" end="01:37:01.280" region="bottomCenter">Pathetic!</p>
      <p xml:id="p1625" begin="01:37:01.400" end="01:37:04.640" region="bottomCenter">Whe... where's your spirit<br/>of fighting back?</p>
      <p xml:id="p1626" begin="01:37:04.760" end="01:37:06.480" region="bottomCenter">We were young and ignorant!</p>
      <p xml:id="p1627" begin="01:37:08.880" end="01:37:11.360" region="bottomCenter">A thousand years of imprisonment</p>
      <p xml:id="p1628" begin="01:37:11.880" end="01:37:14.360" region="bottomCenter">has taught us about the rules</p>
      <p xml:id="p1629" begin="01:37:14.960" end="01:37:16.640" region="bottomCenter">and the rulers</p>
      <p xml:id="p1630" begin="01:37:17.960" end="01:37:19.320" region="bottomCenter">Smart</p>
      <p xml:id="p1631" begin="01:37:19.600" end="01:37:21.400" region="bottomCenter">But you're so unpredictable</p>
      <p xml:id="p1632" begin="01:37:21.520" end="01:37:22.920" region="bottomCenter">How can I trust you?</p>
      <p xml:id="p1633" begin="01:37:23.200" end="01:37:25.800" region="bottomCenter">Unless you let me place on you...</p>
      <p xml:id="p1634" begin="01:37:25.920" end="01:37:27.400" region="bottomCenter">We are willing</p>
      <p xml:id="p1635" begin="01:37:37.520" end="01:37:39.080" region="bottomCenter">The three Loongs willingly agreed</p>
      <p xml:id="p1636" begin="01:37:39.200" end="01:37:41.600" region="bottomCenter">to let Wuliang place a curse on them</p>
      <p xml:id="p1637" begin="01:37:41.720" end="01:37:43.200" region="bottomCenter">If they dare<br/>to disobey in the future</p>
      <p xml:id="p1638" begin="01:37:43.320" end="01:37:46.360" region="bottomCenter">Wuliang can take their lives<br/>at any time</p>
      <p xml:id="p1639" begin="01:37:47.160" end="01:37:49.560" region="bottomCenter">Wuliang then fulfilled his promise</p>
      <p xml:id="p1640" begin="01:37:49.680" end="01:37:52.400" region="bottomCenter">freeing them<br/>from the Sea-Stabilizing Chains</p>
      <p xml:id="p1641" begin="01:37:53.480" end="01:37:55.520" region="bottomCenter">Whenever a powerful force<br/>is discovered</p>
      <p xml:id="p1642" begin="01:37:55.640" end="01:37:56.720" region="bottomCenter">he orchestrates massacres</p>
      <p xml:id="p1643" begin="01:37:56.840" end="01:37:57.760" region="bottomCenter">frames others</p>
      <p xml:id="p1644" begin="01:37:57.880" end="01:37:59.240" region="bottomCenter">and sends troops to capture them</p>
      <p xml:id="p1645" begin="01:38:00.000" end="01:38:01.520" region="bottomCenter">According to Shen Gongbao</p>
      <p xml:id="p1646" begin="01:38:01.640" end="01:38:04.720" region="bottomCenter">he had carried out many<br/>such tasks for Wuliang</p>
      <p xml:id="p1647" begin="01:38:04.840" end="01:38:07.360" region="bottomCenter">in exchange for a chance<br/>to join the Chan Sect</p>
      <p xml:id="p1648" begin="01:38:08.080" end="01:38:11.120" region="bottomCenter">This time, Wuliang came<br/>to destroy Chentang Pass</p>
      <p xml:id="p1649" begin="01:38:11.240" end="01:38:13.520" region="bottomCenter">and frame the Loongs of Eastern Sea</p>
      <p xml:id="p1650" begin="01:38:13.640" end="01:38:15.120" region="bottomCenter">One thing led to another</p>
      <p xml:id="p1651" begin="01:38:15.240" end="01:38:16.880" region="bottomCenter">he ended up recruiting<br/>the three Loong kings</p>
      <p xml:id="p1652" begin="01:38:17.000" end="01:38:18.160" region="bottomCenter">And from them</p>
      <p xml:id="p1653" begin="01:38:18.280" end="01:38:21.160" region="bottomCenter">he learned the secret of<br/>the Demon Orb and the Spirit Pearl</p>
      <p xml:id="p1654" begin="01:38:22.400" end="01:38:23.560" region="bottomCenter">After that</p>
      <p xml:id="p1655" begin="01:38:23.680" end="01:38:26.960" region="bottomCenter">they deliberately left<br/>two clueless survivors</p>
      <p xml:id="p1656" begin="01:38:27.080" end="01:38:29.800" region="bottomCenter">to tell Yu Xu Palace<br/>what had happened</p>
      <p xml:id="p1657" begin="01:38:51.920" end="01:38:53.760" region="bottomCenter">Seeing no hope of breaking through</p>
      <p xml:id="p1658" begin="01:38:53.880" end="01:38:55.560" region="bottomCenter">Shen Gongbao came up with a plan</p>
      <p xml:id="p1659" begin="01:38:55.680" end="01:38:58.040" region="bottomCenter">He had the Yaksha petrify us</p>
      <p xml:id="p1660" begin="01:38:58.160" end="01:39:00.320" region="bottomCenter">then hide us in the sewers</p>
      <p xml:id="p1661" begin="01:39:00.440" end="01:39:03.720" region="bottomCenter">Later, he waited<br/>for the right time to revive us</p>
      <p xml:id="p1662" begin="01:39:04.240" end="01:39:05.240" region="bottomCenter">And you?</p>
      <p xml:id="p1663" begin="01:39:05.560" end="01:39:08.040" region="bottomCenter">My families are gone</p>
      <p xml:id="p1664" begin="01:39:08.160" end="01:39:09.600" region="bottomCenter">I have nothing left to hold onto</p>
      <p xml:id="p1665" begin="01:39:13.440" end="01:39:14.480" region="bottomCenter">Over there!</p>
      <p xml:id="p1666" begin="01:39:31.080" end="01:39:32.840" region="bottomCenter">The demons captured<br/>by the Demon Hunters</p>
      <p xml:id="p1667" begin="01:39:32.960" end="01:39:34.840" region="bottomCenter">are not, as outsiders think</p>
      <p xml:id="p1668" begin="01:39:34.960" end="01:39:38.040" region="bottomCenter">being reformed in Yu Xu Palace</p>
      <p xml:id="p1669" begin="01:39:38.160" end="01:39:41.720" region="bottomCenter">Instead, they are thrown into<br/>the Tianyuan Cauldron by Wuliang</p>
      <p xml:id="p1670" begin="01:39:41.840" end="01:39:43.320" region="bottomCenter">refined into pills of immortality</p>
      <p xml:id="p1671" begin="01:39:43.440" end="01:39:45.760" region="bottomCenter">to strengthen the Chan Sect's power</p>
      <p xml:id="p1672" begin="01:39:45.880" end="01:39:47.120" region="bottomCenter">Brother</p>
      <p xml:id="p1673" begin="01:39:47.240" end="01:39:49.760" region="bottomCenter">how could you<br/>commit such atrocities?</p>
      <p xml:id="p1674" begin="01:39:49.880" end="01:39:51.760" region="bottomCenter">How... How are you<br/>going to face our master</p>
      <p xml:id="p1675" begin="01:39:51.880" end="01:39:53.800" region="bottomCenter">and the teachings we received?</p>
      <p xml:id="p1676" begin="01:39:53.960" end="01:39:57.000" region="bottomCenter">Now that you know what Wuliang did</p>
      <p xml:id="p1677" begin="01:39:57.120" end="01:39:58.800" region="bottomCenter">you should stop before it's too late</p>
      <p xml:id="p1678" begin="01:39:58.920" end="01:40:00.360" region="bottomCenter">Take him back to the palace</p>
      <p xml:id="p1679" begin="01:40:00.480" end="01:40:02.360" region="bottomCenter">to face punishment<br/>from the Supreme Lord</p>
      <p xml:id="p1680" begin="01:40:09.200" end="01:40:12.720" region="bottomCenter">The Demon Hunters were<br/>personally trained by Master Wuliang</p>
      <p xml:id="p1681" begin="01:40:12.840" end="01:40:15.680" region="bottomCenter">Do you think a few words<br/>would turn us against him?</p>
      <p xml:id="p1682" begin="01:40:16.560" end="01:40:17.720" region="bottomCenter">So</p>
      <p xml:id="p1683" begin="01:40:17.960" end="01:40:19.680" region="bottomCenter">I was wrong about the Loongs</p>
      <p xml:id="p1684" begin="01:40:24.240" end="01:40:25.360" region="bottomCenter">Let them go!</p>
      <p xml:id="p1685" begin="01:40:43.120" end="01:40:44.160" region="bottomCenter">Let me help</p>
      <p xml:id="p1686" begin="01:41:09.080" end="01:41:10.440" region="bottomCenter">You betrayed us?</p>
      <p xml:id="p1687" begin="01:41:10.840" end="01:41:12.520" region="bottomCenter">We learned that from you,<br/>Big Brother</p>
      <p xml:id="p1688" begin="01:41:12.640" end="01:41:15.040" region="bottomCenter">Back then,<br/>in order to protect our kind</p>
      <p xml:id="p1689" begin="01:41:15.160" end="01:41:16.480" region="bottomCenter">I had no choice!</p>
      <p xml:id="p1690" begin="01:41:16.600" end="01:41:18.920" region="bottomCenter">Well, in order to protect myself now</p>
      <p xml:id="p1691" begin="01:41:20.080" end="01:41:21.160" region="bottomCenter">Neither do I</p>
      <p xml:id="p1692" begin="01:41:22.600" end="01:41:23.840" region="bottomCenter">My King, wait for us!</p>
      <p xml:id="p1693" begin="01:41:23.960" end="01:41:24.920" region="bottomCenter">Don't leave us behind!</p>
      <p xml:id="p1694" begin="01:41:25.040" end="01:41:26.480" region="bottomCenter">My King, take us with you!</p>
      <p xml:id="p1695" begin="01:41:28.480" end="01:41:30.480" region="bottomCenter">My King! My King!</p>
      <p xml:id="p1696" begin="01:41:33.280" end="01:41:35.120" region="bottomCenter">You've all been sold out!</p>
      <p xml:id="p1697" begin="01:41:44.200" end="01:41:45.720" region="bottomCenter">Loong King of Southern Sea</p>
      <p xml:id="p1698" begin="01:41:49.840" end="01:41:51.200" region="bottomCenter">Loong King of Northern Sea</p>
      <p xml:id="p1699" begin="01:41:55.520" end="01:41:56.920" region="bottomCenter">Loong Queen of Western Sea</p>
      <p xml:id="p1700" begin="01:42:08.000" end="01:42:09.040" region="bottomCenter">Nephew</p>
      <p xml:id="p1701" begin="01:42:09.400" end="01:42:11.160" region="bottomCenter">it's playtime with your uncle</p>
      <p xml:id="p1702" begin="01:42:22.160" end="01:42:23.080" region="bottomCenter">Take my spear!</p>
      <p xml:id="p1703" begin="01:42:30.200" end="01:42:32.240" region="bottomCenter">Take my axe!</p>
      <p xml:id="p1704" begin="01:42:33.680" end="01:42:34.840" region="bottomCenter">Take my wheel!</p>
      <p xml:id="p1705" begin="01:43:08.600" end="01:43:09.760" region="bottomCenter">Take my wheel times a hundred!</p>
      <p xml:id="p1706" begin="01:43:09.880" end="01:43:11.360" region="bottomCenter">Two hundreds!<br/>Three hundreds!</p>
      <p xml:id="p1707" begin="01:43:17.880" end="01:43:19.200" region="bottomCenter">Enough, huh?</p>
      <p xml:id="p1708" begin="01:43:19.480" end="01:43:21.160" region="bottomCenter">Bullshit!<br/>There weren't that many</p>
      <p xml:id="p1709" begin="01:43:21.920" end="01:43:23.680" region="bottomCenter">Your body is still unstable<br/>Don't exhaust yourself</p>
      <p xml:id="p1710" begin="01:43:23.800" end="01:43:25.240" region="bottomCenter">For my mistakes</p>
      <p xml:id="p1711" begin="01:43:25.360" end="01:43:28.560" region="bottomCenter">I would give my life<br/>for freeing the Loongs</p>
      <p xml:id="p1712" begin="01:43:29.520" end="01:43:31.680" region="bottomCenter">Young and vicious</p>
      <p xml:id="p1713" begin="01:43:32.920" end="01:43:35.080" region="bottomCenter">Let me have some fun with you,<br/>little one</p>
      <p xml:id="p1714" begin="01:44:06.560" end="01:44:08.280" region="bottomCenter">Bullying a child<br/>shameless and vile!</p>
      <p xml:id="p1715" begin="01:44:18.960" end="01:44:21.000" region="bottomCenter">Hey! How dare you<br/>hit your master's brother!</p>
      <p xml:id="p1716" begin="01:44:21.160" end="01:44:22.880" region="bottomCenter">Bullying an uncle eat a knuckle!</p>
      <p xml:id="p1717" begin="01:45:01.800" end="01:45:03.600" region="bottomCenter">This won't do. This is a mess</p>
      <p xml:id="p1718" begin="01:45:03.920" end="01:45:05.080" region="bottomCenter">Then let's make it<br/>an even bigger one</p>
      <p xml:id="p1719" begin="01:45:05.200" end="01:45:06.320" region="bottomCenter">How about some vapor?</p>
      <p xml:id="p1720" begin="01:45:07.200" end="01:45:08.040" region="bottomCenter">Sure</p>
      <p xml:id="p1721" begin="01:45:11.480" end="01:45:12.320" region="bottomCenter">Take them down!</p>
      <p xml:id="p1722" begin="01:45:20.000" end="01:45:21.640" region="bottomCenter">Watch out for sneak attacks!</p>
      <p xml:id="p1723" begin="01:45:28.480" end="01:45:30.160" region="bottomCenter">There you are</p>
      <p xml:id="p1724" begin="01:45:32.640" end="01:45:33.920" region="bottomCenter">Careful, it's me!</p>
      <p xml:id="p1725" begin="01:45:34.040" end="01:45:34.880" region="bottomCenter">Brother?</p>
      <p xml:id="p1726" begin="01:45:35.000" end="01:45:35.920" region="bottomCenter">My apologies</p>
      <p xml:id="p1727" begin="01:45:36.600" end="01:45:37.440" region="bottomCenter">Nezha!</p>
      <p xml:id="p1728" begin="01:45:43.320" end="01:45:44.600" region="bottomCenter">Surprise!</p>
      <p xml:id="p1729" begin="01:45:45.400" end="01:45:46.640" region="bottomCenter">Transformation Spell?</p>
      <p xml:id="p1730" begin="01:45:53.440" end="01:45:54.320" region="bottomCenter">Are you insane?</p>
      <p xml:id="p1731" begin="01:45:54.440" end="01:45:55.520" region="bottomCenter">You can't fool me</p>
      <p xml:id="p1732" begin="01:45:59.440" end="01:46:00.360" region="bottomCenter">What are you...</p>
      <p xml:id="p1733" begin="01:46:00.480" end="01:46:02.280" region="bottomCenter">Code.<br/>She sells seashells by the seashore</p>
      <p xml:id="p1734" begin="01:46:02.640" end="01:46:03.480" region="bottomCenter">What?</p>
      <p xml:id="p1735" begin="01:46:03.680" end="01:46:05.120" region="bottomCenter">You don't know the code<br/>Imposter!</p>
      <p xml:id="p1736" begin="01:46:07.360" end="01:46:08.920" region="bottomCenter">So you really are an imposter!</p>
      <p xml:id="p1737" begin="01:46:14.080" end="01:46:15.400" region="bottomCenter">Unbelievable!</p>
      <p xml:id="p1738" begin="01:46:21.680" end="01:46:23.040" region="bottomCenter">Serves you right</p>
      <p xml:id="p1739" begin="01:46:24.920" end="01:46:25.760" region="bottomCenter">Code</p>
      <p xml:id="p1740" begin="01:46:26.000" end="01:46:31.600" region="bottomCenter">Eh... he sells bells<br/>in the big well?</p>
      <p xml:id="p1741" begin="01:46:31.720" end="01:46:32.600" region="bottomCenter">Wrong!</p>
      <p xml:id="p1742" begin="01:46:33.560" end="01:46:35.280" region="bottomCenter">It's "she sells seashells<br/>by the seashore"</p>
      <p xml:id="p1743" begin="01:46:35.400" end="01:46:36.720" region="bottomCenter">"and the shells she sells<br/>all smell for sure"</p>
      <p xml:id="p1744" begin="01:46:37.040" end="01:46:38.760" region="bottomCenter">I'm the real one!</p>
      <p xml:id="p1745" begin="01:46:38.880" end="01:46:40.960" region="bottomCenter">How come I don't know this code?</p>
      <p xml:id="p1746" begin="01:46:41.080" end="01:46:42.560" region="bottomCenter">We just made it up!</p>
      <p xml:id="p1747" begin="01:46:44.480" end="01:46:46.240" region="bottomCenter">Can you make it easier?</p>
      <p xml:id="p1748" begin="01:46:46.360" end="01:46:48.640" region="bottomCenter">It's too hard!</p>
      <p xml:id="p1749" begin="01:46:49.840" end="01:46:51.520" region="bottomCenter">You idiot!</p>
      <p xml:id="p1750" begin="01:46:51.640" end="01:46:53.200" region="bottomCenter">Don't come near me! Imposter!</p>
      <p xml:id="p1751" begin="01:46:53.320" end="01:46:54.440" region="bottomCenter">I'm the real Ao Shun!</p>
      <p xml:id="p1752" begin="01:46:54.560" end="01:46:55.920" region="bottomCenter">Crap! You don't know the code!</p>
      <p xml:id="p1753" begin="01:46:56.040" end="01:46:57.560" region="bottomCenter">Neither do you!</p>
      <p xml:id="p1754" begin="01:46:58.240" end="01:46:59.080" region="bottomCenter">That's true</p>
      <p xml:id="p1755" begin="01:46:59.600" end="01:47:00.800" region="bottomCenter">Does it mean I'm an imposter, too?</p>
      <p xml:id="p1756" begin="01:47:02.240" end="01:47:03.560" region="bottomCenter">My goodness</p>
      <p xml:id="p1757" begin="01:47:03.920" end="01:47:04.920" region="bottomCenter">Tai Chi flows in harmony divine</p>
      <p xml:id="p1758" begin="01:47:05.040" end="01:47:06.000" region="bottomCenter">Five elements perfectly align</p>
      <p xml:id="p1759" begin="01:47:06.120" end="01:47:07.480" region="bottomCenter">True fire of Samadhi<br/>ignites the gold</p>
      <p xml:id="p1760" begin="01:47:07.600" end="01:47:08.840" region="bottomCenter">A perfect pill, its power unfolds</p>
      <p xml:id="p1761" begin="01:47:08.960" end="01:47:11.280" region="bottomCenter">Swift and Uplift!</p>
      <p xml:id="p1762" begin="01:47:39.280" end="01:47:40.720" region="bottomCenter">Why are you so scared?</p>
      <p xml:id="p1763" begin="01:47:40.840" end="01:47:43.960" region="bottomCenter">We used to bathe in lava<br/>like it's nothing</p>
      <p xml:id="p1764" begin="01:47:44.880" end="01:47:46.720" region="bottomCenter">Hot! Hot!</p>
      <p xml:id="p1765" begin="01:47:48.760" end="01:47:49.680" region="bottomCenter">Oh no!</p>
      <p xml:id="p1766" begin="01:47:49.800" end="01:47:51.440" region="bottomCenter">It's the true fire of Samadhi</p>
      <p xml:id="p1767" begin="01:47:53.720" end="01:47:54.800" region="bottomCenter">What are you looking at?</p>
      <p xml:id="p1768" begin="01:47:55.040" end="01:47:57.400" region="bottomCenter">If anyone should eat this, it's me!</p>
      <p xml:id="p1769" begin="01:48:01.200" end="01:48:02.120" region="bottomCenter">Yum</p>
      <p xml:id="p1770" begin="01:48:06.760" end="01:48:07.880" region="bottomCenter">Let go of my father!</p>
      <p xml:id="p1771" begin="01:48:09.640" end="01:48:10.480" region="bottomCenter">Freeze!</p>
      <p xml:id="p1772" begin="01:48:21.960" end="01:48:23.760" region="bottomCenter">What a Spirit Pearl!</p>
      <p xml:id="p1773" begin="01:48:23.880" end="01:48:26.880" region="bottomCenter">Perfect match with the Demon Orb</p>
      <p xml:id="p1774" begin="01:48:28.080" end="01:48:29.080" region="bottomCenter">Ao Bing!</p>
      <p xml:id="p1775" begin="01:48:32.480" end="01:48:33.400" region="bottomCenter">Freeze!</p>
      <p xml:id="p1776" begin="01:48:45.760" end="01:48:46.800" region="bottomCenter">The Heart-Piercing Curse</p>
      <p xml:id="p1777" begin="01:48:47.200" end="01:48:50.760" region="bottomCenter">Since I already knew<br/>your true identities</p>
      <p xml:id="p1778" begin="01:48:51.000" end="01:48:53.760" region="bottomCenter">how could I not have a backup plan?</p>
      <p xml:id="p1779" begin="01:48:56.520" end="01:48:57.360" region="bottomCenter">This is impossible!</p>
      <p xml:id="p1780" begin="01:48:57.480" end="01:48:58.480" region="bottomCenter">That curse is quite complex</p>
      <p xml:id="p1781" begin="01:48:58.680" end="01:49:00.160" region="bottomCenter">When did you cast it?</p>
      <p xml:id="p1782" begin="01:49:01.800" end="01:49:05.720" region="bottomCenter">Oh... That's why<br/>the Ascension Spell took so long</p>
      <p xml:id="p1783" begin="01:49:05.840" end="01:49:06.840" region="bottomCenter">You slipped in something</p>
      <p xml:id="p1784" begin="01:49:37.960" end="01:49:39.400" region="bottomCenter">You old fart!</p>
      <p xml:id="p1785" begin="01:49:44.000" end="01:49:45.960" region="bottomCenter">Even the Demon Orb</p>
      <p xml:id="p1786" begin="01:49:46.080" end="01:49:50.680" region="bottomCenter">won't be able to break<br/>the Heart-Piercing Curse so quick</p>
      <p xml:id="p1787" begin="01:49:51.000" end="01:49:55.280" region="bottomCenter">A thousand spikes have pierced<br/>through your nerves and veins</p>
      <p xml:id="p1788" begin="01:49:55.640" end="01:49:57.240" region="bottomCenter">Forcing any movement</p>
      <p xml:id="p1789" begin="01:49:57.360" end="01:49:59.120" region="bottomCenter">will only result in your body</p>
      <p xml:id="p1790" begin="01:49:59.240" end="01:50:00.800" region="bottomCenter">being torn apart</p>
      <p xml:id="p1791" begin="01:50:02.040" end="01:50:06.520" region="bottomCenter">No wonder<br/>I couldn't sense any living aura</p>
      <p xml:id="p1792" begin="01:50:06.640" end="01:50:09.000" region="bottomCenter">You were petrified</p>
      <p xml:id="p1793" begin="01:50:09.440" end="01:50:10.760" region="bottomCenter">But being alive</p>
      <p xml:id="p1794" begin="01:50:10.880" end="01:50:12.720" region="bottomCenter">you'll only hurt Nezha</p>
      <p xml:id="p1795" begin="01:50:14.680" end="01:50:15.840" region="bottomCenter">The Spirit Pearl</p>
      <p xml:id="p1796" begin="01:50:17.880" end="01:50:19.040" region="bottomCenter">and the Demon Orb</p>
      <p xml:id="p1797" begin="01:50:20.000" end="01:50:21.840" region="bottomCenter">are precious treasures</p>
      <p xml:id="p1798" begin="01:50:22.640" end="01:50:26.200" region="bottomCenter">I could've treated you well</p>
      <p xml:id="p1799" begin="01:50:29.280" end="01:50:31.760" region="bottomCenter">but now you're only useful<br/>for making pills</p>
      <p xml:id="p1800" begin="01:50:47.120" end="01:50:47.960" region="bottomCenter">Ao Bing!</p>
      <p xml:id="p1801" begin="01:50:48.240" end="01:50:49.080" region="bottomCenter">Father!</p>
      <p xml:id="p1802" begin="01:50:49.200" end="01:50:50.880" region="bottomCenter">You... you're still alive!</p>
      <p xml:id="p1803" begin="01:50:52.560" end="01:50:54.160" region="bottomCenter">It's the Heart-Piercing Curse<br/>casted by Wuliang</p>
      <p xml:id="p1804" begin="01:50:54.400" end="01:50:55.640" region="bottomCenter">And he was the one that<br/>slaughtered Chentang Pass</p>
      <p xml:id="p1805" begin="01:50:55.760" end="01:50:56.600" region="bottomCenter">framing it on the Loongs</p>
      <p xml:id="p1806" begin="01:51:00.200" end="01:51:01.040" region="bottomCenter">Father</p>
      <p xml:id="p1807" begin="01:51:01.160" end="01:51:02.920" region="bottomCenter">Nezha was deceived<br/>Don't blame him</p>
      <p xml:id="p1808" begin="01:51:03.040" end="01:51:04.520" region="bottomCenter">Whatever you want to do, do it to me</p>
      <p xml:id="p1809" begin="01:51:04.640" end="01:51:06.080" region="bottomCenter">Leave my parents out of this</p>
      <p xml:id="p1810" begin="01:51:12.000" end="01:51:14.520" region="bottomCenter">Killing you won't change anything</p>
      <p xml:id="p1811" begin="01:51:28.520" end="01:51:31.080" region="bottomCenter">We're all doomed to die here</p>
      <p xml:id="p1812" begin="01:51:31.200" end="01:51:34.080" region="bottomCenter">If anyone still holds grudges</p>
      <p xml:id="p1813" begin="01:51:34.720" end="01:51:35.880" region="bottomCenter">be my guest</p>
      <p xml:id="p1814" begin="01:51:44.880" end="01:51:46.320" region="bottomCenter">Brother</p>
      <p xml:id="p1815" begin="01:51:46.440" end="01:51:48.560" region="bottomCenter">the Chan Sect has a noble reputation</p>
      <p xml:id="p1816" begin="01:51:48.680" end="01:51:52.600" region="bottomCenter">how could you commit<br/>such a horrible clanger?</p>
      <p xml:id="p1817" begin="01:51:52.720" end="01:51:53.880" region="bottomCenter">Don't make more mistakes!</p>
      <p xml:id="p1818" begin="01:51:54.000" end="01:51:55.560" region="bottomCenter">Why don't you go back<br/>and confess to Master?</p>
      <p xml:id="p1819" begin="01:51:55.840" end="01:51:57.640" region="bottomCenter">I'll plead for mercy on your behalf</p>
      <p xml:id="p1820" begin="01:51:57.760" end="01:51:58.640" region="bottomCenter">You...</p>
      <p xml:id="p1821" begin="01:51:59.080" end="01:52:01.400" region="bottomCenter">Indiscriminate fool!</p>
      <p xml:id="p1822" begin="01:52:01.520" end="01:52:04.840" region="bottomCenter">If the immortals' place<br/>in the world were secured</p>
      <p xml:id="p1823" begin="01:52:04.960" end="01:52:07.560" region="bottomCenter">or you ungrateful slackers<br/>were half as</p>
      <p xml:id="p1824" begin="01:52:07.680" end="01:52:09.840" region="bottomCenter">diligent as the demons</p>
      <p xml:id="p1825" begin="01:52:09.960" end="01:52:12.280" region="bottomCenter">I wouldn't have wasted<br/>this much time and efforts!</p>
      <p xml:id="p1826" begin="01:52:12.680" end="01:52:14.640" region="bottomCenter">Even if it leads to my own doom</p>
      <p xml:id="p1827" begin="01:52:14.760" end="01:52:16.200" region="bottomCenter">and infamy</p>
      <p xml:id="p1828" begin="01:52:16.320" end="01:52:19.760" region="bottomCenter">I did it for the eternal dominance<br/>of Chan Sect</p>
      <p xml:id="p1829" begin="01:52:19.880" end="01:52:21.040" region="bottomCenter">conscience...</p>
      <p xml:id="p1830" begin="01:52:21.840" end="01:52:23.120" region="bottomCenter">conscience...</p>
      <p xml:id="p1831" begin="01:52:23.240" end="01:52:24.080" region="bottomCenter">conscience...</p>
      <p xml:id="p1832" begin="01:52:27.480" end="01:52:29.480" region="bottomCenter">My conscience is clear</p>
      <p xml:id="p1833" begin="01:52:32.640" end="01:52:34.200" region="bottomCenter">Another one is done</p>
      <p xml:id="p1834" begin="01:52:34.360" end="01:52:35.840" region="bottomCenter">I can't possibly eat any more</p>
      <p xml:id="p1835" begin="01:52:35.960" end="01:52:37.120" region="bottomCenter">You should try some</p>
      <p xml:id="p1836" begin="01:52:37.240" end="01:52:38.080" region="bottomCenter">Thanks</p>
      <p xml:id="p1837" begin="01:52:38.200" end="01:52:40.680" region="bottomCenter">When my fins are done,<br/>you should try some too</p>
      <p xml:id="p1838" begin="01:52:40.880" end="01:52:42.120" region="bottomCenter">The claws are ready as well</p>
      <p xml:id="p1839" begin="01:52:42.240" end="01:52:43.560" region="bottomCenter">We should swop and share</p>
      <p xml:id="p1840" begin="01:52:44.600" end="01:52:45.440" region="bottomCenter">What's going on?</p>
      <p xml:id="p1841" begin="01:52:46.360" end="01:52:48.280" region="bottomCenter">My body...</p>
      <p xml:id="p1842" begin="01:52:50.880" end="01:52:52.280" region="bottomCenter">He's become a pill!</p>
      <p xml:id="p1843" begin="01:52:52.400" end="01:52:53.640" region="bottomCenter">I'm still so young</p>
      <p xml:id="p1844" begin="01:52:53.760" end="01:52:55.000" region="bottomCenter">I don't want to die</p>
      <p xml:id="p1845" begin="01:52:55.120" end="01:52:56.440" region="bottomCenter">No, let me out</p>
      <p xml:id="p1846" begin="01:52:56.560" end="01:52:58.080" region="bottomCenter">Help!</p>
      <p xml:id="p1847" begin="01:52:58.440" end="01:52:59.760" region="bottomCenter">Stay calm!</p>
      <p xml:id="p1848" begin="01:52:59.880" end="01:53:01.720" region="bottomCenter">Focus all your energy!</p>
      <p xml:id="p1849" begin="01:53:02.040" end="01:53:04.520" region="bottomCenter">Hold on for as long as you can</p>
      <p xml:id="p1850" begin="01:53:11.840" end="01:53:12.880" region="bottomCenter">Son!</p>
      <p xml:id="p1851" begin="01:53:13.000" end="01:53:14.480" region="bottomCenter">Your power is greater than mine</p>
      <p xml:id="p1852" begin="01:53:14.600" end="01:53:16.040" region="bottomCenter">You can get through</p>
      <p xml:id="p1853" begin="01:53:16.160" end="01:53:18.240" region="bottomCenter">If you can hold out<br/>until the heart-piercing curse fades</p>
      <p xml:id="p1854" begin="01:53:18.360" end="01:53:19.880" region="bottomCenter">you'll have a chance to escape</p>
      <p xml:id="p1855" begin="01:53:20.080" end="01:53:22.760" region="bottomCenter">The heart-piercing curse<br/>takes at least six hours</p>
      <p xml:id="p1856" begin="01:53:22.880" end="01:53:24.360" region="bottomCenter">I'm afraid...</p>
      <p xml:id="p1857" begin="01:53:24.480" end="01:53:25.640" region="bottomCenter">I won't be able to last that long</p>
      <p xml:id="p1858" begin="01:53:31.680" end="01:53:32.680" region="bottomCenter">- My lady<br/>- Mom</p>
      <p xml:id="p1859" begin="01:53:32.800" end="01:53:33.800" region="bottomCenter">Wake up, mom</p>
      <p xml:id="p1860" begin="01:53:33.920" end="01:53:36.640" region="bottomCenter">Nezha, Nezha?</p>
      <p xml:id="p1861" begin="01:53:37.840" end="01:53:38.680" region="bottomCenter">Nezha</p>
      <p xml:id="p1862" begin="01:53:38.920" end="01:53:40.200" region="bottomCenter">I'm here, Mom</p>
      <p xml:id="p1863" begin="01:53:40.320" end="01:53:41.960" region="bottomCenter">You guys must not give up</p>
      <p xml:id="p1864" begin="01:53:42.080" end="01:53:43.200" region="bottomCenter">Don't worry about us</p>
      <p xml:id="p1865" begin="01:53:43.480" end="01:53:46.320" region="bottomCenter">Try to stay focus</p>
      <p xml:id="p1866" begin="01:53:46.440" end="01:53:47.680" region="bottomCenter">I'm fine, Mom</p>
      <p xml:id="p1867" begin="01:53:47.800" end="01:53:49.040" region="bottomCenter">I don't feel the fire</p>
      <p xml:id="p1868" begin="01:53:49.320" end="01:53:51.400" region="bottomCenter">Nothing kills you, kiddo</p>
      <p xml:id="p1869" begin="01:53:51.640" end="01:53:54.120" region="bottomCenter">If I am correct</p>
      <p xml:id="p1870" begin="01:53:54.240" end="01:53:56.680" region="bottomCenter">flames of the Demon Orb<br/>and the true fire of Samadhi</p>
      <p xml:id="p1871" begin="01:53:56.800" end="01:53:58.120" region="bottomCenter">share the same origin</p>
      <p xml:id="p1872" begin="01:53:58.520" end="01:54:01.280" region="bottomCenter">Then the Tianyuan Cauldron<br/>can't harm you</p>
      <p xml:id="p1873" begin="01:54:01.720" end="01:54:02.800" region="bottomCenter">That's right</p>
      <p xml:id="p1874" begin="01:54:02.920" end="01:54:04.480" region="bottomCenter">My mistake</p>
      <p xml:id="p1875" begin="01:54:07.760" end="01:54:09.120" region="bottomCenter">Don't bother</p>
      <p xml:id="p1876" begin="01:54:09.320" end="01:54:12.000" region="bottomCenter">This is just my avatar</p>
      <p xml:id="p1877" begin="01:54:13.360" end="01:54:15.320" region="bottomCenter">As I suspected, the Demon Orb</p>
      <p xml:id="p1878" begin="01:54:15.440" end="01:54:16.720" region="bottomCenter">is indestructible</p>
      <p xml:id="p1879" begin="01:54:16.840" end="01:54:21.880" region="bottomCenter">No wonder the Supreme Lord had to<br/>destroy you with the Wrath of Heaven</p>
      <p xml:id="p1880" begin="01:54:26.040" end="01:54:27.560" region="bottomCenter">Nezha</p>
      <p xml:id="p1881" begin="01:54:28.120" end="01:54:31.240" region="bottomCenter">I see you're a good son</p>
      <p xml:id="p1882" begin="01:54:31.360" end="01:54:33.920" region="bottomCenter">How about I give you<br/>a chance to prove that?</p>
      <p xml:id="p1883" begin="01:54:34.240" end="01:54:35.400" region="bottomCenter">The Oblivion Pill</p>
      <p xml:id="p1884" begin="01:54:36.160" end="01:54:38.000" region="bottomCenter">Swallow it</p>
      <p xml:id="p1885" begin="01:54:38.120" end="01:54:40.360" region="bottomCenter">and I'll release your parents</p>
      <p xml:id="p1886" begin="01:54:40.480" end="01:54:41.320" region="bottomCenter">What do you say?</p>
      <p xml:id="p1887" begin="01:54:41.480" end="01:54:43.960" region="bottomCenter">I may be ruthless</p>
      <p xml:id="p1888" begin="01:54:44.080" end="01:54:46.400" region="bottomCenter">but I always keep my promises</p>
      <p xml:id="p1889" begin="01:54:46.520" end="01:54:50.400" region="bottomCenter">Otherwise,<br/>all those elites of the demons</p>
      <p xml:id="p1890" begin="01:54:50.520" end="01:54:52.120" region="bottomCenter">wouldn't swear loyalty to me</p>
      <p xml:id="p1891" begin="01:54:52.400" end="01:54:54.600" region="bottomCenter">As long as you swallow it</p>
      <p xml:id="p1892" begin="01:54:54.720" end="01:54:57.120" region="bottomCenter">I swear to Heaven</p>
      <p xml:id="p1893" begin="01:54:57.280" end="01:54:59.120" region="bottomCenter">I won't harm your parents</p>
      <p xml:id="p1894" begin="01:55:13.800" end="01:55:15.040" region="bottomCenter">What are you doing?</p>
      <p xml:id="p1895" begin="01:55:15.600" end="01:55:18.080" region="bottomCenter">Using his parents' lives<br/>to threaten a kid?</p>
      <p xml:id="p1896" begin="01:55:18.560" end="01:55:19.840" region="bottomCenter">And you call yourself a god?</p>
      <p xml:id="p1897" begin="01:55:20.360" end="01:55:22.040" region="bottomCenter">You aren't even worthy to be a human</p>
      <p xml:id="p1898" begin="01:55:24.400" end="01:55:25.240" region="bottomCenter">Nezha</p>
      <p xml:id="p1899" begin="01:55:25.440" end="01:55:26.680" region="bottomCenter">leave us be</p>
      <p xml:id="p1900" begin="01:55:26.800" end="01:55:28.840" region="bottomCenter">You must live</p>
      <p xml:id="p1901" begin="01:55:28.960" end="01:55:30.680" region="bottomCenter">Hold on until<br/>the heart-piercing curse is broken</p>
      <p xml:id="p1902" begin="01:55:30.800" end="01:55:32.840" region="bottomCenter">or until your two brothers find you</p>
      <p xml:id="p1903" begin="01:55:33.120" end="01:55:36.160" region="bottomCenter">You really think<br/>I can't kill the Demon Orb?</p>
      <p xml:id="p1904" begin="01:55:36.280" end="01:55:38.720" region="bottomCenter">It's just a matter of time</p>
      <p xml:id="p1905" begin="01:55:38.840" end="01:55:40.160" region="bottomCenter">Once you're dead</p>
      <p xml:id="p1906" begin="01:55:40.280" end="01:55:43.640" region="bottomCenter">I have a hundred ways to destroy him</p>
      <p xml:id="p1907" begin="01:55:48.360" end="01:55:52.680" region="bottomCenter">I just don't want to die for nothing</p>
      <p xml:id="p1908" begin="01:55:52.800" end="01:55:56.080" region="bottomCenter">Why won't you let me?</p>
      <p xml:id="p1909" begin="01:55:56.280" end="01:55:59.480" region="bottomCenter">Why won't you?</p>
      <p xml:id="p1910" begin="01:55:59.680" end="01:56:02.760" region="bottomCenter">If your trade your life for ours</p>
      <p xml:id="p1911" begin="01:56:02.880" end="01:56:06.720" region="bottomCenter">do you think we could live in peace?</p>
      <p xml:id="p1912" begin="01:56:08.600" end="01:56:09.680" region="bottomCenter">Nezha</p>
      <p xml:id="p1913" begin="01:56:09.800" end="01:56:12.080" region="bottomCenter">No, mom</p>
      <p xml:id="p1914" begin="01:56:12.560" end="01:56:13.920" region="bottomCenter">It'll hurt you</p>
      <p xml:id="p1915" begin="01:56:14.040" end="01:56:15.000" region="bottomCenter">It's okay</p>
      <p xml:id="p1916" begin="01:56:15.440" end="01:56:16.760" region="bottomCenter">This is the end</p>
      <p xml:id="p1917" begin="01:56:18.360" end="01:56:20.880" region="bottomCenter">I just want to hug you one last time</p>
      <p xml:id="p1918" begin="01:56:21.680" end="01:56:23.720" region="bottomCenter">Mom</p>
      <p xml:id="p1919" begin="01:56:24.480" end="01:56:27.280" region="bottomCenter">I guess I won't get<br/>to see you grow up</p>
      <p xml:id="p1920" begin="01:56:28.280" end="01:56:29.840" region="bottomCenter">From now on</p>
      <p xml:id="p1921" begin="01:56:30.840" end="01:56:33.440" region="bottomCenter">you'll have to walk your own path</p>
      <p xml:id="p1922" begin="01:57:41.720" end="01:57:44.440" region="bottomCenter">I... I'm useless</p>
      <p xml:id="p1923" begin="01:57:45.160" end="01:57:47.040" region="bottomCenter">Useless</p>
      <p xml:id="p1924" begin="01:57:47.840" end="01:57:50.160" region="bottomCenter">I was born a demon</p>
      <p xml:id="p1925" begin="01:57:50.560" end="01:57:53.160" region="bottomCenter">and have always caused you pain</p>
      <p xml:id="p1926" begin="01:57:54.360" end="01:57:56.080" region="bottomCenter">I wanted so badly</p>
      <p xml:id="p1927" begin="01:57:56.200" end="01:57:58.600" region="bottomCenter">to make you proud</p>
      <p xml:id="p1928" begin="01:58:04.320" end="01:58:07.000" region="bottomCenter">This is all my fault</p>
      <p xml:id="p1929" begin="01:58:07.680" end="01:58:10.960" region="bottomCenter">I'm sorry, Mom</p>
      <p xml:id="p1930" begin="01:58:11.720" end="01:58:14.080" region="bottomCenter">I'm sorry</p>
      <p xml:id="p1931" begin="01:58:15.280" end="01:58:18.480" region="bottomCenter">Every day I spent with you</p>
      <p xml:id="p1932" begin="01:58:18.840" end="01:58:21.480" region="bottomCenter">I was so happy</p>
      <p xml:id="p1933" begin="01:58:22.080" end="01:58:25.000" region="bottomCenter">I never cared</p>
      <p xml:id="p1934" begin="01:58:25.760" end="01:58:29.040" region="bottomCenter">whether you were an immortal<br/>or a demon</p>
      <p xml:id="p1935" begin="01:58:30.240" end="01:58:32.080" region="bottomCenter">All I know is</p>
      <p xml:id="p1936" begin="01:58:32.720" end="01:58:35.560" region="bottomCenter">you are my son</p>
      <p xml:id="p1937" begin="01:58:37.600" end="01:58:38.720" region="bottomCenter">Mommy</p>
      <p xml:id="p1938" begin="01:58:39.240" end="01:58:40.560" region="bottomCenter">will always</p>
      <p xml:id="p1939" begin="01:58:41.840" end="01:58:42.920" region="bottomCenter">love...</p>
      <p xml:id="p1940" begin="01:59:23.400" end="01:59:24.680" region="bottomCenter">Nezha, stay calm!</p>
      <p xml:id="p1941" begin="01:59:24.800" end="01:59:25.680" region="bottomCenter">Stop!</p>
      <p xml:id="p1942" begin="01:59:25.800" end="01:59:27.160" region="bottomCenter">Your body will be torn apart!</p>
      <p xml:id="p1943" begin="02:00:10.520" end="02:00:13.680" region="bottomCenter">The True Fire of Samadhi<br/>has compensated for</p>
      <p xml:id="p1944" begin="02:00:13.800" end="02:00:15.080" region="bottomCenter">the fire needed for body rebuilding</p>
      <p xml:id="p1945" begin="02:00:16.280" end="02:00:17.800" region="bottomCenter">Nezha's physical form</p>
      <p xml:id="p1946" begin="02:00:19.120" end="02:00:21.040" region="bottomCenter">is complete now!</p>
      <p xml:id="p1947" begin="02:00:36.320" end="02:00:37.360" region="bottomCenter">Dad</p>
      <p xml:id="p1948" begin="02:00:38.280" end="02:00:39.360" region="bottomCenter">take care of Mom</p>
      <p xml:id="p1949" begin="02:00:52.280" end="02:00:53.840" region="bottomCenter">Help me break the cauldron!</p>
      <p xml:id="p1950" begin="02:01:27.000" end="02:01:27.880" region="bottomCenter">Oh no!</p>
      <p xml:id="p1951" begin="02:01:28.000" end="02:01:30.000" region="bottomCenter">They are absorbing the energy<br/>of the Tianyuan Cauldron!</p>
      <p xml:id="p1952" begin="02:01:31.640" end="02:01:34.760" region="bottomCenter">Roota Maxima!</p>
      <p xml:id="p1953" begin="02:01:58.760" end="02:02:00.920" region="bottomCenter">Demon Hunters, by my command</p>
      <p xml:id="p1954" begin="02:02:01.080" end="02:02:02.080" region="bottomCenter">march!</p>
      <p xml:id="p1955" begin="02:02:57.040" end="02:02:57.880" region="bottomCenter">Father</p>
      <p xml:id="p1956" begin="02:02:58.000" end="02:02:59.560" region="bottomCenter">you need to save your energy<br/>for self-protection</p>
      <p xml:id="p1957" begin="02:02:59.680" end="02:03:02.720" region="bottomCenter">We've been backing down<br/>for far too long</p>
      <p xml:id="p1958" begin="02:03:02.840" end="02:03:04.320" region="bottomCenter">We thought if we gave everything</p>
      <p xml:id="p1959" begin="02:03:04.440" end="02:03:06.640" region="bottomCenter">then Wuliang would let us live</p>
      <p xml:id="p1960" begin="02:03:06.760" end="02:03:09.320" region="bottomCenter">But in the end,<br/>they still want us dead</p>
      <p xml:id="p1961" begin="02:03:09.440" end="02:03:11.360" region="bottomCenter">If that's what they want</p>
      <p xml:id="p1962" begin="02:03:12.000" end="02:03:15.560" region="bottomCenter">then we'll fight them to death!</p>
      <p xml:id="p1963" begin="02:03:15.680" end="02:03:17.600" region="bottomCenter">Yes, let's fight!</p>
      <p xml:id="p1964" begin="02:03:17.720" end="02:03:21.720" region="bottomCenter">Fight! Fight! Fight!</p>
      <p xml:id="p1965" begin="02:03:31.280" end="02:03:33.720" region="bottomCenter">We can't let them out!</p>
      <p xml:id="p1966" begin="02:04:20.120" end="02:04:21.800" region="bottomCenter">Do not give up!</p>
      <p xml:id="p1967" begin="02:04:21.920" end="02:04:24.400" region="bottomCenter">Hang in there!</p>
      <p xml:id="p1968" begin="02:04:47.880" end="02:04:49.320" region="bottomCenter">Make it...</p>
      <p xml:id="p1969" begin="02:04:50.120" end="02:04:52.760" region="bottomCenter">break!</p>
      <p xml:id="p1970" begin="02:05:43.240" end="02:05:44.360" region="bottomCenter">The cauldron!</p>
      <p xml:id="p1971" begin="02:05:44.480" end="02:05:45.760" region="bottomCenter">My cauldron!</p>
      <p xml:id="p1972" begin="02:05:45.960" end="02:05:48.680" region="bottomCenter">There goes the foundation<br/>of Chan Sect!</p>
      <p xml:id="p1973" begin="02:06:44.200" end="02:06:47.760" region="bottomCenter">Kill all these jerks!</p>
      <p xml:id="p1974" begin="02:06:53.240" end="02:06:54.320" region="bottomCenter">Attack!</p>
      <p xml:id="p1975" begin="02:07:29.120" end="02:07:32.240" region="bottomCenter">You ungrateful traitors</p>
      <p xml:id="p1976" begin="02:07:32.360" end="02:07:33.480" region="bottomCenter">Can't tell right from wrong!</p>
      <p xml:id="p1977" begin="02:07:46.800" end="02:07:48.560" region="bottomCenter">Roaring Loong Waves!</p>
      <p xml:id="p1978" begin="02:07:58.600" end="02:08:01.720" region="bottomCenter">So those two minions of his<br/>are monsters too</p>
      <p xml:id="p1979" begin="02:08:01.840" end="02:08:03.480" region="bottomCenter">Demons, immortals...</p>
      <p xml:id="p1980" begin="02:08:03.600" end="02:08:06.040" region="bottomCenter">it's all part of your trickery!</p>
      <p xml:id="p1981" begin="02:08:07.000" end="02:08:08.760" region="bottomCenter">You despicable lowlife</p>
      <p xml:id="p1982" begin="02:08:08.880" end="02:08:11.240" region="bottomCenter">How dare you oppose me!</p>
      <p xml:id="p1983" begin="02:08:34.480" end="02:08:37.920" region="bottomCenter">Witness my true powers!</p>
      <p xml:id="p1984" begin="02:10:32.120" end="02:10:33.840" region="bottomCenter">I'll give you two</p>
      <p xml:id="p1985" begin="02:10:33.960" end="02:10:35.880" region="bottomCenter">one last chance<br/>because I value talents</p>
      <p xml:id="p1986" begin="02:10:36.000" end="02:10:37.280" region="bottomCenter">Surrender now</p>
      <p xml:id="p1987" begin="02:10:37.400" end="02:10:39.280" region="bottomCenter">and I'll grant you immortality</p>
      <p xml:id="p1988" begin="02:10:39.680" end="02:10:40.920" region="bottomCenter">Hell with immortality!</p>
      <p xml:id="p1989" begin="02:10:41.840" end="02:10:43.280" region="bottomCenter">I'm all demon</p>
      <p xml:id="p1990" begin="02:10:43.960" end="02:10:45.000" region="bottomCenter">So what?</p>
      <p xml:id="p1991" begin="02:10:48.480" end="02:10:50.280" region="bottomCenter">You claim to be a guiding light</p>
      <p xml:id="p1992" begin="02:10:50.560" end="02:10:52.040" region="bottomCenter">but all you do is bully the weak</p>
      <p xml:id="p1993" begin="02:10:52.160" end="02:10:53.640" region="bottomCenter">and bring chaos to the world</p>
      <p xml:id="p1994" begin="02:10:54.720" end="02:10:57.280" region="bottomCenter">You are the real evil!</p>
      <p xml:id="p1995" begin="02:11:05.120" end="02:11:06.760" region="bottomCenter">Ignorant fools</p>
      <p xml:id="p1996" begin="02:11:06.880" end="02:11:08.680" region="bottomCenter">the immortals rule the world</p>
      <p xml:id="p1997" begin="02:11:08.800" end="02:11:11.680" region="bottomCenter">Siding with the powerful<br/>is the only way out</p>
      <p xml:id="p1998" begin="02:11:11.800" end="02:11:13.880" region="bottomCenter">Either accept that or</p>
      <p xml:id="p1999" begin="02:11:14.000" end="02:11:16.080" region="bottomCenter">you'll have no place to run to</p>
      <p xml:id="p2000" begin="02:11:16.200" end="02:11:17.560" region="bottomCenter">If there's no place to go</p>
      <p xml:id="p2001" begin="02:11:18.160" end="02:11:20.440" region="bottomCenter">I will open up one myself!</p>
      <p xml:id="p2002" begin="02:11:23.840" end="02:11:25.800" region="bottomCenter">If not accepted</p>
      <p xml:id="p2003" begin="02:11:26.200" end="02:11:30.120" region="bottomCenter">I will overturn!</p>
      <p xml:id="p2004" begin="02:11:40.000" end="02:11:40.920" region="bottomCenter">Master!</p>
      <p xml:id="p2005" begin="02:11:42.640" end="02:11:44.720" region="bottomCenter">My face...</p>
      <p xml:id="p2006" begin="02:11:44.960" end="02:11:49.120" region="bottomCenter">You...<br/>You fools broke my Ageless Spell!</p>
      <p xml:id="p2007" begin="02:11:49.480" end="02:11:51.960" region="bottomCenter">Old fart</p>
      <p xml:id="p2008" begin="02:12:03.440" end="02:12:06.920" region="bottomCenter">Ba...back to the palace</p>
      <p xml:id="p2009" begin="02:12:18.120" end="02:12:19.400" region="bottomCenter">Wait for me!</p>
      <p xml:id="p2010" begin="02:13:02.920" end="02:13:04.560" region="bottomCenter">My father plans to lead the Loongs</p>
      <p xml:id="p2011" begin="02:13:04.680" end="02:13:06.120" region="bottomCenter">deep into the ocean to hide</p>
      <p xml:id="p2012" begin="02:13:06.320" end="02:13:07.760" region="bottomCenter">Now that your identity is exposed</p>
      <p xml:id="p2013" begin="02:13:07.880" end="02:13:09.320" region="bottomCenter">why don't you come with us?</p>
      <p xml:id="p2014" begin="02:13:09.720" end="02:13:10.760" region="bottomCenter">No</p>
      <p xml:id="p2015" begin="02:13:11.720" end="02:13:14.760" region="bottomCenter">I've been hiding all my life<br/>concealing myself</p>
      <p xml:id="p2016" begin="02:13:15.320" end="02:13:16.720" region="bottomCenter">until there was nowhere to run</p>
      <p xml:id="p2017" begin="02:13:17.320" end="02:13:20.080" region="bottomCenter">Now I finally know<br/>how to face the world</p>
      <p xml:id="p2018" begin="02:13:20.240" end="02:13:22.240" region="bottomCenter">Wuliang is one of the most<br/>powerful immortals</p>
      <p xml:id="p2019" begin="02:13:22.360" end="02:13:24.200" region="bottomCenter">and is trusted by the Supreme Lord</p>
      <p xml:id="p2020" begin="02:13:24.480" end="02:13:26.160" region="bottomCenter">He may not fall so easily</p>
      <p xml:id="p2021" begin="02:13:26.280" end="02:13:28.480" region="bottomCenter">Plus, immortals and demons<br/>walk different paths</p>
      <p xml:id="p2022" begin="02:13:28.600" end="02:13:30.080" region="bottomCenter">like water and fire</p>
      <p xml:id="p2023" begin="02:13:30.480" end="02:13:32.400" region="bottomCenter">Immortals, demons...</p>
      <p xml:id="p2024" begin="02:13:32.520" end="02:13:35.480" region="bottomCenter">Those are just excuses for<br/>controlling those who are different</p>
      <p xml:id="p2025" begin="02:13:36.920" end="02:13:38.560" region="bottomCenter">So what?</p>
      <p xml:id="p2026" begin="02:13:38.680" end="02:13:40.960" region="bottomCenter">You think you can change that?</p>
      <p xml:id="p2027" begin="02:13:45.200" end="02:13:46.320" region="bottomCenter">I want to try</p>
      <p xml:id="p2028" begin="02:13:49.320" end="02:13:51.320" region="bottomCenter">Perhaps I'm too old</p>
      <p xml:id="p2029" begin="02:13:51.520" end="02:13:54.280" region="bottomCenter">to fight against the world</p>
      <p xml:id="p2030" begin="02:13:54.760" end="02:13:55.760" region="bottomCenter">Ao Bing</p>
      <p xml:id="p2031" begin="02:14:31.600" end="02:14:33.200" region="bottomCenter">I know that</p>
      <p xml:id="p2032" begin="02:14:33.320" end="02:14:35.120" region="bottomCenter">once you've made up your mind</p>
      <p xml:id="p2033" begin="02:14:35.240" end="02:14:36.520" region="bottomCenter">you'll always follow through</p>
      <p xml:id="p2034" begin="02:14:37.800" end="02:14:39.040" region="bottomCenter">My son</p>
      <p xml:id="p2035" begin="02:14:39.160" end="02:14:40.600" region="bottomCenter">In the past</p>
      <p xml:id="p2036" begin="02:14:40.720" end="02:14:42.680" region="bottomCenter">I've put too much burden on you</p>
      <p xml:id="p2037" begin="02:14:42.800" end="02:14:45.320" region="bottomCenter">and never even<br/>cared about what you think</p>
      <p xml:id="p2038" begin="02:14:45.760" end="02:14:47.600" region="bottomCenter">I apologize</p>
      <p xml:id="p2039" begin="02:14:48.280" end="02:14:52.200" region="bottomCenter">I only wanted to use my experience<br/>to give you a good life</p>
      <p xml:id="p2040" begin="02:14:53.000" end="02:14:54.640" region="bottomCenter">But now I see</p>
      <p xml:id="p2041" begin="02:14:54.760" end="02:14:56.040" region="bottomCenter">the experience<br/>of the older generation</p>
      <p xml:id="p2042" begin="02:14:56.160" end="02:14:57.480" region="bottomCenter">is but the past</p>
      <p xml:id="p2043" begin="02:14:57.600" end="02:14:59.280" region="bottomCenter">and may not be right for you</p>
      <p xml:id="p2044" begin="02:15:00.920" end="02:15:04.080" region="bottomCenter">You must walk your own path</p>
      <p xml:id="p2045" begin="02:15:04.560" end="02:15:05.960" region="bottomCenter">From now on</p>
      <p xml:id="p2046" begin="02:15:06.680" end="02:15:09.200" region="bottomCenter">follow your heart</p>
      <p xml:id="p2047" begin="02:15:40.400" end="02:15:41.880" region="bottomCenter">I knew you'd come back</p>
      <p xml:id="p2048" begin="02:15:42.240" end="02:15:43.360" region="bottomCenter">Why?</p>
      <p xml:id="p2049" begin="02:15:44.400" end="02:15:45.760" region="bottomCenter">Because we are both too young</p>
      <p xml:id="p2050" begin="02:15:49.360" end="02:15:50.640" region="bottomCenter">Too young to fear</p>
      <p xml:id="p2051" begin="02:17:45.040" end="02:17:47.120" region="bottomCenter">Master, your face...</p>
      <p xml:id="p2052" begin="02:17:47.280" end="02:17:48.360" region="bottomCenter">It's fine</p>
      <p xml:id="p2053" begin="02:17:48.880" end="02:17:50.960" region="bottomCenter">Crana already took care of it</p>
      <p xml:id="p2054" begin="02:17:51.320" end="02:17:52.480" region="bottomCenter">The cauldron is destroyed</p>
      <p xml:id="p2055" begin="02:17:52.600" end="02:17:54.480" region="bottomCenter">and the Chan Sect<br/>no longer has a sure-win</p>
      <p xml:id="p2056" begin="02:17:54.600" end="02:17:57.120" region="bottomCenter">We've committed<br/>an unforgivable crime</p>
      <p xml:id="p2057" begin="02:17:57.240" end="02:18:01.200" region="bottomCenter">We must act before the Master<br/>comes out of seclusion</p>
      <p xml:id="p2058" begin="02:18:01.320" end="02:18:03.320" region="bottomCenter">Come on, let's go see him</p>
      <p xml:id="p2059" begin="02:18:04.160" end="02:18:06.600" region="bottomCenter">Is the holding cell hidden enough?</p>
      <p xml:id="p2060" begin="02:18:06.720" end="02:18:08.280" region="bottomCenter">No one else will come here</p>
      <p xml:id="p2061" begin="02:18:08.400" end="02:18:10.200" region="bottomCenter">The cell is also shielded from magic</p>
      <p xml:id="p2062" begin="02:18:10.320" end="02:18:11.280" region="bottomCenter">And gate can only be opened</p>
      <p xml:id="p2063" begin="02:18:11.400" end="02:18:13.160" region="bottomCenter">by you and the only guard</p>
      <p xml:id="p2064" begin="02:18:21.360" end="02:18:24.080" region="bottomCenter">Slacking, dozing off</p>
      <p xml:id="p2065" begin="02:18:29.280" end="02:18:30.440" region="bottomCenter">What's going on?</p>
      <p xml:id="p2066" begin="02:18:30.560" end="02:18:32.600" region="bottomCenter">This gate<br/>works with face-recognition</p>
      <p xml:id="p2067" begin="02:18:32.720" end="02:18:34.680" region="bottomCenter">Since your appearance has changed</p>
      <p xml:id="p2068" begin="02:18:34.880" end="02:18:36.200" region="bottomCenter">you need to re-register</p>
      <p xml:id="p2069" begin="02:18:36.760" end="02:18:37.920" region="bottomCenter">Go ahead</p>
      <p xml:id="p2070" begin="02:19:05.160" end="02:19:07.280" region="bottomCenter">Are you mocking me?</p>
      <p xml:id="p2071" begin="02:19:07.400" end="02:19:08.680" region="bottomCenter">I curse you to sleep for ten years</p>
      <p xml:id="p2072" begin="02:19:16.520" end="02:19:18.920" region="bottomCenter">You've suffered, my brother</p>
      <p xml:id="p2073" begin="02:19:21.400" end="02:19:23.760" region="bottomCenter">It is you who have suffered, brother</p>
      <p xml:id="p2074" begin="02:19:23.880" end="02:19:27.040" region="bottomCenter">Who... who did this to you?</p>
      <p xml:id="p2075" begin="02:19:28.080" end="02:19:32.040" region="bottomCenter">Do you know why<br/>I recruited you back then?</p>
      <p xml:id="p2076" begin="02:19:32.680" end="02:19:35.760" region="bottomCenter">I needed a demon</p>
      <p xml:id="p2077" begin="02:19:36.320" end="02:19:38.520" region="bottomCenter">When the Deification War comes</p>
      <p xml:id="p2078" begin="02:19:38.640" end="02:19:42.160" region="bottomCenter">I will entrust you<br/>with an important task</p>
      <p xml:id="p2079" begin="02:19:42.320" end="02:19:43.400" region="bottomCenter">Delusional</p>
      <p xml:id="p2080" begin="02:19:46.000" end="02:19:48.080" region="bottomCenter">Father!</p>
      <p xml:id="p2081" begin="02:19:48.320" end="02:19:49.640" region="bottomCenter">Don't worry</p>
      <p xml:id="p2082" begin="02:19:49.760" end="02:19:51.400" region="bottomCenter">He's still breathing</p>
      <p xml:id="p2083" begin="02:19:51.880" end="02:19:55.160" region="bottomCenter">Let me place a curse on you</p>
      <p xml:id="p2084" begin="02:19:55.280" end="02:19:57.680" region="bottomCenter">and your father will<br/>live a comfortable life</p>
      <p xml:id="p2085" begin="02:19:57.800" end="02:20:00.160" region="bottomCenter">at Yu Xu Palace</p>
      <p xml:id="p2086" begin="02:20:03.560" end="02:20:05.200" region="bottomCenter">Your two guests have arrived</p>
      <p xml:id="p2087" begin="02:20:05.400" end="02:20:07.160" region="bottomCenter">Think about it</p>
      <p xml:id="p2088" begin="02:20:16.800" end="02:20:18.600" region="bottomCenter">The medicine is working</p>
      <p xml:id="p2089" begin="02:20:19.280" end="02:20:20.440" region="bottomCenter">What should we do now?</p>
      <p xml:id="p2090" begin="02:20:20.600" end="02:20:21.960" region="bottomCenter">Who else can open the gate?</p>
      <p xml:id="p2091" begin="02:20:28.520" end="02:20:29.960" region="bottomCenter">Ten years...</p>
      <p xml:id="p2092" begin="02:20:37.640" end="02:20:39.600" region="bottomCenter">Jinzha of Cloud Cave,<br/>Wulong Mountain</p>
      <p xml:id="p2093" begin="02:20:39.800" end="02:20:41.960" region="bottomCenter">Muzha of White Crane Cave,<br/>Jiugong Mountain</p>
      <p xml:id="p2094" begin="02:20:42.080" end="02:20:43.360" region="bottomCenter">reporting back to duty</p>
      <p xml:id="p2095" begin="02:20:49.080" end="02:20:51.080" region="bottomCenter">Master, bear with me a little longer</p>
      <p xml:id="p2096" begin="02:20:56.080" end="02:20:57.600" region="bottomCenter">I think it's enough</p>
      <p xml:id="p2097" begin="02:21:04.360" end="02:21:05.400" region="bottomCenter">It seems</p>
      <p xml:id="p2098" begin="02:21:05.520" end="02:21:06.440" region="bottomCenter">the left eye<br/>still isn't swollen enough</p>
      <p xml:id="p2099" begin="02:21:06.960" end="02:21:08.000" region="bottomCenter">Add some more<br/>to the right cheek, too</p>
      <p xml:id="p2100" begin="02:21:11.320" end="02:21:12.280" region="bottomCenter">Wait</p>
      <p xml:id="p2101" begin="02:21:12.440" end="02:21:14.240" region="bottomCenter">Were you just laughing at me?</p>
      <p xml:id="p2102" begin="02:21:14.400" end="02:21:15.280" region="bottomCenter">We wouldn't dare</p>
      <p xml:id="p2103" begin="02:21:15.400" end="02:21:16.240" region="bottomCenter">Master, you're suffering</p>
      <p xml:id="p2104" begin="02:21:16.360" end="02:21:18.040" region="bottomCenter">It pains our hearts<br/>to see you like this</p>
      <p xml:id="p2105" begin="02:21:18.160" end="02:21:19.800" region="bottomCenter">- Really?<br/>- We solemnly swear</p>
      <p xml:id="p2106" begin="02:21:19.920" end="02:21:21.160" region="bottomCenter">to heaven and earth</p>
      <p xml:id="p2107" begin="02:21:26.320" end="02:21:27.880" region="bottomCenter">Alright, alright</p>
      <p xml:id="p2108" begin="02:21:38.880" end="02:21:41.200" region="bottomCenter">I might have...<br/>beaten too hard</p>
      <p xml:id="p2109" begin="02:21:41.320" end="02:21:42.160" region="bottomCenter">What?</p>
      <p xml:id="p2110" begin="02:21:42.280" end="02:21:43.120" region="bottomCenter">Don't worry</p>
      <p xml:id="p2111" begin="02:21:43.240" end="02:21:44.400" region="bottomCenter">Put it on,<br/>we'll come back when it heals</p>
      <p xml:id="p2112" begin="02:21:45.600" end="02:21:47.400" region="bottomCenter">Master, you're meant for greatness</p>
      <p xml:id="p2113" begin="02:21:47.520" end="02:21:49.080" region="bottomCenter">This is all for the future<br/>of the Chan Sect</p>
      <p xml:id="p2114" begin="02:21:49.200" end="02:21:50.080" region="bottomCenter">Let's try a few more times</p>
      <p xml:id="p2115" begin="02:21:50.200" end="02:21:51.200" region="bottomCenter">we'll get it right eventually</p>
      <p xml:id="p2116" begin="02:21:51.320" end="02:21:52.680" region="bottomCenter">Catch him! Don't let him go!</p>
      <p xml:id="p2117" begin="02:21:52.800" end="02:21:53.800" region="bottomCenter">Quick! Apply the medicine!</p>
      <p xml:id="p2118" begin="02:21:53.920" end="02:21:55.200" region="bottomCenter">Do it!</p>
      <p xml:id="p2119" begin="02:21:55.320" end="02:21:56.800" region="bottomCenter">Let go of me!</p>
    </div>
  </body>
</tt>